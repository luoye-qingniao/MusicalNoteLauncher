<UserControl
	x:Class="MusicalNoteLauncher.Pages.LoaderVersionPage"
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:conv="clr-namespace:MusicalNoteLauncher.Converters"
	Background="{DynamicResource BackgroundBrush}">
	<UserControl.Resources>
		<conv:BoolToVisibilityConverter x:Key="LocalBoolToVisibilityConverter"/>
	</UserControl.Resources>
	<Grid>
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto" />
			<RowDefinition Height="*" />
		</Grid.RowDefinitions>

		<!-- 标题栏 -->
		<Border
			Grid.Row="0"
			Background="{DynamicResource CardBackgroundBrush}"
			Padding="16,12">
			<StackPanel Orientation="Horizontal" VerticalAlignment="Center">
				<Button
					Content="返回"
					Style="{StaticResource NavButton}"
					Padding="12,6"
					Margin="0,0,16,0"
					Click="BtnBack_Click" />
				<TextBlock
					x:Name="txtTitle"
					Text="选择版本"
					FontSize="18"
					FontWeight="SemiBold"
					Foreground="{DynamicResource TextPrimaryBrush}"
					FontFamily="Microsoft YaHei"
					VerticalAlignment="Center" />
			</StackPanel>
		</Border>

		<!-- 内容区域 -->
		<Grid Grid.Row="1" Margin="16">
			<Grid.RowDefinitions>
				<RowDefinition Height="Auto" />
				<RowDefinition Height="*" />
			</Grid.RowDefinitions>

			<!-- 版本信息提示 -->
			<Border
				Grid.Row="0"
				Background="{DynamicResource CardBackgroundBrush}"
				CornerRadius="10"
				Padding="16"
				Margin="0,0,0,12">
				<StackPanel>
					<TextBlock
						x:Name="txtInfo"
						FontSize="15"
						Foreground="{DynamicResource TextPrimaryBrush}"
						FontFamily="Microsoft YaHei"
						Margin="0,0,0,6" />
					<TextBlock
						Text="选择您需要安装的版本"
						FontSize="12"
						Foreground="#888888"
						FontFamily="Microsoft YaHei"
						TextWrapping="Wrap" />
				</StackPanel>
			</Border>

			<!-- 加载中 -->
			<Border
				x:Name="pnlLoading"
				Grid.Row="1"
				Background="Transparent"
				Visibility="Collapsed"
				HorizontalAlignment="Center"
				VerticalAlignment="Center">
				<StackPanel HorizontalAlignment="Center">
					<TextBlock
						Text="加载中..."
						FontSize="16"
						Foreground="{DynamicResource TextSecondaryBrush}"
						FontFamily="Microsoft YaHei"
						HorizontalAlignment="Center"
						Margin="0,0,0,12" />
					<Border Height="3" Width="200"
						Background="#333333" CornerRadius="2">
						<Border Width="60"
							Background="#2196F3" CornerRadius="2"
							HorizontalAlignment="Left">
							<Border.Triggers>
								<EventTrigger RoutedEvent="Loaded">
									<BeginStoryboard>
										<Storyboard RepeatBehavior="Forever" AutoReverse="True">
											<ThicknessAnimation
												Storyboard.TargetProperty="Margin"
												From="0,0,0,0" To="140,0,0,0" Duration="0:0:1"
												AutoReverse="True" />
										</Storyboard>
									</BeginStoryboard>
								</EventTrigger>
							</Border.Triggers>
						</Border>
					</Border>
				</StackPanel>
			</Border>

			<!-- Vanilla 直接下载视图 -->
			<Border
				x:Name="pnlVanilla"
				Grid.Row="1"
				Visibility="Collapsed"
				VerticalAlignment="Center"
				HorizontalAlignment="Center"
				Background="{DynamicResource CardHoverBrush}"
				CornerRadius="10"
				Padding="40">
				<StackPanel HorizontalAlignment="Center">
					<TextBlock
						Text="直接下载原版"
						FontSize="20"
						FontWeight="SemiBold"
						Foreground="{DynamicResource TextPrimaryBrush}"
						FontFamily="Microsoft YaHei"
						HorizontalAlignment="Center"
						Margin="0,0,0,10" />
					<TextBlock
						x:Name="txtVanillaDesc"
						Foreground="#888888"
						FontSize="14"
						FontFamily="Microsoft YaHei"
						HorizontalAlignment="Center"
						TextWrapping="Wrap"
						Margin="0,0,0,20" />
					<Border
						x:Name="btnVanillaDownload"
						Cursor="Hand"
						CornerRadius="6"
						Background="#2196F3"
						Padding="24,10"
						HorizontalAlignment="Center"
						MouseLeftButtonUp="VanillaDownload_Click">
						<Border.Resources>
							<Style TargetType="Border">
								<Setter Property="Background" Value="#2196F3"/>
								<Style.Triggers>
									<Trigger Property="IsMouseOver" Value="True">
										<Setter Property="Background" Value="#1976D2"/>
									</Trigger>
								</Style.Triggers>
							</Style>
						</Border.Resources>
						<TextBlock Text="开始下载"
							FontSize="14"
							FontWeight="SemiBold"
							Foreground="{DynamicResource TextPrimaryBrush}"
							FontFamily="Microsoft YaHei"
							HorizontalAlignment="Center"/>
					</Border>
				</StackPanel>
			</Border>

			<!-- 版本列表（推荐版本 + 其他版本分组） -->
			<ScrollViewer
				x:Name="svVersions"
				Grid.Row="1"
				Visibility="Collapsed"
				VerticalScrollBarVisibility="Auto"
				HorizontalScrollBarVisibility="Disabled"
				PreviewMouseWheel="LbVersions_PreviewMouseWheel">
				<StackPanel>

					<!-- 推荐版本分组 -->
					<Border
						Background="#2A2A2A"
						CornerRadius="8"
						Padding="12"
						Margin="0,0,0,8">
						<StackPanel>
							<TextBlock
								Text="推荐版本"
								FontSize="14"
								FontWeight="SemiBold"
								Foreground="{DynamicResource TextPrimaryBrush}"
								FontFamily="Microsoft YaHei"
								Margin="0,0,0,8" />
							<ItemsControl
								x:Name="icRecommendedVersions"
								Background="Transparent"
								MouseLeftButtonUp="LbVersions_MouseLeftButtonUp">
								<ItemsControl.ItemContainerStyle>
									<Style TargetType="ContentPresenter">
										<Setter Property="Focusable" Value="False"/>
									</Style>
								</ItemsControl.ItemContainerStyle>
								<ItemsControl.ItemTemplate>
									<DataTemplate>
										<Border
											Background="#353535"
											CornerRadius="8"
											Margin="0,0,0,8"
											Padding="14"
											Cursor="Hand">
											<Grid>
												<Grid.ColumnDefinitions>
													<ColumnDefinition Width="Auto" />
													<ColumnDefinition Width="*" />
													<ColumnDefinition Width="Auto" />
												</Grid.ColumnDefinitions>
												<Image
													Grid.Column="0"
													Source="{Binding Path=CurrentLoaderIcon, RelativeSource={RelativeSource AncestorType=UserControl}}"
													Width="40"
													Height="40"
													Stretch="Uniform"
													RenderOptions.BitmapScalingMode="HighQuality"
													Margin="0,0,12,0"
													VerticalAlignment="Center" />
												<StackPanel Grid.Column="1" VerticalAlignment="Center">
													<TextBlock
														Text="{Binding DisplayVersion}"
														FontSize="15"
														FontWeight="SemiBold"
														Foreground="{DynamicResource TextPrimaryBrush}"
														FontFamily="Microsoft YaHei" />
													<TextBlock
														Text="{Binding Type, StringFormat='类型: {0}'}"
														FontSize="12"
														Foreground="#888888"
														FontFamily="Microsoft YaHei"
														Margin="0,3,0,0" />
												</StackPanel>
												<Border Grid.Column="2" Background="#2196F3"
													CornerRadius="4" Padding="8,2"
													VerticalAlignment="Center">
													<TextBlock Text="推荐"
														FontSize="11" Foreground="{DynamicResource TextPrimaryBrush}"
														FontWeight="SemiBold"
														FontFamily="Microsoft YaHei" />
												</Border>
											</Grid>
										</Border>
									</DataTemplate>
								</ItemsControl.ItemTemplate>
							</ItemsControl>
						</StackPanel>
					</Border>

					<!-- 其他版本分组 -->
					<Border
						Background="#2A2A2A"
						CornerRadius="8"
						Padding="12"
						Margin="0,0,0,8">
						<StackPanel>
							<TextBlock
								Text="其他版本"
								FontSize="14"
								FontWeight="SemiBold"
								Foreground="{DynamicResource TextPrimaryBrush}"
								FontFamily="Microsoft YaHei"
								Margin="0,0,0,8" />
							<ItemsControl
								x:Name="icOtherVersions"
								Background="Transparent"
								MouseLeftButtonUp="LbVersions_MouseLeftButtonUp">
								<ItemsControl.ItemContainerStyle>
									<Style TargetType="ContentPresenter">
										<Setter Property="Focusable" Value="False"/>
									</Style>
								</ItemsControl.ItemContainerStyle>
								<ItemsControl.ItemTemplate>
									<DataTemplate>
										<Border
											Background="{DynamicResource CardHoverBrush}"
											CornerRadius="8"
											Margin="0,0,0,8"
											Padding="14"
											Cursor="Hand">
											<Grid>
												<Grid.ColumnDefinitions>
													<ColumnDefinition Width="Auto" />
													<ColumnDefinition Width="*" />
												</Grid.ColumnDefinitions>
												<Image
													Grid.Column="0"
													Source="{Binding Path=CurrentLoaderIcon, RelativeSource={RelativeSource AncestorType=UserControl}}"
													Width="40"
													Height="40"
													Stretch="Uniform"
													RenderOptions.BitmapScalingMode="HighQuality"
													Margin="0,0,12,0"
													VerticalAlignment="Center" />
												<StackPanel Grid.Column="1" VerticalAlignment="Center">
													<TextBlock
														Text="{Binding DisplayVersion}"
														FontSize="15"
														FontWeight="SemiBold"
														Foreground="{DynamicResource TextPrimaryBrush}"
														FontFamily="Microsoft YaHei" />
													<TextBlock
														Text="{Binding Type, StringFormat='类型: {0}'}"
														FontSize="12"
														Foreground="#888888"
														FontFamily="Microsoft YaHei"
														Margin="0,3,0,0" />
												</StackPanel>
											</Grid>
										</Border>
									</DataTemplate>
								</ItemsControl.ItemTemplate>
							</ItemsControl>
						</StackPanel>
					</Border>
				</StackPanel>
			</ScrollViewer>
		</Grid>
	</Grid>
</UserControl>
