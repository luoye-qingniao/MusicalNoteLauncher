<UserControl
	x:Class="MusicalNoteLauncher.Pages.ModpacksPage" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:local="clr-namespace:MusicalNoteLauncher.Pages" xmlns:core="clr-namespace:MusicalNoteLauncher.Core"
	Background="{DynamicResource BackgroundBrush}">
	<Grid Background="{DynamicResource BackgroundBrush}">
		<Grid.RowDefinitions>
			<RowDefinition Height="60" />
			<RowDefinition Height="*" />
		</Grid.RowDefinitions>

		<!-- 头部 -->
		<Border Grid.Row="0" Background="{DynamicResource CardHoverBrush}">
			<StackPanel Orientation="Horizontal" Margin="20,0" VerticalAlignment="Center">
				<Button Content="← 返回" Background="#00FFFFFF" Foreground="#2196F3" BorderThickness="0"
				        FontSize="14" FontFamily="Microsoft YaHei" Cursor="Hand" Margin="0,0,20,0" Click="BtnBack_Click"/>
				<Border Background="#9C27B0" CornerRadius="8" Width="32" Height="32" Margin="0,0,10,0">
					<TextBlock Text="📁" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center"/>
				</Border>
				<TextBlock Text="整合包" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}" FontFamily="Microsoft YaHei"/>
			</StackPanel>
		</Border>

		<Grid Row="1" Margin="24,20,24,24">
			<Grid.RowDefinitions>
				<RowDefinition Height="Auto" />
				<RowDefinition Height="*" />
			</Grid.RowDefinitions>

			<!-- 信息横幅 -->
			<Border Grid.Row="0" Background="{DynamicResource CardHoverBrush}" CornerRadius="12" Padding="0" Margin="0,0,0,16">
				<Border CornerRadius="12,0,0,12">
					<Border.Background>
						<LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
							<GradientStop Color="#1E1525" Offset="0"/>
							<GradientStop Color="#2D2D2D" Offset="1"/>
						</LinearGradientBrush>
					</Border.Background>
					<Grid>
						<Grid.ColumnDefinitions>
							<ColumnDefinition Width="4"/>
							<ColumnDefinition Width="*"/>
						</Grid.ColumnDefinitions>
						<Border Grid.Column="0" Background="#9C27B0" CornerRadius="3,0,0,3"/>
						<StackPanel Grid.Column="1" Margin="16,14,16,14">
							<TextBlock Text="📁 整合包下载" FontSize="15" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}"
							           FontFamily="Microsoft YaHei" Margin="0,0,0,6"/>
							<TextBlock Text="整合包包含了Mod、材质包和配置文件，可以一键安装并体验完整的游戏玩法"
							           FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" FontFamily="Microsoft YaHei" TextWrapping="Wrap"/>
						</StackPanel>
					</Grid>
				</Border>
			</Border>

			<!-- 列表区域 -->
			<Border Grid.Row="1" Background="{DynamicResource CardHoverBrush}" CornerRadius="12" Padding="4">
				<ListBox Name="lbModpacks" Background="#00FFFFFF" BorderThickness="0"
				         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
					<ItemsControl.ItemContainerStyle>
						<Style TargetType="{x:Type ListBoxItem}">
							<Setter Property="HorizontalAlignment" Value="Stretch"/>
							<Setter Property="HorizontalContentAlignment" Value="Stretch"/>
							<Setter Property="Height" Value="128"/>
							<Setter Property="Template">
								<Setter.Value>
									<ControlTemplate TargetType="ListBoxItem">
										<Border x:Name="itemBorder" Background="#00FFFFFF"
										        CornerRadius="10" Padding="2" Margin="6,3">
											<ContentPresenter/>
										</Border>
										<ControlTemplate.Triggers>
											<Trigger Property="IsMouseOver" Value="True">
												<Setter TargetName="itemBorder" Property="Background" Value="#FFFFFF08"/>
											</Trigger>
										</ControlTemplate.Triggers>
									</ControlTemplate>
								</Setter.Value>
							</Setter>
						</Style>
					</ItemsControl.ItemContainerStyle>
					<ItemsControl.ItemTemplate>
						<DataTemplate>
							<Border Background="{DynamicResource SurfaceBrush}" CornerRadius="10" Padding="16" Height="120">
								<Border.Effect>
									<DropShadowEffect BlurRadius="6" ShadowDepth="1" Opacity="0.12" Color="Black"/>
								</Border.Effect>
								<Grid>
									<Grid.ColumnDefinitions>
										<ColumnDefinition Width="80"/>
										<ColumnDefinition Width="*"/>
										<ColumnDefinition Width="120"/>
									</Grid.ColumnDefinitions>

									<!-- 图标 -->
									<Border Grid.Column="0" Background="{DynamicResource SurfaceBrush}" CornerRadius="12"
									        Width="80" Height="80" VerticalAlignment="Center">
										<Border.Effect>
											<DropShadowEffect BlurRadius="8" ShadowDepth="2" Opacity="0.2" Color="Black"/>
										</Border.Effect>
										<UIElement.OpacityMask>
											<VisualBrush>
												<VisualBrush.Visual>
													<Rectangle Width="80" Height="80" RadiusX="12" RadiusY="12" Fill="#FFFFFFFF"/>
												</VisualBrush.Visual>
											</VisualBrush>
										</UIElement.OpacityMask>
										<Image Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"
										       Source="{Binding IconUrl}"/>
									</Border>

									<!-- 信息 -->
									<StackPanel Grid.Column="1" Margin="14,0,0,0" VerticalAlignment="Center">
										<StackPanel Orientation="Horizontal">
											<TextBlock FontSize="15" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}"
											           FontFamily="Microsoft YaHei" TextTrimming="CharacterEllipsis"
											           MaxWidth="400" Text="{Binding Name, FallbackValue=未知名称}"/>
											<Border CornerRadius="4" Margin="8,0,0,0" VerticalAlignment="Center"
											        Padding="6,2" Background="#9C27B0">
												<TextBlock FontSize="10" FontWeight="SemiBold" Foreground="White"
												           Text="{Binding Version, FallbackValue=未知版本}"/>
											</Border>
										</StackPanel>
										<TextBlock FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" FontFamily="Microsoft YaHei"
										           Margin="0,5,0,5" TextTrimming="CharacterEllipsis" MaxWidth="500"
										           Height="24" Text="{Binding Description, FallbackValue=暂无描述}"/>
										<StackPanel Orientation="Horizontal">
											<TextBlock FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"
											           FontFamily="Microsoft YaHei" Margin="0,0,14,0"
											           TextTrimming="CharacterEllipsis" MaxWidth="150"
											           Text="{Binding Author, FallbackValue=未知作者}"/>
											<TextBlock FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"
											           FontFamily="Microsoft YaHei"
											           Text="{Binding Downloads, FallbackValue=0}"/>
										</StackPanel>
									</StackPanel>

									<!-- 下载安装按钮 -->
									<Button Grid.Column="2" Content="下载安装" Width="100" Height="42"
									        FontSize="13" FontWeight="SemiBold" FontFamily="Microsoft YaHei"
									        Foreground="White" Cursor="Hand" VerticalAlignment="Center" Click="BtnDownload_Click">
										<Button.Template>
											<ControlTemplate TargetType="Button">
												<Border x:Name="btnBorder" CornerRadius="10" Padding="18,8">
													<Border.Background>
														<LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
															<GradientStop Color="#1EBB8E" Offset="0"/>
															<GradientStop Color="#168A6E" Offset="1"/>
														</LinearGradientBrush>
													</Border.Background>
													<Border.Effect>
														<DropShadowEffect BlurRadius="8" ShadowDepth="2" Opacity="0.3" Color="#1EBB8E"/>
													</Border.Effect>
													<ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
												</Border>
												<ControlTemplate.Triggers>
													<Trigger Property="IsMouseOver" Value="True">
														<Setter TargetName="btnBorder" Property="Background">
															<Setter.Value>
																<LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
																	<GradientStop Color="#20D49E" Offset="0"/>
																	<GradientStop Color="#1EBB8E" Offset="1"/>
																</LinearGradientBrush>
															</Setter.Value>
														</Setter>
													</Trigger>
													<Trigger Property="IsPressed" Value="True">
														<Setter TargetName="btnBorder" Property="Background" Value="#147A5E"/>
													</Trigger>
												</ControlTemplate.Triggers>
											</ControlTemplate>
										</Button.Template>
									</Button>
								</Grid>
							</Border>
						</DataTemplate>
					</ItemsControl.ItemTemplate>
				</ListBox>
			</Border>
		</Grid>

		<!-- 版本选择面板（覆盖层） -->
		<Border x:Name="VersionPanel" Grid.Row="1" Visibility="Collapsed" Panel.ZIndex="100">
			<Border.Background>
				<LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
					<GradientStop Color="#E6101010" Offset="0"/>
					<GradientStop Color="#F01E1E1E" Offset="1"/>
				</LinearGradientBrush>
			</Border.Background>
			<Grid Margin="40,30,40,40">
				<Grid.RowDefinitions>
					<RowDefinition Height="Auto"/>
					<RowDefinition Height="Auto"/>
					<RowDefinition Height="*"/>
					<RowDefinition Height="Auto"/>
				</Grid.RowDefinitions>
				<Grid.Effect>
					<DropShadowEffect BlurRadius="30" ShadowDepth="4" Opacity="0.5" Color="Black"/>
				</Grid.Effect>

				<!-- 标题栏 -->
				<Border Grid.Row="0" CornerRadius="12,12,0,0" Padding="20,18">
					<Border.Background>
						<LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
							<GradientStop Color="#2A1535" Offset="0"/>
							<GradientStop Color="#2D2D2D" Offset="1"/>
						</LinearGradientBrush>
					</Border.Background>
					<StackPanel Orientation="Horizontal">
						<Button x:Name="VersionBackBtn" Content="← 返回列表"
						        Background="#00FFFFFF" Foreground="#CE93D8" BorderThickness="0"
						        FontSize="14" FontWeight="SemiBold" FontFamily="Microsoft YaHei"
						        Cursor="Hand" Padding="8,4" Click="VersionBackBtn_Click">
							<Button.Template>
								<ControlTemplate TargetType="Button">
									<Border x:Name="bd" Background="{TemplateBinding Background}"
									        CornerRadius="6" Padding="{TemplateBinding Padding}">
										<ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
										                  TextElement.Foreground="{TemplateBinding Foreground}"/>
									</Border>
									<ControlTemplate.Triggers>
										<Trigger Property="IsMouseOver" Value="True">
											<Setter TargetName="bd" Property="Background" Value="#32203D"/>
										</Trigger>
									</ControlTemplate.Triggers>
								</ControlTemplate>
							</Button.Template>
						</Button>
						<Border Width="1" Background="{DynamicResource SurfaceBrush}" Margin="14,4"/>
						<StackPanel Orientation="Horizontal" VerticalAlignment="Center">
							<TextBlock Text="📋" FontSize="18" VerticalAlignment="Center" Margin="0,0,10,0"/>
							<TextBlock x:Name="VersionTitle" Text="选择下载版本"
							           FontSize="17" FontWeight="Bold" Foreground="White"
							           FontFamily="Microsoft YaHei" VerticalAlignment="Center"/>
						</StackPanel>
					</StackPanel>
				</Border>

				<!-- 版本筛选栏 -->
				<Border Grid.Row="1" Background="{DynamicResource CardBackgroundBrush}" Padding="10,8" BorderBrush="#2D2D2D" BorderThickness="0,0,0,1">
					<StackPanel x:Name="VersionFilterPanel" Orientation="Horizontal"/>
				</Border>

				<!-- 版本列表 -->
				<Border Grid.Row="2" Background="{DynamicResource CardBackgroundBrush}">
					<ListView x:Name="VersionListView" Background="Transparent" Foreground="White"
					          BorderThickness="0" ScrollViewer.HorizontalScrollBarVisibility="Disabled"
					          Margin="4,0" MouseDoubleClick="VersionListView_MouseDoubleClick">
						<ListView.ItemContainerStyle>
							<Style TargetType="ListViewItem">
								<Setter Property="Background" Value="Transparent"/>
								<Setter Property="Padding" Value="14,12"/>
								<Setter Property="Margin" Value="0,2"/>
								<Setter Property="Template">
									<Setter.Value>
										<ControlTemplate TargetType="ListViewItem">
											<Border x:Name="Bd" Background="{TemplateBinding Background}"
											        CornerRadius="8" Padding="{TemplateBinding Padding}" Margin="8,2">
												<ContentPresenter/>
											</Border>
											<ControlTemplate.Triggers>
												<Trigger Property="IsMouseOver" Value="True">
													<Setter TargetName="Bd" Property="Background" Value="{DynamicResource CardBackgroundBrush}"/>
													<Setter TargetName="Bd" Property="Effect">
														<Setter.Value>
															<DropShadowEffect BlurRadius="6" ShadowDepth="1" Opacity="0.2" Color="#9C27B0"/>
														</Setter.Value>
													</Setter>
												</Trigger>
												<Trigger Property="IsSelected" Value="True">
													<Setter TargetName="Bd" Property="Background" Value="#1A3350"/>
												</Trigger>
											</ControlTemplate.Triggers>
										</ControlTemplate>
									</Setter.Value>
								</Setter>
							</Style>
						</ListView.ItemContainerStyle>
						<ListView.ItemTemplate>
							<DataTemplate>
								<Grid>
									<Grid.ColumnDefinitions>
										<ColumnDefinition Width="*"/>
										<ColumnDefinition Width="Auto"/>
									</Grid.ColumnDefinitions>
									<StackPanel Grid.Column="0" VerticalAlignment="Center">
										<StackPanel Orientation="Horizontal">
											<TextBlock Text="{Binding VersionName}" FontSize="14" FontWeight="Bold"
											           Foreground="White" FontFamily="Microsoft YaHei"/>
											<Border CornerRadius="4" Margin="10,0,0,0" VerticalAlignment="Center"
											        Padding="7,3" Background="{Binding VersionType, Converter={StaticResource VersionTypeColorConverter}}">
												<Border.Effect>
													<DropShadowEffect BlurRadius="3" ShadowDepth="0" Opacity="0.4" Color="Black"/>
												</Border.Effect>
												<TextBlock Text="{Binding VersionType}" FontSize="10" FontWeight="SemiBold" Foreground="White"/>
											</Border>
											<Border x:Name="RecBadge" CornerRadius="4" Margin="6,0,0,0" VerticalAlignment="Center"
											        Padding="7,3" Visibility="{Binding IsRecommended, Converter={StaticResource BoolToVisibilityConverter}}"
											        Background="#FF1EBB8E">
												<Border.Effect>
													<DropShadowEffect BlurRadius="4" ShadowDepth="0" Opacity="0.4" Color="#1EBB8E"/>
												</Border.Effect>
												<StackPanel Orientation="Horizontal">
													<TextBlock Text="★" FontSize="10" Foreground="#FFD700" VerticalAlignment="Center" Margin="0,0,3,0"/>
													<TextBlock Text="推荐" FontSize="10" FontWeight="Bold" Foreground="White"/>
												</StackPanel>
											</Border>
										</StackPanel>
										<TextBlock Text="{Binding DisplayInfo}" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"
										           FontFamily="Microsoft YaHei" Margin="0,6,0,0"/>
									</StackPanel>
									<StackPanel Grid.Column="1" VerticalAlignment="Center" Orientation="Horizontal">
										<TextBlock Text="{Binding FileSize, Converter={StaticResource FileSizeConverter}}"
										           FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center" Margin="0,0,12,0"/>
										<Button Content="下载安装" Width="96" Height="34" FontSize="12" FontWeight="SemiBold"
										        FontFamily="Microsoft YaHei" Foreground="White" Cursor="Hand"
										        Click="VersionItemDownload_Click" Tag="{Binding}">
											<Button.Template>
												<ControlTemplate TargetType="Button">
													<Border x:Name="btnBorder" CornerRadius="8" Padding="14,7">
														<Border.Background>
															<LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
																<GradientStop Color="#1EBB8E" Offset="0"/>
																<GradientStop Color="#168A6E" Offset="1"/>
															</LinearGradientBrush>
														</Border.Background>
														<Border.Effect>
															<DropShadowEffect BlurRadius="6" ShadowDepth="2" Opacity="0.3" Color="#1EBB8E"/>
														</Border.Effect>
														<ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
													</Border>
													<ControlTemplate.Triggers>
														<Trigger Property="IsMouseOver" Value="True">
															<Setter TargetName="btnBorder" Property="Background">
																<Setter.Value>
																	<LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
																		<GradientStop Color="#20D49E" Offset="0"/>
																		<GradientStop Color="#1EBB8E" Offset="1"/>
																	</LinearGradientBrush>
																</Setter.Value>
															</Setter>
														</Trigger>
														<Trigger Property="IsPressed" Value="True">
															<Setter TargetName="btnBorder" Property="Background" Value="#147A5E"/>
														</Trigger>
													</ControlTemplate.Triggers>
												</ControlTemplate>
											</Button.Template>
										</Button>
									</StackPanel>
								</Grid>
							</DataTemplate>
						</ListView.ItemTemplate>
					</ListView>
				</Border>

				<!-- 底部操作栏 -->
				<Border Grid.Row="3" CornerRadius="0,0,12,12" Padding="14,12">
					<Border.Background>
						<LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
							<GradientStop Color="#2D2D2D" Offset="0"/>
							<GradientStop Color="#252525" Offset="1"/>
						</LinearGradientBrush>
					</Border.Background>
					<Grid>
						<TextBlock x:Name="VersionCountText" Text="" FontSize="13"
						           Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center" HorizontalAlignment="Left"
						           FontFamily="Microsoft YaHei"/>
						<Button x:Name="VersionCancelBtn" Content="取消" Width="110" Height="34"
						        FontSize="13" FontWeight="SemiBold" FontFamily="Microsoft YaHei"
						        Foreground="{DynamicResource TextPrimaryBrush}" Cursor="Hand" HorizontalAlignment="Right"
						        Click="VersionBackBtn_Click">
							<Button.Template>
								<ControlTemplate TargetType="Button">
									<Border x:Name="cancelBorder" Background="{DynamicResource SurfaceBrush}" CornerRadius="8"
									        BorderBrush="#555555" BorderThickness="1">
										<ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
									</Border>
									<ControlTemplate.Triggers>
										<Trigger Property="IsMouseOver" Value="True">
											<Setter TargetName="cancelBorder" Property="Background" Value="#4A4A4A"/>
											<Setter TargetName="cancelBorder" Property="BorderBrush" Value="#777777"/>
										</Trigger>
										<Trigger Property="IsPressed" Value="True">
											<Setter TargetName="cancelBorder" Property="Background" Value="{DynamicResource SurfaceBrush}"/>
										</Trigger>
									</ControlTemplate.Triggers>
								</ControlTemplate>
							</Button.Template>
						</Button>
					</Grid>
				</Border>
			</Grid>
		</Border>

		<!-- 安装进度覆盖层 -->
		<Border x:Name="InstallProgressOverlay" Grid.Row="1" Visibility="Collapsed" Panel.ZIndex="200">
			<Border.Background>
				<LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
					<GradientStop Color="#E6101010" Offset="0"/>
					<GradientStop Color="#F01E1E1E" Offset="1"/>
				</LinearGradientBrush>
			</Border.Background>
			<Grid HorizontalAlignment="Center" VerticalAlignment="Center" Width="420">
				<Border Background="{DynamicResource CardBackgroundBrush}" CornerRadius="16" Padding="30,28"
				        BorderBrush="#444444" BorderThickness="1">
					<Border.Effect>
						<DropShadowEffect BlurRadius="24" ShadowDepth="4" Opacity="0.5" Color="Black"/>
					</Border.Effect>
					<StackPanel>
						<StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,16">
							<TextBlock Text="📦" FontSize="24" VerticalAlignment="Center" Margin="0,0,10,0"/>
							<TextBlock x:Name="InstallTitleText" Text="正在安装整合包..."
							           FontSize="18" FontWeight="Bold" Foreground="White"
							           FontFamily="Microsoft YaHei" VerticalAlignment="Center"/>
						</StackPanel>
						<TextBlock x:Name="InstallStatusText" Text="准备中..."
						           FontSize="14" Foreground="{DynamicResource TextPrimaryBrush}" FontFamily="Microsoft YaHei"
						           HorizontalAlignment="Center" Margin="0,0,0,18" TextWrapping="Wrap" TextAlignment="Center"/>
						<ProgressBar x:Name="InstallProgressBar" Height="8" Minimum="0" Maximum="100" Value="0"
						             BorderThickness="0" Margin="0,0,0,16">
							<ProgressBar.Foreground>
								<LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
									<GradientStop Color="#1EBB8E" Offset="0"/>
									<GradientStop Color="#20D49E" Offset="1"/>
								</LinearGradientBrush>
							</ProgressBar.Foreground>
							<ProgressBar.Background>
								<SolidColorBrush Color="#333333"/>
							</ProgressBar.Background>
						</ProgressBar>
						<TextBlock x:Name="InstallPercentText" Text="0%"
						           FontSize="28" FontWeight="Bold" Foreground="#1EBB8E"
						           FontFamily="Microsoft YaHei" HorizontalAlignment="Center"/>
						<Button x:Name="InstallCancelBtn" Content="取消" Width="100" Height="34"
						        FontSize="13" FontWeight="SemiBold" FontFamily="Microsoft YaHei"
						        Foreground="{DynamicResource TextPrimaryBrush}" Cursor="Hand" HorizontalAlignment="Center"
						        Margin="0,16,0,0" Click="InstallCancelBtn_Click">
							<Button.Template>
								<ControlTemplate TargetType="Button">
									<Border x:Name="cancelBorder" Background="{DynamicResource SurfaceBrush}" CornerRadius="8"
									        BorderBrush="#555555" BorderThickness="1">
										<ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
									</Border>
									<ControlTemplate.Triggers>
										<Trigger Property="IsMouseOver" Value="True">
											<Setter TargetName="cancelBorder" Property="Background" Value="#4A4A4A"/>
										</Trigger>
									</ControlTemplate.Triggers>
								</ControlTemplate>
							</Button.Template>
						</Button>
					</StackPanel>
				</Border>
			</Grid>
		</Border>
	</Grid>
</UserControl>