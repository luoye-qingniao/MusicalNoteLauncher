<UserControl
	x:Class="MusicalNoteLauncher.Pages.GameVersionsPage" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:local="clr-namespace:MusicalNoteLauncher.Pages"
	Background="{DynamicResource BackgroundBrush}"
	PreviewMouseWheel="Page_PreviewMouseWheel">
	<FrameworkElement.Resources>
		<local:VersionTypeToColorConverter
			x:Key="VersionTypeToColorConverter" />
		<local:VersionTypeToTextConverter
			x:Key="VersionTypeToTextConverter" />
		<local:VersionTypeToIconConverter
			x:Key="VersionTypeToIconConverter" />
		<local:StatusToBackgroundConverter
			x:Key="StatusToBackgroundConverter" />
		<local:StatusToEnabledConverter
			x:Key="StatusToEnabledConverter" />
		<local:StatusToVisibilityConverter
			x:Key="StatusToVisibilityConverter" />
		<local:BooleanToVisibilityConverter
			x:Key="BooleanToVisibilityConverter" />
		<local:BooleanToAngleConverter
			x:Key="BooleanToAngleConverter" />
		<local:ProgressWidthConverter
			x:Key="ProgressWidthConverter" />
		<Style
			x:Key="DarkScrollBarStyle"
			TargetType="{x:Type ScrollBar}">
			<Setter
				Property="Background"
				Value="{DynamicResource CardBackgroundBrush}" />
			<Setter
				Property="Foreground"
				Value="#555555" />
			<Setter
				Property="Width"
				Value="12" />
			<Setter
				Property="Template">
				<Setter.Value>
					<ControlTemplate
						TargetType="{x:Type ScrollBar}">
						<Grid
							Background="{DynamicResource CardBackgroundBrush}">
							<Border
								Name="TrackBackground"
								Background="{DynamicResource CardBackgroundBrush}"
								CornerRadius="2" />
							<RepeatButton
								Name="LineUp"
								Command="ScrollBar.LineUpCommand"
								Background="{DynamicResource CardBackgroundBrush}"
								Foreground="#555555"
								Height="0"
								Visibility="Collapsed" />
							<RepeatButton
								Name="LineDown"
								Command="ScrollBar.LineDownCommand"
								Background="{DynamicResource CardBackgroundBrush}"
								Foreground="#555555"
								Height="0"
								Visibility="Collapsed" />
							<Thumb
								Name="Thumb"
								Background="#555555"
								Margin="2,0">
								<Control.Template>
									<ControlTemplate>
										<Border
											Background="#555555"
											CornerRadius="4" />
									</ControlTemplate>
								</Control.Template>
							</Thumb>
						</Grid>
					</ControlTemplate>
				</Setter.Value>
			</Setter>
		</Style>
		<Style
			x:Key="DarkHorizontalScrollBarStyle"
			TargetType="{x:Type ScrollBar}">
			<Setter
				Property="Background"
				Value="{DynamicResource CardBackgroundBrush}" />
			<Setter
				Property="Foreground"
				Value="#555555" />
			<Setter
				Property="Height"
				Value="12" />
			<Setter
				Property="Template">
				<Setter.Value>
					<ControlTemplate
						TargetType="{x:Type ScrollBar}">
						<Grid
							Background="{DynamicResource CardBackgroundBrush}">
							<Border
								Name="TrackBackground"
								Background="{DynamicResource CardBackgroundBrush}"
								CornerRadius="2" />
							<RepeatButton
								Name="LineLeft"
								Command="ScrollBar.LineLeftCommand"
								Background="{DynamicResource CardBackgroundBrush}"
								Foreground="#555555"
								Width="0"
								Visibility="Collapsed" />
							<RepeatButton
								Name="LineRight"
								Command="ScrollBar.LineRightCommand"
								Background="{DynamicResource CardBackgroundBrush}"
								Foreground="#555555"
								Width="0"
								Visibility="Collapsed" />
							<Thumb
								Name="Thumb"
								Background="#555555"
								Margin="0,2">
								<Control.Template>
									<ControlTemplate>
										<Border
											Background="#555555"
											CornerRadius="4" />
									</ControlTemplate>
								</Control.Template>
							</Thumb>
						</Grid>
					</ControlTemplate>
				</Setter.Value>
			</Setter>
		</Style>
		<Style
			x:Key="DarkListBoxItemStyle"
			TargetType="{x:Type ListBoxItem}">
			<Setter
				Property="Background"
				Value="#00FFFFFF" />
			<Setter
				Property="BorderThickness"
				Value="0" />
			<Setter
				Property="Padding"
				Value="0" />
			<Setter
				Property="Margin"
				Value="0" />
			<Setter
				Property="FrameworkElement.FocusVisualStyle"
				Value="{x:Null}" />
			<Setter
				Property="HorizontalContentAlignment"
				Value="Stretch" />
			<Setter
				Property="VerticalContentAlignment"
				Value="Stretch" />
		</Style>
		<Style
			x:Key="GroupHeaderToggleStyle"
			TargetType="{x:Type ToggleButton}">
			<Setter
				Property="Background"
				Value="#2A2A2A" />
			<Setter
				Property="BorderThickness"
				Value="0" />
			<Setter
				Property="Padding"
				Value="12,10" />
			<Setter
				Property="Margin"
				Value="0,0,0,8" />
			<Setter
				Property="HorizontalAlignment"
				Value="Stretch" />
			<Setter
				Property="FrameworkElement.Cursor"
				Value="Hand" />
			<Setter
				Property="Template">
				<Setter.Value>
					<ControlTemplate
						TargetType="{x:Type ToggleButton}">
						<Border
							Background="#2A2A2A"
							CornerRadius="8"
							Padding="12,10">
							<Grid
								Width="Auto">
								<Grid.ColumnDefinitions>
									<ColumnDefinition
										Width="*" />
									<ColumnDefinition
										Width="Auto" />
								</Grid.ColumnDefinitions>
								<TextBlock
									Grid.Column="0"
									FontSize="14"
									FontWeight="SemiBold"
									Foreground="{DynamicResource TextPrimaryBrush}"
									FontFamily="Microsoft YaHei"
									VerticalAlignment="Center"
									Text="{Binding Name}" />
								<Path
									Grid.Column="1"
									Data="M0,2 L4,6 L8,2"
									Fill="#888888"
									Stroke="#00FFFFFF"
									StrokeThickness="1"
									Width="10"
									Height="10"
									HorizontalAlignment="Center"
									VerticalAlignment="Center">
									<UIElement.RenderTransform>
										<RotateTransform
											CenterX="4"
											CenterY="5"
											Angle="{Binding IsChecked, RelativeSource={RelativeSource TemplatedParent}, Converter={local:BooleanToAngleConverter}}" />
									</UIElement.RenderTransform>
								</Path>
							</Grid>
						</Border>
					</ControlTemplate>
				</Setter.Value>
			</Setter>
		</Style>
		<Style
			x:Key="LatestVersionGroupHeaderStyle"
			TargetType="{x:Type Border}">
			<Setter
				Property="Background"
				Value="#2A2A2A" />
			<Setter
				Property="Border.CornerRadius"
				Value="8" />
			<Setter
				Property="Border.Padding"
				Value="12" />
			<Setter
				Property="Margin"
				Value="0,0,0,8" />
		</Style>
	</FrameworkElement.Resources>
	<Grid
		Background="{DynamicResource BackgroundBrush}">
		<Grid.RowDefinitions>
			<RowDefinition
				Height="60" />
			<RowDefinition
				Height="*" />
		</Grid.RowDefinitions>
		<Border
			Grid.Row="0"
			Background="{DynamicResource CardHoverBrush}">
			<StackPanel
				Orientation="Horizontal"
				Margin="20,0"
				VerticalAlignment="Center">
				<Button
					Content="← 返回"
					Background="#00FFFFFF"
					Foreground="#2196F3"
					BorderThickness="0"
					FontSize="14"
					FontFamily="Microsoft YaHei"
					Cursor="Hand"
					Margin="0,0,20,0"
					Click="BtnBack_Click" />
				<TextBlock
					Text="游戏版本"
					FontSize="20"
					FontWeight="Bold"
					Foreground="{DynamicResource TextPrimaryBrush}" />
			</StackPanel>
		</Border>
		<Grid
			Row="1"
			Margin="20">
			<TabControl
				Name="VersionTabControl"
				Background="#00FFFFFF"
				BorderThickness="0">
				<FrameworkElement.Resources>
					<ResourceDictionary>
						<Style
							TargetType="{x:Type TabItem}"
							x:Key="{x:Type TabItem}">
							<Setter
								Property="Template">
								<Setter.Value>
									<ControlTemplate
										TargetType="{x:Type TabItem}">
										<Border
											Name="TabBorder"
											Background="#00FFFFFF"
											Padding="20,12"
											Margin="0,0,8,0">
											<StackPanel
												Orientation="Vertical">
												<TextBlock
													Name="HeaderText"
													Text="{TemplateBinding Header}"
													FontSize="14"
													FontFamily="Microsoft YaHei"
													Foreground="#9C9C9C" />
												<Border
													Name="Underline"
													Height="2"
													Background="#2196F3"
													Margin="0,4,0,0"
													Visibility="Collapsed" />
											</StackPanel>
										</Border>
										<ControlTemplate.Triggers>
											<Trigger
												Property="TabItem.IsSelected"
												Value="True">
												<Setter
													TargetName="TabBorder"
													Property="Background"
													Value="#2A2A2A" />
												<Setter
													TargetName="HeaderText"
													Property="Foreground"
													Value="#FFFFFF" />
												<Setter
													TargetName="Underline"
													Property="Visibility"
													Value="Visible" />
											</Trigger>
										</ControlTemplate.Triggers>
									</ControlTemplate>
								</Setter.Value>
							</Setter>
						</Style>
					</ResourceDictionary>
				</FrameworkElement.Resources>
				<TabItem
					Header="可下载版本">
					<Grid>
						<Grid.RowDefinitions>
							<RowDefinition
								Height="Auto" />
							<RowDefinition
								Height="*" />
						</Grid.RowDefinitions>
						<Border
							Grid.Row="0"
							Background="{DynamicResource SurfaceBrush}"
							CornerRadius="8"
							Padding="16"
							Margin="0,0,0,16">
							<StackPanel>
								<TextBlock
									Text="📦 游戏版本下载"
									FontSize="14"
									Foreground="{DynamicResource TextPrimaryBrush}"
									FontFamily="Microsoft YaHei"
									Margin="0,0,0,8" />
								<TextBlock
									Text="选择您想要下载的Minecraft游戏版本，支持最新版本和历史版本"
									FontSize="12"
									Foreground="{DynamicResource TextSecondaryBrush}"
									FontFamily="Microsoft YaHei"
									TextWrapping="Wrap" />
								<TextBlock
									x:Name="loadingLatest"
									Text="⏳ 正在加载版本列表..."
									FontSize="13"
									Foreground="#2196F3"
									FontFamily="Microsoft YaHei"
									Margin="0,4,0,0" />
							</StackPanel>
						</Border>
						<Border
							Grid.Row="1"
							Background="{DynamicResource CardBackgroundBrush}"
							CornerRadius="12"
							Padding="16"
							ClipToBounds="True">
							<ScrollViewer
								VerticalScrollBarVisibility="Auto"
								HorizontalScrollBarVisibility="Disabled">
								<StackPanel
									Name="VersionsContainer">
									<Border
										Style="{StaticResource LatestVersionGroupHeaderStyle}">
										<StackPanel>
											<TextBlock
												Text="最新版本"
												FontSize="14"
												FontWeight="SemiBold"
												Foreground="{DynamicResource TextPrimaryBrush}"
												FontFamily="Microsoft YaHei"
												Margin="0,0,0,8" />
											<ListView
												Name="lvLatestVersions"
												Background="#00FFFFFF"
												BorderThickness="0"
												VirtualizingPanel.IsVirtualizing="True"
												VirtualizingPanel.VirtualizationMode="Recycling"
												ScrollViewer.CanContentScroll="False"
												ScrollViewer.VerticalScrollBarVisibility="Disabled">
												<ItemsControl.ItemTemplate>
													<DataTemplate>
														<Border
															CornerRadius="8"
															Margin="0,0,0,8"
															Padding="14"
															Background="#353535"
															Cursor="Hand">
															<Grid>
																<Grid.ColumnDefinitions>
																	<ColumnDefinition
																		Width="Auto" />
																	<ColumnDefinition
																		Width="*" />
																	<ColumnDefinition
																		Width="Auto" />
																</Grid.ColumnDefinitions>
																<Image
																	Grid.Column="0"
																	Width="48"
																	Height="48"
																	Margin="0,0,16,0"
																	Stretch="Uniform"
																	Source="{Binding VersionType, Converter={local:VersionTypeToIconConverter}}" />
																<StackPanel
																	Grid.Column="1"
																	VerticalAlignment="Center">
																	<TextBlock
																		FontSize="18"
																		FontWeight="Bold"
																		Foreground="{DynamicResource TextPrimaryBrush}"
																		FontFamily="Microsoft YaHei"
																		Text="{Binding VersionId}" />
																	<TextBlock
																		FontSize="13"
																		Foreground="#888888"
																		FontFamily="Microsoft YaHei"
																		Text="{Binding Description}" />
																</StackPanel>
																<!--未知连接 ID：6-->
																<Button
																	Grid.Column="2"
																	Cursor="Hand"
																	VerticalAlignment="Center"
																	MinWidth="88"
																	Height="32"
																	BorderThickness="0"
																	Background="#2196F3"
																	Foreground="{DynamicResource TextPrimaryBrush}"
																	FontSize="13"
																	FontWeight="SemiBold"
																	FontFamily="Microsoft YaHei"
																	Content="{Binding StatusText}"
																	IsEnabled="{Binding CanDownload}"
																	Click="BtnDownload_Click">
																	<Control.Template>
																		<ControlTemplate
																			TargetType="{x:Type Button}">
																			<Border
																				CornerRadius="6"
																				Background="{TemplateBinding Background}">
																				<ContentPresenter
																					HorizontalAlignment="Center"
																					VerticalAlignment="Center" />
																			</Border>
																		</ControlTemplate>
																	</Control.Template>
																	<FrameworkElement.Style>
																		<Style
																			TargetType="{x:Type Button}">
																			<Style.Triggers>
																				<Trigger
																					Property="UIElement.IsMouseOver"
																					Value="True">
																					<Setter
																						Property="Background"
																						Value="#1976D2" />
																				</Trigger>
																				<DataTrigger
																					Value="已下载"
																					Binding="{Binding Status}">
																					<Setter
																						Property="Background"
																						Value="#388E3C" />
																					<Setter
																						Property="Foreground"
																						Value="#B0BEC5" />
																					<Setter
																						Property="IsEnabled"
																						Value="False" />
																				</DataTrigger>
																			</Style.Triggers>
																		</Style>
																	</FrameworkElement.Style>
																</Button>
															</Grid>
														</Border>
													</DataTemplate>
												</ItemsControl.ItemTemplate>
											</ListView>
										</StackPanel>
									</Border>
									<ItemsControl
										Name="icVersions"
										Background="#00FFFFFF"
										PreviewMouseLeftButtonDown="VersionsContainer_PreviewMouseLeftButtonDown">
										<FrameworkElement.ToolTip>
											<ToolTip>点击刷新版本列表</ToolTip>
										</FrameworkElement.ToolTip>
										<ItemsControl.ItemTemplate>
											<DataTemplate>
												<StackPanel>
													<ToggleButton
														Name="HeaderToggle"
														Style="{StaticResource GroupHeaderToggleStyle}"
														IsChecked="{Binding IsExpanded, Mode=TwoWay}"
														DataContext="{Binding Path=.}" />
													<Border
														Visibility="{Binding IsExpanded, Converter={StaticResource BooleanToVisibilityConverter}}">
														<ListView
															Name="lvGroupVersions"
															Background="#00FFFFFF"
															BorderThickness="0"
															VirtualizingPanel.IsVirtualizing="True"
															VirtualizingPanel.VirtualizationMode="Recycling"
															VirtualizingPanel.CacheLength="50"
															VirtualizingPanel.CacheLengthUnit="Page"
															ScrollViewer.CanContentScroll="True"
															ScrollViewer.VerticalScrollBarVisibility="Disabled"
															ItemsSource="{Binding Versions}">
															<ItemsControl.ItemContainerStyle>
																<Style
																	TargetType="{x:Type ListViewItem}">
																	<Setter
																		Property="Background"
																		Value="#00FFFFFF" />
																	<Setter
																		Property="BorderThickness"
																		Value="0" />
																	<Setter
																		Property="Padding"
																		Value="0" />
																	<Setter
																		Property="Margin"
																		Value="0" />
																	<Setter
																		Property="FrameworkElement.FocusVisualStyle"
																		Value="{x:Null}" />
																</Style>
															</ItemsControl.ItemContainerStyle>
															<ItemsControl.ItemTemplate>
																<DataTemplate>
																	<Border
																		Name="CardBorder"
																		CornerRadius="8"
																		Margin="0,0,0,8"
																		Padding="16,12"
																		Cursor="Hand">
																		<Border.Background>
																			<LinearGradientBrush
																				StartPoint="0,0"
																				EndPoint="0,1">
																				<GradientStop
																					Color="#2A2A2A"
																					Offset="0" />
																				<GradientStop
																					Color="#252525"
																					Offset="1" />
																			</LinearGradientBrush>
																		</Border.Background>
																		<UIElement.Effect>
																			<DropShadowEffect
																				BlurRadius="2"
																				ShadowDepth="1"
																				Opacity="0.1" />
																		</UIElement.Effect>
																		<Grid>
																			<Grid.ColumnDefinitions>
																				<ColumnDefinition
																					Width="*" />
																				<ColumnDefinition
																					Width="Auto" />
																				<ColumnDefinition
																					Width="100" />
																			</Grid.ColumnDefinitions>
																			<StackPanel
																				Grid.Column="0"
																				VerticalAlignment="Center">
																				<StackPanel
																					Orientation="Horizontal"
																					VerticalAlignment="Center">
																					<Image
																						Width="36"
																						Height="36"
																						Stretch="Uniform"
																						Margin="0,0,8,0"
																						Source="{Binding VersionType, Converter={local:VersionTypeToIconConverter}}" />
																					<TextBlock
																						FontSize="18"
																						FontWeight="Bold"
																						Foreground="{DynamicResource TextPrimaryBrush}"
																						FontFamily="Microsoft YaHei"
																						Text="{Binding VersionId}" />
																				</StackPanel>
																				<TextBlock
																					FontSize="12"
																					Foreground="{DynamicResource TextSecondaryBrush}"
																					FontFamily="Microsoft YaHei"
																					Margin="0,4,0,0"
																					Text="{Binding ReleaseTime, StringFormat=yyyy-MM-dd HH:mm:ss}" />
																				<ProgressBar
																					Maximum="100"
																					Height="3"
																					Margin="0,4,0,0"
																					Background="#353535"
																					Foreground="#2196F3"
																					BorderThickness="0"
																					Value="{Binding DownloadProgress}"
																					Visibility="{Binding IsDownloading, Converter={local:BooleanToVisibilityConverter}}" />
																			</StackPanel>
																			<StackPanel
																				Grid.Column="1"
																				VerticalAlignment="Center"
																				Margin="12,0">
																				<Border
																					CornerRadius="10"
																					Padding="8,2"
																					Background="#2E7D32">
																					<TextBlock
																						FontSize="12"
																						Foreground="{DynamicResource TextPrimaryBrush}"
																						FontFamily="Microsoft YaHei"
																						Text="{Binding VersionType, Converter={local:VersionTypeToTextConverter}}" />
																				</Border>
																			</StackPanel>
																			<!--未知连接 ID：8-->
																			<Button
																				Grid.Column="2"
																				Cursor="Hand"
																				VerticalAlignment="Center"
																				Width="90"
																				Height="30"
																				BorderThickness="0"
																				Foreground="{DynamicResource TextPrimaryBrush}"
																				FontSize="12"
																				FontWeight="Bold"
																				FontFamily="Microsoft YaHei"
																				Content="{Binding StatusText}" Click="BtnDownload_Click"
																				IsEnabled="{Binding CanDownload}">
																				<Control.Background>
																					<LinearGradientBrush
																						StartPoint="0,0"
																						EndPoint="0,1">
																						<GradientStop
																							Color="#2196F3"
																							Offset="0" />
																						<GradientStop
																							Color="#1976D2"
																							Offset="1" />
																					</LinearGradientBrush>
																				</Control.Background>
																				<Control.Template>
																					<ControlTemplate
																						TargetType="{x:Type Button}">
																						<Border
																							CornerRadius="8"
																							Background="{TemplateBinding Background}">
																							<ContentPresenter
																								HorizontalAlignment="Center"
																								VerticalAlignment="Center" />
																						</Border>
																					</ControlTemplate>
																				</Control.Template>
																				<FrameworkElement.Style>
																					<Style
																						TargetType="{x:Type Button}">
																						<Style.Triggers>
																							<Trigger
																								Property="IsEnabled"
																								Value="False">
																								<Setter
																									Property="Background"
																									Value="#3A3A3A" />
																								<Setter
																									Property="Foreground"
																									Value="#888888" />
																							</Trigger>
																							<Trigger
																								Property="UIElement.IsMouseOver"
																								Value="True">
																								<Setter
																									Property="Background">
																									<Setter.Value>
																										<LinearGradientBrush
																											StartPoint="0,0"
																											EndPoint="0,1">
																											<GradientStop
																												Color="#1E88E5"
																												Offset="0" />
																											<GradientStop
																												Color="#1565C0"
																												Offset="1" />
																										</LinearGradientBrush>
																									</Setter.Value>
																								</Setter>
																							</Trigger>
																							<DataTrigger
																								Value="已下载"
																								Binding="{Binding Status}">
																								<Setter
																									Property="Background"
																									Value="#424242" />
																								<Setter
																									Property="Foreground"
																									Value="#FFFFFF" />
																								<Setter
																									Property="IsEnabled"
																									Value="False" />
																							</DataTrigger>
																						</Style.Triggers>
																					</Style>
																				</FrameworkElement.Style>
																			</Button>
																		</Grid>
																	</Border>
																	<DataTemplate.Triggers>
																		<Trigger
																			Property="UIElement.IsMouseOver"
																			Value="True">
																			<Setter
																				TargetName="CardBorder"
																				Property="Background">
																				<Setter.Value>
																					<LinearGradientBrush
																						StartPoint="0,0"
																						EndPoint="0,1">
																						<GradientStop
																							Color="#2D2D2D"
																							Offset="0" />
																						<GradientStop
																							Color="#282828"
																							Offset="1" />
																					</LinearGradientBrush>
																				</Setter.Value>
																			</Setter>
																		</Trigger>
																	</DataTemplate.Triggers>
																</DataTemplate>
															</ItemsControl.ItemTemplate>
														</ListView>
													</Border>
												</StackPanel>
											</DataTemplate>
										</ItemsControl.ItemTemplate>
									</ItemsControl>
								</StackPanel>
							</ScrollViewer>
						</Border>
					</Grid>
				</TabItem>
				<TabItem
					Header="已安装版本">
					<Grid>
						<Grid.RowDefinitions>
							<RowDefinition
								Height="Auto" />
							<RowDefinition
								Height="*" />
						</Grid.RowDefinitions>
						<Border
							Grid.Row="0"
							Background="{DynamicResource SurfaceBrush}"
							CornerRadius="8"
							Padding="16"
							Margin="0,0,0,16">
							<StackPanel>
								<TextBlock
									Text="📁 已安装游戏版本"
									FontSize="14"
									Foreground="{DynamicResource TextPrimaryBrush}"
									FontFamily="Microsoft YaHei"
									Margin="0,0,0,8" />
								<TextBlock
									Text="管理本地已下载的Minecraft版本，支持启动和删除操作"
									FontSize="12"
									Foreground="{DynamicResource TextSecondaryBrush}"
									FontFamily="Microsoft YaHei"
									TextWrapping="Wrap" />
								<TextBlock
									x:Name="loadingInstalled"
									Text="⏳ 正在扫描已安装版本..."
									FontSize="13"
									Foreground="#2196F3"
									FontFamily="Microsoft YaHei"
									Margin="0,4,0,0" />
							</StackPanel>
						</Border>
						<Border
							Grid.Row="1"
							Background="{DynamicResource CardBackgroundBrush}"
							CornerRadius="12"
							Padding="16"
							ClipToBounds="True">
							<ScrollViewer
								VerticalScrollBarVisibility="Auto"
								HorizontalScrollBarVisibility="Disabled">
								<StackPanel
									Name="InstalledVersionsContainer"
									PreviewMouseLeftButtonDown="InstalledVersionsContainer_PreviewMouseLeftButtonDown">
									<ItemsControl
										Name="icInstalledVersions"
										Background="#00FFFFFF">
										<ItemsControl.ItemTemplate>
											<DataTemplate>
												<StackPanel>
													<ToggleButton
														Name="InstalledHeaderToggle"
														Style="{StaticResource GroupHeaderToggleStyle}"
														IsChecked="{Binding IsExpanded, Mode=TwoWay}"
														DataContext="{Binding Path=.}" />
													<Border
														Visibility="{Binding IsExpanded, Converter={StaticResource BooleanToVisibilityConverter}}">
														<ListView
															Name="lvInstalledGroupVersions"
															Background="#00FFFFFF"
															BorderThickness="0"
															VirtualizingPanel.IsVirtualizing="True"
															VirtualizingPanel.VirtualizationMode="Recycling"
															ScrollViewer.CanContentScroll="False"
															ScrollViewer.VerticalScrollBarVisibility="Disabled"
															ItemsSource="{Binding Versions}">
															<ItemsControl.ItemTemplate>
																<DataTemplate>
																	<Border
																		Name="InstalledCardBorder"
																		CornerRadius="8"
																		Margin="0,0,0,8"
																		Padding="14"
																		Background="#353535"
																		Cursor="Hand">
																		<Grid>
																			<Grid.ColumnDefinitions>
																				<ColumnDefinition
																					Width="Auto" />
																				<ColumnDefinition
																					Width="*" />
																				<ColumnDefinition
																					Width="Auto" />
																			</Grid.ColumnDefinitions>
																			<StackPanel
																				Grid.Column="0"
																				Orientation="Horizontal"
																				VerticalAlignment="Center"
																				Margin="0,0,12,0">
																				<Border
																					Width="36"
																					Height="36"
																					CornerRadius="6"
																					Background="#2A2A2A"
																					Padding="2">
																					<Image
																						Width="32"
																						Height="32"
																						Stretch="Uniform"
																						Source="{Binding VersionType, Converter={StaticResource VersionTypeToIconConverter}}" />
																				</Border>
																			</StackPanel>
																			<StackPanel
																				Grid.Column="1"
																				VerticalAlignment="Center">
																				<StackPanel
																					Orientation="Horizontal">
																					<TextBlock
																						FontSize="14"
																						FontWeight="SemiBold"
																						Foreground="{DynamicResource TextPrimaryBrush}"
																						FontFamily="Microsoft YaHei"
																						Text="{Binding VersionId}" />
																					<Border
																						Margin="8,0,0,0"
																						Padding="4,2"
																						CornerRadius="4"
																						Background="{Binding VersionType, Converter={StaticResource VersionTypeToColorConverter}}">
																						<TextBlock
																							FontSize="10"
																							Foreground="{DynamicResource TextPrimaryBrush}"
																							FontFamily="Microsoft YaHei"
																							Text="{Binding VersionType, Converter={StaticResource VersionTypeToTextConverter}}" />
																					</Border>
																				</StackPanel>
																				<TextBlock
																					FontSize="12"
																					Foreground="#888888"
																					FontFamily="Microsoft YaHei"
																					Margin="0,4,0,0"
																					Text="{Binding ReleaseTime, StringFormat={}{0:yyyy年MM月dd日}}" />
																			</StackPanel>
																			<StackPanel
																				Grid.Column="2"
																				Orientation="Horizontal"
																				VerticalAlignment="Center"
																				Margin="12,0,0,0">
																				<!--未知连接 ID：11-->
																				<Button
																					Content="启动"
																					Click="BtnLaunchGame_Click"
																					Cursor="Hand"
																					VerticalAlignment="Center"
																					Width="70"
																					Height="30"
																					BorderThickness="0"
																					Foreground="{DynamicResource TextPrimaryBrush}"
																					FontSize="12"
																					FontWeight="Bold"
																					FontFamily="Microsoft YaHei"
																					Margin="0,0,8,0">
																					<Control.Background>
																						<LinearGradientBrush
																							StartPoint="0,0"
																							EndPoint="0,1">
																							<GradientStop
																								Color="#2196F3"
																								Offset="0" />
																							<GradientStop
																								Color="#1976D2"
																								Offset="1" />
																						</LinearGradientBrush>
																					</Control.Background>
																					<Control.Template>
																						<ControlTemplate
																							TargetType="{x:Type Button}">
																							<Border
																								Name="border"
																								CornerRadius="6"
																								Background="{TemplateBinding Background}"
																								BorderThickness="0">
																								<ContentPresenter
																									HorizontalAlignment="Center"
																									VerticalAlignment="Center" />
																							</Border>
																						</ControlTemplate>
																					</Control.Template>
																					<FrameworkElement.Style>
																						<Style
																							TargetType="{x:Type Button}">
																							<Style.Triggers>
																								<Trigger
																									Property="UIElement.IsMouseOver"
																									Value="True">
																									<Setter
																										Property="Background">
																										<Setter.Value>
																											<LinearGradientBrush
																												StartPoint="0,0"
																												EndPoint="0,1">
																												<GradientStop
																													Color="#1E88E5"
																													Offset="0" />
																												<GradientStop
																													Color="#1565C0"
																													Offset="1" />
																											</LinearGradientBrush>
																										</Setter.Value>
																									</Setter>
																								</Trigger>
																							</Style.Triggers>
																						</Style>
																					</FrameworkElement.Style>
																				</Button>
																				<!--未知连接 ID：12-->
																				<Button
																					Content="删除"
																					Click="BtnDeleteVersion_Click"
																					Cursor="Hand"
																					VerticalAlignment="Center"
																					Width="70"
																					Height="30"
																					BorderThickness="0"
																					Foreground="{DynamicResource TextPrimaryBrush}"
																					FontSize="12"
																					FontWeight="Bold"
																					FontFamily="Microsoft YaHei">
																					<Control.Background>
																						<LinearGradientBrush
																							StartPoint="0,0"
																							EndPoint="0,1">
																							<GradientStop
																								Color="#757575"
																								Offset="0" />
																							<GradientStop
																								Color="#616161"
																								Offset="1" />
																						</LinearGradientBrush>
																					</Control.Background>
																					<Control.Template>
																						<ControlTemplate
																							TargetType="{x:Type Button}">
																							<Border
																								Name="Deleteborder"
																								CornerRadius="6"
																								Background="{TemplateBinding Background}"
																								BorderThickness="0">
																								<ContentPresenter
																									HorizontalAlignment="Center"
																									VerticalAlignment="Center" />
																							</Border>
																						</ControlTemplate>
																					</Control.Template>
																					<FrameworkElement.Style>
																						<Style
																							TargetType="{x:Type Button}">
																							<Style.Triggers>
																								<Trigger
																									Property="UIElement.IsMouseOver"
																									Value="True">
																									<Setter
																										Property="Background">
																										<Setter.Value>
																											<LinearGradientBrush
																												StartPoint="0,0"
																												EndPoint="0,1">
																												<GradientStop
																													Color="#E53935"
																													Offset="0" />
																												<GradientStop
																													Color="#C62828"
																													Offset="1" />
																											</LinearGradientBrush>
																										</Setter.Value>
																									</Setter>
																								</Trigger>
																							</Style.Triggers>
																						</Style>
																					</FrameworkElement.Style>
																				</Button>
																			</StackPanel>
																		</Grid>
																	</Border>
																	<DataTemplate.Triggers>
																		<Trigger
																			Property="UIElement.IsMouseOver"
																			Value="True">
																			<Setter
																				TargetName="InstalledCardBorder"
																				Property="Background">
																				<Setter.Value>
																					<LinearGradientBrush
																						StartPoint="0,0"
																						EndPoint="0,1">
																						<GradientStop
																							Color="#2D2D2D"
																							Offset="0" />
																						<GradientStop
																							Color="#282828"
																							Offset="1" />
																					</LinearGradientBrush>
																				</Setter.Value>
																			</Setter>
																		</Trigger>
																	</DataTemplate.Triggers>
																</DataTemplate>
															</ItemsControl.ItemTemplate>
														</ListView>
													</Border>
												</StackPanel>
											</DataTemplate>
										</ItemsControl.ItemTemplate>
									</ItemsControl>
								</StackPanel>
							</ScrollViewer>
						</Border>
					</Grid>
				</TabItem>
				<!-- [增量新增] 基岩版下载 -->
				<TabItem Header="基岩版">
					<Grid>
						<Grid.RowDefinitions>
							<RowDefinition Height="Auto"/>
							<RowDefinition Height="Auto"/>
							<RowDefinition Height="*"/>
						</Grid.RowDefinitions>
						<!-- 说明区 -->
						<Border Grid.Row="0" Background="{DynamicResource SurfaceBrush}" CornerRadius="8" Padding="16" Margin="0,0,0,16">
							<StackPanel>
								<TextBlock Text="🌍 基岩版下载" FontSize="14" Foreground="{DynamicResource TextPrimaryBrush}" FontFamily="Microsoft YaHei" Margin="0,0,0,8"/>
								<TextBlock Text="下载 Minecraft Bedrock Edition，支持自动断点续传与SHA1完整性校验" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" FontFamily="Microsoft YaHei" TextWrapping="Wrap"/>
								<TextBlock
									x:Name="loadingBedrock"
									Text="⏳ 正在加载基岩版列表..."
									FontSize="13"
									Foreground="#2196F3"
									FontFamily="Microsoft YaHei"
									Margin="0,4,0,0" />
							</StackPanel>
						</Border>
						<!-- 操作区 -->
						<Border Grid.Row="1" Background="{DynamicResource CardHoverBrush}" CornerRadius="8" Padding="16" Margin="0,0,0,12">
							<Grid>
								<Grid.ColumnDefinitions>
									<ColumnDefinition Width="Auto"/>
									<ColumnDefinition Width="*"/>
									<ColumnDefinition Width="Auto"/>
								</Grid.ColumnDefinitions>
								<Button x:Name="btnBedrockRefresh" Grid.Column="0" Content="刷新版本列表" Background="#2196F3" Foreground="{DynamicResource TextPrimaryBrush}" BorderThickness="0" FontSize="13" FontFamily="Microsoft YaHei" Cursor="Hand" Width="120" Height="36" Click="BtnBedrockRefresh_Click">
									<Control.Template>
										<ControlTemplate TargetType="{x:Type Button}">
											<Border Name="border" Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
												<ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
											</Border>
											<ControlTemplate.Triggers>
												<Trigger Property="IsMouseOver" Value="True">
													<Setter TargetName="border" Property="Background" Value="#1976D2"/>
												</Trigger>
												<Trigger Property="IsPressed" Value="True">
													<Setter TargetName="border" Property="Background" Value="#1565C0"/>
												</Trigger>
												<Trigger Property="IsEnabled" Value="False">
													<Setter TargetName="border" Property="Background" Value="#555555"/>
													<Setter Property="Foreground" Value="#AAAAAA"/>
												</Trigger>
											</ControlTemplate.Triggers>
										</ControlTemplate>
									</Control.Template>
								</Button>
								<TextBlock x:Name="txtBedrockStatus" Grid.Column="1" Text="就绪" FontSize="13" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center" Margin="16,0,0,0" FontFamily="Microsoft YaHei"/>
								<Button x:Name="btnBedrockCancel" Grid.Column="2" Content="取消下载" Background="#E74C3C" Foreground="{DynamicResource TextPrimaryBrush}" BorderThickness="0" FontSize="13" FontFamily="Microsoft YaHei" Cursor="Hand" Width="80" Height="36" Click="BtnBedrockCancel_Click" Visibility="Collapsed"/>
							</Grid>
						</Border>
						<!-- 进度条（下载中显示） -->
						<Border x:Name="panelBedrockProgress" Grid.Row="1" Background="{DynamicResource CardHoverBrush}" CornerRadius="8" Padding="16" Margin="0,0,0,12" Visibility="Collapsed">
							<StackPanel>
								<Grid>
									<TextBlock Text="下载进度" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}"/>
									<TextBlock x:Name="txtBedrockPercent" Text="0%" FontSize="13" FontWeight="Bold" Foreground="#2196F3" HorizontalAlignment="Right"/>
								</Grid>
								<ProgressBar x:Name="barBedrockProgress" Minimum="0" Maximum="100" Height="6" Margin="0,8,0,4" Background="{DynamicResource SurfaceBrush}" Foreground="#2196F3" BorderThickness="0"/>
								<TextBlock x:Name="txtBedrockSize" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"/>
							</StackPanel>
						</Border>
						<!-- 版本列表 -->
						<Border Grid.Row="2" Background="{DynamicResource CardBackgroundBrush}" CornerRadius="12" Padding="16" ClipToBounds="True">
							<ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
								<ItemsControl
									x:Name="icBedrockVersions"
									Background="Transparent">
									<FrameworkElement.ToolTip>
										<ToolTip>点击刷新版本列表</ToolTip>
									</FrameworkElement.ToolTip>
									<ItemsControl.ItemTemplate>
										<DataTemplate>
											<StackPanel>
												<ToggleButton
													Style="{StaticResource GroupHeaderToggleStyle}"
													IsChecked="{Binding IsExpanded, Mode=TwoWay}"
													DataContext="{Binding Path=.}" />
												<Border
													Visibility="{Binding IsExpanded, Converter={StaticResource BooleanToVisibilityConverter}}">
													<ListView
														Background="Transparent" BorderThickness="0"
														VirtualizingPanel.IsVirtualizing="True"
														VirtualizingPanel.VirtualizationMode="Recycling"
														VirtualizingPanel.CacheLength="50"
														VirtualizingPanel.CacheLengthUnit="Page"
														ScrollViewer.CanContentScroll="False"
														ScrollViewer.VerticalScrollBarVisibility="Disabled"
														ItemsSource="{Binding Versions}">
														<ItemsControl.ItemContainerStyle>
															<Style TargetType="ListViewItem">
																<Setter Property="Background" Value="Transparent"/>
																<Setter Property="BorderThickness" Value="0"/>
																<Setter Property="Padding" Value="0"/>
																<Setter Property="Margin" Value="0,0,0,6"/>
																<Setter Property="FocusVisualStyle" Value="{x:Null}"/>
															</Style>
														</ItemsControl.ItemContainerStyle>
														<ItemsControl.ItemTemplate>
															<DataTemplate>
																<Border CornerRadius="8" Margin="0,0,0,8" Padding="14"
																        Background="#353535" Cursor="Hand">
																	<Grid>
																		<Grid.ColumnDefinitions>
																			<ColumnDefinition Width="Auto"/>
																			<ColumnDefinition Width="*"/>
																			<ColumnDefinition Width="Auto"/>
																		</Grid.ColumnDefinitions>
																		<Image Grid.Column="0" Width="48" Height="48"
																		       Margin="0,0,16,0" Stretch="Uniform"
																		       Source="{Binding Type, Converter={local:VersionTypeToIconConverter}}"/>
																		<StackPanel Grid.Column="1" VerticalAlignment="Center">
																			<TextBlock FontSize="18" FontWeight="Bold"
																			           Foreground="{DynamicResource TextPrimaryBrush}" FontFamily="Microsoft YaHei"
																			           Text="{Binding Id}"/>
																			<TextBlock FontSize="13" Foreground="#888888"
																			           FontFamily="Microsoft YaHei"
																			           Text="{Binding Description}"/>
																		</StackPanel>
																		<Button Grid.Column="2" Cursor="Hand"
																		        VerticalAlignment="Center"
																		        MinWidth="88" Height="32" BorderThickness="0"
																		        Background="#2196F3"
																		        Foreground="{DynamicResource TextPrimaryBrush}" FontSize="13"
																		        FontWeight="SemiBold" FontFamily="Microsoft YaHei"
																		        Content="{Binding StatusText}"
																		        IsEnabled="{Binding CanDownload}"
																		        Tag="{Binding}"
																		        Click="BtnBedrockDownload_Click">
																			<Control.Template>
																				<ControlTemplate TargetType="{x:Type Button}">
																					<Border CornerRadius="6"
																					        Background="{TemplateBinding Background}">
																						<ContentPresenter HorizontalAlignment="Center"
																						                  VerticalAlignment="Center"/>
																					</Border>
																				</ControlTemplate>
																			</Control.Template>
																			<FrameworkElement.Style>
																				<Style TargetType="{x:Type Button}">
																					<Style.Triggers>
																						<Trigger Property="UIElement.IsMouseOver" Value="True">
																							<Setter Property="Background" Value="#1976D2"/>
																						</Trigger>
																						<DataTrigger Value="True" Binding="{Binding IsDownloaded}">
																							<Setter Property="Background" Value="#424242"/>
																							<Setter Property="Foreground" Value="#B0BEC5"/>
																						</DataTrigger>
																					</Style.Triggers>
																				</Style>
																			</FrameworkElement.Style>
																		</Button>
																	</Grid>
																</Border>
															</DataTemplate>
														</ItemsControl.ItemTemplate>
													</ListView>
												</Border>
											</StackPanel>
										</DataTemplate>
									</ItemsControl.ItemTemplate>
								</ItemsControl>
							</ScrollViewer>
						</Border>
					</Grid>
				</TabItem>
			</TabControl>
		</Grid>
	</Grid>
</UserControl>

