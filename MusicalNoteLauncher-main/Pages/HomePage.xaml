<UserControl
	x:Class="MusicalNoteLauncher.Pages.HomePage" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	Background="#1E1E1E" xmlns:pages="clr-namespace:MusicalNoteLauncher.Pages">
	<ScrollViewer
		VerticalScrollBarVisibility="Auto"
		HorizontalScrollBarVisibility="Disabled"
		Padding="20">
		<Grid>
			<Grid.RowDefinitions>
				<RowDefinition
					Height="Auto" />
				<RowDefinition
					Height="*" />
				<RowDefinition
					Height="Auto" />
			</Grid.RowDefinitions>
			<Border
				Grid.Row="0"
				Background="#2D2D2D"
				CornerRadius="12"
				Padding="20"
				Margin="0,0,0,16">
				<StackPanel>
					<StackPanel.Resources>
						<Storyboard x:Key="FadeOutAnimation">
							<DoubleAnimation
								Storyboard.TargetProperty="Opacity"
								From="1"
								To="0"
								Duration="0:0:0.3" />
						</Storyboard>
						<Storyboard x:Key="FadeInAnimation">
							<DoubleAnimation
								Storyboard.TargetProperty="Opacity"
								From="0"
								To="1"
								Duration="0:0:0.3" />
						</Storyboard>
					</StackPanel.Resources>
					
					<StackPanel
						Orientation="Horizontal"
						VerticalAlignment="Center"
						Margin="0,0,0,8">
						<TextBlock
							Text="🔥 热门模组："
							FontSize="14"
							Foreground="#FFFFFF"
							FontFamily="Microsoft YaHei"
							VerticalAlignment="Center" />
						<StackPanel Name="spModContent" Orientation="Horizontal" VerticalAlignment="Center">
							<TextBlock
								Name="txtModName"
								FontSize="14"
								Foreground="#2ECC71"
								FontFamily="Microsoft YaHei"
								VerticalAlignment="Center"
								Margin="4,0,0,0"
								Text="加载中..." />
							<TextBlock
								Name="txtModSource"
								FontSize="10"
								Foreground="#666666"
								FontFamily="Microsoft YaHei"
								VerticalAlignment="Center"
								Margin="8,0,0,0" />
						</StackPanel>
						<Button
							Name="btnViewModDetail"
							Content="点击查看"
							Background="#333333"
							Foreground="#FFFFFF"
							BorderBrush="#444444"
							BorderThickness="1"
							Padding="12,6"
							FontSize="12"
							FontFamily="Microsoft YaHei"
							Cursor="Hand"
							MinWidth="70"
							Margin="16,0,0,0"
							Click="BtnViewModDetail_Click">
							<Control.Template>
								<ControlTemplate
									TargetType="{x:Type Button}">
									<Border
										Name="border"
										Background="{TemplateBinding Background}"
										BorderBrush="{TemplateBinding BorderBrush}"
										BorderThickness="{TemplateBinding BorderThickness}"
										CornerRadius="4"
										Padding="{TemplateBinding Padding}">
										<ContentPresenter
											HorizontalAlignment="Center"
											VerticalAlignment="Center" />
									</Border>
									<ControlTemplate.Triggers>
										<Trigger
											Property="UIElement.IsMouseOver"
											Value="True">
											<Setter
												TargetName="border"
												Property="Background"
												Value="#2D2D2D" />
										</Trigger>
									</ControlTemplate.Triggers>
								</ControlTemplate>
							</Control.Template>
						</Button>
					</StackPanel>
					<StackPanel
						Orientation="Horizontal"
						VerticalAlignment="Center">
						<TextBlock
							Text="📦 热门整合包："
							FontSize="14"
							Foreground="#FFFFFF"
							FontFamily="Microsoft YaHei"
							VerticalAlignment="Center" />
						<StackPanel Name="spPackContent" Orientation="Horizontal" VerticalAlignment="Center">
							<TextBlock
								Name="txtPackName"
								FontSize="14"
								Foreground="#3498DB"
								FontFamily="Microsoft YaHei"
								VerticalAlignment="Center"
								Margin="4,0,0,0"
								Text="加载中..." />
							<TextBlock
								Name="txtPackSource"
								FontSize="10"
								Foreground="#666666"
								FontFamily="Microsoft YaHei"
								VerticalAlignment="Center"
								Margin="8,0,0,0" />
						</StackPanel>
						<Button
							Name="btnViewPackDetail"
							Content="点击查看"
							Background="#333333"
							Foreground="#FFFFFF"
							BorderBrush="#444444"
							BorderThickness="1"
							Padding="12,6"
							FontSize="12"
							FontFamily="Microsoft YaHei"
							Cursor="Hand"
							MinWidth="70"
							Margin="16,0,0,0"
							Click="BtnViewPackDetail_Click">
							<Control.Template>
								<ControlTemplate
									TargetType="{x:Type Button}">
									<Border
										Name="border"
										Background="{TemplateBinding Background}"
										BorderBrush="{TemplateBinding BorderBrush}"
										BorderThickness="{TemplateBinding BorderThickness}"
										CornerRadius="4"
										Padding="{TemplateBinding Padding}">
										<ContentPresenter
											HorizontalAlignment="Center"
											VerticalAlignment="Center" />
									</Border>
									<ControlTemplate.Triggers>
										<Trigger
											Property="UIElement.IsMouseOver"
											Value="True">
											<Setter
												TargetName="border"
												Property="Background"
												Value="#2D2D2D" />
										</Trigger>
									</ControlTemplate.Triggers>
								</ControlTemplate>
							</Control.Template>
						</Button>
					</StackPanel>
				</StackPanel>
			</Border>
			<Grid
				Row="1">
				<Grid.ColumnDefinitions>
					<ColumnDefinition
						Width="2*" />
					<ColumnDefinition
						Width="1*" />
				</Grid.ColumnDefinitions>
				<Grid
					Column="0"
					Margin="0,0,15,0">
					<Grid.RowDefinitions>
						<RowDefinition
							Height="*" />
						<RowDefinition
							Height="Auto" />
					</Grid.RowDefinitions>
					<Border
						Grid.Row="0"
						Background="#2D2D2D"
						CornerRadius="12"
						Padding="16"
						Margin="0,0,0,12">
						<Grid>
							<Grid.RowDefinitions>
								<RowDefinition
									Height="Auto" />
								<RowDefinition
									Height="*" />
							</Grid.RowDefinitions>
							<TextBlock
								Grid.Row="0"
								Text="自定义组件区"
								FontSize="14"
								FontWeight="SemiBold"
								Foreground="#FFFFFF"
								FontFamily="Microsoft YaHei"
								Margin="0,0,0,12" />
							<Border
								Grid.Row="1"
								Background="#333333"
								CornerRadius="8">
								<Grid
									VerticalAlignment="Center"
									HorizontalAlignment="Center">
									<StackPanel
										HorizontalAlignment="Center">
										<TextBlock
											Text="暂未设置自定义组件"
											FontSize="13"
											Foreground="#FFFFFF"
											FontFamily="Microsoft YaHei"
											HorizontalAlignment="Center" />
										<Button
											Name="btnGoToStore"
											Content="去组件商店看看？"
											Background="#333333"
											Foreground="#FFFFFF"
											BorderBrush="#444444"
											BorderThickness="1"
											Padding="12,6"
											FontSize="12"
											FontFamily="Microsoft YaHei"
											Cursor="Hand"
											Margin="0,8,0,0"
											Click="BtnGoToStore_Click">
											<Control.Template>
												<ControlTemplate
													TargetType="{x:Type Button}">
													<Border
														Name="border"
														Background="{TemplateBinding Background}"
														BorderBrush="{TemplateBinding BorderBrush}"
														BorderThickness="{TemplateBinding BorderThickness}"
														CornerRadius="4"
														Padding="{TemplateBinding Padding}">
														<ContentPresenter
															HorizontalAlignment="Center"
															VerticalAlignment="Center" />
													</Border>
													<ControlTemplate.Triggers>
														<Trigger
															Property="UIElement.IsMouseOver"
															Value="True">
															<Setter
																TargetName="border"
																Property="BorderBrush"
																Value="#555555" />
															<Setter
																TargetName="border"
																Property="Background"
																Value="#3A3A3A" />
														</Trigger>
														<Trigger
															Property="IsPressed"
															Value="True">
															<Setter
																TargetName="border"
																Property="Background"
																Value="#444444" />
														</Trigger>
													</ControlTemplate.Triggers>
												</ControlTemplate>
											</Control.Template>
										</Button>
									</StackPanel>
								</Grid>
							</Border>
						</Grid>
					</Border>
					<Border
						Grid.Row="1"
						Background="#2D2D2D"
						CornerRadius="12"
						Padding="16">
						<StackPanel>
							<TextBlock
								Text="游戏启动设置（可选）"
								FontSize="14"
								FontWeight="SemiBold"
								Foreground="#FFFFFF"
								FontFamily="Microsoft YaHei"
								Margin="0,0,0,12" />
							<Grid
								Margin="0,0,0,10"
								HorizontalAlignment="Stretch">
								<Grid.ColumnDefinitions>
									<ColumnDefinition
										Width="*" />
									<ColumnDefinition
										Width="*" />
								</Grid.ColumnDefinitions>
								<StackPanel
									Grid.Column="0"
									Margin="0,0,10,0"
									HorizontalAlignment="Stretch">
									<TextBlock
										Text="游戏昵称"
										FontSize="12"
										Foreground="#AAAAAA"
										FontFamily="Microsoft YaHei"
										Margin="0,0,0,6" />
									<ComboBox
										Name="cboPlayerName"
										Background="#333333"
										Foreground="#FFFFFF"
										BorderBrush="#444444"
										BorderThickness="1"
										MinWidth="120"
										HorizontalAlignment="Stretch"
										FontSize="14"
										FontFamily="Microsoft YaHei"
										Cursor="Hand">
										<Control.Template>
											<ControlTemplate
												TargetType="{x:Type ComboBox}">
												<Grid>
													<ToggleButton
														Name="ToggleButton"
														Grid.Column="2"
														Focusable="false"
														ClickMode="Press"
														Background="{TemplateBinding Background}"
														BorderBrush="{TemplateBinding BorderBrush}"
														BorderThickness="{TemplateBinding BorderThickness}"
														IsChecked="{Binding Path=IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}">
														<Control.Template>
															<ControlTemplate
																TargetType="{x:Type ToggleButton}">
																<Border
																	Name="toggleBorder"
																	Background="{TemplateBinding Background}"
																	BorderBrush="{TemplateBinding BorderBrush}"
																	BorderThickness="{TemplateBinding BorderThickness}"
																	CornerRadius="4">
																	<Grid>
																		<Grid.ColumnDefinitions>
																			<ColumnDefinition
																				Width="*" />
																			<ColumnDefinition
																				Width="24" />
																		</Grid.ColumnDefinitions>
																		<ContentPresenter
																			Grid.Column="0"
																			HorizontalAlignment="Left"
																			VerticalAlignment="Center"
																			Margin="8,0,0,0" />
																		<Path
																			Name="Arrow"
																			Grid.Column="1"
																			Data="M0,0 L5,5 L10,0"
																			Fill="#FFFFFF"
																			HorizontalAlignment="Center"
																			VerticalAlignment="Center"
																			Width="10"
																			Height="6"
																			Stretch="Uniform" />
																	</Grid>
																</Border>
																<ControlTemplate.Triggers>
																	<Trigger
																		Property="UIElement.IsMouseOver"
																		Value="True">
																		<Setter
																			TargetName="toggleBorder"
																			Property="Background"
																			Value="#3A3A3A" />
																		<Setter
																			TargetName="toggleBorder"
																			Property="BorderBrush"
																			Value="#555555" />
																	</Trigger>
																	<Trigger
																		Property="ToggleButton.IsChecked"
																		Value="True">
																		<Setter
																			TargetName="Arrow"
																			Property="Data"
																			Value="M0,5 L5,0 L10,5" />
																	</Trigger>
																	<Trigger
																		Property="IsEnabled"
																		Value="False">
																		<Setter
																			TargetName="toggleBorder"
																			Property="UIElement.Opacity"
																			Value="0.5" />
																	</Trigger>
																</ControlTemplate.Triggers>
															</ControlTemplate>
														</Control.Template>
													</ToggleButton>
													<ContentPresenter
														Name="ContentSite"
														IsHitTestVisible="False"
														Content="{TemplateBinding SelectionBoxItem}"
														ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
														ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"
														Margin="8,8,24,8"
														HorizontalAlignment="Left"
														VerticalAlignment="Center" />
													<Popup
														Name="Popup"
														Placement="Bottom"
														IsOpen="{TemplateBinding IsDropDownOpen}"
														AllowsTransparency="True"
														Focusable="False"
														PopupAnimation="Slide"
														StaysOpen="False">
														<Grid
															Name="DropDown"
															SnapsToDevicePixels="True"
															MinWidth="{TemplateBinding ActualWidth}"
															MaxHeight="{TemplateBinding MaxDropDownHeight}"
															Margin="0,2,0,0">
															<Border
																Name="DropDownBorder"
																Background="#333333"
																BorderBrush="#444444"
																BorderThickness="1"
																CornerRadius="4"
																Padding="2">
																<ScrollViewer
																	Margin="2"
																	SnapsToDevicePixels="True">
																	<ItemsPresenter
																		KeyboardNavigation.DirectionalNavigation="Contained" />
																</ScrollViewer>
															</Border>
														</Grid>
													</Popup>
												</Grid>
												<ControlTemplate.Triggers>
													<Trigger
														Property="ItemsControl.HasItems"
														Value="False">
														<Setter
															TargetName="DropDownBorder"
															Property="MinHeight"
															Value="40" />
													</Trigger>
													<Trigger
														Property="IsEnabled"
														Value="False">
														<Setter
															Property="Foreground"
															Value="#888888" />
													</Trigger>
													<Trigger
														Property="ItemsControl.IsGrouping"
														Value="True">
														<Setter
															Property="ScrollViewer.CanContentScroll"
															Value="False" />
													</Trigger>
													<Trigger
														Property="ComboBox.IsDropDownOpen"
														Value="True">
														<Setter
															TargetName="ToggleButton"
															Property="Background"
															Value="#3A3A3A" />
														<Setter
															TargetName="ToggleButton"
															Property="BorderBrush"
															Value="#555555" />
													</Trigger>
												</ControlTemplate.Triggers>
											</ControlTemplate>
										</Control.Template>
										<ComboBoxItem
											Background="#333333"
											Foreground="#FFFFFF"
											Padding="12,10"
											IsSelected="True">Player</ComboBoxItem>
										<ComboBoxItem
											Background="#333333"
											Foreground="#FFFFFF"
											Padding="12,10">Steve</ComboBoxItem>
										<ComboBoxItem
											Background="#333333"
											Foreground="#FFFFFF"
											Padding="12,10">Alex</ComboBoxItem>
									</ComboBox>
								</StackPanel>
								<StackPanel
									Grid.Column="1"
									Margin="0,0,10,0"
									HorizontalAlignment="Stretch">
									<TextBlock
										Text="内存分配"
										FontSize="12"
										Foreground="#AAAAAA"
										FontFamily="Microsoft YaHei"
										Margin="0,0,0,6" />
									<ComboBox
										Name="cboMemory"
										Background="#333333"
										Foreground="#FFFFFF"
										BorderBrush="#444444"
										BorderThickness="1"
										MinWidth="120"
										HorizontalAlignment="Stretch"
										FontSize="14"
										FontFamily="Microsoft YaHei"
										Cursor="Hand">
										<Control.Template>
											<ControlTemplate
												TargetType="{x:Type ComboBox}">
												<Grid>
													<ToggleButton
														Name="ToggleButton"
														Grid.Column="2"
														Focusable="false"
														ClickMode="Press"
														Background="{TemplateBinding Background}"
														BorderBrush="{TemplateBinding BorderBrush}"
														BorderThickness="{TemplateBinding BorderThickness}"
														IsChecked="{Binding Path=IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}">
														<Control.Template>
															<ControlTemplate
																TargetType="{x:Type ToggleButton}">
																<Border
																	Name="toggleBorder"
																	Background="{TemplateBinding Background}"
																	BorderBrush="{TemplateBinding BorderBrush}"
																	BorderThickness="{TemplateBinding BorderThickness}"
																	CornerRadius="4">
																	<Grid>
																		<Grid.ColumnDefinitions>
																			<ColumnDefinition
																				Width="*" />
																			<ColumnDefinition
																				Width="24" />
																		</Grid.ColumnDefinitions>
																		<ContentPresenter
																			Grid.Column="0"
																			HorizontalAlignment="Left"
																			VerticalAlignment="Center"
																			Margin="8,0,0,0" />
																		<Path
																			Name="Arrow"
																			Grid.Column="1"
																			Data="M0,0 L5,5 L10,0"
																			Fill="#FFFFFF"
																			HorizontalAlignment="Center"
																			VerticalAlignment="Center"
																			Width="10"
																			Height="6"
																			Stretch="Uniform" />
																	</Grid>
																</Border>
																<ControlTemplate.Triggers>
																	<Trigger
																		Property="UIElement.IsMouseOver"
																		Value="True">
																		<Setter
																			TargetName="toggleBorder"
																			Property="Background"
																			Value="#3A3A3A" />
																		<Setter
																			TargetName="toggleBorder"
																			Property="BorderBrush"
																			Value="#555555" />
																	</Trigger>
																	<Trigger
																		Property="ToggleButton.IsChecked"
																		Value="True">
																		<Setter
																			TargetName="Arrow"
																			Property="Data"
																			Value="M0,5 L5,0 L10,5" />
																	</Trigger>
																	<Trigger
																		Property="IsEnabled"
																		Value="False">
																		<Setter
																			TargetName="toggleBorder"
																			Property="UIElement.Opacity"
																			Value="0.5" />
																	</Trigger>
																</ControlTemplate.Triggers>
															</ControlTemplate>
														</Control.Template>
													</ToggleButton>
													<ContentPresenter
														Name="ContentSite"
														IsHitTestVisible="False"
														Content="{TemplateBinding SelectionBoxItem}"
														ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
														ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"
														Margin="8,8,24,8"
														HorizontalAlignment="Left"
														VerticalAlignment="Center" />
													<Popup
														Name="Popup"
														Placement="Bottom"
														IsOpen="{TemplateBinding IsDropDownOpen}"
														AllowsTransparency="True"
														Focusable="False"
														PopupAnimation="Slide"
														StaysOpen="False">
														<Grid
															Name="DropDown"
															SnapsToDevicePixels="True"
															MinWidth="{TemplateBinding ActualWidth}"
															MaxHeight="{TemplateBinding MaxDropDownHeight}"
															Margin="0,2,0,0">
															<Border
																Name="DropDownBorder"
																Background="#333333"
																BorderBrush="#444444"
																BorderThickness="1"
																CornerRadius="4"
																Padding="2">
																<ScrollViewer
																	Margin="2"
																	SnapsToDevicePixels="True">
																	<ItemsPresenter
																		KeyboardNavigation.DirectionalNavigation="Contained" />
																</ScrollViewer>
															</Border>
														</Grid>
													</Popup>
												</Grid>
												<ControlTemplate.Triggers>
													<Trigger
														Property="ItemsControl.HasItems"
														Value="False">
														<Setter
															TargetName="DropDownBorder"
															Property="MinHeight"
															Value="40" />
													</Trigger>
													<Trigger
														Property="IsEnabled"
														Value="False">
														<Setter
															Property="Foreground"
															Value="#888888" />
													</Trigger>
													<Trigger
														Property="ItemsControl.IsGrouping"
														Value="True">
														<Setter
															Property="ScrollViewer.CanContentScroll"
															Value="False" />
													</Trigger>
													<Trigger
														Property="ComboBox.IsDropDownOpen"
														Value="True">
														<Setter
															TargetName="ToggleButton"
															Property="Background"
															Value="#3A3A3A" />
														<Setter
															TargetName="ToggleButton"
															Property="BorderBrush"
															Value="#555555" />
													</Trigger>
												</ControlTemplate.Triggers>
											</ControlTemplate>
										</Control.Template>
										<ComboBoxItem
											Background="#333333"
											Foreground="#FFFFFF"
											Padding="12,10"
											IsSelected="True">2G</ComboBoxItem>
										<ComboBoxItem
											Background="#333333"
											Foreground="#FFFFFF"
											Padding="12,10">4G</ComboBoxItem>
										<ComboBoxItem
											Background="#333333"
											Foreground="#FFFFFF"
											Padding="12,10">8G</ComboBoxItem>
										<ComboBoxItem
											Background="#333333"
											Foreground="#FFFFFF"
											Padding="12,10">16G</ComboBoxItem>
									</ComboBox>
								</StackPanel>
							</Grid>
							<Grid
								Margin="0,0,0,10"
								HorizontalAlignment="Stretch">
								<Grid.ColumnDefinitions>
									<ColumnDefinition
										Width="*" />
									<ColumnDefinition
										Width="*" />
								</Grid.ColumnDefinitions>
								<StackPanel
									Grid.Column="0"
									Margin="0,0,10,0"
									HorizontalAlignment="Stretch">
									<TextBlock
										Text="窗口大小"
										FontSize="12"
										Foreground="#AAAAAA"
										FontFamily="Microsoft YaHei"
										Margin="0,0,0,6" />
									<ComboBox
										Name="cboResolution"
										Background="#333333"
										Foreground="#FFFFFF"
										BorderBrush="#444444"
										BorderThickness="1"
										MinWidth="120"
										HorizontalAlignment="Stretch"
										FontSize="14"
										FontFamily="Microsoft YaHei"
										Cursor="Hand">
										<Control.Template>
											<ControlTemplate
												TargetType="{x:Type ComboBox}">
												<Grid>
													<ToggleButton
														Name="ToggleButton"
														Grid.Column="2"
														Focusable="false"
														ClickMode="Press"
														Background="{TemplateBinding Background}"
														BorderBrush="{TemplateBinding BorderBrush}"
														BorderThickness="{TemplateBinding BorderThickness}"
														IsChecked="{Binding Path=IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}">
														<Control.Template>
															<ControlTemplate
																TargetType="{x:Type ToggleButton}">
																<Border
																	Name="toggleBorder"
																	Background="{TemplateBinding Background}"
																	BorderBrush="{TemplateBinding BorderBrush}"
																	BorderThickness="{TemplateBinding BorderThickness}"
																	CornerRadius="4">
																	<Grid>
																		<Grid.ColumnDefinitions>
																			<ColumnDefinition
																				Width="*" />
																			<ColumnDefinition
																				Width="24" />
																		</Grid.ColumnDefinitions>
																		<ContentPresenter
																			Grid.Column="0"
																			HorizontalAlignment="Left"
																			VerticalAlignment="Center"
																			Margin="8,0,0,0" />
																		<Path
																			Name="Arrow"
																			Grid.Column="1"
																			Data="M0,0 L5,5 L10,0"
																			Fill="#FFFFFF"
																			HorizontalAlignment="Center"
																			VerticalAlignment="Center"
																			Width="10"
																			Height="6"
																			Stretch="Uniform" />
																	</Grid>
																</Border>
																<ControlTemplate.Triggers>
																	<Trigger
																		Property="UIElement.IsMouseOver"
																		Value="True">
																		<Setter
																			TargetName="toggleBorder"
																			Property="Background"
																			Value="#3A3A3A" />
																		<Setter
																			TargetName="toggleBorder"
																			Property="BorderBrush"
																			Value="#555555" />
																	</Trigger>
																	<Trigger
																		Property="ToggleButton.IsChecked"
																		Value="True">
																		<Setter
																			TargetName="Arrow"
																			Property="Data"
																			Value="M0,5 L5,0 L10,5" />
