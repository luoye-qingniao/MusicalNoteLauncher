<UserControl
	x:Class="MusicalNoteLauncher.Pages.ProfilePage" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:core="clr-namespace:MusicalNoteLauncher.Core"
	Background="#1E1E1E" xmlns:pages="clr-namespace:MusicalNoteLauncher.Pages">
	<UserControl.Resources>
		<DropShadowEffect x:Key="CardShadow" Color="Black" Opacity="0.3" BlurRadius="12" ShadowDepth="4" />
		<DropShadowEffect x:Key="ButtonShadow" Color="Black" Opacity="0.2" BlurRadius="8" ShadowDepth="2" />

		<Style x:Key="StatCardStyle" TargetType="Border">
			<Setter Property="Background" Value="#1E1E1E" />
			<Setter Property="CornerRadius" Value="12" />
			<Setter Property="Padding" Value="20" />
			<Setter Property="Effect" Value="{StaticResource CardShadow}" />
		</Style>

		<Style x:Key="PrimaryButtonStyle" TargetType="Button">
			<Setter Property="Background" Value="#6C5CE7" />
			<Setter Property="Foreground" Value="White" />
			<Setter Property="BorderThickness" Value="0" />
			<Setter Property="Padding" Value="16,10" />
			<Setter Property="FontSize" Value="13" />
			<Setter Property="FontFamily" Value="Microsoft YaHei" />
			<Setter Property="Cursor" Value="Hand" />
			<Setter Property="Effect" Value="{StaticResource ButtonShadow}" />
			<Setter Property="Template">
				<Setter.Value>
					<ControlTemplate TargetType="Button">
						<Border Name="border" Background="{TemplateBinding Background}" CornerRadius="12" Padding="{TemplateBinding Padding}">
							<ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
						</Border>
						<ControlTemplate.Triggers>
							<Trigger Property="IsMouseOver" Value="True">
								<Setter TargetName="border" Property="Background" Value="#5B4CDB" />
							</Trigger>
							<Trigger Property="IsPressed" Value="True">
								<Setter TargetName="border" Property="Background" Value="#4A3FBA" />
							</Trigger>
						</ControlTemplate.Triggers>
					</ControlTemplate>
				</Setter.Value>
			</Setter>
		</Style>

		<Style x:Key="SecondaryButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
			<Setter Property="Background" Value="#2D2D2D" />
			<Setter Property="Foreground" Value="#FFFFFF" />
			<Setter Property="BorderThickness" Value="1" />
			<Setter Property="BorderBrush" Value="#3A3A3A" />
			<Style.Triggers>
				<Trigger Property="IsMouseOver" Value="True">
					<Setter Property="Background" Value="#383838" />
				</Trigger>
			</Style.Triggers>
		</Style>

		<Style x:Key="AccountCardButton" TargetType="Button">
			<Setter Property="Background" Value="#2D2D2D" />
			<Setter Property="BorderBrush" Value="#3A3A3A" />
			<Setter Property="BorderThickness" Value="1" />
			<Setter Property="HorizontalContentAlignment" Value="Stretch" />
			<Setter Property="Cursor" Value="Hand" />
			<Setter Property="Template">
				<Setter.Value>
					<ControlTemplate TargetType="Button">
						<Border Name="border" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="12" Padding="12,10">
							<ContentPresenter />
						</Border>
						<ControlTemplate.Triggers>
							<Trigger Property="IsMouseOver" Value="True">
								<Setter TargetName="border" Property="Background" Value="#383838" />
								<Setter TargetName="border" Property="BorderBrush" Value="#555555" />
							</Trigger>
						</ControlTemplate.Triggers>
					</ControlTemplate>
				</Setter.Value>
			</Setter>
		</Style>

		<core:AccountTypeColorConverter x:Key="TypeColorConverter" />
	</UserControl.Resources>

	<ScrollViewer VerticalScrollBarVisibility="Auto">
		<Grid>
			<!-- ============ 卡片选择入口（初始显示） ============ -->
			<Grid x:Name="PanelSelect" Margin="20" Visibility="Visible">
				<Grid.RowDefinitions>
					<RowDefinition Height="Auto" />
					<RowDefinition Height="*" />
				</Grid.RowDefinitions>
				<!-- 标题 -->
				<TextBlock Grid.Row="0" Text="个人主页" Foreground="#FFFFFF" FontSize="24" FontWeight="SemiBold" FontFamily="Microsoft YaHei" Margin="0,0,0,20" />
				<!-- 两个入口卡片 -->
				<Grid Grid.Row="1">
					<Grid.ColumnDefinitions>
						<ColumnDefinition Width="*" />
						<ColumnDefinition Width="*" />
					</Grid.ColumnDefinitions>
					<!-- 青鸟账号 -->
					<Button Grid.Column="0" Background="#383838" Foreground="#FFFFFF" BorderBrush="#3A3A3A" BorderThickness="1" Padding="16,10" FontSize="14" FontFamily="Microsoft YaHei" Cursor="Hand" Margin="0,0,12,0" Click="BtnEnterQingniao_Click">
						<Control.Template>
							<ControlTemplate TargetType="{x:Type Button}">
								<Border Name="border" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="12" Padding="{TemplateBinding Padding}">
									<ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
								</Border>
								<ControlTemplate.Triggers>
									<Trigger Property="UIElement.IsMouseOver" Value="True">
										<Setter TargetName="border" Property="BorderBrush" Value="#2196F3" />
										<Setter TargetName="border" Property="Background" Value="#2D2D2D" />
									</Trigger>
								</ControlTemplate.Triggers>
							</ControlTemplate>
						</Control.Template>
						<StackPanel>
							<TextBlock Text="🔷" FontSize="36" HorizontalAlignment="Center" Margin="0,0,0,10" />
							<TextBlock Text="青鸟账号" FontSize="16" Foreground="#FFFFFF" FontWeight="SemiBold" FontFamily="Microsoft YaHei" HorizontalAlignment="Center" />
							<TextBlock Text="个人资料、游戏统计与快捷操作" FontSize="12" Foreground="#AAAAAA" FontFamily="Microsoft YaHei" HorizontalAlignment="Center" Margin="0,6,0,0" />
						</StackPanel>
					</Button>
					<!-- 游戏账号 -->
					<Button Grid.Column="1" Background="#383838" Foreground="#FFFFFF" BorderBrush="#3A3A3A" BorderThickness="1" Padding="16,10" FontSize="14" FontFamily="Microsoft YaHei" Cursor="Hand" Margin="0,0,0,0" Click="BtnEnterGameAccount_Click">
						<Control.Template>
							<ControlTemplate TargetType="{x:Type Button}">
								<Border Name="border" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="12" Padding="{TemplateBinding Padding}">
									<ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
								</Border>
								<ControlTemplate.Triggers>
									<Trigger Property="UIElement.IsMouseOver" Value="True">
										<Setter TargetName="border" Property="BorderBrush" Value="#2196F3" />
										<Setter TargetName="border" Property="Background" Value="#2D2D2D" />
									</Trigger>
								</ControlTemplate.Triggers>
							</ControlTemplate>
						</Control.Template>
						<StackPanel>
							<TextBlock Text="🎮" FontSize="36" HorizontalAlignment="Center" Margin="0,0,0,10" />
							<TextBlock Text="游戏账号" FontSize="16" Foreground="#FFFFFF" FontWeight="SemiBold" FontFamily="Microsoft YaHei" HorizontalAlignment="Center" />
							<TextBlock Text="管理离线/微软/外置登录账号" FontSize="12" Foreground="#AAAAAA" FontFamily="Microsoft YaHei" HorizontalAlignment="Center" Margin="0,6,0,0" />
						</StackPanel>
					</Button>
				</Grid>
			</Grid>

			<!-- ============ 青鸟账号详情 ============ -->
			<Grid x:Name="PanelQingniao" Margin="20" Visibility="Collapsed">
				<Grid.RowDefinitions>
					<RowDefinition Height="Auto" />
					<RowDefinition Height="*" />
				</Grid.RowDefinitions>
				<!-- 返回按钮 + 标题 -->
				<StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,16">
					<Button Content="← 返回" Style="{StaticResource SecondaryButtonStyle}" Padding="12,8" Margin="0,0,16,0" Click="BtnBackToSelect_Click" />
					<TextBlock Text="青鸟账号" Foreground="#FFFFFF" FontSize="20" FontWeight="SemiBold" FontFamily="Microsoft YaHei" VerticalAlignment="Center" />
				</StackPanel>
				<Grid Grid.Row="1">
					<Grid.ColumnDefinitions>
						<ColumnDefinition Width="320" />
						<ColumnDefinition Width="*" />
					</Grid.ColumnDefinitions>
					<Border Grid.Column="0" Style="{StaticResource StatCardStyle}" Margin="0,0,16,0">
						<StackPanel HorizontalAlignment="Center">
							<Border Width="120" Height="120" CornerRadius="60">
								<Border.Background>
									<LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
										<GradientStop Color="#6C5CE7" Offset="0" />
										<GradientStop Color="#A29BFE" Offset="1" />
									</LinearGradientBrush>
								</Border.Background>
								<Border.Effect>
									<DropShadowEffect Color="#6C5CE7" Opacity="0.4" BlurRadius="20" ShadowDepth="0" />
								</Border.Effect>
								<TextBlock Text="👤" FontSize="56" HorizontalAlignment="Center" VerticalAlignment="Center" />
							</Border>
							<TextBlock Name="txtUsername" Text="Player" Foreground="#FFFFFF" FontSize="22" FontWeight="SemiBold" FontFamily="Microsoft YaHei" HorizontalAlignment="Center" Margin="0,12,0,0" />
							<TextBlock Name="txtLoginMode" Text="离线模式" Foreground="#AAAAAA" FontSize="14" FontFamily="Microsoft YaHei" HorizontalAlignment="Center" Margin="0,4,0,20" />
							<Border Background="#252525" CornerRadius="12" Padding="20" Margin="0,0,0,20">
								<Grid>
									<Grid.ColumnDefinitions>
										<ColumnDefinition Width="*" />
										<ColumnDefinition Width="*" />
										<ColumnDefinition Width="*" />
									</Grid.ColumnDefinitions>
									<StackPanel Grid.Column="0" HorizontalAlignment="Center">
										<Border Background="#FF6B6B" CornerRadius="10" Padding="12,8" Margin="0,0,0,8">
											<TextBlock Text="🕐" Foreground="#FFFFFF" FontSize="20" HorizontalAlignment="Center" />
										</Border>
										<TextBlock Text="0" Foreground="#FFFFFF" FontSize="22" FontWeight="Bold" HorizontalAlignment="Center" />
										<TextBlock Text="游戏时长" Foreground="#AAAAAA" FontSize="12" FontFamily="Microsoft YaHei" HorizontalAlignment="Center" />
									</StackPanel>
									<StackPanel Grid.Column="1" HorizontalAlignment="Center">
										<Border Background="#4ECDC4" CornerRadius="8" Padding="12,8" Margin="0,0,0,8">
											<TextBlock Text="🎮" Foreground="#FFFFFF" FontSize="20" HorizontalAlignment="Center" />
										</Border>
										<TextBlock Text="0" Foreground="#FFFFFF" FontSize="22" FontWeight="Bold" HorizontalAlignment="Center" />
										<TextBlock Text="启动次数" Foreground="#AAAAAA" FontSize="12" FontFamily="Microsoft YaHei" HorizontalAlignment="Center" />
									</StackPanel>
									<StackPanel Grid.Column="2" HorizontalAlignment="Center">
										<Border Background="#FFE66D" CornerRadius="8" Padding="12,8" Margin="0,0,0,8">
											<TextBlock Text="🧩" Foreground="#1E1E1E" FontSize="20" HorizontalAlignment="Center" />
										</Border>
										<TextBlock Text="0" Foreground="#FFFFFF" FontSize="22" FontWeight="Bold" HorizontalAlignment="Center" />
										<TextBlock Text="模组数" Foreground="#AAAAAA" FontSize="12" FontFamily="Microsoft YaHei" HorizontalAlignment="Center" />
									</StackPanel>
								</Grid>
							</Border>
							<Button Content="✏️ 编辑个人资料" Style="{StaticResource PrimaryButtonStyle}" HorizontalAlignment="Stretch" Click="BtnEditProfile_Click" />
							<Button Content="🔄 切换账号" Style="{StaticResource SecondaryButtonStyle}" HorizontalAlignment="Stretch" Margin="0,8,0,0" Click="BtnSwitchAccount_Click" />
						</StackPanel>
					</Border>
					<StackPanel Grid.Column="1">
						<Border Style="{StaticResource StatCardStyle}" Margin="0,0,0,16">
							<StackPanel>
								<TextBlock Text="最近游戏" Foreground="#FFFFFF" FontSize="16" FontWeight="SemiBold" FontFamily="Microsoft YaHei" Margin="0,0,0,15" />
								<TextBlock Text="暂无游戏记录" Foreground="#888888" FontSize="13" FontFamily="Microsoft YaHei" HorizontalAlignment="Center" Margin="0,20,0,20" />
							</StackPanel>
						</Border>
						<Border Style="{StaticResource StatCardStyle}" Margin="0,0,0,16">
							<StackPanel>
								<TextBlock Text="游戏统计详情" Foreground="#FFFFFF" FontSize="16" FontWeight="SemiBold" FontFamily="Microsoft YaHei" Margin="0,0,0,15" />
								<Grid>
									<Grid.ColumnDefinitions>
										<ColumnDefinition Width="*" />
										<ColumnDefinition Width="*" />
									</Grid.ColumnDefinitions>
									<Grid.RowDefinitions>
										<RowDefinition Height="Auto" />
										<RowDefinition Height="Auto" />
									</Grid.RowDefinitions>
									<StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,0,15">
										<TextBlock Text="最喜欢的版本" Foreground="#AAAAAA" FontSize="12" FontFamily="Microsoft YaHei" />
										<TextBlock Text="尚未设置" Foreground="#FFFFFF" FontSize="13" FontFamily="Microsoft YaHei" />
									</StackPanel>
									<StackPanel Grid.Row="0" Grid.Column="1" Margin="0,0,0,15">
										<TextBlock Text="常用模组数量" Foreground="#AAAAAA" FontSize="12" FontFamily="Microsoft YaHei" />
										<TextBlock Text="0 个" Foreground="#FFFFFF" FontSize="13" FontFamily="Microsoft YaHei" />
									</StackPanel>
									<StackPanel Grid.Row="1" Grid.Column="0">
										<TextBlock Text="累计游戏时间" Foreground="#AAAAAA" FontSize="12" FontFamily="Microsoft YaHei" />
										<TextBlock Text="0 小时" Foreground="#FFFFFF" FontSize="13" FontFamily="Microsoft YaHei" />
									</StackPanel>
									<StackPanel Grid.Row="1" Grid.Column="1">
										<TextBlock Text="最近登录" Foreground="#AAAAAA" FontSize="12" FontFamily="Microsoft YaHei" />
										<TextBlock Text="今天" Foreground="#FFFFFF" FontSize="13" FontFamily="Microsoft YaHei" />
									</StackPanel>
								</Grid>
							</StackPanel>
						</Border>
						<Border Style="{StaticResource StatCardStyle}" Margin="0,0,0,0">
							<StackPanel>
								<TextBlock Text="快捷操作" Foreground="#FFFFFF" FontSize="16" FontWeight="SemiBold" FontFamily="Microsoft YaHei" Margin="0,0,0,15" />
								<Grid>
									<Grid.ColumnDefinitions>
										<ColumnDefinition Width="*" />
										<ColumnDefinition Width="*" />
										<ColumnDefinition Width="*" />
									</Grid.ColumnDefinitions>
									<Button Grid.Column="0" Content="🎮 快速开始" Style="{StaticResource PrimaryButtonStyle}" Margin="0,0,8,0" Click="BtnQuickStart_Click">
										<Button.Background>
											<LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
												<GradientStop Color="#2196F3" Offset="0" />
												<GradientStop Color="#64B5F6" Offset="1" />
											</LinearGradientBrush>
										</Button.Background>
									</Button>
									<Button Grid.Column="1" Content="🧩 浏览模组" Style="{StaticResource PrimaryButtonStyle}" Margin="0,0,8,0" Click="BtnBrowseMods_Click">
										<Button.Background>
											<LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
												<GradientStop Color="#2ECC71" Offset="0" />
												<GradientStop Color="#66BB6A" Offset="1" />
											</LinearGradientBrush>
										</Button.Background>
									</Button>
									<Button Grid.Column="2" Content="⚙️ 游戏设置" Style="{StaticResource PrimaryButtonStyle}" Click="BtnGameSettings_Click">
										<Button.Background>
											<LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
												<GradientStop Color="#E74C3C" Offset="0" />
												<GradientStop Color="#EF5350" Offset="1" />
											</LinearGradientBrush>
										</Button.Background>
									</Button>
								</Grid>
							</StackPanel>
						</Border>
					</StackPanel>
				</Grid>
			</Grid>

			<!-- ============ 游戏账号详情 ============ -->
			<Grid x:Name="PanelGameAccount" Margin="20" Visibility="Collapsed">
				<Grid.RowDefinitions>
					<RowDefinition Height="Auto" />
					<RowDefinition Height="*" />
				</Grid.RowDefinitions>
				<!-- 返回按钮 + 标题 -->
				<StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,16">
					<Button Content="← 返回" Style="{StaticResource SecondaryButtonStyle}" Padding="12,8" Margin="0,0,16,0" Click="BtnBackToSelect_Click" />
					<TextBlock Text="游戏账号" Foreground="#FFFFFF" FontSize="20" FontWeight="SemiBold" FontFamily="Microsoft YaHei" VerticalAlignment="Center" />
				</StackPanel>
                <!-- 游戏账号管理内容 -->
                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="220" />
                         <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <!-- 左侧：登录按钮 -->
                    <Border Grid.Column="0" Background="#252525" CornerRadius="12" Padding="0" Margin="0,0,8,0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <Border Grid.Row="0" Background="#2D2D2D" CornerRadius="12,12,0,0" Padding="16,14">
                                <StackPanel>
                                    <TextBlock Text="添加账号" Foreground="#FFFFFF" FontSize="15" FontWeight="SemiBold" FontFamily="Microsoft YaHei" Margin="0,0,0,12" />
                                    <StackPanel>
                                        <Button Style="{StaticResource AccountCardButton}" Background="#2ECC71" BorderThickness="0" Margin="0,0,0,6" Click="BtnAddOfflineAccount_Click" ToolTip="离线登录 - 无需正版验证">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="⬡" FontSize="18" Foreground="#FFFFFF" VerticalAlignment="Center" Margin="0,0,8,0" />
                                                <TextBlock Text="离线登录" FontSize="13" Foreground="#FFFFFF" FontFamily="Microsoft YaHei" VerticalAlignment="Center" />
                                            </StackPanel>
                                        </Button>
                                        <Button Style="{StaticResource AccountCardButton}" Background="#3498DB" BorderThickness="0" Margin="0,0,0,6" Click="BtnAddMicrosoftAccount_Click" ToolTip="微软登录 - 正版验证">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="⊞" FontSize="18" Foreground="#FFFFFF" VerticalAlignment="Center" Margin="0,0,8,0" />
                                                <TextBlock Text="微软登录" FontSize="13" Foreground="#FFFFFF" FontFamily="Microsoft YaHei" VerticalAlignment="Center" />
                                            </StackPanel>
                                        </Button>
                                        <Button Style="{StaticResource AccountCardButton}" Background="#9B59B6" BorderThickness="0" Click="BtnAddAuthlibAccount_Click" ToolTip="外置登录 - Authlib-Injector">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="🌐" FontSize="18" Foreground="#FFFFFF" VerticalAlignment="Center" Margin="0,0,8,0" />
                                                <TextBlock Text="外置登录" FontSize="13" Foreground="#FFFFFF" FontFamily="Microsoft YaHei" VerticalAlignment="Center" />
                                            </StackPanel>
                                        </Button>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Border>
                    <!-- 右侧：已有账号列表 -->
                    <Border Grid.Column="1" Background="#252525" CornerRadius="12" Padding="0" Margin="8,0,0,0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <Border Grid.Row="0" Background="#2D2D2D" CornerRadius="12,12,0,0" Padding="16,14">
                                <TextBlock Text="已有账号" Foreground="#FFFFFF" FontSize="15" FontWeight="SemiBold" FontFamily="Microsoft YaHei" />
                            </Border>
                            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="8,12,8,12">
                                <ItemsControl Name="AccountListControl">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Button Style="{StaticResource AccountCardButton}" Margin="0,0,0,8" Click="AccountCard_Click" Tag="{Binding}">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <Border Grid.Column="0" Width="36" Height="36" CornerRadius="18" Background="#383838" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                        <Image Source="{Binding HeadImage}" Stretch="UniformToFill" Width="36" Height="36">
                                                            <Image.Clip>
                                                                <EllipseGeometry RadiusX="18" RadiusY="18" Center="18,18" />
                                                            </Image.Clip>
                                                        </Image>
                                                    </Border>
                                                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="10,0,0,0">
                                                        <TextBlock Text="{Binding Name}" Foreground="#FFFFFF" FontSize="13" FontWeight="SemiBold" FontFamily="Microsoft YaHei" TextTrimming="CharacterEllipsis" MaxWidth="110" />
                                                        <Border Background="{Binding Type, Converter={StaticResource TypeColorConverter}}" CornerRadius="4" Padding="6,1" HorizontalAlignment="Left" Margin="0,3,0,0">
                                                            <TextBlock Text="{Binding TypeDisplay}" Foreground="#FFFFFF" FontSize="10" FontFamily="Microsoft YaHei" />
                                                        </Border>
                                                    </StackPanel>
                                                    <Border Grid.Column="2" Width="8" Height="8" CornerRadius="4" VerticalAlignment="Center" Margin="6,0,0,0">
                                                        <Border.Style>
                                                            <Style TargetType="Border">
                                                                <Setter Property="Background" Value="Transparent" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                                        <Setter Property="Background" Value="#2ECC71" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Border.Style>
                                                    </Border>
                                                    <Button Grid.Column="3" Content="✕" Width="24" Height="24" FontSize="11" Background="Transparent" Foreground="#888888" BorderThickness="0" Cursor="Hand" Margin="4,0,0,0" Click="BtnDeleteAccount_Click" Tag="{Binding}" ToolTip="删除账号" />
                                                </Grid>
                                            </Button>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>
        </Grid>
    </ScrollViewer>
</UserControl>
