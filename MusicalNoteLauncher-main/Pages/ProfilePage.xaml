<UserControl
	x:Class="MusicalNoteLauncher.Pages.ProfilePage" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:core="clr-namespace:MusicalNoteLauncher.Core"
	Background="{DynamicResource BackgroundBrush}" xmlns:pages="clr-namespace:MusicalNoteLauncher.Pages">
	<UserControl.Resources>
		<DropShadowEffect x:Key="CardShadow" Color="Black" Opacity="0.3" BlurRadius="12" ShadowDepth="4" />
		<DropShadowEffect x:Key="ButtonShadow" Color="Black" Opacity="0.2" BlurRadius="8" ShadowDepth="2" />

		<Style x:Key="StatCardStyle" TargetType="Border">
			<Setter Property="Background" Value="{DynamicResource BackgroundBrush}" />
			<Setter Property="CornerRadius" Value="12" />
			<Setter Property="Padding" Value="20" />
			<Setter Property="Effect" Value="{StaticResource CardShadow}" />
		</Style>

		<Style x:Key="PrimaryButtonStyle" TargetType="Button">
			<Setter Property="Background" Value="#6C5CE7" />
			<Setter Property="Foreground" Value="White" />
			<Setter Property="BorderThickness" Value="0" />
			<Setter Property="Padding" Value="16,10" />
			<Setter Property="FontSize" Value="13" />
			<Setter Property="FontFamily" Value="Microsoft YaHei" />
			<Setter Property="Cursor" Value="Hand" />
			<Setter Property="Effect" Value="{StaticResource ButtonShadow}" />
			<Setter Property="Template">
				<Setter.Value>
					<ControlTemplate TargetType="Button">
						<Border Name="border" Background="{TemplateBinding Background}" CornerRadius="12" Padding="{TemplateBinding Padding}">
							<ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
						</Border>
						<ControlTemplate.Triggers>
							<Trigger Property="IsMouseOver" Value="True">
								<Setter TargetName="border" Property="Background" Value="#5B4CDB" />
							</Trigger>
							<Trigger Property="IsPressed" Value="True">
								<Setter TargetName="border" Property="Background" Value="#4A3FBA" />
							</Trigger>
						</ControlTemplate.Triggers>
					</ControlTemplate>
				</Setter.Value>
			</Setter>
		</Style>

		<Style x:Key="SecondaryButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
			<Setter Property="Background" Value="{DynamicResource CardHoverBrush}" />
			<Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
			<Setter Property="BorderThickness" Value="1" />
			<Setter Property="BorderBrush" Value="{DynamicResource SurfaceBrush}" />
			<Style.Triggers>
				<Trigger Property="IsMouseOver" Value="True">
					<Setter Property="Background" Value="{DynamicResource SurfaceBrush}" />
				</Trigger>
			</Style.Triggers>
		</Style>

		<Style x:Key="AccountCardButton" TargetType="Button">
			<Setter Property="Background" Value="{DynamicResource CardHoverBrush}" />
			<Setter Property="BorderBrush" Value="{DynamicResource SurfaceBrush}" />
			<Setter Property="BorderThickness" Value="1" />
			<Setter Property="HorizontalContentAlignment" Value="Stretch" />
			<Setter Property="Cursor" Value="Hand" />
			<Setter Property="Template">
				<Setter.Value>
					<ControlTemplate TargetType="Button">
						<Border Name="border" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="12" Padding="12,10">
							<ContentPresenter />
						</Border>
						<ControlTemplate.Triggers>
							<Trigger Property="IsMouseOver" Value="True">
								<Setter TargetName="border" Property="Background" Value="{DynamicResource SurfaceBrush}" />
								<Setter TargetName="border" Property="BorderBrush" Value="{DynamicResource SurfaceBrush}" />
							</Trigger>
						</ControlTemplate.Triggers>
					</ControlTemplate>
				</Setter.Value>
			</Setter>
		</Style>

		<Style x:Key="AccountActionButton" TargetType="Button">
			<Setter Property="Width" Value="28" />
			<Setter Property="Height" Value="28" />
			<Setter Property="Background" Value="Transparent" />
			<Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
			<Setter Property="BorderThickness" Value="0" />
			<Setter Property="FontSize" Value="12" />
			<Setter Property="FontFamily" Value="Microsoft YaHei" />
			<Setter Property="Cursor" Value="Hand" />
			<Setter Property="Template">
				<Setter.Value>
					<ControlTemplate TargetType="Button">
						<Border Name="bg" Background="{TemplateBinding Background}" CornerRadius="6" Padding="4">
							<ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
						</Border>
						<ControlTemplate.Triggers>
							<Trigger Property="IsMouseOver" Value="True">
								<Setter TargetName="bg" Property="Background" Value="{DynamicResource SurfaceBrush}" />
							</Trigger>
							<Trigger Property="IsPressed" Value="True">
								<Setter TargetName="bg" Property="Background" Value="{DynamicResource SurfaceBrush}" />
							</Trigger>
						</ControlTemplate.Triggers>
					</ControlTemplate>
				</Setter.Value>
			</Setter>
		</Style>

		<Style x:Key="AccountDeleteButton" TargetType="Button" BasedOn="{StaticResource AccountActionButton}">
			<Setter Property="Foreground" Value="#777777" />
			<Setter Property="Width" Value="22" />
			<Setter Property="Height" Value="22" />
			<Setter Property="FontSize" Value="10" />
			<Style.Triggers>
				<Trigger Property="IsMouseOver" Value="True">
					<Setter Property="Foreground" Value="#F44336" />
				</Trigger>
			</Style.Triggers>
		</Style>

		<core:AccountTypeColorConverter x:Key="TypeColorConverter" />
	</UserControl.Resources>

	<ScrollViewer VerticalScrollBarVisibility="Auto">
		<Grid>
			<!-- ============ 卡片选择入口（初始显示） ============ -->
			<Grid x:Name="PanelSelect" Margin="20" Visibility="Visible">
				<Grid.RowDefinitions>
					<RowDefinition Height="Auto" />
					<RowDefinition Height="*" />
				</Grid.RowDefinitions>
				<!-- 标题 -->
				<TextBlock Grid.Row="0" Text="个人主页" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="24" FontWeight="SemiBold" FontFamily="Microsoft YaHei" Margin="0,0,0,20" />
				<!-- 两个入口卡片 -->
				<Grid Grid.Row="1">
					<Grid.ColumnDefinitions>
						<ColumnDefinition Width="*" />
						<ColumnDefinition Width="*" />
					</Grid.ColumnDefinitions>
					<!-- 青鸟账号 -->
					<Button Grid.Column="0" Background="{DynamicResource SurfaceBrush}" Foreground="{DynamicResource TextPrimaryBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Padding="16,10" FontSize="14" FontFamily="Microsoft YaHei" Cursor="Hand" Margin="0,0,12,0" Click="BtnEnterQingniao_Click">
						<Control.Template>
							<ControlTemplate TargetType="{x:Type Button}">
								<Border Name="border" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="12" Padding="{TemplateBinding Padding}">
									<ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
								</Border>
								<ControlTemplate.Triggers>
									<Trigger Property="UIElement.IsMouseOver" Value="True">
										<Setter TargetName="border" Property="BorderBrush" Value="#2196F3" />
										<Setter TargetName="border" Property="Background" Value="{DynamicResource CardHoverBrush}" />
									</Trigger>
								</ControlTemplate.Triggers>
							</ControlTemplate>
						</Control.Template>
						<StackPanel>
							<TextBlock Text="🔷" FontSize="36" HorizontalAlignment="Center" Margin="0,0,0,10" />
							<TextBlock Text="青鸟账号" FontSize="16" Foreground="{DynamicResource TextPrimaryBrush}" FontWeight="SemiBold" FontFamily="Microsoft YaHei" HorizontalAlignment="Center" />
							<TextBlock Text="个人资料、游戏统计与快捷操作" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" FontFamily="Microsoft YaHei" HorizontalAlignment="Center" Margin="0,6,0,0" />
						</StackPanel>
					</Button>
					<!-- 游戏账号 -->
					<Button Grid.Column="1" Background="{DynamicResource SurfaceBrush}" Foreground="{DynamicResource TextPrimaryBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Padding="16,10" FontSize="14" FontFamily="Microsoft YaHei" Cursor="Hand" Margin="0,0,0,0" Click="BtnEnterGameAccount_Click">
						<Control.Template>
							<ControlTemplate TargetType="{x:Type Button}">
								<Border Name="border" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="12" Padding="{TemplateBinding Padding}">
									<ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
								</Border>
								<ControlTemplate.Triggers>
									<Trigger Property="UIElement.IsMouseOver" Value="True">
										<Setter TargetName="border" Property="BorderBrush" Value="#2196F3" />
										<Setter TargetName="border" Property="Background" Value="{DynamicResource CardHoverBrush}" />
									</Trigger>
								</ControlTemplate.Triggers>
							</ControlTemplate>
						</Control.Template>
						<StackPanel>
							<TextBlock Text="🎮" FontSize="36" HorizontalAlignment="Center" Margin="0,0,0,10" />
							<TextBlock Text="游戏账号" FontSize="16" Foreground="{DynamicResource TextPrimaryBrush}" FontWeight="SemiBold" FontFamily="Microsoft YaHei" HorizontalAlignment="Center" />
							<TextBlock Text="管理离线/微软/外置登录账号" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" FontFamily="Microsoft YaHei" HorizontalAlignment="Center" Margin="0,6,0,0" />
						</StackPanel>
					</Button>
				</Grid>
			</Grid>

			<!-- ============ 青鸟账号详情 ============ -->
			<Grid x:Name="PanelQingniao" Margin="20" Visibility="Collapsed">
				<Grid.RowDefinitions>
					<RowDefinition Height="Auto" />
					<RowDefinition Height="*" />
				</Grid.RowDefinitions>
				<!-- 返回按钮 + 标题 -->
				<StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,16">
					<Button Content="← 返回" Style="{StaticResource SecondaryButtonStyle}" Padding="12,8" Margin="0,0,16,0" Click="BtnBackToSelect_Click" />
					<TextBlock Text="青鸟账号" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="20" FontWeight="SemiBold" FontFamily="Microsoft YaHei" VerticalAlignment="Center" />
				</StackPanel>
				<Grid Grid.Row="1">
					<Grid.ColumnDefinitions>
						<ColumnDefinition Width="320" />
						<ColumnDefinition Width="*" />
					</Grid.ColumnDefinitions>
					<Border Grid.Column="0" Style="{StaticResource StatCardStyle}" Margin="0,0,16,0">
						<StackPanel HorizontalAlignment="Center">
							<Border Width="120" Height="120" CornerRadius="60" HorizontalAlignment="Center" VerticalAlignment="Center"
								Background="{DynamicResource CardHoverBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="2" Padding="0">
							<Border Width="116" Height="116" CornerRadius="58" ClipToBounds="True">
								<Image x:Name="imgQingniaoHead" Stretch="UniformToFill" Width="116" Height="116">
									<Image.Clip>
										<EllipseGeometry RadiusX="58" RadiusY="58" Center="58,58" />
									</Image.Clip>
								</Image>
							</Border>
						</Border>
							<TextBlock Name="txtUsername" Text="Player" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="22" FontWeight="SemiBold" FontFamily="Microsoft YaHei" HorizontalAlignment="Center" Margin="0,12,0,0" />
							<TextBlock Name="txtLoginMode" Text="离线模式" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="14" FontFamily="Microsoft YaHei" HorizontalAlignment="Center" Margin="0,4,0,20" />
							<Border Background="{DynamicResource CardBackgroundBrush}" CornerRadius="12" Padding="20" Margin="0,0,0,20">
								<Grid>
									<Grid.ColumnDefinitions>
										<ColumnDefinition Width="*" />
										<ColumnDefinition Width="*" />
										<ColumnDefinition Width="*" />
									</Grid.ColumnDefinitions>
									<StackPanel Grid.Column="0" HorizontalAlignment="Center">
										<Border Background="#FF6B6B" CornerRadius="10" Padding="12,8" Margin="0,0,0,8">
											<TextBlock Text="🕐" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="20" HorizontalAlignment="Center" />
										</Border>
										<TextBlock Text="0" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="22" FontWeight="Bold" HorizontalAlignment="Center" />
										<TextBlock Text="游戏时长" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12" FontFamily="Microsoft YaHei" HorizontalAlignment="Center" />
									</StackPanel>
									<StackPanel Grid.Column="1" HorizontalAlignment="Center">
										<Border Background="#4ECDC4" CornerRadius="8" Padding="12,8" Margin="0,0,0,8">
											<TextBlock Text="🎮" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="20" HorizontalAlignment="Center" />
										</Border>
										<TextBlock Text="0" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="22" FontWeight="Bold" HorizontalAlignment="Center" />
										<TextBlock Text="启动次数" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12" FontFamily="Microsoft YaHei" HorizontalAlignment="Center" />
									</StackPanel>
									<StackPanel Grid.Column="2" HorizontalAlignment="Center">
										<Border Background="#FFE66D" CornerRadius="8" Padding="12,8" Margin="0,0,0,8">
											<TextBlock Text="🧩" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="20" HorizontalAlignment="Center" />
										</Border>
										<TextBlock Text="0" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="22" FontWeight="Bold" HorizontalAlignment="Center" />
										<TextBlock Text="模组数" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12" FontFamily="Microsoft YaHei" HorizontalAlignment="Center" />
									</StackPanel>
								</Grid>
							</Border>
							<Button Content="✏️ 编辑个人资料" Style="{StaticResource PrimaryButtonStyle}" HorizontalAlignment="Stretch" Click="BtnEditProfile_Click" />
							<Button Content="🔄 切换账号" Style="{StaticResource SecondaryButtonStyle}" HorizontalAlignment="Stretch" Margin="0,8,0,0" Click="BtnSwitchAccount_Click" />
						</StackPanel>
					</Border>
					<StackPanel Grid.Column="1">
						<Border Style="{StaticResource StatCardStyle}" Margin="0,0,0,16">
							<StackPanel>
								<TextBlock Text="最近游戏" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="16" FontWeight="SemiBold" FontFamily="Microsoft YaHei" Margin="0,0,0,15" />
								<TextBlock Text="暂无游戏记录" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="13" FontFamily="Microsoft YaHei" HorizontalAlignment="Center" Margin="0,20,0,20" />
							</StackPanel>
						</Border>
						<Border Style="{StaticResource StatCardStyle}" Margin="0,0,0,16">
							<StackPanel>
								<TextBlock Text="游戏统计详情" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="16" FontWeight="SemiBold" FontFamily="Microsoft YaHei" Margin="0,0,0,15" />
								<Grid>
									<Grid.ColumnDefinitions>
										<ColumnDefinition Width="*" />
										<ColumnDefinition Width="*" />
									</Grid.ColumnDefinitions>
									<Grid.RowDefinitions>
										<RowDefinition Height="Auto" />
										<RowDefinition Height="Auto" />
									</Grid.RowDefinitions>
									<StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,0,15">
										<TextBlock Text="最喜欢的版本" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12" FontFamily="Microsoft YaHei" />
										<TextBlock Text="尚未设置" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="13" FontFamily="Microsoft YaHei" />
									</StackPanel>
									<StackPanel Grid.Row="0" Grid.Column="1" Margin="0,0,0,15">
										<TextBlock Text="常用模组数量" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12" FontFamily="Microsoft YaHei" />
										<TextBlock Text="0 个" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="13" FontFamily="Microsoft YaHei" />
									</StackPanel>
									<StackPanel Grid.Row="1" Grid.Column="0">
										<TextBlock Text="累计游戏时间" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12" FontFamily="Microsoft YaHei" />
										<TextBlock Text="0 小时" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="13" FontFamily="Microsoft YaHei" />
									</StackPanel>
									<StackPanel Grid.Row="1" Grid.Column="1">
										<TextBlock Text="最近登录" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12" FontFamily="Microsoft YaHei" />
										<TextBlock Text="今天" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="13" FontFamily="Microsoft YaHei" />
									</StackPanel>
								</Grid>
							</StackPanel>
						</Border>
						<Border Style="{StaticResource StatCardStyle}" Margin="0,0,0,0">
							<StackPanel>
								<TextBlock Text="快捷操作" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="16" FontWeight="SemiBold" FontFamily="Microsoft YaHei" Margin="0,0,0,15" />
								<Grid>
									<Grid.ColumnDefinitions>
										<ColumnDefinition Width="*" />
										<ColumnDefinition Width="*" />
										<ColumnDefinition Width="*" />
									</Grid.ColumnDefinitions>
									<Button Grid.Column="0" Content="🎮 快速开始" Style="{StaticResource PrimaryButtonStyle}" Margin="0,0,8,0" Click="BtnQuickStart_Click">
										<Button.Background>
											<LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
												<GradientStop Color="#2196F3" Offset="0" />
												<GradientStop Color="#64B5F6" Offset="1" />
											</LinearGradientBrush>
										</Button.Background>
									</Button>
									<Button Grid.Column="1" Content="🧩 浏览模组" Style="{StaticResource PrimaryButtonStyle}" Margin="0,0,8,0" Click="BtnBrowseMods_Click">
										<Button.Background>
											<LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
												<GradientStop Color="#2ECC71" Offset="0" />
												<GradientStop Color="#66BB6A" Offset="1" />
											</LinearGradientBrush>
										</Button.Background>
									</Button>
									<Button Grid.Column="2" Content="⚙️ 游戏设置" Style="{StaticResource PrimaryButtonStyle}" Click="BtnGameSettings_Click">
										<Button.Background>
											<LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
												<GradientStop Color="#E74C3C" Offset="0" />
												<GradientStop Color="#EF5350" Offset="1" />
											</LinearGradientBrush>
										</Button.Background>
									</Button>
								</Grid>
							</StackPanel>
						</Border>
					</StackPanel>
				</Grid>
			</Grid>

			<!-- ============ 游戏账号详情 ============ -->
			<Grid x:Name="PanelGameAccount" Margin="20" Visibility="Collapsed">
				<Grid.RowDefinitions>
					<RowDefinition Height="Auto" />
					<RowDefinition Height="*" />
				</Grid.RowDefinitions>
				<!-- 返回按钮 + 标题 -->
				<StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,16">
					<Button Content="← 返回" Style="{StaticResource SecondaryButtonStyle}" Padding="12,8" Margin="0,0,16,0" Click="BtnBackToSelect_Click" />
					<TextBlock Text="游戏账号" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="20" FontWeight="SemiBold" FontFamily="Microsoft YaHei" VerticalAlignment="Center" />
				</StackPanel>
                <!-- 游戏账号管理内容 -->
                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="220" />
                         <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <!-- 左侧：登录按钮 -->
                    <Border Grid.Column="0" Background="{DynamicResource CardBackgroundBrush}" CornerRadius="12" Padding="0" Margin="0,0,8,0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <Border Grid.Row="0" Background="{DynamicResource CardHoverBrush}" CornerRadius="12,12,0,0" Padding="16,14">
                                <StackPanel>
                                    <TextBlock Text="添加账号" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="15" FontWeight="SemiBold" FontFamily="Microsoft YaHei" Margin="0,0,0,12" />
                                    <StackPanel>
                                        <Button Style="{StaticResource AccountCardButton}" Background="#2ECC71" BorderThickness="0" Margin="0,0,0,6" Click="BtnAddOfflineAccount_Click" ToolTip="离线登录 - 无需正版验证">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="⬡" FontSize="18" Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center" Margin="0,0,8,0" />
                                                <TextBlock Text="离线登录" FontSize="13" Foreground="{DynamicResource TextPrimaryBrush}" FontFamily="Microsoft YaHei" VerticalAlignment="Center" />
                                            </StackPanel>
                                        </Button>
                                        <Button Style="{StaticResource AccountCardButton}" Background="#3498DB" BorderThickness="0" Margin="0,0,0,6" Click="BtnAddMicrosoftAccount_Click" ToolTip="微软登录 - 正版验证">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="⊞" FontSize="18" Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center" Margin="0,0,8,0" />
                                                <TextBlock Text="微软登录" FontSize="13" Foreground="{DynamicResource TextPrimaryBrush}" FontFamily="Microsoft YaHei" VerticalAlignment="Center" />
                                            </StackPanel>
                                        </Button>
                                        <Button Style="{StaticResource AccountCardButton}" Background="#9B59B6" BorderThickness="0" Click="BtnAddAuthlibAccount_Click" ToolTip="外置登录 - Authlib-Injector">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="🌐" FontSize="18" Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center" Margin="0,0,8,0" />
                                                <TextBlock Text="外置登录" FontSize="13" Foreground="{DynamicResource TextPrimaryBrush}" FontFamily="Microsoft YaHei" VerticalAlignment="Center" />
                                            </StackPanel>
                                        </Button>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Border>
                    <!-- 右侧：已有账号列表 -->
                    <Border Grid.Column="1" Background="{DynamicResource CardBackgroundBrush}" CornerRadius="12" Padding="0" Margin="8,0,0,0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <Border Grid.Row="0" Background="{DynamicResource CardHoverBrush}" CornerRadius="12,12,0,0" Padding="16,14">
                                <TextBlock Text="已有账号" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="15" FontWeight="SemiBold" FontFamily="Microsoft YaHei" />
                            </Border>
                            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="8,12,8,12">
                                <ItemsControl Name="AccountListControl">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Button Style="{StaticResource AccountCardButton}" Margin="0,0,0,8" Click="AccountCard_Click" Tag="{Binding}">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <!-- 左侧: 头像 + 名称/类型 -->
                                                    <StackPanel Grid.Column="0" Orientation="Horizontal">
                                                        <Border Width="32" Height="32" CornerRadius="0" Background="Transparent" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                            <Image Source="{Binding HeadImage}" Stretch="Uniform" Width="32" Height="32"
                                                                   RenderOptions.BitmapScalingMode="NearestNeighbor" />
                                                        </Border>
                                                        <StackPanel VerticalAlignment="Center" Margin="12,0,0,0">
                                                            <TextBlock Text="{Binding Name}" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="13" FontWeight="SemiBold" FontFamily="Microsoft YaHei" TextTrimming="CharacterEllipsis" MaxWidth="120" />
                                                            <Border Background="{Binding Type, Converter={StaticResource TypeColorConverter}}" CornerRadius="4" Padding="6,1" HorizontalAlignment="Left" Margin="0,4,0,0">
                                                                <TextBlock Text="{Binding TypeDisplay}" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="10" FontFamily="Microsoft YaHei" />
                                                            </Border>
                                                        </StackPanel>
                                                    </StackPanel>
                                                    <!-- 右侧: 操作按钮组 -->
                                                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                                        <!-- 选中指示器 -->
                                                        <Border Width="8" Height="8" CornerRadius="4" VerticalAlignment="Center" Margin="0,0,8,0">
                                                            <Border.Style>
                                                                <Style TargetType="Border">
                                                                    <Setter Property="Background" Value="Transparent" />
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                                            <Setter Property="Background" Value="#2ECC71" />
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Border.Style>
                                                        </Border>
                                                        <!-- 分隔线 -->
                                                        <Border Width="1" Height="20" Background="{DynamicResource SurfaceBrush}" VerticalAlignment="Center" Margin="0,0,8,0" />
                                                        <Button Style="{StaticResource AccountActionButton}" Click="BtnRefreshAccount_Click" Tag="{Binding}" ToolTip="刷新账号">
                                                            <TextBlock Text="🔄" FontSize="13" />
                                                        </Button>
                                                        <Button Style="{StaticResource AccountActionButton}" Click="BtnEditSkin_Click" Tag="{Binding}" ToolTip="上传皮肤" Margin="2,0,0,0">
                                                            <TextBlock Text="🎨" FontSize="13" />
                                                        </Button>
                                                        <Button Style="{StaticResource AccountActionButton}" Click="BtnCopyUuid_Click" Tag="{Binding}" ToolTip="复制 UUID" Margin="2,0,0,0">
                                                            <TextBlock Text="📋" FontSize="12" />
                                                        </Button>
                                                        <!-- 分隔线 -->
                                                        <Border Width="1" Height="20" Background="{DynamicResource SurfaceBrush}" VerticalAlignment="Center" Margin="4,0,4,0" />
                                                        <Button Style="{StaticResource AccountDeleteButton}" Click="BtnDeleteAccount_Click" Tag="{Binding}" ToolTip="删除账号">
                                                            <TextBlock Text="✕" FontSize="11" />
                                                        </Button>
                                                    </StackPanel>
                                                </Grid>
                                            </Button>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>
        </Grid>
    </ScrollViewer>
</UserControl>
