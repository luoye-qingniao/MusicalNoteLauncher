<UserControl
x:Class="MusicalNoteLauncher.Pages.LoaderSelectionPage"
xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
Background="{DynamicResource BackgroundBrush}">
<UserControl.Resources>

<!-- 小型移除按钮样式 -->
<Style x:Key="RemoveButtonStyle" TargetType="Button">
    <Setter Property="Background" Value="Transparent"/>
    <Setter Property="Foreground" Value="#E07C73"/>
    <Setter Property="BorderThickness" Value="0"/>
    <Setter Property="Cursor" Value="Hand"/>
    <Setter Property="FontSize" Value="13"/>
    <Setter Property="FontFamily" Value="Microsoft YaHei"/>
    <Setter Property="FontWeight" Value="SemiBold"/>
    <Setter Property="Padding" Value="16,4"/>
    <Setter Property="Margin" Value="0,0,14,0"/>
    <Setter Property="Height" Value="32"/>
    <Setter Property="VerticalAlignment" Value="Center"/>
    <Setter Property="Template">
        <Setter.Value>
            <ControlTemplate TargetType="Button">
                <Border x:Name="b"
                        CornerRadius="6"
                        Background="#322626"
                        BorderBrush="#4A3030"
                        BorderThickness="1"
                        Padding="{TemplateBinding Padding}">
                    <TextBlock Text="移除"
                               Foreground="{TemplateBinding Foreground}"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                </Border>
                <ControlTemplate.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter TargetName="b" Property="Background" Value="#4A2E2A"/>
                        <Setter TargetName="b" Property="BorderBrush" Value="#C0392B"/>
                        <Setter Property="Foreground" Value="#FF8A80"/>
                    </Trigger>
                    <Trigger Property="IsPressed" Value="True">
                        <Setter TargetName="b" Property="Background" Value="#3A1E1A"/>
                        <Setter TargetName="b" Property="BorderBrush" Value="#E74C3C"/>
                    </Trigger>
                    <Trigger Property="IsEnabled" Value="False">
                        <Setter TargetName="b" Property="Background" Value="#2A2A2A"/>
                        <Setter TargetName="b" Property="BorderBrush" Value="#333333"/>
                        <Setter Property="Foreground" Value="#555555"/>
                    </Trigger>
                </ControlTemplate.Triggers>
            </ControlTemplate>
        </Setter.Value>
    </Setter>
</Style>

<!-- 底部下载按钮样式 -->
<Style x:Key="DownloadButtonStyle" TargetType="Button">
<Setter Property="Background" Value="#23854E"/>
<Setter Property="Foreground" Value="#FFFFFF"/>
<Setter Property="BorderThickness" Value="0"/>
<Setter Property="Cursor" Value="Hand"/>
<Setter Property="FontSize" Value="15"/>
<Setter Property="FontWeight" Value="SemiBold"/>
<Setter Property="FontFamily" Value="Microsoft YaHei"/>
<Setter Property="Padding" Value="36,12"/>
<Setter Property="Template">
<Setter.Value>
<ControlTemplate TargetType="Button">
<Border x:Name="b" CornerRadius="6"
Background="{TemplateBinding Background}"
Padding="{TemplateBinding Padding}">
<TextBlock Text="{TemplateBinding Content}"
Foreground="{TemplateBinding Foreground}"
HorizontalAlignment="Center"
VerticalAlignment="Center"/>
</Border>
<ControlTemplate.Triggers>
<Trigger Property="IsMouseOver" Value="True">
<Setter TargetName="b" Property="Background" Value="#1E7042"/>
</Trigger>
<Trigger Property="IsEnabled" Value="False">
<Setter TargetName="b" Property="Background" Value="#333333"/>
<Setter Property="Foreground" Value="#666666"/>
</Trigger>
</ControlTemplate.Triggers>
</ControlTemplate>
</Setter.Value>
</Setter>
</Style>

</UserControl.Resources>

<Grid>
<Grid.RowDefinitions>
<RowDefinition Height="Auto"/>
<RowDefinition Height="*"/>
<RowDefinition Height="Auto"/>
</Grid.RowDefinitions>

<!-- 顶部栏 -->
<Border Grid.Row="0" Background="{DynamicResource CardBackgroundBrush}" Padding="0,16,24,16">
<Grid>
<Grid.ColumnDefinitions>
<ColumnDefinition Width="Auto"/>
<ColumnDefinition Width="*"/>
<ColumnDefinition Width="Auto"/>
</Grid.ColumnDefinitions>
<Button
Grid.Column="0"
Content="← 返回"
Background="Transparent"
Foreground="#BDBDBD"
BorderThickness="0"
FontSize="14"
FontFamily="Microsoft YaHei"
Padding="24,6"
HorizontalAlignment="Left"
Click="BtnBack_Click"/>
<TextBlock
Grid.Column="1"
Text="选择模组加载器"
FontSize="17"
FontWeight="SemiBold"
Foreground="{DynamicResource TextPrimaryBrush}"
FontFamily="Microsoft YaHei"
HorizontalAlignment="Center"
VerticalAlignment="Center"/>
<Border
Grid.Column="2"
CornerRadius="14"
Background="#2E2E2E"
Padding="14,6"
VerticalAlignment="Center">
<TextBlock
x:Name="txtVersionInfo"
FontSize="13"
Foreground="#BDBDBD"
FontFamily="Microsoft YaHei"/>
</Border>
</Grid>
</Border>

<!-- 加载器列表 -->
<ScrollViewer Grid.Row="1"
VerticalScrollBarVisibility="Auto"
HorizontalScrollBarVisibility="Disabled"
Background="Transparent">
<StackPanel Margin="32,28,32,20">

<!-- Forge -->
<Border x:Name="brdForge"
Background="#2A2A2A"
BorderBrush="{DynamicResource BorderBrush}"
BorderThickness="1"
CornerRadius="8"
Padding="0"
Margin="0,0,0,10"
Cursor="Hand"
MouseLeftButtonUp="ForgeCard_Click">
<Grid>
<Grid.ColumnDefinitions>
<ColumnDefinition Width="6"/>
<ColumnDefinition Width="72"/>
<ColumnDefinition Width="*"/>
<ColumnDefinition Width="Auto"/>
<ColumnDefinition Width="Auto"/>
</Grid.ColumnDefinitions>

<Border Grid.Column="0"
x:Name="barForge"
Background="#2A2A2A"
CornerRadius="4,0,0,4"/>

<Border Grid.Column="1"
x:Name="iconBoxForge"
Background="Transparent"
CornerRadius="8"
Margin="12,12,8,12"
Width="48" Height="48"
VerticalAlignment="Center">
<Image x:Name="imgForge"
Stretch="Uniform"
HorizontalAlignment="Center"
VerticalAlignment="Center"
RenderOptions.BitmapScalingMode="HighQuality"/>
</Border>

<StackPanel Grid.Column="2" VerticalAlignment="Center" Margin="8,0,0,0">
<TextBlock Text="Forge"
FontSize="15"
FontWeight="SemiBold"
Foreground="{DynamicResource TextPrimaryBrush}"
FontFamily="Microsoft YaHei"/>
<TextBlock x:Name="txtForgeStatus"
Text=""
FontSize="12"
Foreground="#B0B0B0"
FontFamily="Microsoft YaHei"
Margin="0,4,0,0"/>
</StackPanel>

<TextBlock Grid.Column="3"
Text="›"
FontSize="24"
Foreground="#555555"
VerticalAlignment="Center"
Margin="12,0,8,0"/>

<Button Grid.Column="4"
x:Name="btnRemoveForge"
Style="{StaticResource RemoveButtonStyle}"
Visibility="Collapsed"
Click="RemoveForge_Click"/>
</Grid>
</Border>

<!-- Fabric -->
<Border x:Name="brdFabric"
Background="#2A2A2A"
BorderBrush="{DynamicResource BorderBrush}"
BorderThickness="1"
CornerRadius="8"
Padding="0"
Margin="0,0,0,10"
Cursor="Hand"
MouseLeftButtonUp="FabricCard_Click">
<Grid>
<Grid.ColumnDefinitions>
<ColumnDefinition Width="6"/>
<ColumnDefinition Width="72"/>
<ColumnDefinition Width="*"/>
<ColumnDefinition Width="Auto"/>
<ColumnDefinition Width="Auto"/>
