</ScrollViewer>

<!-- 底部下载栏 -->
<Border Grid.Row="2" Background="{DynamicResource CardBackgroundBrush}" Padding="32,16">
<Grid>
<StackPanel VerticalAlignment="Center" Orientation="Horizontal" MaxWidth="800">
<Ellipse Width="8" Height="8"
x:Name="dotStatus"
Fill="#757575"
Margin="0,0,10,0"
VerticalAlignment="Center"/>
<StackPanel VerticalAlignment="Center">
<TextBlock
x:Name="txtDownloadSummary"
FontSize="14"
Foreground="#BDBDBD"
FontFamily="Microsoft YaHei"
Text="请选择需要添加的加载器"/>
<ProgressBar
x:Name="pbDownload"
Height="4"
Margin="0,8,0,0"
Minimum="0"
Maximum="100"
Value="0"
Background="#333333"
Foreground="#2196F3"
Visibility="Collapsed"/>
</StackPanel>
</StackPanel>
<Button
x:Name="btnDownload"
HorizontalAlignment="Right"
Content="开始下载"
Style="{StaticResource DownloadButtonStyle}"
Click="BtnDownload_Click"/>
</Grid>
</Border>
</Grid>
</UserControl>

