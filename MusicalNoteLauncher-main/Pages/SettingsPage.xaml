									<TextBlock
										Text="关于"
										Foreground="{DynamicResource TextPrimaryBrush}"
										FontSize="18"
										FontWeight="SemiBold"
										FontFamily="Microsoft YaHei"
										Margin="0,0,0,16" />
									<Border
										Background="{DynamicResource SurfaceBrush}"
										CornerRadius="8"
										Padding="20"
										Margin="0,0,0,16">
										<StackPanel
											HorizontalAlignment="Center">
											<TextBlock
												Text="🎵 MNL"
												FontSize="20"
												FontWeight="Bold"
												Foreground="{DynamicResource TextPrimaryBrush}"
												FontFamily="Microsoft YaHei"
												Margin="0,0,0,8" />
											<TextBlock
												Text="版本 1.0.0"
												FontSize="14"
												Foreground="{DynamicResource TextSecondaryBrush}"
												FontFamily="Microsoft YaHei"
												Margin="0,0,0,12" />
											<TextBlock
												Text="一款功能强大的Minecraft启动器"
												FontSize="12"
												Foreground="#888888"
												FontFamily="Microsoft YaHei"
												TextAlignment="Center" />
										</StackPanel>
									</Border>
									<Border
										Background="{DynamicResource SurfaceBrush}"
										CornerRadius="8"
										Padding="16">
										<StackPanel>
											<TextBlock
												Text="功能特性"
												Foreground="{DynamicResource TextPrimaryBrush}"
												FontSize="14"
												FontWeight="SemiBold"
												FontFamily="Microsoft YaHei"
												Margin="0,0,0,12" />
											<StackPanel>
												<TextBlock
													Text="• 支持多版本游戏下载"
													Foreground="{DynamicResource TextSecondaryBrush}"
													FontSize="12"
													FontFamily="Microsoft YaHei"
													Margin="0,4,0,0" />
												<TextBlock
													Text="• 整合包一键安装"
													Foreground="{DynamicResource TextSecondaryBrush}"
													FontSize="12"
													FontFamily="Microsoft YaHei"
													Margin="0,4,0,0" />
												<TextBlock
													Text="• Mod模组管理"
													Foreground="{DynamicResource TextSecondaryBrush}"
													FontSize="12"
													FontFamily="Microsoft YaHei"
													Margin="0,4,0,0" />
												<TextBlock
													Text="• 光影材质支持"
													Foreground="{DynamicResource TextSecondaryBrush}"
													FontSize="12"
													FontFamily="Microsoft YaHei"
													Margin="0,4,0,0" />
												<TextBlock
													Text="• 自定义Java参数"
													Foreground="{DynamicResource TextSecondaryBrush}"
													FontSize="12"
													FontFamily="Microsoft YaHei"
													Margin="0,4,0,0" />
											</StackPanel>
										</StackPanel>
									</Border>
									<Button
										Content="检查更新"
										Background="{DynamicResource PrimaryBrush}"
										Foreground="{DynamicResource TextPrimaryBrush}"
										BorderThickness="0"
										Padding="16,10"
										FontSize="14"
										FontFamily="Microsoft YaHei"
										Cursor="Hand"
										Margin="0,20,0,0"
										HorizontalAlignment="Left"
										Click="BtnCheckUpdate_Click">
										<Control.Template>
											<ControlTemplate
												TargetType="{x:Type Button}">
												<Border
													Name="border"
													Background="{TemplateBinding Background}"
													CornerRadius="4"
													Padding="{TemplateBinding Padding}">
													<ContentPresenter
														HorizontalAlignment="Center"
														VerticalAlignment="Center" />
												</Border>
												<ControlTemplate.Triggers>
													<Trigger
														Property="UIElement.IsMouseOver"
														Value="True">
														<Setter
															TargetName="border"
															Property="Background"
															Value="{DynamicResource PrimaryDarkBrush}" />
													</Trigger>
												</ControlTemplate.Triggers>
											</ControlTemplate>
										</Control.Template>
									</Button>
								</StackPanel>
							</TabItem>
						</TabControl>
						<Button
							Content="保存设置"
							Background="{DynamicResource PrimaryBrush}"
							Foreground="{DynamicResource TextPrimaryBrush}"
							BorderThickness="0"
							Padding="16,10"
							FontSize="14"
							FontFamily="Microsoft YaHei"
							Cursor="Hand"
							Margin="0,30,0,0"
							HorizontalAlignment="Left"
							Click="BtnSaveSettings_Click">
							<Control.Template>
								<ControlTemplate
									TargetType="{x:Type Button}">
									<Border
										Name="border"
										Background="{TemplateBinding Background}"
										CornerRadius="4"
										Padding="{TemplateBinding Padding}">
										<ContentPresenter
											HorizontalAlignment="Center"
											VerticalAlignment="Center" />
									</Border>
									<ControlTemplate.Triggers>
										<Trigger
											Property="UIElement.IsMouseOver"
											Value="True">
											<Setter
												TargetName="border"
												Property="Background"
												Value="{DynamicResource PrimaryDarkBrush}" />
										</Trigger>
									</ControlTemplate.Triggers>
								</ControlTemplate>
							</Control.Template>
						</Button>
					</StackPanel>
				</Border>
			</Grid>
		</Grid>
	</ScrollViewer>
</UserControl>

