<UserControl
	x:Class="MusicalNoteLauncher.Pages.SettingsPage" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	Background="{DynamicResource BackgroundBrush}" xmlns:pages="clr-namespace:MusicalNoteLauncher.Pages">
	<ScrollViewer
		VerticalScrollBarVisibility="Auto">
		<Grid
			Margin="20">
			<Grid.RowDefinitions>
				<RowDefinition
					Height="Auto" />
				<RowDefinition
					Height="*" />
			</Grid.RowDefinitions>
			<TextBlock
				Grid.Row="0"
				Text="设置中心"
				Foreground="{DynamicResource TextPrimaryBrush}"
				FontSize="24"
				FontWeight="SemiBold"
				FontFamily="Microsoft YaHei"
				Margin="0,0,0,20" />
			<Grid
				Row="1">
				<Grid.ColumnDefinitions>
					<ColumnDefinition
						Width="200" />
					<ColumnDefinition
						Width="*" />
				</Grid.ColumnDefinitions>
				<Border
					Grid.Column="0"
					Background="{DynamicResource CardBackgroundBrush}"
					CornerRadius="8"
					Padding="10"
					Margin="0,0,16,0">
					<StackPanel>
						<Button
							Name="btnCategoryGeneral"
							Content="常规设置"
							Background="{DynamicResource PrimaryBrush}"
							Foreground="{DynamicResource TextPrimaryBrush}"
							BorderThickness="0"
							Padding="12,10"
							FontSize="13"
							FontFamily="Microsoft YaHei"
							Cursor="Hand"
							HorizontalContentAlignment="Left"
							Margin="0,4"
							Click="BtnCategory_Click">
							<Control.Template>
								<ControlTemplate
									TargetType="{x:Type Button}">
									<Border
										Name="border"
										Background="{TemplateBinding Background}"
										CornerRadius="4"
										Padding="{TemplateBinding Padding}">
										<ContentPresenter
											HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
											VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
									</Border>
									<ControlTemplate.Triggers>
										<Trigger
											Property="UIElement.IsMouseOver"
											Value="True">
											<Setter
												TargetName="border"
												Property="Background"
												Value="{DynamicResource PrimaryDarkBrush}" />
										</Trigger>
									</ControlTemplate.Triggers>
								</ControlTemplate>
							</Control.Template>
						</Button>
						<Button
							Name="btnCategoryGame"
							Content="游戏设置"
							Background="{DynamicResource SurfaceBrush}"
							Foreground="{DynamicResource TextPrimaryBrush}"
							BorderThickness="0"
							Padding="12,10"
							FontSize="13"
							FontFamily="Microsoft YaHei"
							Cursor="Hand"
							HorizontalContentAlignment="Left"
							Margin="0,4"
							Click="BtnCategory_Click">
							<Control.Template>
								<ControlTemplate
									TargetType="{x:Type Button}">
									<Border
										Name="border"
										Background="{TemplateBinding Background}"
										CornerRadius="4"
										Padding="{TemplateBinding Padding}">
										<ContentPresenter
											HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
											VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
									</Border>
									<ControlTemplate.Triggers>
										<Trigger
											Property="UIElement.IsMouseOver"
											Value="True">
											<Setter
												TargetName="border"
												Property="Background"
												Value="{DynamicResource CardHoverBrush}" />
										</Trigger>
									</ControlTemplate.Triggers>
								</ControlTemplate>
							</Control.Template>
						</Button>
						<Button
							Name="btnCategoryJava"
							Content="Java设置"
							Background="{DynamicResource SurfaceBrush}"
							Foreground="{DynamicResource TextPrimaryBrush}"
							BorderThickness="0"
							Padding="12,10"
							FontSize="13"
							FontFamily="Microsoft YaHei"
							Cursor="Hand"
							HorizontalContentAlignment="Left"
							Margin="0,4"
							Click="BtnCategory_Click">
							<Control.Template>
								<ControlTemplate
									TargetType="{x:Type Button}">
									<Border
										Name="border"
										Background="{TemplateBinding Background}"
										CornerRadius="4"
										Padding="{TemplateBinding Padding}">
										<ContentPresenter
											HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
											VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
									</Border>
									<ControlTemplate.Triggers>
										<Trigger
											Property="UIElement.IsMouseOver"
											Value="True">
											<Setter
												TargetName="border"
												Property="Background"
												Value="{DynamicResource CardHoverBrush}" />
										</Trigger>
									</ControlTemplate.Triggers>
								</ControlTemplate>
							</Control.Template>
						</Button>
						<Button
							Name="btnCategoryDownload"
							Content="下载设置"
							Background="{DynamicResource SurfaceBrush}"
							Foreground="{DynamicResource TextPrimaryBrush}"
							BorderThickness="0"
							Padding="12,10"
							FontSize="13"
							FontFamily="Microsoft YaHei"
							Cursor="Hand"
							HorizontalContentAlignment="Left"
							Margin="0,4"
							Click="BtnCategory_Click">
							<Control.Template>
								<ControlTemplate
									TargetType="{x:Type Button}">
									<Border
										Name="border"
										Background="{TemplateBinding Background}"
										CornerRadius="4"
										Padding="{TemplateBinding Padding}">
										<ContentPresenter
											HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
											VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
									</Border>
									<ControlTemplate.Triggers>
										<Trigger
											Property="UIElement.IsMouseOver"
											Value="True">
											<Setter
												TargetName="border"
												Property="Background"
												Value="{DynamicResource CardHoverBrush}" />
										</Trigger>
									</ControlTemplate.Triggers>
								</ControlTemplate>
							</Control.Template>
						</Button>
						<Button
							Name="btnCategoryAbout"
							Content="关于"
							Background="{DynamicResource SurfaceBrush}"
							Foreground="{DynamicResource TextPrimaryBrush}"
							BorderThickness="0"
							Padding="12,10"
							FontSize="13"
							FontFamily="Microsoft YaHei"
							Cursor="Hand"
							HorizontalContentAlignment="Left"
							Margin="0,4"
							Click="BtnCategory_Click">
							<Control.Template>
								<ControlTemplate
									TargetType="{x:Type Button}">
									<Border
										Name="border"
										Background="{TemplateBinding Background}"
										CornerRadius="4"
										Padding="{TemplateBinding Padding}">
										<ContentPresenter
											HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
											VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
									</Border>
									<ControlTemplate.Triggers>
										<Trigger
											Property="UIElement.IsMouseOver"
											Value="True">
											<Setter
												TargetName="border"
												Property="Background"
												Value="{DynamicResource CardHoverBrush}" />
										</Trigger>
									</ControlTemplate.Triggers>
								</ControlTemplate>
							</Control.Template>
						</Button>
					</StackPanel>
				</Border>
				<Border
					Grid.Column="1"
					Background="{DynamicResource CardBackgroundBrush}"
					CornerRadius="8"
					Padding="20">
					<StackPanel>
						<TabControl
							Name="tabSettings"
							Background="#00FFFFFF"
							BorderThickness="0"
							SelectedIndex="0">
							<Control.Template>
								<ControlTemplate
									TargetType="{x:Type TabControl}">
									<Border
										Background="#00FFFFFF">
										<ContentPresenter
											ContentSource="SelectedContent" />
									</Border>
								</ControlTemplate>
							</Control.Template>
							<TabItem
								Header="常规设置"
								IsSelected="True">
								<StackPanel>
									<TextBlock
										Text="常规设置"
										Foreground="{DynamicResource TextPrimaryBrush}"
										FontSize="18"
										FontWeight="SemiBold"
										FontFamily="Microsoft YaHei"
										Margin="0,0,0,16" />
									<TextBlock
										Text="启动设置"
										Foreground="{DynamicResource TextSecondaryBrush}"
										FontSize="12"
										FontFamily="Microsoft YaHei"
										Margin="0,0,0,8" />
									<CheckBox
										Name="chkAutoLogin"
										Content="启动时自动登录上次账号"
										IsChecked="False"
										Foreground="{DynamicResource TextPrimaryBrush}"
										FontFamily="Microsoft YaHei"
										Margin="0,8,0,0" />
									<CheckBox
										Name="chkMinimizeToTray"
										Content="最小化到系统托盘"
										IsChecked="False"
										Foreground="{DynamicResource TextPrimaryBrush}"
										FontFamily="Microsoft YaHei"
										Margin="0,8,0,0" />
									<CheckBox
										Name="chkCheckUpdate"
										Content="自动检查更新"
										IsChecked="True"
										Foreground="{DynamicResource TextPrimaryBrush}"
										FontFamily="Microsoft YaHei"
										Margin="0,8,0,0" />
									<TextBlock
										Text="界面设置"
										Foreground="{DynamicResource TextSecondaryBrush}"
										FontSize="12"
										FontFamily="Microsoft YaHei"
										Margin="0,24,0,8" />
									<CheckBox
										Name="chkShowSplash"
										Content="显示启动画面"
										IsChecked="True"
										Foreground="{DynamicResource TextPrimaryBrush}"
										FontFamily="Microsoft YaHei"
										Margin="0,8,0,0" />
									<CheckBox
									Name="chkHardwareAcceleration"
									Content="启用硬件加速"
									IsChecked="True"
									Foreground="{DynamicResource TextPrimaryBrush}"
									FontFamily="Microsoft YaHei"
									Margin="0,8,0,0" />
								<TextBlock
									Text="配色主题"
									Foreground="{DynamicResource TextSecondaryBrush}"
									FontSize="12"
									FontFamily="Microsoft YaHei"
									Margin="0,24,0,8" />
								<Grid>
									<Grid.ColumnDefinitions>
										<ColumnDefinition Width="*" />
										<ColumnDefinition Width="Auto" />
									</Grid.ColumnDefinitions>
									<ComboBox
										Name="cbThemeColor"
										Grid.Column="0"
										Background="{DynamicResource SurfaceBrush}"
										Foreground="{DynamicResource TextPrimaryBrush}"
										BorderBrush="{DynamicResource BorderBrush}"
										BorderThickness="1"
										Padding="10,6"
										FontSize="13"
										FontFamily="Microsoft YaHei"
										Cursor="Hand"
										SelectionChanged="CbThemeColor_SelectionChanged">
										<ComboBox.ItemTemplate>
											<DataTemplate>
												<TextBlock Text="{Binding Name}"
													Foreground="{DynamicResource TextPrimaryBrush}"
													FontSize="13"
													FontFamily="Microsoft YaHei"
													VerticalAlignment="Center" />
											</DataTemplate>
										</ComboBox.ItemTemplate>
										<Control.Template>
											<ControlTemplate TargetType="{x:Type ComboBox}">
												<Grid>
													<Border Background="{TemplateBinding Background}"
															BorderBrush="{TemplateBinding BorderBrush}"
															BorderThickness="{TemplateBinding BorderThickness}"
															CornerRadius="4">
														<Grid>
															<Grid.ColumnDefinitions>
																<ColumnDefinition Width="*" />
																<ColumnDefinition Width="Auto" />
															</Grid.ColumnDefinitions>
															<ContentPresenter Grid.Column="0"
																Content="{TemplateBinding SelectedItem}"
																ContentTemplate="{TemplateBinding ItemTemplate}"
																Margin="{TemplateBinding Padding}"
																VerticalAlignment="Center" />
															<ToggleButton Grid.Column="1"
																Background="{DynamicResource SurfaceBrush}" BorderThickness="0" Padding="8"
																IsChecked="{Binding Path=IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}">
																<Path Data="M0,0 L8,0 L4,4" Fill="#FFFFFF"
																	Width="8" Height="8" Stretch="Fill" />
															</ToggleButton>
														</Grid>
													</Border>
													<Popup IsOpen="{TemplateBinding IsDropDownOpen}"
														Placement="Bottom" AllowsTransparency="True">
														<Border Background="{DynamicResource CardBackgroundBrush}"
															BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="4"
															MinWidth="{TemplateBinding ActualWidth}">
															<ScrollViewer MaxHeight="200">
																<ItemsPresenter />
															</ScrollViewer>
														</Border>
													</Popup>
												</Grid>
											</ControlTemplate>
										</Control.Template>
									</ComboBox>
									<StackPanel Grid.Column="1" Orientation="Horizontal" Margin="12,0,0,0" VerticalAlignment="Center">
										<Border Name="previewPrimaryColor"
											Width="28" Height="28" CornerRadius="4"
											Background="{DynamicResource PrimaryBrush}"
											Margin="0,0,8,0" />
										<Border Name="previewSecondaryColor"
											Width="28" Height="28" CornerRadius="4"
											Background="{DynamicResource PrimaryDarkBrush}" />
									</StackPanel>
								</Grid>
								<TextBlock
									Text="游戏目录"
									Foreground="{DynamicResource TextSecondaryBrush}"
									FontSize="12"
									FontFamily="Microsoft YaHei"
									Margin="0,24,0,8" />
									<Grid>
										<Grid.ColumnDefinitions>
											<ColumnDefinition
												Width="*" />
											<ColumnDefinition
												Width="Auto" />
										</Grid.ColumnDefinitions>
										<TextBox
											Name="txtGamePath"
											Grid.Column="0"
											Text="%appdata%\.minecraft"
											Background="{DynamicResource SurfaceBrush}"
											Foreground="{DynamicResource TextPrimaryBrush}"
											BorderBrush="{DynamicResource BorderBrush}"
											BorderThickness="1"
											Padding="10,8"
											FontSize="13"
											FontFamily="Microsoft YaHei"
											IsReadOnly="True" />
										<Button
											Grid.Column="1"
											Content="浏览"
											Background="{DynamicResource SurfaceBrush}"
											Foreground="{DynamicResource TextPrimaryBrush}"
											BorderThickness="1"
											BorderBrush="{DynamicResource BorderBrush}"
											Padding="12,8"
											FontSize="13"
											FontFamily="Microsoft YaHei"
											Cursor="Hand"
											Margin="8,0,0,0"
											Click="BtnBrowseGamePath_Click">
											<Control.Template>
												<ControlTemplate
													TargetType="{x:Type Button}">
													<Border
														Name="border"
														Background="{TemplateBinding Background}"
														BorderBrush="{TemplateBinding BorderBrush}"
														BorderThickness="{TemplateBinding BorderThickness}"
														CornerRadius="4"
														Padding="{TemplateBinding Padding}">
														<ContentPresenter
															HorizontalAlignment="Center"
															VerticalAlignment="Center" />
													</Border>
													<ControlTemplate.Triggers>
														<Trigger
															Property="UIElement.IsMouseOver"
															Value="True">
															<Setter
																TargetName="border"
																Property="Background"
																Value="{DynamicResource CardHoverBrush}" />
														</Trigger>
													</ControlTemplate.Triggers>
												</ControlTemplate>
											</Control.Template>
										</Button>
									</Grid>
								</StackPanel>
							</TabItem>
							<TabItem
								Header="游戏设置">
								<StackPanel>
									<TextBlock
										Text="游戏设置"
										Foreground="{DynamicResource TextPrimaryBrush}"
										FontSize="18"
										FontWeight="SemiBold"
										FontFamily="Microsoft YaHei"
										Margin="0,0,0,16" />
									<TextBlock
										Text="内存设置 (MB)"
										Foreground="{DynamicResource TextSecondaryBrush}"
										FontSize="12"
										FontFamily="Microsoft YaHei"
										Margin="0,0,0,8" />
									<Grid>
										<Grid.ColumnDefinitions>
											<ColumnDefinition
												Width="*" />
											<ColumnDefinition
												Width="*" />
										</Grid.ColumnDefinitions>
										<StackPanel
											Grid.Column="0"
											Margin="0,0,16,0">
											<TextBlock
												Text="最小内存"
												Foreground="{DynamicResource TextPrimaryBrush}"
												FontSize="12"
												FontFamily="Microsoft YaHei"
												Margin="0,0,0,4" />
											<TextBox
												Name="txtMinMemory"
												Text="2048"
												Background="{DynamicResource SurfaceBrush}"
												Foreground="{DynamicResource TextPrimaryBrush}"
												BorderBrush="{DynamicResource BorderBrush}"
												BorderThickness="1"
												Padding="10,8"
												FontSize="13"
												FontFamily="Microsoft YaHei" />
										</StackPanel>
										<StackPanel
											Grid.Column="1">
											<TextBlock
												Text="最大内存"
												Foreground="{DynamicResource TextPrimaryBrush}"
												FontSize="12"
												FontFamily="Microsoft YaHei"
												Margin="0,0,0,4" />
											<TextBox
												Name="txtMaxMemory"
												Text="4096"
												Background="{DynamicResource SurfaceBrush}"
												Foreground="{DynamicResource TextPrimaryBrush}"
												BorderBrush="{DynamicResource BorderBrush}"
												BorderThickness="1"
												Padding="10,8"
												FontSize="13"
												FontFamily="Microsoft YaHei" />
										</StackPanel>
									</Grid>
									<TextBlock
										Text="分辨率设置"
										Foreground="{DynamicResource TextSecondaryBrush}"
										FontSize="12"
										FontFamily="Microsoft YaHei"
										Margin="0,24,0,8" />
									<Grid>
										<Grid.ColumnDefinitions>
											<ColumnDefinition
												Width="*" />
											<ColumnDefinition
												Width="Auto" />
										</Grid.ColumnDefinitions>
										<ComboBox
											Name="cbResolution"
											Background="{DynamicResource SurfaceBrush}"
											Foreground="{DynamicResource TextPrimaryBrush}"
											BorderBrush="{DynamicResource BorderBrush}"
											BorderThickness="1"
											Padding="10,6"
											FontSize="13"
											FontFamily="Microsoft YaHei"
											Grid.Column="0">
											<Control.Template>
												<ControlTemplate
													TargetType="{x:Type ComboBox}">
													<Grid>
														<Border
															Background="{TemplateBinding Background}"
															BorderBrush="{TemplateBinding BorderBrush}"
															BorderThickness="{TemplateBinding BorderThickness}"
															CornerRadius="4">
															<Grid>
																<Grid.ColumnDefinitions>
																	<ColumnDefinition
																		Width="*" />
																	<ColumnDefinition
																		Width="Auto" />
																</Grid.ColumnDefinitions>
																<ContentPresenter
																	Grid.Column="0"
																	Content="{TemplateBinding SelectionBoxItem}"
																	ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
																	Margin="{TemplateBinding Padding}"
																	VerticalAlignment="Center" />
																<ToggleButton
																	Grid.Column="1"
																	Background="{DynamicResource SurfaceBrush}"
																	BorderThickness="0"
																	Padding="8"
																	IsChecked="{Binding Path=IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}">
																	<Path
																		Data="M0,0 L8,0 L4,4"
																		Fill="#FFFFFF"
																		Width="8"
																		Height="8"
																		Stretch="Fill" />
																</ToggleButton>
															</Grid>
														</Border>
														<Popup
															IsOpen="{TemplateBinding IsDropDownOpen}"
															Placement="Bottom"
															AllowsTransparency="True">
															<Border
																Background="{DynamicResource CardBackgroundBrush}"
																BorderBrush="{DynamicResource BorderBrush}"
																BorderThickness="1"
																CornerRadius="4"
																MinWidth="{TemplateBinding ActualWidth}">
																<ScrollViewer
																	MaxHeight="200">
																	<ItemsPresenter />
																</ScrollViewer>
															</Border>
														</Popup>
													</Grid>
												</ControlTemplate>
											</Control.Template>
											<ComboBoxItem
												Content="800×600"
												Foreground="{DynamicResource TextPrimaryBrush}"
												Background="{DynamicResource CardBackgroundBrush}" />
											<ComboBoxItem
												Content="1024×768"
												Foreground="{DynamicResource TextPrimaryBrush}"
												Background="{DynamicResource CardBackgroundBrush}" />
											<ComboBoxItem
												Content="1280×720"
												Foreground="{DynamicResource TextPrimaryBrush}"
												Background="{DynamicResource CardBackgroundBrush}" />
											<ComboBoxItem
												Content="1280×1024"
												IsSelected="True"
												Foreground="{DynamicResource TextPrimaryBrush}"
												Background="{DynamicResource CardBackgroundBrush}" />
											<ComboBoxItem
												Content="1920×1080"
												Foreground="{DynamicResource TextPrimaryBrush}"
												Background="{DynamicResource CardBackgroundBrush}" />
										</ComboBox>
										<CheckBox
											Name="chkFullscreen"
											Content="全屏模式"
											IsChecked="False"
											Foreground="{DynamicResource TextPrimaryBrush}"
											FontFamily="Microsoft YaHei"
											Grid.Column="1"
											Margin="16,0,0,0"
											VerticalAlignment="Center" />
									</Grid>
								</StackPanel>
							</TabItem>
							<TabItem
								Header="Java设置">
								<StackPanel>
									<TextBlock
										Text="Java设置"
										Foreground="{DynamicResource TextPrimaryBrush}"
										FontSize="18"
										FontWeight="SemiBold"
										FontFamily="Microsoft YaHei"
										Margin="0,0,0,16" />
									<Border
										Background="{DynamicResource SurfaceBrush}"
										CornerRadius="8"
										Padding="16"
										Margin="0,0,0,16">
										<StackPanel>
											<TextBlock
												Text="自动检测 Java 环境"
												Foreground="{DynamicResource TextPrimaryBrush}"
												FontSize="14"
												FontWeight="SemiBold"
												FontFamily="Microsoft YaHei"
												Margin="0,0,0,12" />
											<Button
												Name="btnDetectJava"
												Content="🔍 检测系统 Java"
												Background="{DynamicResource SurfaceBrush}"
												Foreground="{DynamicResource TextPrimaryBrush}"
												BorderThickness="1"
												BorderBrush="{DynamicResource BorderBrush}"
												Padding="12,8"
												FontSize="13"
												FontFamily="Microsoft YaHei"
												Cursor="Hand"
												Margin="0,0,0,12"
												Click="BtnDetectJava_Click">
												<Control.Template>
													<ControlTemplate
														TargetType="{x:Type Button}">
														<Border
															Name="border"
															Background="{TemplateBinding Background}"
															BorderBrush="{TemplateBinding BorderBrush}"
															BorderThickness="{TemplateBinding BorderThickness}"
															CornerRadius="4"
															Padding="{TemplateBinding Padding}">
															<ContentPresenter
																HorizontalAlignment="Center"
																VerticalAlignment="Center" />
														</Border>
														<ControlTemplate.Triggers>
															<Trigger
																Property="UIElement.IsMouseOver"
																Value="True">
																<Setter
																	TargetName="border"
																	Property="Background"
																	Value="{DynamicResource CardHoverBrush}" />
															</Trigger>
														</ControlTemplate.Triggers>
													</ControlTemplate>
												</Control.Template>
											</Button>
											<ItemsControl
											Name="javaList"
											Margin="0,0,0,12">
											<ItemsControl.ItemTemplate>
												<DataTemplate>
													<Border
														Background="{DynamicResource CardBackgroundBrush}"
														CornerRadius="6"
														Padding="10"
														Margin="0,0,0,6">
														<Grid>
															<Grid.ColumnDefinitions>
																<ColumnDefinition Width="*" />
																<ColumnDefinition Width="Auto" />
															</Grid.ColumnDefinitions>
															<StackPanel Grid.Column="0">
																<TextBlock
																	FontSize="12"
																	Foreground="{DynamicResource TextPrimaryBrush}"
																	Text="{Binding Path}" />
																<TextBlock
																	FontSize="11"
																	Foreground="{DynamicResource TextSecondaryBrush}"
																	Margin="0,2,0,0">
																	<Run Text="版本: Java " />
																	<Run Text="{Binding MajorVersion}" />
																	<Run Text=" | 最大内存: " />
																	<Run Text="{Binding MaxMemoryMb}" />
																	<Run Text=" MB" />
																</TextBlock>
															</StackPanel>
															<Button
																Grid.Column="1"
																Content="使用此版本"
																Background="#4CAF50"
																Foreground="{DynamicResource TextPrimaryBrush}"
