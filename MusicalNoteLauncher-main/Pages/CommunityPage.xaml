<UserControl
	x:Class="MusicalNoteLauncher.Pages.CommunityPage"
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:pages="clr-namespace:MusicalNoteLauncher.Pages"
	Background="#121212">
	<UserControl.Resources>
		<Storyboard x:Key="FadeInAnimation">
			<DoubleAnimation
				Storyboard.TargetProperty="Opacity"
				From="0"
				To="1"
				Duration="0:0:0.3" />
		</Storyboard>
		<Style x:Key="PostCardStyle" TargetType="Border">
			<Setter Property="Background" Value="#1E1E1E" />
			<Setter Property="CornerRadius" Value="12" />
			<Setter Property="Padding" Value="20" />
			<Setter Property="Margin" Value="0,0,0,16" />
			<Style.Triggers>
				<Trigger Property="IsMouseOver" Value="True">
					<Setter Property="Background" Value="#252525" />
				</Trigger>
			</Style.Triggers>
		</Style>
		<Style x:Key="PrimaryButtonStyle" TargetType="Button">
			<Setter Property="Background" Value="#6C5CE7" />
			<Setter Property="Foreground" Value="White" />
			<Setter Property="BorderThickness" Value="0" />
			<Setter Property="Padding" Value="20,10" />
			<Setter Property="FontSize" Value="14" />
			<Setter Property="FontFamily" Value="Microsoft YaHei" />
			<Setter Property="Cursor" Value="Hand" />
			<Setter Property="MinWidth" Value="100" />
			<Setter Property="Template">
				<Setter.Value>
					<ControlTemplate TargetType="{x:Type Button}">
						<Border
							Name="border"
							Background="{TemplateBinding Background}"
							CornerRadius="8"
							Padding="{TemplateBinding Padding}">
							<ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
						</Border>
						<ControlTemplate.Triggers>
							<Trigger Property="IsMouseOver" Value="True">
								<Setter TargetName="border" Property="Background" Value="#5B4CDB" />
								<Setter TargetName="border" Property="Effect">
									<Setter.Value>
										<DropShadowEffect Color="#6C5CE7" Opacity="0.5" BlurRadius="10" />
									</Setter.Value>
								</Setter>
							</Trigger>
							<Trigger Property="IsPressed" Value="True">
								<Setter TargetName="border" Property="Background" Value="#4A3FBA" />
							</Trigger>
						</ControlTemplate.Triggers>
					</ControlTemplate>
				</Setter.Value>
			</Setter>
		</Style>
		<Style x:Key="SecondaryButtonStyle" TargetType="Button">
			<Setter Property="Background" Value="#2D2D2D" />
			<Setter Property="Foreground" Value="#FFFFFF" />
			<Setter Property="BorderThickness" Value="1" />
			<Setter Property="BorderBrush" Value="#3A3A3A" />
			<Setter Property="Padding" Value="14,6" />
			<Setter Property="FontSize" Value="12" />
			<Setter Property="FontFamily" Value="Microsoft YaHei" />
			<Setter Property="Cursor" Value="Hand" />
			<Setter Property="Template">
				<Setter.Value>
					<ControlTemplate TargetType="{x:Type Button}">
						<Border
							Name="border"
							Background="{TemplateBinding Background}"
							BorderBrush="{TemplateBinding BorderBrush}"
							BorderThickness="{TemplateBinding BorderThickness}"
							CornerRadius="6"
							Padding="{TemplateBinding Padding}">
							<ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
						</Border>
						<ControlTemplate.Triggers>
							<Trigger Property="UIElement.IsMouseOver" Value="True">
								<Setter TargetName="border" Property="Background" Value="#383838" />
								<Setter TargetName="border" Property="BorderBrush" Value="#4A4A4A" />
							</Trigger>
						</ControlTemplate.Triggers>
					</ControlTemplate>
				</Setter.Value>
			</Setter>
		</Style>
		<Style x:Key="TextBoxStyle" TargetType="TextBox">
			<Setter Property="Background" Value="#1E1E1E" />
			<Setter Property="Foreground" Value="#FFFFFF" />
			<Setter Property="BorderBrush" Value="#2D2D2D" />
			<Setter Property="BorderThickness" Value="1" />
			<Setter Property="Padding" Value="15" />
			<Setter Property="FontSize" Value="14" />
			<Setter Property="FontFamily" Value="Microsoft YaHei" />
			<Setter Property="TextWrapping" Value="Wrap" />
			<Setter Property="AcceptsReturn" Value="True" />
			<Setter Property="Template">
				<Setter.Value>
					<ControlTemplate TargetType="{x:Type TextBox}">
						<Border
							Name="border"
							Background="{TemplateBinding Background}"
							BorderBrush="{TemplateBinding BorderBrush}"
							BorderThickness="{TemplateBinding BorderThickness}"
							CornerRadius="10">
							<ScrollViewer x:Name="PART_ContentHost" Margin="2" />
						</Border>
						<ControlTemplate.Triggers>
							<Trigger Property="IsFocused" Value="True">
								<Setter TargetName="border" Property="BorderBrush" Value="#6C5CE7" />
								<Setter TargetName="border" Property="Effect">
									<Setter.Value>
										<DropShadowEffect Color="#6C5CE7" Opacity="0.3" BlurRadius="8" />
									</Setter.Value>
								</Setter>
							</Trigger>
						</ControlTemplate.Triggers>
					</ControlTemplate>
				</Setter.Value>
			</Setter>
		</Style>
	</UserControl.Resources>
	<ScrollViewer VerticalScrollBarVisibility="Auto" Background="#121212">
		<Grid Margin="30,20">
			<Grid.RowDefinitions>
				<RowDefinition Height="Auto" />
				<RowDefinition Height="Auto" />
				<RowDefinition Height="Auto" />
				<RowDefinition Height="Auto" />
			</Grid.RowDefinitions>
			<!-- 页面标题 -->
			<StackPanel Grid.Row="0" Margin="0,0,0,24">
				<TextBlock
					Text="🎮 交流社区"
					Foreground="#FFFFFF"
					FontSize="28"
					FontWeight="Bold"
					FontFamily="Microsoft YaHei" />
				<TextBlock
					Text="与其他玩家分享你的游戏心得"
					Foreground="#888888"
					FontSize="14"
					FontFamily="Microsoft YaHei"
					Margin="0,4,0,0" />
			</StackPanel>
			<!-- 发布帖子区域 -->
			<Border
				Grid.Row="1"
				Background="#1E1E1E"
				CornerRadius="16"
				Padding="24"
				Margin="0,0,0,24">
				<StackPanel>
					<StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,0,16">
						<Border Width="48" Height="48" Background="#6C5CE7" CornerRadius="24">
							<TextBlock Text="👤" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center" />
						</Border>
						<StackPanel Margin="12,0,0,0">
							<TextBlock
								Text="发布新帖子"
								Foreground="#FFFFFF"
								FontSize="16"
								FontWeight="SemiBold"
								FontFamily="Microsoft YaHei" />
							<TextBlock
								Text="分享你的想法和游戏体验"
								Foreground="#888888"
								FontSize="12"
								FontFamily="Microsoft YaHei" />
						</StackPanel>
					</StackPanel>
					<TextBox
						Name="txtPostContent"
						Style="{StaticResource TextBoxStyle}"
						Height="100" />
					<StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
						<Button
							Content="📷 添加图片"
							Style="{StaticResource SecondaryButtonStyle}"
							Margin="0,0,12,0" />
						<Button
							Content="发布帖子"
							Style="{StaticResource PrimaryButtonStyle}"
							Click="BtnPost_Click" />
					</StackPanel>
				</StackPanel>
			</Border>
			<!-- 帖子统计 -->
			<Grid Grid.Row="2" Margin="0,0,0,20">
				<Grid.ColumnDefinitions>
					<ColumnDefinition Width="Auto" />
					<ColumnDefinition Width="Auto" />
					<ColumnDefinition Width="Auto" />
				</Grid.ColumnDefinitions>
				<Border Grid.Column="0" Background="#252525" CornerRadius="8" Padding="12,8" Margin="0,0,12,0">
					<StackPanel Orientation="Horizontal">
						<TextBlock Text="🔥" FontSize="16" Margin="0,0,8,0" />
						<StackPanel>
							<TextBlock Text="热门帖子" Foreground="#FFFFFF" FontSize="11" FontFamily="Microsoft YaHei" />
							<TextBlock Text="248" Foreground="#FF6B6B" FontSize="18" FontWeight="Bold" FontFamily="Microsoft YaHei" />
						</StackPanel>
					</StackPanel>
				</Border>
				<Border Grid.Column="1" Background="#252525" CornerRadius="8" Padding="12,8" Margin="0,0,12,0">
					<StackPanel Orientation="Horizontal">
						<TextBlock Text="💬" FontSize="16" Margin="0,0,8,0" />
						<StackPanel>
							<TextBlock Text="今日回复" Foreground="#FFFFFF" FontSize="11" FontFamily="Microsoft YaHei" />
							<TextBlock Text="3.2K" Foreground="#4ECDC4" FontSize="18" FontWeight="Bold" FontFamily="Microsoft YaHei" />
						</StackPanel>
					</StackPanel>
				</Border>
				<Border Grid.Column="2" Background="#252525" CornerRadius="8" Padding="12,8">
					<StackPanel Orientation="Horizontal">
						<TextBlock Text="👥" FontSize="16" Margin="0,0,8,0" />
						<StackPanel>
							<TextBlock Text="活跃用户" Foreground="#FFFFFF" FontSize="11" FontFamily="Microsoft YaHei" />
							<TextBlock Text="1.5K" Foreground="#FFE66D" FontSize="18" FontWeight="Bold" FontFamily="Microsoft YaHei" />
						</StackPanel>
					</StackPanel>
				</Border>
			</Grid>
			<!-- 热门帖子列表 -->
			<Border Grid.Row="3" Background="#1E1E1E" CornerRadius="16" Padding="20">
				<Grid>
					<Grid.RowDefinitions>
						<RowDefinition Height="Auto" />
						<RowDefinition Height="*" />
					</Grid.RowDefinitions>
					<StackPanel Grid.Row="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,0,20">
						<TextBlock
							Text="🔥 热门帖子"
							Foreground="#FFFFFF"
							FontSize="18"
							FontWeight="Bold"
							FontFamily="Microsoft YaHei" />
						<StackPanel Orientation="Horizontal" Margin="12,0,0,0">
							<Button Content="最新" Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,8,0" />
							<Button Content="热门" Background="#6C5CE7" Foreground="White" Padding="10,4" FontSize="11">
								<Button.Template>
									<ControlTemplate TargetType="Button">
										<Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
											<ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
										</Border>
									</ControlTemplate>
								</Button.Template>
							</Button>
						</StackPanel>
					</StackPanel>
					<ListBox
						Name="lstPosts"
						Grid.Row="1"
						Background="Transparent"
						BorderThickness="0"
						Foreground="#FFFFFF"
						FontFamily="Microsoft YaHei"
						ScrollViewer.HorizontalScrollBarVisibility="Disabled"
						ScrollViewer.VerticalScrollBarVisibility="Disabled">
						<ListBox.ItemTemplate>
							<DataTemplate>
								<Border Style="{StaticResource PostCardStyle}">
									<StackPanel>
										<Grid Margin="0,0,0,12">
											<Grid.ColumnDefinitions>
												<ColumnDefinition Width="Auto" />
												<ColumnDefinition Width="*" />
												<ColumnDefinition Width="Auto" />
											</Grid.ColumnDefinitions>
											<Border
												Grid.Column="0"
												Width="44"
												Height="44"
												Background="{Binding AvatarColor}"
												CornerRadius="22"
												Margin="0,0,14,0">
												<TextBlock
													Text="{Binding AvatarEmoji}"
													FontSize="20"
													HorizontalAlignment="Center"
													VerticalAlignment="Center" />
											</Border>
											<StackPanel Grid.Column="1" VerticalAlignment="Center">
												<TextBlock
													Foreground="#FFFFFF"
													FontSize="15"
													FontWeight="SemiBold"
													Text="{Binding Author}" />
												<TextBlock
													Foreground="#888888"
													FontSize="12"
													Text="{Binding Time}" />
											</StackPanel>
											<Button
												Grid.Column="2"
												Content="💬 回复"
												Style="{StaticResource SecondaryButtonStyle}"
												Click="BtnReply_Click"
												Tag="{Binding Id}" />
										</Grid>
										<TextBlock
											Foreground="#FFFFFF"
											FontSize="14"
											TextWrapping="Wrap"
											Margin="0,0,0,12"
											Text="{Binding Content}" />
										<StackPanel Orientation="Horizontal" VerticalAlignment="Center">
											<Button
												Content="👍 {Binding LikeCount}"
												Style="{StaticResource SecondaryButtonStyle}"
												Padding="10,4"
												FontSize="12"
												Click="BtnLike_Click"
												Tag="{Binding Id}" />
											<TextBlock
												Text="| 评论 {Binding CommentCount}"
												Foreground="#888888"
												FontSize="12"
												FontFamily="Microsoft YaHei"
												Margin="8,0,0,0" />
											<TextBlock
												Text="| 浏览 {Binding ViewCount}"
												Foreground="#888888"
												FontSize="12"
												FontFamily="Microsoft YaHei"
												Margin="8,0,0,0" />
										</StackPanel>
									</StackPanel>
								</Border>
							</DataTemplate>
						</ListBox.ItemTemplate>
					</ListBox>
				</Grid>
			</Border>
		</Grid>
	</ScrollViewer>
</UserControl>

