<UserControl
	x:Class="MusicalNoteLauncher.Pages.FriendsListPage" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	Background="#1E1E1E" xmlns:pages="clr-namespace:MusicalNoteLauncher.Pages">
	<ScrollViewer
		VerticalScrollBarVisibility="Auto">
		<Grid
			Margin="20">
			<Grid.RowDefinitions>
				<RowDefinition
					Height="Auto" />
				<RowDefinition
					Height="*" />
			</Grid.RowDefinitions>
			<Grid
				Row="0"
				Margin="0,0,0,20">
				<TextBlock
					Text="好友列表"
					Foreground="#FFFFFF"
					FontSize="24"
					FontWeight="SemiBold"
					FontFamily="Microsoft YaHei"
					VerticalAlignment="Center" />
				<Button
					Content="添加好友"
					Background="#2196F3"
					Foreground="#FFFFFF"
					BorderThickness="0"
					Padding="16,8"
					FontSize="13"
					FontFamily="Microsoft YaHei"
					Cursor="Hand"
					HorizontalAlignment="Right"
					Click="BtnAddFriend_Click">
					<Control.Template>
						<ControlTemplate
							TargetType="{x:Type Button}">
							<Border
								Name="border"
								Background="{TemplateBinding Background}"
								CornerRadius="4"
								Padding="{TemplateBinding Padding}">
								<ContentPresenter
									HorizontalAlignment="Center"
									VerticalAlignment="Center" />
							</Border>
							<ControlTemplate.Triggers>
								<Trigger
									Property="UIElement.IsMouseOver"
									Value="True">
									<Setter
										TargetName="border"
										Property="Background"
										Value="#1976D2" />
								</Trigger>
							</ControlTemplate.Triggers>
						</ControlTemplate>
					</Control.Template>
				</Button>
			</Grid>
			<Grid
				Row="1">
				<Grid.ColumnDefinitions>
					<ColumnDefinition
						Width="*" />
					<ColumnDefinition
						Width="350" />
				</Grid.ColumnDefinitions>
				<Border
					Grid.Column="0"
					Background="#252525"
					CornerRadius="8"
					Padding="15"
					Margin="0,0,16,0">
					<Grid>
						<Grid.RowDefinitions>
							<RowDefinition
								Height="Auto" />
							<RowDefinition
								Height="*" />
						</Grid.RowDefinitions>
						<StackPanel
							Grid.Row="0"
							Orientation="Horizontal"
							Margin="0,0,0,15">
							<Button
								Name="btnFilterAll"
								Content="全部"
								Background="#2196F3"
								Foreground="#FFFFFF"
								BorderThickness="0"
								Padding="12,6"
								FontSize="12"
								FontFamily="Microsoft YaHei"
								Cursor="Hand"
								Margin="0,0,8,0"
								Click="BtnFilter_Click">
								<Control.Template>
									<ControlTemplate
										TargetType="{x:Type Button}">
										<Border
											Name="border"
											Background="{TemplateBinding Background}"
											CornerRadius="4"
											Padding="{TemplateBinding Padding}">
											<ContentPresenter
												HorizontalAlignment="Center"
												VerticalAlignment="Center" />
										</Border>
										<ControlTemplate.Triggers>
											<Trigger
												Property="UIElement.IsMouseOver"
												Value="True">
												<Setter
													TargetName="border"
													Property="Background"
													Value="#1976D2" />
											</Trigger>
										</ControlTemplate.Triggers>
									</ControlTemplate>
								</Control.Template>
							</Button>
							<Button
								Name="btnFilterOnline"
								Content="在线"
								Background="#383838"
								Foreground="#FFFFFF"
								BorderThickness="0"
								Padding="12,6"
								FontSize="12"
								FontFamily="Microsoft YaHei"
								Cursor="Hand"
								Margin="0,0,8,0"
								Click="BtnFilter_Click">
								<Control.Template>
									<ControlTemplate
										TargetType="{x:Type Button}">
										<Border
											Name="border"
											Background="{TemplateBinding Background}"
											CornerRadius="4"
											Padding="{TemplateBinding Padding}">
											<ContentPresenter
												HorizontalAlignment="Center"
												VerticalAlignment="Center" />
										</Border>
										<ControlTemplate.Triggers>
											<Trigger
												Property="UIElement.IsMouseOver"
												Value="True">
												<Setter
													TargetName="border"
													Property="Background"
													Value="#2D2D2D" />
											</Trigger>
										</ControlTemplate.Triggers>
									</ControlTemplate>
								</Control.Template>
							</Button>
							<Button
								Name="btnFilterOffline"
								Content="离线"
								Background="#383838"
								Foreground="#FFFFFF"
								BorderThickness="0"
								Padding="12,6"
								FontSize="12"
								FontFamily="Microsoft YaHei"
								Cursor="Hand"
								Click="BtnFilter_Click">
								<Control.Template>
									<ControlTemplate
										TargetType="{x:Type Button}">
										<Border
											Name="border"
											Background="{TemplateBinding Background}"
											CornerRadius="4"
											Padding="{TemplateBinding Padding}">
											<ContentPresenter
												HorizontalAlignment="Center"
												VerticalAlignment="Center" />
										</Border>
										<ControlTemplate.Triggers>
											<Trigger
												Property="UIElement.IsMouseOver"
												Value="True">
												<Setter
													TargetName="border"
													Property="Background"
													Value="#2D2D2D" />
											</Trigger>
										</ControlTemplate.Triggers>
									</ControlTemplate>
								</Control.Template>
							</Button>
						</StackPanel>
						<ListBox
							Name="lstFriends"
							Grid.Row="1"
							Background="#1E1E1E"
							BorderThickness="0"
							Foreground="#FFFFFF"
							FontFamily="Microsoft YaHei">
							<ItemsControl.ItemTemplate>
								<DataTemplate>
									<Border
										Background="#2D2D2D"
										CornerRadius="4"
										Padding="12,10"
										Margin="0,4">
										<Grid>
											<Grid.ColumnDefinitions>
												<ColumnDefinition
													Width="Auto" />
												<ColumnDefinition
													Width="*" />
												<ColumnDefinition
													Width="Auto" />
											</Grid.ColumnDefinitions>
											<Border
												Grid.Column="0"
												Width="44"
												Height="44"
												CornerRadius="22"
												Margin="0,0,12,0"
												Background="{Binding AvatarColor}">
												<TextBlock
													FontSize="20"
													HorizontalAlignment="Center"
													VerticalAlignment="Center"
													Text="{Binding AvatarEmoji}" />
											</Border>
											<StackPanel
												Grid.Column="1"
												VerticalAlignment="Center">
												<TextBlock
													Foreground="#FFFFFF"
													FontSize="14"
													Text="{Binding FriendName}" />
												<TextBlock
													FontSize="12"
													Text="{Binding StatusText}"
													Foreground="{Binding StatusColor}" />
											</StackPanel>
											<StackPanel
												Grid.Column="2"
												Orientation="Horizontal"
												VerticalAlignment="Center">
												<!--未知连接 ID：6-->
												<Button
													Content="邀请"
													Background="#2196F3"
													Foreground="#FFFFFF"
													BorderThickness="0"
													Padding="10,4"
													FontSize="11"
													FontFamily="Microsoft YaHei"
													Cursor="Hand"
													Margin="0,0,6,0">
													<Control.Template>
														<ControlTemplate
															TargetType="{x:Type Button}">
															<Border
																Name="border"
																Background="{TemplateBinding Background}"
																CornerRadius="4"
																Padding="{TemplateBinding Padding}">
																<ContentPresenter
																	HorizontalAlignment="Center"
																	VerticalAlignment="Center" />
															</Border>
															<ControlTemplate.Triggers>
																<Trigger
																	Property="UIElement.IsMouseOver"
																	Value="True">
																	<Setter
																		TargetName="border"
																		Property="Background"
																		Value="#1976D2" />
																</Trigger>
															</ControlTemplate.Triggers>
														</ControlTemplate>
													</Control.Template>
												</Button>
												<!--未知连接 ID：7-->
												<Button
													Content="聊天"
													Background="#383838"
													Foreground="#FFFFFF"
													BorderThickness="1"
													BorderBrush="#3A3A3A"
													Padding="10,4"
													FontSize="11"
													FontFamily="Microsoft YaHei"
													Cursor="Hand">
													<Control.Template>
														<ControlTemplate
															TargetType="{x:Type Button}">
															<Border
																Name="border"
																Background="{TemplateBinding Background}"
																BorderBrush="{TemplateBinding BorderBrush}"
																BorderThickness="{TemplateBinding BorderThickness}"
																CornerRadius="4"
																Padding="{TemplateBinding Padding}">
																<ContentPresenter
																	HorizontalAlignment="Center"
																	VerticalAlignment="Center" />
															</Border>
															<ControlTemplate.Triggers>
																<Trigger
																	Property="UIElement.IsMouseOver"
																	Value="True">
																	<Setter
																		TargetName="border"
																		Property="Background"
																		Value="#2D2D2D" />
																</Trigger>
															</ControlTemplate.Triggers>
														</ControlTemplate>
													</Control.Template>
												</Button>
											</StackPanel>
										</Grid>
									</Border>
								</DataTemplate>
							</ItemsControl.ItemTemplate>
						</ListBox>
					</Grid>
				</Border>
				<Border
					Grid.Column="1"
					Background="#252525"
					CornerRadius="8"
					Padding="15">
					<Grid>
						<Grid.RowDefinitions>
							<RowDefinition
								Height="Auto" />
							<RowDefinition
								Height="*" />
							<RowDefinition
								Height="Auto" />
						</Grid.RowDefinitions>
						<StackPanel
							Grid.Row="0"
							Margin="0,0,0,15">
							<TextBlock
								Text="聊天"
								Foreground="#FFFFFF"
								FontSize="16"
								FontWeight="SemiBold"
								FontFamily="Microsoft YaHei" />
							<TextBlock
								Text="选择一位好友开始聊天"
								Foreground="#888888"
								FontSize="13"
								FontFamily="Microsoft YaHei"
								Margin="0,4,0,0" />
						</StackPanel>
						<Border
							Grid.Row="1"
							Background="#1E1E1E"
							CornerRadius="4"
							Padding="10"
							Margin="0,0,0,15">
							<TextBlock
								Text="暂无聊天记录"
								Foreground="#666666"
								FontSize="13"
								FontFamily="Microsoft YaHei"
								HorizontalAlignment="Center"
								VerticalAlignment="Center" />
						</Border>
						<Grid
							Row="2">
							<Grid.ColumnDefinitions>
								<ColumnDefinition
									Width="*" />
								<ColumnDefinition
									Width="Auto" />
							</Grid.ColumnDefinitions>
							<TextBox
								Name="txtMessage"
								Grid.Column="0"
								Background="#383838"
								Foreground="#FFFFFF"
								BorderBrush="#3A3A3A"
								BorderThickness="1"
								Padding="10,8"
								FontSize="13"
								FontFamily="Microsoft YaHei"
								Margin="0,0,8,0" />
							<Button
								Grid.Column="1"
								Content="发送"
								Background="#2196F3"
								Foreground="#FFFFFF"
								BorderThickness="0"
								Padding="16,8"
								FontSize="13"
								FontFamily="Microsoft YaHei"
								Cursor="Hand"
								Click="BtnSend_Click">
								<Control.Template>
									<ControlTemplate
										TargetType="{x:Type Button}">
										<Border
											Name="border"
											Background="{TemplateBinding Background}"
											CornerRadius="4"
											Padding="{TemplateBinding Padding}">
											<ContentPresenter
												HorizontalAlignment="Center"
												VerticalAlignment="Center" />
										</Border>
										<ControlTemplate.Triggers>
											<Trigger
												Property="UIElement.IsMouseOver"
												Value="True">
												<Setter
													TargetName="border"
													Property="Background"
													Value="#1976D2" />
											</Trigger>
										</ControlTemplate.Triggers>
									</ControlTemplate>
								</Control.Template>
							</Button>
						</Grid>
					</Grid>
				</Border>
			</Grid>
		</Grid>
	</ScrollViewer>
</UserControl>

