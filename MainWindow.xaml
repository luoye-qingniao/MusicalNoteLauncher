<Window x:Class="MusicalNoteLauncher.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="MC音符启动器"
        Height="700" Width="1100"
        MinHeight="700" MinWidth="1100"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Background="#1E1E1E">

    <Grid x:Name="MainGrid">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- 左侧导航栏 -->
        <Border Grid.Column="0" Background="#2D2D2D">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- 顶部标题 -->
                <StackPanel Grid.Row="0" Margin="15,20,15,20">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <TextBlock Text="🎵" FontSize="28" VerticalAlignment="Center"/>
                        <TextBlock Text="MC音符"
                                   FontSize="22"
                                   FontWeight="Bold"
                                   Foreground="#FFFFFF"
                                   FontFamily="Microsoft YaHei"
                                   VerticalAlignment="Center"
                                   Margin="10,0,0,0"/>
                    </StackPanel>
                    <TextBlock Text="启动器"
                               FontSize="14"
                               Foreground="#AAAAAA"
                               FontFamily="Microsoft YaHei"
                               HorizontalAlignment="Center"
                               Margin="0,5,0,0"/>
                </StackPanel>

                <!-- 导航菜单 -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="10,0">
                    <StackPanel>
                        <!-- 主界面 - 默认选中项 -->
                        <Button x:Name="btnHome"
                                Background="#2196F3"
                                Foreground="#FFFFFF"
                                BorderThickness="0"
                                Padding="12,10"
                                FontSize="14"
                                FontWeight="SemiBold"
                                FontFamily="Microsoft YaHei"
                                Cursor="Hand"
                                HorizontalContentAlignment="Left"
                                VerticalContentAlignment="Center"
                                Margin="0,2"
                                Click="BtnNav_Click" Tag="Home">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="border"
                                            Background="{TemplateBinding Background}"
                                            CornerRadius="4"
                                            Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" 
                                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="border" Property="Background" Value="#1976D2"/>
                                        </Trigger>
                                        <Trigger Property="IsPressed" Value="True">
                                            <Setter TargetName="border" Property="Background" Value="#1565C0"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="🏠" FontSize="16" VerticalAlignment="Center" Width="24"/>
                                <TextBlock Text="主界面" FontSize="14" FontFamily="Microsoft YaHei" VerticalAlignment="Center" Margin="8,0,0,0"/>
                            </StackPanel>
                        </Button>

                        <!-- 下载 -->
                        <Button x:Name="btnDownload"
                                Background="Transparent"
                                Foreground="#AAAAAA"
                                BorderThickness="0"
                                Padding="12,10"
                                FontSize="14"
                                FontFamily="Microsoft YaHei"
                                Cursor="Hand"
                                HorizontalContentAlignment="Left"
                                VerticalContentAlignment="Center"
                                Margin="0,2"
                                Click="BtnNav_Click" Tag="Download">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="border"
                                            Background="{TemplateBinding Background}"
                                            CornerRadius="4"
                                            Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" 
                                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="border" Property="Background" Value="#383838"/>
                                            <Setter Property="Foreground" Value="#FFFFFF"/>
                                        </Trigger>
                                        <Trigger Property="IsPressed" Value="True">
                                            <Setter TargetName="border" Property="Background" Value="#3A3A3A"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="⬇️" FontSize="16" VerticalAlignment="Center" Width="24"/>
                                <TextBlock Text="下载" FontSize="14" FontFamily="Microsoft YaHei" VerticalAlignment="Center" Margin="8,0,0,0"/>
                            </StackPanel>
                        </Button>

                        <!-- 模组管理 -->
                        <Button x:Name="btnMods"
                                Background="Transparent"
                                Foreground="#AAAAAA"
                                BorderThickness="0"
                                Padding="12,10"
                                FontSize="14"
                                FontFamily="Microsoft YaHei"
                                Cursor="Hand"
                                HorizontalContentAlignment="Left"
                                VerticalContentAlignment="Center"
                                Margin="0,2"
                                Click="BtnNav_Click" Tag="Mods">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="border"
                                            Background="{TemplateBinding Background}"
                                            CornerRadius="4"
                                            Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" 
                                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="border" Property="Background" Value="#383838"/>
                                            <Setter Property="Foreground" Value="#FFFFFF"/>
                                        </Trigger>
                                        <Trigger Property="IsPressed" Value="True">
                                            <Setter TargetName="border" Property="Background" Value="#3A3A3A"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="🧩" FontSize="16" VerticalAlignment="Center" Width="24"/>
                                <TextBlock Text="模组管理" FontSize="14" FontFamily="Microsoft YaHei" VerticalAlignment="Center" Margin="8,0,0,0"/>
                            </StackPanel>
                        </Button>

                        <!-- 存档管理 -->
                        <Button x:Name="btnSaves"
                                Background="Transparent"
                                Foreground="#AAAAAA"
                                BorderThickness="0"
                                Padding="12,10"
                                FontSize="14"
                                FontFamily="Microsoft YaHei"
                                Cursor="Hand"
                                HorizontalContentAlignment="Left"
                                VerticalContentAlignment="Center"
                                Margin="0,2"
                                Click="BtnNav_Click" Tag="Saves">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="border"
                                            Background="{TemplateBinding Background}"
                                            CornerRadius="4"
                                            Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" 
                                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="border" Property="Background" Value="#383838"/>
                                            <Setter Property="Foreground" Value="#FFFFFF"/>
                                        </Trigger>
                                        <Trigger Property="IsPressed" Value="True">
                                            <Setter TargetName="border" Property="Background" Value="#3A3A3A"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="📁" FontSize="16" VerticalAlignment="Center" Width="24"/>
                                <TextBlock Text="存档管理" FontSize="14" FontFamily="Microsoft YaHei" VerticalAlignment="Center" Margin="8,0,0,0"/>
                            </StackPanel>
                        </Button>

                        <!-- 联机社交 -->
                        <Button x:Name="btnMultiplayer"
                                Background="Transparent"
                                Foreground="#AAAAAA"
                                BorderThickness="0"
                                Padding="12,10"
                                FontSize="14"
                                FontFamily="Microsoft YaHei"
                                Cursor="Hand"
                                HorizontalContentAlignment="Left"
                                VerticalContentAlignment="Center"
                                Margin="0,2"
                                Click="BtnNav_Click" Tag="Multiplayer">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="border"
                                            Background="{TemplateBinding Background}"
                                            CornerRadius="4"
                                            Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" 
                                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="border" Property="Background" Value="#383838"/>
                                            <Setter Property="Foreground" Value="#FFFFFF"/>
                                        </Trigger>
                                        <Trigger Property="IsPressed" Value="True">
                                            <Setter TargetName="border" Property="Background" Value="#3A3A3A"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="🌐" FontSize="16" VerticalAlignment="Center" Width="24"/>
                                <TextBlock Text="联机社交" FontSize="14" FontFamily="Microsoft YaHei" VerticalAlignment="Center" Margin="8,0,0,0"/>
                            </StackPanel>
                        </Button>

                        <!-- 下载任务 -->
                        <Button x:Name="btnDownloadTasks"
                                Background="Transparent"
                                Foreground="#AAAAAA"
                                BorderThickness="0"
                                Padding="12,10"
                                FontSize="14"
                                FontFamily="Microsoft YaHei"
                                Cursor="Hand"
                                HorizontalContentAlignment="Left"
                                VerticalContentAlignment="Center"
                                Margin="0,2"
                                Click="BtnNav_Click" Tag="DownloadTasks">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="border"
                                            Background="{TemplateBinding Background}"
                                            CornerRadius="4"
                                            Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" 
                                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="border" Property="Background" Value="#383838"/>
                                            <Setter Property="Foreground" Value="#FFFFFF"/>
                                        </Trigger>
                                        <Trigger Property="IsPressed" Value="True">
                                            <Setter TargetName="border" Property="Background" Value="#3A3A3A"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="📥" FontSize="16" VerticalAlignment="Center" Width="24"/>
                                <TextBlock Text="下载任务" FontSize="14" FontFamily="Microsoft YaHei" VerticalAlignment="Center" Margin="8,0,0,0"/>
                            </StackPanel>
                        </Button>

                        <!-- 交流社区 -->
                        <Button x:Name="btnCommunity"
                                Background="Transparent"
                                Foreground="#AAAAAA"
                                BorderThickness="0"
                                Padding="12,10"
                                FontSize="14"
                                FontFamily="Microsoft YaHei"
                                Cursor="Hand"
                                HorizontalContentAlignment="Left"
                                VerticalContentAlignment="Center"
                                Margin="0,2"
                                Click="BtnNav_Click" Tag="Community">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="border"
                                            Background="{TemplateBinding Background}"
                                            CornerRadius="4"
                                            Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" 
                                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="border" Property="Background" Value="#383838"/>
                                            <Setter Property="Foreground" Value="#FFFFFF"/>
                                        </Trigger>
                                        <Trigger Property="IsPressed" Value="True">
                                            <Setter TargetName="border" Property="Background" Value="#3A3A3A"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="💬" FontSize="16" VerticalAlignment="Center" Width="24"/>
                                <TextBlock Text="交流社区" FontSize="14" FontFamily="Microsoft YaHei" VerticalAlignment="Center" Margin="8,0,0,0"/>
                            </StackPanel>
                        </Button>

                        <!-- 组件商店 -->
                        <Button x:Name="btnComponentStore"
                                Background="Transparent"
                                Foreground="#AAAAAA"
                                BorderThickness="0"
                                Padding="12,10"
                                FontSize="14"
                                FontFamily="Microsoft YaHei"
                                Cursor="Hand"
                                HorizontalContentAlignment="Left"
                                VerticalContentAlignment="Center"
                                Margin="0,2"
                                Click="BtnNav_Click" Tag="ComponentStore">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="border"
                                            Background="{TemplateBinding Background}"
                                            CornerRadius="4"
                                            Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" 
                                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="border" Property="Background" Value="#383838"/>
                                            <Setter Property="Foreground" Value="#FFFFFF"/>
                                        </Trigger>
                                        <Trigger Property="IsPressed" Value="True">
                                            <Setter TargetName="border" Property="Background" Value="#3A3A3A"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="🛒" FontSize="16" VerticalAlignment="Center" Width="24"/>
                                <TextBlock Text="组件商店" FontSize="14" FontFamily="Microsoft YaHei" VerticalAlignment="Center" Margin="8,0,0,0"/>
                            </StackPanel>
                        </Button>

                        <!-- 个人主页 -->
                        <Button x:Name="btnProfile"
                                Background="Transparent"
                                Foreground="#AAAAAA"
                                BorderThickness="0"
                                Padding="12,10"
                                FontSize="14"
                                FontFamily="Microsoft YaHei"
                                Cursor="Hand"
                                HorizontalContentAlignment="Left"
                                VerticalContentAlignment="Center"
                                Margin="0,2"
                                Click="BtnNav_Click" Tag="Profile">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="border"
                                            Background="{TemplateBinding Background}"
                                            CornerRadius="4"
                                            Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" 
                                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="border" Property="Background" Value="#383838"/>
                                            <Setter Property="Foreground" Value="#FFFFFF"/>
                                        </Trigger>
                                        <Trigger Property="IsPressed" Value="True">
                                            <Setter TargetName="border" Property="Background" Value="#3A3A3A"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="👤" FontSize="16" VerticalAlignment="Center" Width="24"/>
                                <TextBlock Text="个人主页" FontSize="14" FontFamily="Microsoft YaHei" VerticalAlignment="Center" Margin="8,0,0,0"/>
                            </StackPanel>
                        </Button>

                        <!-- 好友列表 -->
                        <Button x:Name="btnFriends"
                                Background="Transparent"
                                Foreground="#AAAAAA"
                                BorderThickness="0"
                                Padding="12,10"
                                FontSize="14"
                                FontFamily="Microsoft YaHei"
                                Cursor="Hand"
                                HorizontalContentAlignment="Left"
                                VerticalContentAlignment="Center"
                                Margin="0,2"
                                Click="BtnNav_Click" Tag="Friends">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="border"
                                            Background="{TemplateBinding Background}"
                                            CornerRadius="4"
                                            Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" 
                                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="border" Property="Background" Value="#383838"/>
                                            <Setter Property="Foreground" Value="#FFFFFF"/>
                                        </Trigger>
                                        <Trigger Property="IsPressed" Value="True">
                                            <Setter TargetName="border" Property="Background" Value="#3A3A3A"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="👥" FontSize="16" VerticalAlignment="Center" Width="24"/>
                                <TextBlock Text="好友列表" FontSize="14" FontFamily="Microsoft YaHei" VerticalAlignment="Center" Margin="8,0,0,0"/>
                            </StackPanel>
                        </Button>

                        <!-- 邮件查看 -->
                        <Button x:Name="btnMail"
                                Background="Transparent"
                                Foreground="#AAAAAA"
                                BorderThickness="0"
                                Padding="12,10"
                                FontSize="14"
                                FontFamily="Microsoft YaHei"
                                Cursor="Hand"
                                HorizontalContentAlignment="Left"
                                VerticalContentAlignment="Center"
                                Margin="0,2"
                                Click="BtnNav_Click" Tag="Mail">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="border"
                                            Background="{TemplateBinding Background}"
                                            CornerRadius="4"
                                            Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" 
                                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="border" Property="Background" Value="#383838"/>
                                            <Setter Property="Foreground" Value="#FFFFFF"/>
                                        </Trigger>
                                        <Trigger Property="IsPressed" Value="True">
                                            <Setter TargetName="border" Property="Background" Value="#3A3A3A"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="✉️" FontSize="16" VerticalAlignment="Center" Width="24"/>
                                <TextBlock Text="邮件查看" FontSize="14" FontFamily="Microsoft YaHei" VerticalAlignment="Center" Margin="8,0,0,0"/>
                            </StackPanel>
                        </Button>

                        <!-- 设置中心 -->
                        <Button x:Name="btnSettings"
                                Background="Transparent"
                                Foreground="#AAAAAA"
                                BorderThickness="0"
                                Padding="12,10"
                                FontSize="14"
                                FontFamily="Microsoft YaHei"
                                Cursor="Hand"
                                HorizontalContentAlignment="Left"
                                VerticalContentAlignment="Center"
                                Margin="0,2"
                                Click="BtnNav_Click" Tag="Settings">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="border"
                                            Background="{TemplateBinding Background}"
                                            CornerRadius="4"
                                            Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" 
                                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="border" Property="Background" Value="#383838"/>
                                            <Setter Property="Foreground" Value="#FFFFFF"/>
                                        </Trigger>
                                        <Trigger Property="IsPressed" Value="True">
                                            <Setter TargetName="border" Property="Background" Value="#3A3A3A"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="⚙️" FontSize="16" VerticalAlignment="Center" Width="24"/>
                                <TextBlock Text="设置中心" FontSize="14" FontFamily="Microsoft YaHei" VerticalAlignment="Center" Margin="8,0,0,0"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </ScrollViewer>

                <!-- 底部用户信息 -->
                <StackPanel Grid.Row="2" Margin="10,0,10,15">
                    <Border Background="#383838"
                            CornerRadius="8"
                            Padding="12,10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" 
                                    Background="#2196F3" 
                                    Width="36" Height="36" 
                                    CornerRadius="18"
                                    Margin="0,0,12,0">
                                <TextBlock Text="👤" 
                                           FontSize="16" 
                                           HorizontalAlignment="Center" 
                                           VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock x:Name="txtCurrentUser"
                                           Text="user"
                                           FontSize="13"
                                           FontWeight="SemiBold"
                                           Foreground="#FFFFFF"
                                           FontFamily="Microsoft YaHei"/>
                                <TextBlock x:Name="txtUserMode"
                                           Text="离线模式"
                                           FontSize="11"
                                           Foreground="#AAAAAA"
                                           FontFamily="Microsoft YaHei"
                                           Margin="0,2,0,0"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                    <!-- 退出登录 -->
                    <Button x:Name="btnLogout"
                            Background="Transparent"
                            Foreground="#E74C3C"
                            BorderThickness="0"
                            Padding="12,10"
                            FontSize="13"
                            FontFamily="Microsoft YaHei"
                            Cursor="Hand"
                            HorizontalContentAlignment="Left"
                            VerticalContentAlignment="Center"
                            Margin="0,8,0,0"
                            Click="BtnLogout_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="border"
                                        Background="{TemplateBinding Background}"
                                        CornerRadius="4"
                                        Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" 
                                                      VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="border" Property="Background" Value="#383838"/>
                                    </Trigger>
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter TargetName="border" Property="Background" Value="#3A3A3A"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🚪" FontSize="14" VerticalAlignment="Center" Width="20"/>
                            <TextBlock Text="退出登录" 
                                       FontSize="13" 
                                       FontFamily="Microsoft YaHei" 
                                       VerticalAlignment="Center" 
                                       Margin="6,0,0,0"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- 右侧主内容区 - 双容器页面切换布局 -->
        <Grid x:Name="mainContentArea" Grid.Column="1" Background="#1E1E1E">
            <!-- 固定大小的容器，防止布局重排 -->
            <Grid Width="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType=Grid}}"
                  Height="{Binding ActualHeight, RelativeSource={RelativeSource AncestorType=Grid}}">
                
                <!-- 旧页面容器 -->
                <ContentControl x:Name="pageContainerOld"
                               HorizontalAlignment="Left"
                               VerticalAlignment="Top"
                               Width="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType=Grid}}"
                               Height="{Binding ActualHeight, RelativeSource={RelativeSource AncestorType=Grid}}">
                    <ContentControl.RenderTransform>
                        <TranslateTransform X="0" Y="0"/>
                    </ContentControl.RenderTransform>
                </ContentControl>

                <!-- 新页面容器（覆盖在旧页面之上） -->
                <ContentControl x:Name="pageContainerNew"
                               HorizontalAlignment="Left"
                               VerticalAlignment="Top"
                               Width="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType=Grid}}"
                               Height="{Binding ActualHeight, RelativeSource={RelativeSource AncestorType=Grid}}">
                    <ContentControl.RenderTransform>
                        <TranslateTransform X="30" Y="0"/>
                    </ContentControl.RenderTransform>
                </ContentControl>
            </Grid>
        </Grid>
    </Grid>
</Window>