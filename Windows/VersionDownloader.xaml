<Window x:Class="MusicalNoteLauncher.Windows.VersionDownloader"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="版本下载" Height="600" Width="600"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        SnapsToDevicePixels="True" UseLayoutRounding="True">
    <Border Background="{StaticResource BackgroundBrush}" 
            CornerRadius="12" 
            Effect="{StaticResource CardShadow}"
            SnapsToDevicePixels="True"
            UseLayoutRounding="True">
        <Grid>
            <!-- 标题栏 -->
            <Grid Height="48" Background="{StaticResource CardBackgroundBrush}" Margin="0,0,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="48"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="版本下载" 
                           FontSize="16" 
                           FontWeight="SemiBold" 
                           Foreground="{StaticResource TextPrimaryBrush}"
                           VerticalAlignment="Center" 
                           Margin="20,0,0,0"
                           SnapsToDevicePixels="True"
                           UseLayoutRounding="True"/>
                <Button Grid.Column="1" 
                        Style="{StaticResource NavButton}" 
                        Click="btnClose_Click"
                        SnapsToDevicePixels="True"
                        UseLayoutRounding="True">
                    <TextBlock Text="×" FontSize="24" Margin="-4,0,0,0"/>
                </Button>
            </Grid>

            <Grid Margin="0,48,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="180"/>
                </Grid.RowDefinitions>

                <!-- 过滤选项 -->
                <Border Grid.Row="0" 
                        Background="{StaticResource CardBackgroundBrush}" 
                        Margin="16,16,16,8"
                        Padding="12,8"
                        CornerRadius="8"
                        SnapsToDevicePixels="True"
                        UseLayoutRounding="True">
                    <StackPanel Orientation="Horizontal">
                        <CheckBox x:Name="chkShowAllVersions"
                                  Content="显示所有版本（含快照版）"
                                  Foreground="{StaticResource TextPrimaryBrush}"
                                  IsChecked="False"
                                  Checked="chkShowAllVersions_Changed"
                                  Unchecked="chkShowAllVersions_Changed"
                                  VerticalContentAlignment="Center"
                                  SnapsToDevicePixels="True"
                                  UseLayoutRounding="True"/>
                        <TextBlock x:Name="txtVersionCount"
                                   Text=""
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   FontSize="12"
                                   Margin="20,0,0,0"
                                   VerticalAlignment="Center"
                                   SnapsToDevicePixels="True"
                                   UseLayoutRounding="True"/>
                    </StackPanel>
                </Border>

                <!-- 版本列表 -->
                <Grid Grid.Row="1">
                    <ListBox x:Name="lstVersions" 
                             Background="Transparent"
                             BorderThickness="0"
                             SelectionMode="Single"
                             SelectionChanged="lstVersions_SelectionChanged"
                             SnapsToDevicePixels="True"
                             UseLayoutRounding="True"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{StaticResource SurfaceBrush}" 
                                        CornerRadius="8"
                                        Padding="16,12"
                                        Margin="0,4,0,4"
                                        SnapsToDevicePixels="True"
                                        UseLayoutRounding="True">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="80"/>
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="{Binding Id}"
                                                       FontSize="14"
                                                       FontWeight="SemiBold"
                                                       Foreground="{StaticResource TextPrimaryBrush}"
                                                       SnapsToDevicePixels="True"
                                                       UseLayoutRounding="True"/>
                                            <TextBlock Text="{Binding ReleaseTime, StringFormat='yyyy-MM-dd'}"
                                                       FontSize="12"
                                                       Foreground="{StaticResource TextSecondaryBrush}"
                                                       Margin="0,4,0,0"
                                                       SnapsToDevicePixels="True"
                                                       UseLayoutRounding="True"/>
                                        </StackPanel>

                                        <Border Grid.Column="1"
                                                Background="{StaticResource PrimaryBrush}"
                                                CornerRadius="4"
                                                Padding="8,4"
                                                Margin="8,0"
                                                VerticalAlignment="Center"
                                                SnapsToDevicePixels="True"
                                                UseLayoutRounding="True"
                                                Visibility="{Binding Type, Converter={StaticResource TypeToVisibilityConverter}}">
                                            <TextBlock Text="{Binding DisplayType}"
                                                       FontSize="11"
                                                       Foreground="White"
                                                       SnapsToDevicePixels="True"
                                                       UseLayoutRounding="True"/>
                                        </Border>

                                        <TextBlock Grid.Column="2"
                                                   Text="{Binding IsDownloaded, Converter={StaticResource DownloadStatusConverter}}"
                                                   FontSize="12"
                                                   VerticalAlignment="Center"
                                                   TextAlignment="Right"
                                                   SnapsToDevicePixels="True"
                                                   UseLayoutRounding="True"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <!-- 加载提示 -->
                    <Border x:Name="loadingPanel"
                            Background="#80000000"
                            CornerRadius="8"
                            Visibility="Collapsed"
                            SnapsToDevicePixels="True"
                            UseLayoutRounding="True">
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                            <TextBlock Text="正在加载版本列表..."
                                       FontSize="14"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       HorizontalAlignment="Center"
                                       SnapsToDevicePixels="True"
                                       UseLayoutRounding="True"/>
                            <ProgressBar IsIndeterminate="True"
                                         Width="200"
                                         Height="4"
                                         Margin="0,16,0,0"
                                         Background="{StaticResource SurfaceBrush}"
                                         Foreground="{StaticResource PrimaryBrush}"
                                         SnapsToDevicePixels="True"
                                         UseLayoutRounding="True"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- 下载控制区域 -->
                <Border Grid.Row="2" 
                        Background="{StaticResource CardBackgroundBrush}" 
                        Margin="16,8,16,16"
                        CornerRadius="8"
                        SnapsToDevicePixels="True"
                        UseLayoutRounding="True">
                    <Grid Margin="16">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="100"/>
                        </Grid.ColumnDefinitions>

                        <!-- 版本信息 -->
                        <TextBlock x:Name="txtVersionInfo" 
                                   Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="4"
                                   Text=""
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   FontSize="13"
                                   SnapsToDevicePixels="True"
                                   UseLayoutRounding="True"/>

                        <!-- Forge安装选项 -->
                        <Grid Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="4" Margin="0,8,0,0">
                            <CheckBox x:Name="chkInstallForge"
                                      Content="同时安装 Forge 模组加载器"
                                      Foreground="{StaticResource TextPrimaryBrush}"
                                      IsChecked="False"
                                      VerticalContentAlignment="Center"
                                      SnapsToDevicePixels="True"
                                      UseLayoutRounding="True"
                                      Checked="chkInstallForge_Checked"
                                      Unchecked="chkInstallForge_Unchecked"/>
                            <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" Visibility="Collapsed" x:Name="pnlForgeVersion">
                                <TextBlock Text="Forge版本: " Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" VerticalAlignment="Center"/>
                                <ComboBox x:Name="cmbForgeVersion" Width="120" Background="{StaticResource SurfaceBrush}" Foreground="{StaticResource TextPrimaryBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" FontSize="12">
                                    <ComboBox.Resources>
                                        <Style TargetType="ComboBoxItem">
                                            <Setter Property="Background" Value="#2D2D2D"/>
                                            <Setter Property="Foreground" Value="#FFFFFF"/>
                                            <Style.Triggers>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter Property="Background" Value="#2196F3"/>
                                                </Trigger>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="#3A3A3A"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </ComboBox.Resources>
                                </ComboBox>
                            </StackPanel>
                        </Grid>

                        <!-- 进度条 -->
                        <Border Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="4"
                                Height="8" 
                                Margin="0,10,0,10"
                                Background="{StaticResource SurfaceBrush}"
                                CornerRadius="4"
                                SnapsToDevicePixels="True"
                                UseLayoutRounding="True">
                            <ProgressBar x:Name="progressBar" 
                                         Height="8" 
                                         Background="Transparent"
                                         Foreground="{StaticResource PrimaryBrush}"
                                         BorderThickness="0"
                                         SnapsToDevicePixels="True"
                                         UseLayoutRounding="True"/>
                        </Border>

                        <!-- 进度信息 -->
                        <TextBlock x:Name="txtProgress" 
                                   Grid.Row="3" Grid.Column="0"
                                   Text="0% (0 MB / 0 MB)"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   FontSize="12"
                                   SnapsToDevicePixels="True"
                                   UseLayoutRounding="True"/>

                        <!-- 下载速度 -->
                        <TextBlock x:Name="txtSpeed" 
                                   Grid.Row="3" Grid.Column="3"
                                   Text="速度: --"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   FontSize="12"
                                   TextAlignment="Right"
                                   SnapsToDevicePixels="True"
                                   UseLayoutRounding="True"/>

                        <!-- 控制按钮 -->
                        <Button x:Name="btnDownload" 
                                Grid.Row="4" Grid.Column="1"
                                Content="下载" 
                                Style="{StaticResource PrimaryButton}"
                                Click="btnDownload_Click"
                                Margin="4,12,4,0"
                                SnapsToDevicePixels="True"
                                UseLayoutRounding="True"/>
                        <Button x:Name="btnPause" 
                                Grid.Row="4" Grid.Column="2"
                                Content="暂停" 
                                Style="{StaticResource SecondaryButton}"
                                Click="btnPause_Click"
                                Margin="4,12,4,0"
                                IsEnabled="False"
                                SnapsToDevicePixels="True"
                                UseLayoutRounding="True"/>
                        <Button x:Name="btnCancel" 
                                Grid.Row="4" Grid.Column="3"
                                Content="取消" 
                                Style="{StaticResource SecondaryButton}"
                                Click="btnCancel_Click"
                                Margin="4,12,4,0"
                                IsEnabled="False"
                                SnapsToDevicePixels="True"
                                UseLayoutRounding="True"/>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Border>
</Window>