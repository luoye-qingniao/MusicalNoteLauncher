<UserControl
	x:Class="MusicalNoteLauncher.Pages.ComponentStorePage" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	Background="#1E1E1E" xmlns:pages="clr-namespace:MusicalNoteLauncher.Pages">
	<ScrollViewer
		VerticalScrollBarVisibility="Auto">
		<Grid
			Margin="20">
			<Grid.RowDefinitions>
				<RowDefinition
					Height="Auto" />
				<RowDefinition
					Height="Auto" />
				<RowDefinition
					Height="*" />
			</Grid.RowDefinitions>
			<TextBlock
				Grid.Row="0"
				Text="组件商店"
				Foreground="#FFFFFF"
				FontSize="24"
				FontWeight="SemiBold"
				FontFamily="Microsoft YaHei"
				Margin="0,0,0,20" />
			<Grid
				Row="1"
				Margin="0,0,0,20">
				<Grid.ColumnDefinitions>
					<ColumnDefinition
						Width="*" />
					<ColumnDefinition
						Width="Auto" />
				</Grid.ColumnDefinitions>
				<TextBox
					Name="txtSearch"
					Grid.Column="0"
					Background="#383838"
					Foreground="#FFFFFF"
					BorderBrush="#3A3A3A"
					BorderThickness="1"
					Padding="12,8"
					FontSize="13"
					FontFamily="Microsoft YaHei"
					Margin="0,0,10,0" />
				<Button
					Grid.Column="1"
					Content="搜索"
					Background="#2196F3"
					Foreground="#FFFFFF"
					BorderThickness="0"
					Padding="20,8"
					FontSize="13"
					FontFamily="Microsoft YaHei"
					Cursor="Hand"
					Click="BtnSearch_Click">
					<Control.Template>
						<ControlTemplate
							TargetType="{x:Type Button}">
							<Border
								Name="border"
								Background="{TemplateBinding Background}"
								CornerRadius="4"
								Padding="{TemplateBinding Padding}">
								<ContentPresenter
									HorizontalAlignment="Center"
									VerticalAlignment="Center" />
							</Border>
							<ControlTemplate.Triggers>
								<Trigger
									Property="UIElement.IsMouseOver"
									Value="True">
									<Setter
										TargetName="border"
										Property="Background"
										Value="#1976D2" />
								</Trigger>
							</ControlTemplate.Triggers>
						</ControlTemplate>
					</Control.Template>
				</Button>
			</Grid>
			<Grid
				Row="2">
				<Grid.RowDefinitions>
					<RowDefinition
						Height="Auto" />
					<RowDefinition
						Height="*" />
				</Grid.RowDefinitions>
				<StackPanel
					Grid.Row="0"
					Orientation="Horizontal"
					Margin="0,0,0,20">
					<Button
						Name="btnCategoryAll"
						Content="全部"
						Background="#2196F3"
						Foreground="#FFFFFF"
						BorderThickness="0"
						Padding="16,8"
						FontSize="13"
						FontFamily="Microsoft YaHei"
						Cursor="Hand"
						Margin="0,0,8,0"
						Click="BtnCategory_Click">
						<Control.Template>
							<ControlTemplate
								TargetType="{x:Type Button}">
								<Border
									Name="border"
									Background="{TemplateBinding Background}"
									CornerRadius="4"
									Padding="{TemplateBinding Padding}">
									<ContentPresenter
										HorizontalAlignment="Center"
										VerticalAlignment="Center" />
								</Border>
								<ControlTemplate.Triggers>
									<Trigger
										Property="UIElement.IsMouseOver"
										Value="True">
										<Setter
											TargetName="border"
											Property="Background"
											Value="#1976D2" />
									</Trigger>
								</ControlTemplate.Triggers>
							</ControlTemplate>
						</Control.Template>
					</Button>
					<Button
						Name="btnCategoryMods"
						Content="模组"
						Background="#383838"
						Foreground="#FFFFFF"
						BorderThickness="0"
						Padding="16,8"
						FontSize="13"
						FontFamily="Microsoft YaHei"
						Cursor="Hand"
						Margin="0,0,8,0"
						Click="BtnCategory_Click">
						<Control.Template>
							<ControlTemplate
								TargetType="{x:Type Button}">
								<Border
									Name="border"
									Background="{TemplateBinding Background}"
									CornerRadius="4"
									Padding="{TemplateBinding Padding}">
									<ContentPresenter
										HorizontalAlignment="Center"
										VerticalAlignment="Center" />
								</Border>
								<ControlTemplate.Triggers>
									<Trigger
										Property="UIElement.IsMouseOver"
										Value="True">
										<Setter
											TargetName="border"
											Property="Background"
											Value="#2D2D2D" />
									</Trigger>
								</ControlTemplate.Triggers>
							</ControlTemplate>
						</Control.Template>
					</Button>
					<Button
						Name="btnCategoryPacks"
						Content="整合包"
						Background="#383838"
						Foreground="#FFFFFF"
						BorderThickness="0"
						Padding="16,8"
						FontSize="13"
						FontFamily="Microsoft YaHei"
						Cursor="Hand"
						Margin="0,0,8,0"
						Click="BtnCategory_Click">
						<Control.Template>
							<ControlTemplate
								TargetType="{x:Type Button}">
								<Border
									Name="border"
									Background="{TemplateBinding Background}"
									CornerRadius="4"
									Padding="{TemplateBinding Padding}">
									<ContentPresenter
										HorizontalAlignment="Center"
										VerticalAlignment="Center" />
								</Border>
								<ControlTemplate.Triggers>
									<Trigger
										Property="UIElement.IsMouseOver"
										Value="True">
										<Setter
											TargetName="border"
											Property="Background"
											Value="#2D2D2D" />
									</Trigger>
								</ControlTemplate.Triggers>
							</ControlTemplate>
						</Control.Template>
					</Button>
					<Button
						Name="btnCategoryShaders"
						Content="光影"
						Background="#383838"
						Foreground="#FFFFFF"
						BorderThickness="0"
						Padding="16,8"
						FontSize="13"
						FontFamily="Microsoft YaHei"
						Cursor="Hand"
						Margin="0,0,8,0"
						Click="BtnCategory_Click">
						<Control.Template>
							<ControlTemplate
								TargetType="{x:Type Button}">
								<Border
									Name="border"
									Background="{TemplateBinding Background}"
									CornerRadius="4"
									Padding="{TemplateBinding Padding}">
									<ContentPresenter
										HorizontalAlignment="Center"
										VerticalAlignment="Center" />
								</Border>
								<ControlTemplate.Triggers>
									<Trigger
										Property="UIElement.IsMouseOver"
										Value="True">
										<Setter
											TargetName="border"
											Property="Background"
											Value="#2D2D2D" />
									</Trigger>
								</ControlTemplate.Triggers>
							</ControlTemplate>
						</Control.Template>
					</Button>
					<Button
						Name="btnCategoryTextures"
						Content="材质"
						Background="#383838"
						Foreground="#FFFFFF"
						BorderThickness="0"
						Padding="16,8"
						FontSize="13"
						FontFamily="Microsoft YaHei"
						Cursor="Hand"
						Margin="0,0,8,0"
						Click="BtnCategory_Click">
						<Control.Template>
							<ControlTemplate
								TargetType="{x:Type Button}">
								<Border
									Name="border"
									Background="{TemplateBinding Background}"
									CornerRadius="4"
									Padding="{TemplateBinding Padding}">
									<ContentPresenter
										HorizontalAlignment="Center"
										VerticalAlignment="Center" />
								</Border>
								<ControlTemplate.Triggers>
									<Trigger
										Property="UIElement.IsMouseOver"
										Value="True">
										<Setter
											TargetName="border"
											Property="Background"
											Value="#2D2D2D" />
									</Trigger>
								</ControlTemplate.Triggers>
							</ControlTemplate>
						</Control.Template>
					</Button>
					<Button
						Name="btnCategoryMaps"
						Content="地图"
						Background="#383838"
						Foreground="#FFFFFF"
						BorderThickness="0"
						Padding="16,8"
						FontSize="13"
						FontFamily="Microsoft YaHei"
						Cursor="Hand"
						Click="BtnCategory_Click">
						<Control.Template>
							<ControlTemplate
								TargetType="{x:Type Button}">
								<Border
									Name="border"
									Background="{TemplateBinding Background}"
									CornerRadius="4"
									Padding="{TemplateBinding Padding}">
									<ContentPresenter
										HorizontalAlignment="Center"
										VerticalAlignment="Center" />
								</Border>
								<ControlTemplate.Triggers>
									<Trigger
										Property="UIElement.IsMouseOver"
										Value="True">
										<Setter
											TargetName="border"
											Property="Background"
											Value="#2D2D2D" />
									</Trigger>
								</ControlTemplate.Triggers>
							</ControlTemplate>
						</Control.Template>
					</Button>
				</StackPanel>
				<ListBox
					Name="lstComponents"
					Grid.Row="1"
					Background="#1E1E1E"
					BorderThickness="0"
					Foreground="#FFFFFF"
					FontFamily="Microsoft YaHei">
					<ItemsControl.ItemTemplate>
						<DataTemplate>
							<Border
								Background="#252525"
								CornerRadius="8"
								Padding="15"
								Margin="0,6">
								<Grid>
									<Grid.ColumnDefinitions>
										<ColumnDefinition
											Width="80" />
										<ColumnDefinition
											Width="*" />
										<ColumnDefinition
											Width="Auto" />
									</Grid.ColumnDefinitions>
									<Border
										Grid.Column="0"
										Width="80"
										Height="80"
										Background="#2D2D2D"
										CornerRadius="4">
										<TextBlock
											Text="🧩"
											FontSize="32"
											HorizontalAlignment="Center"
											VerticalAlignment="Center" />
									</Border>
									<StackPanel
										Grid.Column="1"
										Margin="15,0">
										<TextBlock
											Foreground="#FFFFFF"
											FontSize="15"
											FontWeight="SemiBold"
											Text="{Binding ComponentName}" />
										<TextBlock
											Foreground="#AAAAAA"
											FontSize="12"
											Margin="0,4,0,0"
											Text="{Binding ComponentCategory}" />
										<TextBlock
											Foreground="#888888"
											FontSize="12"
											TextWrapping="Wrap"
											Margin="0,6,0,0"
											Text="{Binding ComponentDesc}" />
										<StackPanel
											Orientation="Horizontal"
											Margin="0,6,0,0">
											<TextBlock
												Text="⭐"
												FontSize="12" />
											<TextBlock
												Foreground="#AAAAAA"
												FontSize="12"
												Margin="4,0,0,0"
												Text="{Binding Rating}" />
											<TextBlock
												Text="下载："
												Foreground="#666666"
												FontSize="12"
												Margin="15,0,0,0" />
											<TextBlock
												Foreground="#2ECC71"
												FontSize="12"
												Text="{Binding DownloadCount}" />
										</StackPanel>
									</StackPanel>
									<!--未知连接 ID：10-->
									<Button
										Grid.Column="2"
										Content="下载"
										Background="#2196F3"
										Foreground="#FFFFFF"
										BorderThickness="0"
										Padding="20,10"
										FontSize="13"
										FontFamily="Microsoft YaHei"
										Cursor="Hand"
										VerticalAlignment="Center">
										<Control.Template>
											<ControlTemplate
												TargetType="{x:Type Button}">
												<Border
													Name="border"
													Background="{TemplateBinding Background}"
													CornerRadius="4"
													Padding="{TemplateBinding Padding}">
													<ContentPresenter
														HorizontalAlignment="Center"
														VerticalAlignment="Center" />
												</Border>
												<ControlTemplate.Triggers>
													<Trigger
														Property="UIElement.IsMouseOver"
														Value="True">
														<Setter
															TargetName="border"
															Property="Background"
															Value="#1976D2" />
													</Trigger>
												</ControlTemplate.Triggers>
											</ControlTemplate>
										</Control.Template>
									</Button>
								</Grid>
							</Border>
						</DataTemplate>
					</ItemsControl.ItemTemplate>
				</ListBox>
			</Grid>
		</Grid>
	</ScrollViewer>
</UserControl>

