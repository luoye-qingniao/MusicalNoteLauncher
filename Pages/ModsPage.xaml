<UserControl
	x:Class="MusicalNoteLauncher.Pages.ModsPage" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:local="clr-namespace:MusicalNoteLauncher.Pages"
	Background="#1E1E1E">
	<Grid
		Background="#1E1E1E">
		<Grid.RowDefinitions>
			<RowDefinition
				Height="60" />
			<RowDefinition
				Height="*" />
		</Grid.RowDefinitions>
		<Border
			Grid.Row="0"
			Background="#2D2D2D">
			<StackPanel
				Orientation="Horizontal"
				Margin="20,0"
				VerticalAlignment="Center">
				<Button
					Content="← 返回"
					Background="#00FFFFFF"
					Foreground="#2196F3"
					BorderThickness="0"
					FontSize="14"
					FontFamily="Microsoft YaHei"
					Cursor="Hand"
					Margin="0,0,20,0"
					Click="BtnBack_Click" />
				<TextBlock
					Text="Mod模组"
					FontSize="20"
					FontWeight="Bold"
					Foreground="#FFFFFF" />
			</StackPanel>
		</Border>
		<Grid
			Row="1"
			Margin="20">
			<Grid.RowDefinitions>
				<RowDefinition
					Height="Auto" />
				<RowDefinition
					Height="Auto" />
				<RowDefinition
					Height="*" />
			</Grid.RowDefinitions>
			<Border
				Grid.Row="0"
				Background="#383838"
				CornerRadius="8"
				Padding="16"
				Margin="0,0,0,16">
				<StackPanel>
					<TextBlock
						Text="🧩 Mod模组下载"
						FontSize="14"
						Foreground="#FFFFFF"
						FontFamily="Microsoft YaHei"
						Margin="0,0,0,8" />
					<TextBlock
						Text="Mod可以为游戏添加新的功能、物品和玩法，让你的Minecraft体验更加丰富"
						FontSize="12"
						Foreground="#AAAAAA"
						FontFamily="Microsoft YaHei"
						TextWrapping="Wrap" />
				</StackPanel>
			</Border>
			<StackPanel
				Grid.Row="1"
				Orientation="Horizontal"
				Margin="0,0,0,16">
				<Button
					Content="全部"
					Background="#383838"
					Foreground="#FFFFFF"
					BorderBrush="#444444"
					BorderThickness="1"
					Padding="12,6"
					FontSize="12"
					Margin="0,0,8,0"
					Cursor="Hand"
					Click="BtnCategory_Click" />
				<Button
					Content="科技"
					Background="#2D2D2D"
					Foreground="#AAAAAA"
					BorderBrush="#3A3A3A"
					BorderThickness="1"
					Padding="12,6"
					FontSize="12"
					Margin="0,0,8,0"
					Cursor="Hand"
					Click="BtnCategory_Click" />
				<Button
					Content="魔法"
					Background="#2D2D2D"
					Foreground="#AAAAAA"
					BorderBrush="#3A3A3A"
					BorderThickness="1"
					Padding="12,6"
					FontSize="12"
					Margin="0,0,8,0"
					Cursor="Hand"
					Click="BtnCategory_Click" />
				<Button
					Content="冒险"
					Background="#2D2D2D"
					Foreground="#AAAAAA"
					BorderBrush="#3A3A3A"
					BorderThickness="1"
					Padding="12,6"
					FontSize="12"
					Margin="0,0,8,0"
					Cursor="Hand"
					Click="BtnCategory_Click" />
				<Button
					Content="优化"
					Background="#2D2D2D"
					Foreground="#AAAAAA"
					BorderBrush="#3A3A3A"
					BorderThickness="1"
					Padding="12,6"
					FontSize="12"
					Margin="0,0,8,0"
					Cursor="Hand"
					Click="BtnCategory_Click" />
			</StackPanel>
			<Border
				Grid.Row="2"
				Background="#2D2D2D"
				CornerRadius="12"
				Padding="16"
				Width="800">
				<ListBox
					Name="lbMods"
					Background="#00FFFFFF"
					BorderThickness="0"
					ScrollViewer.HorizontalScrollBarVisibility="Disabled">
					<ItemsControl.ItemContainerStyle>
						<Style
							TargetType="{x:Type ListBoxItem}">
							<Setter
								Property="HorizontalAlignment"
								Value="Stretch" />
							<Setter
								Property="HorizontalContentAlignment"
								Value="Stretch" />
							<Setter
								Property="Height"
								Value="128" />
						</Style>
					</ItemsControl.ItemContainerStyle>
					<ItemsControl.ItemTemplate>
						<DataTemplate>
							<Border
								Background="#383838"
								CornerRadius="8"
								Padding="14"
								Margin="0,0,0,8"
								Height="120">
								<Grid>
									<Grid.ColumnDefinitions>
										<ColumnDefinition
											Width="80" />
										<ColumnDefinition
											Width="*" />
										<ColumnDefinition
											Width="80" />
									</Grid.ColumnDefinitions>
									<Border
										Grid.Column="0"
										Background="#444444"
										CornerRadius="10"
										Margin="0"
										Width="80"
										Height="80">
										<UIElement.OpacityMask>
											<VisualBrush>
												<VisualBrush.Visual>
													<Rectangle
														Width="80"
														Height="80"
														RadiusX="10"
														RadiusY="10"
														Fill="#FFFFFFFF" />
												</VisualBrush.Visual>
											</VisualBrush>
										</UIElement.OpacityMask>
										<Image
											Stretch="Uniform"
											HorizontalAlignment="Center"
											VerticalAlignment="Center"
											Source="{Binding IconUrl}" />
									</Border>
									<StackPanel
										Grid.Column="1"
										Margin="12,0,0,0">
										<StackPanel
											Orientation="Horizontal">
											<TextBlock
												FontSize="14"
												FontWeight="SemiBold"
												Foreground="#FFFFFF"
												FontFamily="Microsoft YaHei"
												TextTrimming="CharacterEllipsis"
												MaxWidth="400"
												Text="{Binding Name, FallbackValue=未知名称}" />
											<TextBlock
												FontSize="11"
												Foreground="#888888"
												FontFamily="Microsoft YaHei"
												Margin="8,2,0,0"
												Text="{Binding Version, FallbackValue=未知版本}" />
										</StackPanel>
										<TextBlock
											FontSize="12"
											Foreground="#AAAAAA"
											FontFamily="Microsoft YaHei"
											Margin="0,4,0,4"
											TextTrimming="CharacterEllipsis"
											MaxWidth="500"
											Height="28"
											Text="{Binding Description, FallbackValue=暂无描述}" />
										<StackPanel
											Orientation="Horizontal">
											<TextBlock
												FontSize="11"
												Foreground="#888888"
												FontFamily="Microsoft YaHei"
												Margin="0,0,12,0"
												TextTrimming="CharacterEllipsis"
												MaxWidth="150"
												Text="{Binding Author, FallbackValue=未知作者}" />
											<TextBlock
												FontSize="11"
												Foreground="#888888"
												FontFamily="Microsoft YaHei"
												Text="{Binding Downloads, FallbackValue=0}" />
										</StackPanel>
									</StackPanel>
									<!--未知连接 ID：8-->
									<Button
										Grid.Column="2"
										Content="下载"
										Background="#2196F3"
										Foreground="#FFFFFF"
										BorderThickness="0"
										Padding="14,6"
										FontSize="12"
										FontFamily="Microsoft YaHei"
										Cursor="Hand"
										HorizontalAlignment="Center"
										VerticalAlignment="Center"
										Width="70"
										Height="32">
										<Control.Template>
											<ControlTemplate
												TargetType="{x:Type Button}">
												<Border
													Name="border"
													Background="{TemplateBinding Background}"
													CornerRadius="6"
													Padding="{TemplateBinding Padding}">
													<ContentPresenter
														HorizontalAlignment="Center"
														VerticalAlignment="Center" />
												</Border>
												<ControlTemplate.Triggers>
													<Trigger
														Property="UIElement.IsMouseOver"
														Value="True">
														<Setter
															TargetName="border"
															Property="Background"
															Value="#1976D2" />
													</Trigger>
												</ControlTemplate.Triggers>
											</ControlTemplate>
										</Control.Template>
									</Button>
								</Grid>
							</Border>
						</DataTemplate>
					</ItemsControl.ItemTemplate>
				</ListBox>
			</Border>
		</Grid>
	</Grid>
</UserControl>

