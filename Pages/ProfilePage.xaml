<UserControl
	x:Class="MusicalNoteLauncher.Pages.ProfilePage" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	Background="#1E1E1E" xmlns:pages="clr-namespace:MusicalNoteLauncher.Pages">
	<ScrollViewer
		VerticalScrollBarVisibility="Auto">
		<Grid
			Margin="20">
			<Grid.RowDefinitions>
				<RowDefinition
					Height="Auto" />
				<RowDefinition
					Height="*" />
			</Grid.RowDefinitions>
			<TextBlock
				Grid.Row="0"
				Text="个人主页"
				Foreground="#FFFFFF"
				FontSize="24"
				FontWeight="SemiBold"
				FontFamily="Microsoft YaHei"
				Margin="0,0,0,20" />
			<Grid
				Row="1">
				<Grid.ColumnDefinitions>
					<ColumnDefinition
						Width="320" />
					<ColumnDefinition
						Width="*" />
				</Grid.ColumnDefinitions>
				<Border
					Grid.Column="0"
					Background="#252525"
					CornerRadius="8"
					Padding="20"
					Margin="0,0,16,0">
					<StackPanel
						HorizontalAlignment="Center">
						<Border
							Width="100"
							Height="100"
							Background="#2196F3"
							CornerRadius="50"
							Margin="0,0,0,20">
							<TextBlock
								Text="👤"
								FontSize="48"
								HorizontalAlignment="Center"
								VerticalAlignment="Center" />
						</Border>
						<TextBlock
							Name="txtUsername"
							Text="Player"
							Foreground="#FFFFFF"
							FontSize="22"
							FontWeight="SemiBold"
							FontFamily="Microsoft YaHei"
							HorizontalAlignment="Center" />
						<TextBlock
							Name="txtLoginMode"
							Text="离线模式"
							Foreground="#AAAAAA"
							FontSize="14"
							FontFamily="Microsoft YaHei"
							HorizontalAlignment="Center"
							Margin="0,4,0,20" />
						<Border
							Background="#2D2D2D"
							CornerRadius="8"
							Padding="15"
							Margin="0,0,0,15">
							<Grid>
								<Grid.ColumnDefinitions>
									<ColumnDefinition
										Width="*" />
									<ColumnDefinition
										Width="*" />
									<ColumnDefinition
										Width="*" />
								</Grid.ColumnDefinitions>
								<StackPanel
									Grid.Column="0"
									HorizontalAlignment="Center">
									<TextBlock
										Text="0"
										Foreground="#FFFFFF"
										FontSize="20"
										FontWeight="Bold"
										HorizontalAlignment="Center" />
									<TextBlock
										Text="游戏时长"
										Foreground="#AAAAAA"
										FontSize="11"
										FontFamily="Microsoft YaHei"
										HorizontalAlignment="Center" />
								</StackPanel>
								<StackPanel
									Grid.Column="1"
									HorizontalAlignment="Center">
									<TextBlock
										Text="0"
										Foreground="#FFFFFF"
										FontSize="20"
										FontWeight="Bold"
										HorizontalAlignment="Center" />
									<TextBlock
										Text="启动次数"
										Foreground="#AAAAAA"
										FontSize="11"
										FontFamily="Microsoft YaHei"
										HorizontalAlignment="Center" />
								</StackPanel>
								<StackPanel
									Grid.Column="2"
									HorizontalAlignment="Center">
									<TextBlock
										Text="0"
										Foreground="#FFFFFF"
										FontSize="20"
										FontWeight="Bold"
										HorizontalAlignment="Center" />
									<TextBlock
										Text="模组数"
										Foreground="#AAAAAA"
										FontSize="11"
										FontFamily="Microsoft YaHei"
										HorizontalAlignment="Center" />
								</StackPanel>
							</Grid>
						</Border>
						<Button
							Content="编辑个人资料"
							Background="#383838"
							Foreground="#FFFFFF"
							BorderThickness="1"
							BorderBrush="#3A3A3A"
							Padding="15,8"
							FontSize="13"
							FontFamily="Microsoft YaHei"
							Cursor="Hand"
							HorizontalAlignment="Stretch"
							Margin="0,8,0,0"
							Click="BtnEditProfile_Click">
							<Control.Template>
								<ControlTemplate
									TargetType="{x:Type Button}">
									<Border
										Name="border"
										Background="{TemplateBinding Background}"
										BorderBrush="{TemplateBinding BorderBrush}"
										BorderThickness="{TemplateBinding BorderThickness}"
										CornerRadius="4"
										Padding="{TemplateBinding Padding}">
										<ContentPresenter
											HorizontalAlignment="Center"
											VerticalAlignment="Center" />
									</Border>
									<ControlTemplate.Triggers>
										<Trigger
											Property="UIElement.IsMouseOver"
											Value="True">
											<Setter
												TargetName="border"
												Property="Background"
												Value="#2D2D2D" />
										</Trigger>
									</ControlTemplate.Triggers>
								</ControlTemplate>
							</Control.Template>
						</Button>
						<Button
							Content="切换账号"
							Background="#383838"
							Foreground="#FFFFFF"
							BorderThickness="1"
							BorderBrush="#3A3A3A"
							Padding="15,8"
							FontSize="13"
							FontFamily="Microsoft YaHei"
							Cursor="Hand"
							HorizontalAlignment="Stretch"
							Margin="0,8,0,0"
							Click="BtnSwitchAccount_Click">
							<Control.Template>
								<ControlTemplate
									TargetType="{x:Type Button}">
									<Border
										Name="border"
										Background="{TemplateBinding Background}"
										BorderBrush="{TemplateBinding BorderBrush}"
										BorderThickness="{TemplateBinding BorderThickness}"
										CornerRadius="4"
										Padding="{TemplateBinding Padding}">
										<ContentPresenter
											HorizontalAlignment="Center"
											VerticalAlignment="Center" />
									</Border>
									<ControlTemplate.Triggers>
										<Trigger
											Property="UIElement.IsMouseOver"
											Value="True">
											<Setter
												TargetName="border"
												Property="Background"
												Value="#2D2D2D" />
										</Trigger>
									</ControlTemplate.Triggers>
								</ControlTemplate>
							</Control.Template>
						</Button>
					</StackPanel>
				</Border>
				<StackPanel
					Grid.Column="1">
					<Border
						Background="#252525"
						CornerRadius="8"
						Padding="15"
						Margin="0,0,0,16">
						<StackPanel>
							<TextBlock
								Text="最近游戏"
								Foreground="#FFFFFF"
								FontSize="16"
								FontWeight="SemiBold"
								FontFamily="Microsoft YaHei"
								Margin="0,0,0,15" />
							<TextBlock
								Text="暂无游戏记录"
								Foreground="#888888"
								FontSize="13"
								FontFamily="Microsoft YaHei"
								HorizontalAlignment="Center"
								Margin="0,20,0,20" />
						</StackPanel>
					</Border>
					<Border
						Background="#252525"
						CornerRadius="8"
						Padding="15"
						Margin="0,0,0,16">
						<StackPanel>
							<TextBlock
								Text="游戏统计详情"
								Foreground="#FFFFFF"
								FontSize="16"
								FontWeight="SemiBold"
								FontFamily="Microsoft YaHei"
								Margin="0,0,0,15" />
							<Grid>
								<Grid.ColumnDefinitions>
									<ColumnDefinition
										Width="*" />
									<ColumnDefinition
										Width="*" />
								</Grid.ColumnDefinitions>
								<Grid.RowDefinitions>
									<RowDefinition
										Height="Auto" />
									<RowDefinition
										Height="Auto" />
								</Grid.RowDefinitions>
								<StackPanel
									Grid.Row="0"
									Grid.Column="0"
									Margin="0,0,0,15">
									<TextBlock
										Text="最喜欢的版本"
										Foreground="#AAAAAA"
										FontSize="12"
										FontFamily="Microsoft YaHei" />
									<TextBlock
										Text="尚未设置"
										Foreground="#FFFFFF"
										FontSize="13"
										FontFamily="Microsoft YaHei" />
								</StackPanel>
								<StackPanel
									Grid.Row="0"
									Grid.Column="1"
									Margin="0,0,0,15">
									<TextBlock
										Text="常用模组数量"
										Foreground="#AAAAAA"
										FontSize="12"
										FontFamily="Microsoft YaHei" />
									<TextBlock
										Text="0 个"
										Foreground="#FFFFFF"
										FontSize="13"
										FontFamily="Microsoft YaHei" />
								</StackPanel>
								<StackPanel
									Grid.Row="1"
									Grid.Column="0">
									<TextBlock
										Text="累计游戏时间"
										Foreground="#AAAAAA"
										FontSize="12"
										FontFamily="Microsoft YaHei" />
									<TextBlock
										Text="0 小时"
										Foreground="#FFFFFF"
										FontSize="13"
										FontFamily="Microsoft YaHei" />
								</StackPanel>
								<StackPanel
									Grid.Row="1"
									Grid.Column="1">
									<TextBlock
										Text="最近登录"
										Foreground="#AAAAAA"
										FontSize="12"
										FontFamily="Microsoft YaHei" />
									<TextBlock
										Text="今天"
										Foreground="#FFFFFF"
										FontSize="13"
										FontFamily="Microsoft YaHei" />
								</StackPanel>
							</Grid>
						</StackPanel>
					</Border>
					<Border
						Background="#252525"
						CornerRadius="8"
						Padding="15">
						<StackPanel>
							<TextBlock
								Text="快捷操作"
								Foreground="#FFFFFF"
								FontSize="16"
								FontWeight="SemiBold"
								FontFamily="Microsoft YaHei"
								Margin="0,0,0,15" />
							<Grid>
								<Grid.ColumnDefinitions>
									<ColumnDefinition
										Width="*" />
									<ColumnDefinition
										Width="*" />
									<ColumnDefinition
										Width="*" />
								</Grid.ColumnDefinitions>
								<Button
									Grid.Column="0"
									Content="快速开始"
									Background="#2196F3"
									Foreground="#FFFFFF"
									BorderThickness="0"
									Padding="12,10"
									FontSize="12"
									FontFamily="Microsoft YaHei"
									Cursor="Hand"
									Margin="0,0,8,0"
									Click="BtnQuickStart_Click">
									<Control.Template>
										<ControlTemplate
											TargetType="{x:Type Button}">
											<Border
												Name="border"
												Background="{TemplateBinding Background}"
												CornerRadius="4"
												Padding="{TemplateBinding Padding}">
												<ContentPresenter
													HorizontalAlignment="Center"
													VerticalAlignment="Center" />
											</Border>
											<ControlTemplate.Triggers>
												<Trigger
													Property="UIElement.IsMouseOver"
													Value="True">
													<Setter
														TargetName="border"
														Property="Background"
														Value="#1976D2" />
												</Trigger>
											</ControlTemplate.Triggers>
										</ControlTemplate>
									</Control.Template>
								</Button>
								<Button
									Grid.Column="1"
									Content="浏览模组"
									Background="#2ECC71"
									Foreground="#FFFFFF"
									BorderThickness="0"
									Padding="12,10"
									FontSize="12"
									FontFamily="Microsoft YaHei"
									Cursor="Hand"
									Margin="0,0,8,0"
									Click="BtnBrowseMods_Click">
									<Control.Template>
										<ControlTemplate
											TargetType="{x:Type Button}">
											<Border
												Name="border"
												Background="{TemplateBinding Background}"
												CornerRadius="4"
												Padding="{TemplateBinding Padding}">
												<ContentPresenter
													HorizontalAlignment="Center"
													VerticalAlignment="Center" />
											</Border>
											<ControlTemplate.Triggers>
												<Trigger
													Property="UIElement.IsMouseOver"
													Value="True">
													<Setter
														TargetName="border"
														Property="Background"
														Value="#27AE60" />
												</Trigger>
											</ControlTemplate.Triggers>
										</ControlTemplate>
									</Control.Template>
								</Button>
								<Button
									Grid.Column="2"
									Content="游戏设置"
									Background="#E74C3C"
									Foreground="#FFFFFF"
									BorderThickness="0"
									Padding="12,10"
									FontSize="12"
									FontFamily="Microsoft YaHei"
									Cursor="Hand"
									Click="BtnGameSettings_Click">
									<Control.Template>
										<ControlTemplate
											TargetType="{x:Type Button}">
											<Border
												Name="border"
												Background="{TemplateBinding Background}"
												CornerRadius="4"
												Padding="{TemplateBinding Padding}">
												<ContentPresenter
													HorizontalAlignment="Center"
													VerticalAlignment="Center" />
											</Border>
											<ControlTemplate.Triggers>
												<Trigger
													Property="UIElement.IsMouseOver"
													Value="True">
													<Setter
														TargetName="border"
														Property="Background"
														Value="#C0392B" />
												</Trigger>
											</ControlTemplate.Triggers>
										</ControlTemplate>
									</Control.Template>
								</Button>
							</Grid>
						</StackPanel>
					</Border>
				</StackPanel>
			</Grid>
		</Grid>
	</ScrollViewer>
</UserControl>

