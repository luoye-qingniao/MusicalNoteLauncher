<UserControl
	x:Class="MusicalNoteLauncher.Pages.ProfilePage" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	Background="#121212" xmlns:pages="clr-namespace:MusicalNoteLauncher.Pages">
	<UserControl.Resources>
		<DropShadowEffect x:Key="CardShadow" Color="Black" Opacity="0.3" BlurRadius="12" ShadowDepth="4" />
		<DropShadowEffect x:Key="ButtonShadow" Color="Black" Opacity="0.2" BlurRadius="8" ShadowDepth="2" />
		<Style x:Key="StatCardStyle" TargetType="Border">
			<Setter Property="Background" Value="#1E1E1E" />
			<Setter Property="CornerRadius" Value="12" />
			<Setter Property="Padding" Value="20" />
			<Setter Property="Effect" Value="{StaticResource CardShadow}" />
			<Style.Triggers>
				<Trigger Property="IsMouseOver" Value="True">
					<Setter Property="Background" Value="#252525" />
				</Trigger>
			</Style.Triggers>
		</Style>
		<Style x:Key="PrimaryButtonStyle" TargetType="Button">
			<Setter Property="Background" Value="#6C5CE7" />
			<Setter Property="Foreground" Value="White" />
			<Setter Property="BorderThickness" Value="0" />
			<Setter Property="Padding" Value="16,10" />
			<Setter Property="FontSize" Value="13" />
			<Setter Property="FontFamily" Value="Microsoft YaHei" />
			<Setter Property="Cursor" Value="Hand" />
			<Setter Property="Effect" Value="{StaticResource ButtonShadow}" />
			<Setter Property="Template">
				<Setter.Value>
					<ControlTemplate TargetType="Button">
						<Border Name="border" Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}">
							<StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
								<ContentPresenter />
							</StackPanel>
						</Border>
						<ControlTemplate.Triggers>
							<Trigger Property="IsMouseOver" Value="True">
								<Setter TargetName="border" Property="Background" Value="#5B4CDB" />
								<Setter TargetName="border" Property="RenderTransform">
									<Setter.Value>
										<ScaleTransform ScaleX="1.02" ScaleY="1.02" />
									</Setter.Value>
								</Setter>
							</Trigger>
							<Trigger Property="IsPressed" Value="True">
								<Setter TargetName="border" Property="Background" Value="#4A3FBA" />
								<Setter TargetName="border" Property="RenderTransform">
									<Setter.Value>
										<ScaleTransform ScaleX="0.98" ScaleY="0.98" />
									</Setter.Value>
								</Setter>
							</Trigger>
						</ControlTemplate.Triggers>
					</ControlTemplate>
				</Setter.Value>
			</Setter>
		</Style>
		<Style x:Key="SecondaryButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
			<Setter Property="Background" Value="#2D2D2D" />
			<Setter Property="Foreground" Value="#FFFFFF" />
			<Setter Property="BorderThickness" Value="1" />
			<Setter Property="BorderBrush" Value="#3A3A3A" />
			<Style.Triggers>
				<Trigger Property="IsMouseOver" Value="True">
					<Setter Property="Background" Value="#383838" />
				</Trigger>
			</Style.Triggers>
		</Style>
	</UserControl.Resources>
	<ScrollViewer
		VerticalScrollBarVisibility="Auto">
		<Grid
			Margin="20">
			<Grid.RowDefinitions>
				<RowDefinition
					Height="Auto" />
				<RowDefinition
					Height="*" />
			</Grid.RowDefinitions>
			<TextBlock
				Grid.Row="0"
				Text="个人主页"
				Foreground="#FFFFFF"
				FontSize="24"
				FontWeight="SemiBold"
				FontFamily="Microsoft YaHei"
				Margin="0,0,0,20" />
			<Grid
				Row="1">
				<Grid.ColumnDefinitions>
					<ColumnDefinition
						Width="320" />
					<ColumnDefinition
						Width="*" />
				</Grid.ColumnDefinitions>
				<Border
				Grid.Column="0"
				Style="{StaticResource StatCardStyle}"
				Margin="0,0,16,0">
					<StackPanel
						HorizontalAlignment="Center">
						<Border
						Width="120"
						Height="120">
						<Border.Background>
							<LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
								<GradientStop Color="#6C5CE7" Offset="0" />
								<GradientStop Color="#A29BFE" Offset="1" />
							</LinearGradientBrush>
						</Border.Background>
						<Border.CornerRadius>
							<CornerRadius>60</CornerRadius>
						</Border.CornerRadius>
						<Border.Effect>
							<DropShadowEffect Color="#6C5CE7" Opacity="0.4" BlurRadius="20" ShadowDepth="0" />
						</Border.Effect>
						<TextBlock
							Text="👤"
							FontSize="56"
							HorizontalAlignment="Center"
							VerticalAlignment="Center" />
					</Border>
						<TextBlock
							Name="txtUsername"
							Text="Player"
							Foreground="#FFFFFF"
							FontSize="22"
							FontWeight="SemiBold"
							FontFamily="Microsoft YaHei"
							HorizontalAlignment="Center" />
						<TextBlock
							Name="txtLoginMode"
							Text="离线模式"
							Foreground="#AAAAAA"
							FontSize="14"
							FontFamily="Microsoft YaHei"
							HorizontalAlignment="Center"
							Margin="0,4,0,20" />
						<Border
						Background="#252525"
						CornerRadius="12"
						Padding="20"
						Margin="0,0,0,20">
						<Grid>
							<Grid.ColumnDefinitions>
								<ColumnDefinition
									Width="*" />
								<ColumnDefinition
									Width="*" />
								<ColumnDefinition
									Width="*" />
							</Grid.ColumnDefinitions>
							<StackPanel
								Grid.Column="0"
								HorizontalAlignment="Center">
								<Border
									Background="#FF6B6B"
									CornerRadius="8"
									Padding="12,8"
									Margin="0,0,0,8">
									<TextBlock
										Text="🕐"
										Foreground="#FFFFFF"
										FontSize="20"
										HorizontalAlignment="Center" />
								</Border>
								<TextBlock
									Text="0"
									Foreground="#FFFFFF"
									FontSize="22"
									FontWeight="Bold"
									HorizontalAlignment="Center" />
								<TextBlock
									Text="游戏时长"
									Foreground="#AAAAAA"
									FontSize="12"
									FontFamily="Microsoft YaHei"
									HorizontalAlignment="Center" />
							</StackPanel>
							<StackPanel
								Grid.Column="1"
								HorizontalAlignment="Center">
								<Border
									Background="#4ECDC4"
									CornerRadius="8"
									Padding="12,8"
									Margin="0,0,0,8">
									<TextBlock
										Text="🎮"
										Foreground="#FFFFFF"
										FontSize="20"
										HorizontalAlignment="Center" />
								</Border>
								<TextBlock
									Text="0"
									Foreground="#FFFFFF"
									FontSize="22"
									FontWeight="Bold"
									HorizontalAlignment="Center" />
								<TextBlock
									Text="启动次数"
									Foreground="#AAAAAA"
									FontSize="12"
									FontFamily="Microsoft YaHei"
									HorizontalAlignment="Center" />
							</StackPanel>
							<StackPanel
								Grid.Column="2"
								HorizontalAlignment="Center">
								<Border
									Background="#FFE66D"
									CornerRadius="8"
									Padding="12,8"
									Margin="0,0,0,8">
									<TextBlock
										Text="🧩"
										Foreground="#1E1E1E"
										FontSize="20"
										HorizontalAlignment="Center" />
								</Border>
								<TextBlock
									Text="0"
									Foreground="#FFFFFF"
									FontSize="22"
									FontWeight="Bold"
									HorizontalAlignment="Center" />
								<TextBlock
									Text="模组数"
									Foreground="#AAAAAA"
									FontSize="12"
									FontFamily="Microsoft YaHei"
									HorizontalAlignment="Center" />
							</StackPanel>
						</Grid>
					</Border>
					<Button
						Content="✏️ 编辑个人资料"
						Style="{StaticResource PrimaryButtonStyle}"
						HorizontalAlignment="Stretch"
						Margin="0,8,0,0"
						Click="BtnEditProfile_Click" />
					<Button
						Content="🔄 切换账号"
						Style="{StaticResource SecondaryButtonStyle}"
						HorizontalAlignment="Stretch"
						Margin="0,8,0,0"
						Click="BtnSwitchAccount_Click" />
					</StackPanel>
				</Border>
				<StackPanel
					Grid.Column="1">
					<Border
					Style="{StaticResource StatCardStyle}"
					Margin="0,0,0,16">
						<StackPanel>
							<TextBlock
								Text="最近游戏"
								Foreground="#FFFFFF"
								FontSize="16"
								FontWeight="SemiBold"
								FontFamily="Microsoft YaHei"
								Margin="0,0,0,15" />
							<TextBlock
								Text="暂无游戏记录"
								Foreground="#888888"
								FontSize="13"
								FontFamily="Microsoft YaHei"
								HorizontalAlignment="Center"
								Margin="0,20,0,20" />
						</StackPanel>
					</Border>
					<Border
					Style="{StaticResource StatCardStyle}"
					Margin="0,0,0,16">
						<StackPanel>
							<TextBlock
								Text="游戏统计详情"
								Foreground="#FFFFFF"
								FontSize="16"
								FontWeight="SemiBold"
								FontFamily="Microsoft YaHei"
								Margin="0,0,0,15" />
							<Grid>
								<Grid.ColumnDefinitions>
									<ColumnDefinition
										Width="*" />
									<ColumnDefinition
										Width="*" />
								</Grid.ColumnDefinitions>
								<Grid.RowDefinitions>
									<RowDefinition
										Height="Auto" />
									<RowDefinition
										Height="Auto" />
								</Grid.RowDefinitions>
								<StackPanel
									Grid.Row="0"
									Grid.Column="0"
									Margin="0,0,0,15">
									<TextBlock
										Text="最喜欢的版本"
										Foreground="#AAAAAA"
										FontSize="12"
										FontFamily="Microsoft YaHei" />
									<TextBlock
										Text="尚未设置"
										Foreground="#FFFFFF"
										FontSize="13"
										FontFamily="Microsoft YaHei" />
								</StackPanel>
								<StackPanel
									Grid.Row="0"
									Grid.Column="1"
									Margin="0,0,0,15">
									<TextBlock
										Text="常用模组数量"
										Foreground="#AAAAAA"
										FontSize="12"
										FontFamily="Microsoft YaHei" />
									<TextBlock
										Text="0 个"
										Foreground="#FFFFFF"
										FontSize="13"
										FontFamily="Microsoft YaHei" />
								</StackPanel>
								<StackPanel
									Grid.Row="1"
									Grid.Column="0">
									<TextBlock
										Text="累计游戏时间"
										Foreground="#AAAAAA"
										FontSize="12"
										FontFamily="Microsoft YaHei" />
									<TextBlock
										Text="0 小时"
										Foreground="#FFFFFF"
										FontSize="13"
										FontFamily="Microsoft YaHei" />
								</StackPanel>
								<StackPanel
									Grid.Row="1"
									Grid.Column="1">
									<TextBlock
										Text="最近登录"
										Foreground="#AAAAAA"
										FontSize="12"
										FontFamily="Microsoft YaHei" />
									<TextBlock
										Text="今天"
										Foreground="#FFFFFF"
										FontSize="13"
										FontFamily="Microsoft YaHei" />
								</StackPanel>
							</Grid>
						</StackPanel>
					</Border>
					<Border
					Style="{StaticResource StatCardStyle}"
					Margin="0,0,0,0">
						<StackPanel>
							<TextBlock
								Text="快捷操作"
								Foreground="#FFFFFF"
								FontSize="16"
								FontWeight="SemiBold"
								FontFamily="Microsoft YaHei"
								Margin="0,0,0,15" />
							<Grid>
								<Grid.ColumnDefinitions>
									<ColumnDefinition
										Width="*" />
									<ColumnDefinition
										Width="*" />
									<ColumnDefinition
										Width="*" />
								</Grid.ColumnDefinitions>
										<Button
									Grid.Column="0"
									Content="🎮 快速开始"
									Style="{StaticResource PrimaryButtonStyle}"
									Margin="0,0,8,0"
									Click="BtnQuickStart_Click">
									<Button.Background>
										<LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
											<GradientStop Color="#2196F3" Offset="0" />
											<GradientStop Color="#64B5F6" Offset="1" />
										</LinearGradientBrush>
									</Button.Background>
								</Button>
								<Button
									Grid.Column="1"
									Content="🧩 浏览模组"
									Style="{StaticResource PrimaryButtonStyle}"
									Margin="0,0,8,0"
									Click="BtnBrowseMods_Click">
									<Button.Background>
										<LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
											<GradientStop Color="#2ECC71" Offset="0" />
											<GradientStop Color="#66BB6A" Offset="1" />
										</LinearGradientBrush>
									</Button.Background>
								</Button>
								<Button
									Grid.Column="2"
									Content="⚙️ 游戏设置"
									Style="{StaticResource PrimaryButtonStyle}"
									Click="BtnGameSettings_Click">
									<Button.Background>
										<LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
											<GradientStop Color="#E74C3C" Offset="0" />
											<GradientStop Color="#EF5350" Offset="1" />
										</LinearGradientBrush>
									</Button.Background>
								</Button>
							</Grid>
						</StackPanel>
					</Border>
				</StackPanel>
			</Grid>
		</Grid>
	</ScrollViewer>
</UserControl>

