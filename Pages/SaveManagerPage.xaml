<UserControl
	x:Class="MusicalNoteLauncher.Pages.SaveManagerPage" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	Background="#1E1E1E" xmlns:pages="clr-namespace:MusicalNoteLauncher.Pages">
	<Grid
		Background="#1E1E1E">
		<Grid.RowDefinitions>
			<RowDefinition
				Height="60" />
			<RowDefinition
				Height="*" />
		</Grid.RowDefinitions>
		<Border
			Grid.Row="0"
			Background="#2D2D2D">
			<StackPanel
				Orientation="Horizontal"
				Margin="20,0"
				VerticalAlignment="Center">
				<TextBlock
					Text="存档管理"
					FontSize="20"
					FontWeight="Bold"
					Foreground="#FFFFFF" />
			</StackPanel>
		</Border>
		<Grid
			Row="1"
			Margin="20">
			<Grid.RowDefinitions>
				<RowDefinition
					Height="*" />
				<RowDefinition
					Height="Auto" />
			</Grid.RowDefinitions>
			<Border
				Grid.Row="0"
				Background="#252525"
				CornerRadius="12"
				Padding="15"
				Margin="0,0,0,12">
				<Grid>
					<Grid.RowDefinitions>
						<RowDefinition
							Height="Auto" />
						<RowDefinition
							Height="*" />
					</Grid.RowDefinitions>
					<Grid
						Row="0"
						Margin="0,0,0,15">
						<TextBlock
							Text="游戏存档"
							Foreground="#FFFFFF"
							FontSize="16"
							FontWeight="SemiBold"
							FontFamily="Microsoft YaHei"
							VerticalAlignment="Center" />
						<StackPanel
							Orientation="Horizontal"
							HorizontalAlignment="Right">
							<Button
								Content="启动存档"
								Background="#2196F3"
								Foreground="#FFFFFF"
								BorderThickness="0"
								Padding="12,6"
								FontSize="13"
								FontFamily="Microsoft YaHei"
								Cursor="Hand"
								Margin="0,0,8,0"
								Click="BtnLaunchSave_Click">
								<Control.Template>
									<ControlTemplate
										TargetType="{x:Type Button}">
										<Border
											Name="border"
											Background="{TemplateBinding Background}"
											CornerRadius="4"
											Padding="{TemplateBinding Padding}">
											<ContentPresenter
												HorizontalAlignment="Center"
												VerticalAlignment="Center" />
										</Border>
										<ControlTemplate.Triggers>
											<Trigger
												Property="UIElement.IsMouseOver"
												Value="True">
												<Setter
													TargetName="border"
													Property="Background"
													Value="#1976D2" />
											</Trigger>
										</ControlTemplate.Triggers>
									</ControlTemplate>
								</Control.Template>
							</Button>
							<Button
								Content="备份存档"
								Background="#2ECC71"
								Foreground="#FFFFFF"
								BorderThickness="0"
								Padding="12,6"
								FontSize="13"
								FontFamily="Microsoft YaHei"
								Cursor="Hand"
								Margin="0,0,8,0"
								Click="BtnBackupSave_Click">
								<Control.Template>
									<ControlTemplate
										TargetType="{x:Type Button}">
										<Border
											Name="border"
											Background="{TemplateBinding Background}"
											CornerRadius="4"
											Padding="{TemplateBinding Padding}">
											<ContentPresenter
												HorizontalAlignment="Center"
												VerticalAlignment="Center" />
										</Border>
										<ControlTemplate.Triggers>
											<Trigger
												Property="UIElement.IsMouseOver"
												Value="True">
												<Setter
													TargetName="border"
													Property="Background"
													Value="#27AE60" />
											</Trigger>
										</ControlTemplate.Triggers>
									</ControlTemplate>
								</Control.Template>
							</Button>
							<Button
								Content="重命名"
								Background="#383838"
								Foreground="#FFFFFF"
								BorderThickness="1"
								BorderBrush="#3A3A3A"
								Padding="12,6"
								FontSize="13"
								FontFamily="Microsoft YaHei"
								Cursor="Hand"
								Margin="0,0,8,0"
								Click="BtnRenameSave_Click">
								<Control.Template>
									<ControlTemplate
										TargetType="{x:Type Button}">
										<Border
											Name="border"
											Background="{TemplateBinding Background}"
											BorderBrush="{TemplateBinding BorderBrush}"
											BorderThickness="{TemplateBinding BorderThickness}"
											CornerRadius="4"
											Padding="{TemplateBinding Padding}">
											<ContentPresenter
												HorizontalAlignment="Center"
												VerticalAlignment="Center" />
										</Border>
										<ControlTemplate.Triggers>
											<Trigger
												Property="UIElement.IsMouseOver"
												Value="True">
												<Setter
													TargetName="border"
													Property="Background"
													Value="#2D2D2D" />
											</Trigger>
										</ControlTemplate.Triggers>
									</ControlTemplate>
								</Control.Template>
							</Button>
							<Button
								Content="删除存档"
								Background="#383838"
								Foreground="#E74C3C"
								BorderThickness="1"
								BorderBrush="#E74C3C"
								Padding="12,6"
								FontSize="13"
								FontFamily="Microsoft YaHei"
								Cursor="Hand"
								Click="BtnDeleteSave_Click">
								<Control.Template>
									<ControlTemplate
										TargetType="{x:Type Button}">
										<Border
											Name="border"
											Background="{TemplateBinding Background}"
											BorderBrush="{TemplateBinding BorderBrush}"
											BorderThickness="{TemplateBinding BorderThickness}"
											CornerRadius="4"
											Padding="{TemplateBinding Padding}">
											<ContentPresenter
												HorizontalAlignment="Center"
												VerticalAlignment="Center" />
										</Border>
										<ControlTemplate.Triggers>
											<Trigger
												Property="UIElement.IsMouseOver"
												Value="True">
												<Setter
													TargetName="border"
													Property="Background"
													Value="#2D2D2D" />
											</Trigger>
										</ControlTemplate.Triggers>
									</ControlTemplate>
								</Control.Template>
							</Button>
						</StackPanel>
					</Grid>
					<ListBox
						Name="lstSaves"
						Grid.Row="1"
						Background="#1E1E1E"
						BorderThickness="0"
						Foreground="#FFFFFF"
						FontFamily="Microsoft YaHei">
						<ItemsControl.ItemContainerStyle>
							<Style
								TargetType="{x:Type ListBoxItem}">
								<Setter
									Property="HorizontalContentAlignment"
									Value="Stretch" />
							</Style>
						</ItemsControl.ItemContainerStyle>
						<ItemsControl.ItemTemplate>
							<DataTemplate>
								<Border
									Background="#2D2D2D"
									CornerRadius="4"
									Padding="12,10"
									Margin="0,4">
									<Grid>
										<Grid.ColumnDefinitions>
											<ColumnDefinition
												Width="Auto" />
											<ColumnDefinition
												Width="*" />
											<ColumnDefinition
												Width="Auto" />
										</Grid.ColumnDefinitions>
										<TextBlock
											Grid.Column="0"
											Text="📁"
											FontSize="20"
											VerticalAlignment="Center"
											Margin="0,0,10,0" />
										<StackPanel
											Grid.Column="1">
											<TextBlock
												Foreground="#FFFFFF"
												FontSize="14"
												Text="{Binding SaveName}" />
											<TextBlock
												Foreground="#AAAAAA"
												FontSize="12"
												Text="{Binding SaveInfo}" />
										</StackPanel>
										<TextBlock
											Grid.Column="2"
											Foreground="#2ECC71"
											FontSize="12"
											VerticalAlignment="Center"
											Text="{Binding PlayTime}" />
									</Grid>
								</Border>
							</DataTemplate>
						</ItemsControl.ItemTemplate>
					</ListBox>
				</Grid>
			</Border>
			<Grid
				Row="1">
				<Grid.ColumnDefinitions>
					<ColumnDefinition
						Width="*" />
					<ColumnDefinition
						Width="*" />
					<ColumnDefinition
						Width="*" />
				</Grid.ColumnDefinitions>
				<Button
					Grid.Column="0"
					Background="#383838"
					Foreground="#FFFFFF"
					BorderBrush="#3A3A3A"
					BorderThickness="1"
					Padding="16,10"
					FontSize="14"
					FontFamily="Microsoft YaHei"
					Cursor="Hand"
					Margin="0,0,12,0"
					Click="BtnRefreshSaves_Click">
					<Control.Template>
						<ControlTemplate
							TargetType="{x:Type Button}">
							<Border
								Name="border"
								Background="{TemplateBinding Background}"
								BorderBrush="{TemplateBinding BorderBrush}"
								BorderThickness="{TemplateBinding BorderThickness}"
								CornerRadius="12"
								Padding="{TemplateBinding Padding}">
								<ContentPresenter
									HorizontalAlignment="Center"
									VerticalAlignment="Center" />
							</Border>
							<ControlTemplate.Triggers>
								<Trigger
									Property="UIElement.IsMouseOver"
									Value="True">
									<Setter
										TargetName="border"
										Property="BorderBrush"
										Value="#2196F3" />
									<Setter
										TargetName="border"
										Property="Background"
										Value="#2D2D2D" />
								</Trigger>
							</ControlTemplate.Triggers>
						</ControlTemplate>
					</Control.Template>
					<StackPanel>
						<TextBlock
							Text="📁"
							FontSize="32"
							HorizontalAlignment="Center"
							Margin="0,0,0,8" />
						<TextBlock
							Text="游戏存档"
							FontSize="14"
							Foreground="#FFFFFF"
							FontFamily="Microsoft YaHei"
							HorizontalAlignment="Center" />
					</StackPanel>
				</Button>
				<Button
					Grid.Column="1"
					Background="#383838"
					Foreground="#FFFFFF"
					BorderBrush="#3A3A3A"
					BorderThickness="1"
					Padding="16,10"
					FontSize="14"
					FontFamily="Microsoft YaHei"
					Cursor="Hand"
					Margin="0,0,12,0"
					Click="BtnBackupManager_Click">
					<Control.Template>
						<ControlTemplate
							TargetType="{x:Type Button}">
							<Border
								Name="border"
								Background="{TemplateBinding Background}"
								BorderBrush="{TemplateBinding BorderBrush}"
								BorderThickness="{TemplateBinding BorderThickness}"
								CornerRadius="12"
								Padding="{TemplateBinding Padding}">
								<ContentPresenter
									HorizontalAlignment="Center"
									VerticalAlignment="Center" />
							</Border>
							<ControlTemplate.Triggers>
								<Trigger
									Property="UIElement.IsMouseOver"
									Value="True">
									<Setter
										TargetName="border"
										Property="BorderBrush"
										Value="#2196F3" />
									<Setter
										TargetName="border"
										Property="Background"
										Value="#2D2D2D" />
								</Trigger>
							</ControlTemplate.Triggers>
						</ControlTemplate>
					</Control.Template>
					<StackPanel>
						<TextBlock
							Text="💾"
							FontSize="32"
							HorizontalAlignment="Center"
							Margin="0,0,0,8" />
						<TextBlock
							Text="备份管理"
							FontSize="14"
							Foreground="#FFFFFF"
							FontFamily="Microsoft YaHei"
							HorizontalAlignment="Center" />
					</StackPanel>
				</Button>
				<Button
					Grid.Column="2"
					Background="#383838"
					Foreground="#FFFFFF"
					BorderBrush="#3A3A3A"
					BorderThickness="1"
					Padding="16,10"
					FontSize="14"
					FontFamily="Microsoft YaHei"
					Cursor="Hand"
					Margin="0,0,0,0"
					Click="BtnImportSave_Click">
					<Control.Template>
						<ControlTemplate
							TargetType="{x:Type Button}">
							<Border
								Name="border"
								Background="{TemplateBinding Background}"
								BorderBrush="{TemplateBinding BorderBrush}"
								BorderThickness="{TemplateBinding BorderThickness}"
								CornerRadius="12"
								Padding="{TemplateBinding Padding}">
								<ContentPresenter
									HorizontalAlignment="Center"
									VerticalAlignment="Center" />
							</Border>
							<ControlTemplate.Triggers>
								<Trigger
									Property="UIElement.IsMouseOver"
									Value="True">
									<Setter
										TargetName="border"
										Property="BorderBrush"
										Value="#2196F3" />
									<Setter
										TargetName="border"
										Property="Background"
										Value="#2D2D2D" />
								</Trigger>
							</ControlTemplate.Triggers>
						</ControlTemplate>
					</Control.Template>
					<StackPanel>
						<TextBlock
							Text="📥"
							FontSize="32"
							HorizontalAlignment="Center"
							Margin="0,0,0,8" />
						<TextBlock
							Text="导入存档"
							FontSize="14"
							Foreground="#FFFFFF"
							FontFamily="Microsoft YaHei"
							HorizontalAlignment="Center" />
					</StackPanel>
				</Button>
			</Grid>
		</Grid>
	</Grid>
</UserControl>

