<UserControl
	x:Class="MusicalNoteLauncher.Pages.CommunityPage" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	Background="#1E1E1E" xmlns:pages="clr-namespace:MusicalNoteLauncher.Pages">
	<ScrollViewer
		VerticalScrollBarVisibility="Auto">
		<Grid
			Margin="20">
			<Grid.RowDefinitions>
				<RowDefinition
					Height="Auto" />
				<RowDefinition
					Height="Auto" />
				<RowDefinition
					Height="*" />
			</Grid.RowDefinitions>
			<TextBlock
				Grid.Row="0"
				Text="交流社区"
				Foreground="#FFFFFF"
				FontSize="24"
				FontWeight="SemiBold"
				FontFamily="Microsoft YaHei"
				Margin="0,0,0,20" />
			<Border
				Grid.Row="1"
				Background="#252525"
				CornerRadius="8"
				Padding="15"
				Margin="0,0,0,20">
				<StackPanel>
					<TextBlock
						Text="发布帖子"
						Foreground="#FFFFFF"
						FontSize="16"
						FontWeight="SemiBold"
						FontFamily="Microsoft YaHei"
						Margin="0,0,0,15" />
					<TextBox
						Name="txtPostContent"
						Background="#383838"
						Foreground="#FFFFFF"
						BorderBrush="#3A3A3A"
						BorderThickness="1"
						Padding="12,10"
						FontSize="13"
						FontFamily="Microsoft YaHei"
						TextWrapping="Wrap"
						AcceptsReturn="True"
						Height="80" />
					<StackPanel
						Orientation="Horizontal"
						HorizontalAlignment="Right"
						Margin="0,10,0,0">
						<Button
							Content="发布帖子"
							Background="#2196F3"
							Foreground="#FFFFFF"
							BorderThickness="0"
							Padding="16,8"
							FontSize="13"
							FontFamily="Microsoft YaHei"
							Cursor="Hand"
							Click="BtnPost_Click">
							<Control.Template>
								<ControlTemplate
									TargetType="{x:Type Button}">
									<Border
										Name="border"
										Background="{TemplateBinding Background}"
										CornerRadius="4"
										Padding="{TemplateBinding Padding}">
										<ContentPresenter
											HorizontalAlignment="Center"
											VerticalAlignment="Center" />
									</Border>
									<ControlTemplate.Triggers>
										<Trigger
											Property="UIElement.IsMouseOver"
											Value="True">
											<Setter
												TargetName="border"
												Property="Background"
												Value="#1976D2" />
										</Trigger>
									</ControlTemplate.Triggers>
								</ControlTemplate>
							</Control.Template>
						</Button>
					</StackPanel>
				</StackPanel>
			</Border>
			<Border
				Grid.Row="2"
				Background="#252525"
				CornerRadius="8"
				Padding="15">
				<Grid>
					<Grid.RowDefinitions>
						<RowDefinition
							Height="Auto" />
						<RowDefinition
							Height="*" />
					</Grid.RowDefinitions>
					<TextBlock
						Grid.Row="0"
						Text="热门帖子"
						Foreground="#FFFFFF"
						FontSize="16"
						FontWeight="SemiBold"
						FontFamily="Microsoft YaHei"
						Margin="0,0,0,15" />
					<ListBox
						Name="lstPosts"
						Grid.Row="1"
						Background="#1E1E1E"
						BorderThickness="0"
						Foreground="#FFFFFF"
						FontFamily="Microsoft YaHei">
						<ItemsControl.ItemTemplate>
							<DataTemplate>
								<Border
									Background="#2D2D2D"
									CornerRadius="4"
									Padding="15,12"
									Margin="0,6">
									<StackPanel>
										<Grid
											Margin="0,0,0,8">
											<Grid.ColumnDefinitions>
												<ColumnDefinition
													Width="Auto" />
												<ColumnDefinition
													Width="*" />
												<ColumnDefinition
													Width="Auto" />
											</Grid.ColumnDefinitions>
											<Border
												Grid.Column="0"
												Width="36"
												Height="36"
												Background="#2196F3"
												CornerRadius="18"
												Margin="0,0,10,0">
												<TextBlock
													Text="👤"
													FontSize="16"
													HorizontalAlignment="Center"
													VerticalAlignment="Center" />
											</Border>
											<StackPanel
												Grid.Column="1"
												VerticalAlignment="Center">
												<TextBlock
													Foreground="#FFFFFF"
													FontSize="14"
													FontWeight="SemiBold"
													Text="{Binding Author}" />
												<TextBlock
													Foreground="#AAAAAA"
													FontSize="11"
													Text="{Binding Time}" />
											</StackPanel>
											<!--未知连接 ID：4-->
											<Button
												Grid.Column="2"
												Content="回复"
												Background="#383838"
												Foreground="#FFFFFF"
												BorderThickness="1"
												BorderBrush="#3A3A3A"
												Padding="12,4"
												FontSize="12"
												FontFamily="Microsoft YaHei"
												Cursor="Hand">
												<Control.Template>
													<ControlTemplate
														TargetType="{x:Type Button}">
														<Border
															Name="border"
															Background="{TemplateBinding Background}"
															BorderBrush="{TemplateBinding BorderBrush}"
															BorderThickness="{TemplateBinding BorderThickness}"
															CornerRadius="4"
															Padding="{TemplateBinding Padding}">
															<ContentPresenter
																HorizontalAlignment="Center"
																VerticalAlignment="Center" />
														</Border>
														<ControlTemplate.Triggers>
															<Trigger
																Property="UIElement.IsMouseOver"
																Value="True">
																<Setter
																	TargetName="border"
																	Property="Background"
																	Value="#2D2D2D" />
															</Trigger>
														</ControlTemplate.Triggers>
													</ControlTemplate>
												</Control.Template>
											</Button>
										</Grid>
										<TextBlock
											Foreground="#FFFFFF"
											FontSize="13"
											TextWrapping="Wrap"
											Margin="0,0,0,10"
											Text="{Binding Content}" />
										<StackPanel
											Orientation="Horizontal">
											<TextBlock
												Text="👍"
												FontSize="14"
												Margin="0,0,4,0" />
											<TextBlock
												Foreground="#AAAAAA"
												FontSize="12"
												Margin="0,0,15,0"
												Text="{Binding LikeCount}" />
											<TextBlock
												Text="💬"
												FontSize="14"
												Margin="0,0,4,0" />
											<TextBlock
												Foreground="#AAAAAA"
												FontSize="12"
												Text="{Binding CommentCount}" />
										</StackPanel>
									</StackPanel>
								</Border>
							</DataTemplate>
						</ItemsControl.ItemTemplate>
					</ListBox>
				</Grid>
			</Border>
		</Grid>
	</ScrollViewer>
</UserControl>

