<UserControl
	x:Class="MusicalNoteLauncher.Pages.ModManagerPage" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	Background="#1E1E1E" xmlns:pages="clr-namespace:MusicalNoteLauncher.Pages">
	<Grid
		Background="#1E1E1E">
		<Grid.RowDefinitions>
			<RowDefinition
				Height="60" />
			<RowDefinition
				Height="*" />
		</Grid.RowDefinitions>
		<Border
			Grid.Row="0"
			Background="#2D2D2D">
			<StackPanel
				Orientation="Horizontal"
				Margin="20,0"
				VerticalAlignment="Center">
				<TextBlock
					Text="模组管理"
					FontSize="20"
					FontWeight="Bold"
					Foreground="#FFFFFF" />
				<TextBlock
					Name="txtLoaderInfo"
					Margin="15,0,0,0"
					FontSize="14"
					Foreground="#AAAAAA" />
			</StackPanel>
		</Border>
		<Grid
			Name="gridNoLoader"
			Row="1"
			Visibility="Collapsed">
			<Grid
				HorizontalAlignment="Center"
				VerticalAlignment="Center"
				Width="600">
				<Grid.RowDefinitions>
					<RowDefinition
						Height="Auto" />
					<RowDefinition
						Height="Auto" />
					<RowDefinition
						Height="Auto" />
				</Grid.RowDefinitions>
				<Border
					Grid.Row="0"
					Background="#2D2D2D"
					CornerRadius="12"
					Padding="40,30"
					Margin="0,0,0,20">
					<StackPanel>
						<TextBlock
							Text="⚠️"
							FontSize="48"
							HorizontalAlignment="Center"
							Margin="0,0,0,15" />
						<TextBlock
							Text="还未安装 Forge 等模组管理器"
							FontSize="18"
							FontWeight="SemiBold"
							Foreground="#FFFFFF"
							HorizontalAlignment="Center"
							Margin="0,0,0,10" />
						<TextBlock
							Text="暂时无法使用Mod管理功能~"
							FontSize="14"
							Foreground="#AAAAAA"
							HorizontalAlignment="Center" />
					</StackPanel>
				</Border>
				<Button
					Grid.Row="1"
					Content="点击此处安装 Forge"
					Background="#2ECC71"
					Foreground="#FFFFFF"
					BorderThickness="0"
					Padding="24,12"
					FontSize="16"
					FontFamily="Microsoft YaHei"
					Cursor="Hand"
					Click="BtnInstallForge_Click">
					<Control.Template>
						<ControlTemplate
							TargetType="{x:Type Button}">
							<Border
								Name="border"
								Background="{TemplateBinding Background}"
								CornerRadius="8"
								Padding="{TemplateBinding Padding}">
								<ContentPresenter
									HorizontalAlignment="Center"
									VerticalAlignment="Center" />
							</Border>
							<ControlTemplate.Triggers>
								<Trigger
									Property="UIElement.IsMouseOver"
									Value="True">
									<Setter
										TargetName="border"
										Property="Background"
										Value="#27AE60" />
								</Trigger>
							</ControlTemplate.Triggers>
						</ControlTemplate>
					</Control.Template>
				</Button>

			</Grid>
		</Grid>
		<Grid
			Name="gridHasLoader"
			Row="1">
			<Grid
				Margin="20">
				<Grid.RowDefinitions>
					<RowDefinition
						Height="*" />
					<RowDefinition
						Height="Auto" />
				</Grid.RowDefinitions>
				<Border
					Grid.Row="0"
					Background="#252525"
					CornerRadius="12"
					Padding="15"
					Margin="0,0,0,12">
					<Grid>
						<Grid.RowDefinitions>
							<RowDefinition
								Height="Auto" />
							<RowDefinition
								Height="*" />
						</Grid.RowDefinitions>
						<Grid
							Row="0"
							Margin="0,0,0,15">
							<TextBlock
								Text="已安装模组"
								Foreground="#FFFFFF"
								FontSize="16"
								FontWeight="SemiBold"
								FontFamily="Microsoft YaHei"
								VerticalAlignment="Center" />
							<StackPanel
								Orientation="Horizontal"
								HorizontalAlignment="Right">
								<Button
									Content="启用选中"
									Background="#2ECC71"
									Foreground="#FFFFFF"
									BorderThickness="0"
									Padding="12,6"
									FontSize="13"
									FontFamily="Microsoft YaHei"
									Cursor="Hand"
									Margin="0,0,8,0"
									Click="BtnEnableMods_Click">
									<Control.Template>
										<ControlTemplate
											TargetType="{x:Type Button}">
											<Border
												Name="border"
												Background="{TemplateBinding Background}"
												CornerRadius="4"
												Padding="{TemplateBinding Padding}">
												<ContentPresenter
													HorizontalAlignment="Center"
													VerticalAlignment="Center" />
											</Border>
											<ControlTemplate.Triggers>
												<Trigger
													Property="UIElement.IsMouseOver"
													Value="True">
													<Setter
														TargetName="border"
														Property="Background"
														Value="#27AE60" />
												</Trigger>
											</ControlTemplate.Triggers>
										</ControlTemplate>
									</Control.Template>
								</Button>
								<Button
									Content="禁用选中"
									Background="#E74C3C"
									Foreground="#FFFFFF"
									BorderThickness="0"
									Padding="12,6"
									FontSize="13"
									FontFamily="Microsoft YaHei"
									Cursor="Hand"
									Margin="0,0,8,0"
									Click="BtnDisableMods_Click">
									<Control.Template>
										<ControlTemplate
											TargetType="{x:Type Button}">
											<Border
												Name="border"
												Background="{TemplateBinding Background}"
												CornerRadius="4"
												Padding="{TemplateBinding Padding}">
												<ContentPresenter
													HorizontalAlignment="Center"
													VerticalAlignment="Center" />
											</Border>
											<ControlTemplate.Triggers>
												<Trigger
													Property="UIElement.IsMouseOver"
													Value="True">
													<Setter
														TargetName="border"
														Property="Background"
														Value="#C0392B" />
												</Trigger>
											</ControlTemplate.Triggers>
										</ControlTemplate>
									</Control.Template>
								</Button>
								<Button
									Content="卸载选中"
									Background="#383838"
									Foreground="#FFFFFF"
									BorderThickness="1"
									BorderBrush="#E74C3C"
									Padding="12,6"
									FontSize="13"
									FontFamily="Microsoft YaHei"
									Cursor="Hand"
									Click="BtnUninstallMod_Click">
									<Control.Template>
										<ControlTemplate
											TargetType="{x:Type Button}">
											<Border
												Name="border"
												Background="{TemplateBinding Background}"
												BorderBrush="{TemplateBinding BorderBrush}"
												BorderThickness="{TemplateBinding BorderThickness}"
												CornerRadius="4"
												Padding="{TemplateBinding Padding}">
												<ContentPresenter
													HorizontalAlignment="Center"
													VerticalAlignment="Center" />
											</Border>
											<ControlTemplate.Triggers>
												<Trigger
													Property="UIElement.IsMouseOver"
													Value="True">
													<Setter
														TargetName="border"
														Property="Background"
														Value="#2D2D2D" />
												</Trigger>
											</ControlTemplate.Triggers>
										</ControlTemplate>
									</Control.Template>
								</Button>
							</StackPanel>
						</Grid>
						<ListBox
							Name="lstMods"
							Grid.Row="1"
							Background="#1E1E1E"
							BorderThickness="0"
							Foreground="#FFFFFF"
							FontFamily="Microsoft YaHei"
							ScrollViewer.HorizontalScrollBarVisibility="Disabled">
							<ItemsControl.ItemContainerStyle>
								<Style
									TargetType="{x:Type ListBoxItem}">
									<Setter
										Property="HorizontalContentAlignment"
										Value="Stretch" />
									<Setter
										Property="Padding"
										Value="0" />
									<Setter
										Property="Margin"
										Value="0" />
								</Style>
							</ItemsControl.ItemContainerStyle>
							<ItemsControl.ItemTemplate>
								<DataTemplate>
									<Border
										Background="#2D2D2D"
										CornerRadius="4"
										Padding="12,10"
										Margin="0,4">
										<Grid>
											<Grid.ColumnDefinitions>
												<ColumnDefinition
													Width="Auto" />
												<ColumnDefinition
													Width="*" />
												<ColumnDefinition
													Width="Auto" />
											</Grid.ColumnDefinitions>
											<CheckBox
												Grid.Column="0"
												IsChecked="True"
												VerticalAlignment="Center" />
											<StackPanel
												Grid.Column="1"
												Margin="10,0">
												<TextBlock
													Foreground="#FFFFFF"
													FontSize="14"
													Text="{Binding ModName}" />
												<TextBlock
													Foreground="#AAAAAA"
													FontSize="12"
													Text="{Binding ModVersion}" />
											</StackPanel>
											<TextBlock
												Grid.Column="2"
												Text="✓"
												Foreground="#2ECC71"
												FontSize="16"
												VerticalAlignment="Center" />
										</Grid>
									</Border>
								</DataTemplate>
							</ItemsControl.ItemTemplate>
						</ListBox>
					</Grid>
				</Border>
				<Grid
					Row="1">
					<Grid.ColumnDefinitions>
						<ColumnDefinition
							Width="*" />
						<ColumnDefinition
							Width="*" />
						<ColumnDefinition
							Width="*" />
					</Grid.ColumnDefinitions>
					<Button
						Grid.Column="0"
						Background="#383838"
						Foreground="#FFFFFF"
						BorderBrush="#3A3A3A"
						BorderThickness="1"
						Padding="16,10"
						FontSize="14"
						FontFamily="Microsoft YaHei"
						Cursor="Hand"
						Margin="0,0,12,0"
						Click="BtnRefreshMods_Click">
						<Control.Template>
							<ControlTemplate
								TargetType="{x:Type Button}">
								<Border
									Name="border"
									Background="{TemplateBinding Background}"
									BorderBrush="{TemplateBinding BorderBrush}"
									BorderThickness="{TemplateBinding BorderThickness}"
									CornerRadius="12"
									Padding="{TemplateBinding Padding}">
									<ContentPresenter
										HorizontalAlignment="Center"
										VerticalAlignment="Center" />
								</Border>
								<ControlTemplate.Triggers>
									<Trigger
										Property="UIElement.IsMouseOver"
										Value="True">
										<Setter
											TargetName="border"
											Property="BorderBrush"
											Value="#2196F3" />
										<Setter
											TargetName="border"
											Property="Background"
											Value="#2D2D2D" />
									</Trigger>
								</ControlTemplate.Triggers>
							</ControlTemplate>
						</Control.Template>
						<StackPanel>
							<TextBlock
								Text="📦"
								FontSize="32"
								HorizontalAlignment="Center"
								Margin="0,0,0,8" />
							<TextBlock
								Text="已安装模组"
								FontSize="14"
								Foreground="#FFFFFF"
								FontFamily="Microsoft YaHei"
								HorizontalAlignment="Center" />
						</StackPanel>
					</Button>
					<Button
						Grid.Column="1"
						Background="#383838"
						Foreground="#FFFFFF"
						BorderBrush="#3A3A3A"
						BorderThickness="1"
						Padding="16,10"
						FontSize="14"
						FontFamily="Microsoft YaHei"
						Cursor="Hand"
						Margin="0,0,12,0"
						Click="BtnAddMod_Click">
						<Control.Template>
							<ControlTemplate
								TargetType="{x:Type Button}">
								<Border
									Name="border"
									Background="{TemplateBinding Background}"
									BorderBrush="{TemplateBinding BorderBrush}"
									BorderThickness="{TemplateBinding BorderThickness}"
									CornerRadius="12"
									Padding="{TemplateBinding Padding}">
									<ContentPresenter
										HorizontalAlignment="Center"
										VerticalAlignment="Center" />
								</Border>
								<ControlTemplate.Triggers>
									<Trigger
										Property="UIElement.IsMouseOver"
										Value="True">
										<Setter
											TargetName="border"
											Property="BorderBrush"
											Value="#2196F3" />
										<Setter
											TargetName="border"
											Property="Background"
											Value="#2D2D2D" />
									</Trigger>
								</ControlTemplate.Triggers>
							</ControlTemplate>
						</Control.Template>
						<StackPanel>
							<TextBlock
								Text="➕"
								FontSize="32"
								HorizontalAlignment="Center"
								Margin="0,0,0,8" />
							<TextBlock
								Text="添加模组"
								FontSize="14"
								Foreground="#FFFFFF"
								FontFamily="Microsoft YaHei"
								HorizontalAlignment="Center" />
						</StackPanel>
					</Button>
					<Button
						Grid.Column="2"
						Background="#383838"
						Foreground="#FFFFFF"
						BorderBrush="#3A3A3A"
						BorderThickness="1"
						Padding="16,10"
						FontSize="14"
						FontFamily="Microsoft YaHei"
						Cursor="Hand"
						Margin="0,0,0,0"
						Click="BtnModMarket_Click">
						<Control.Template>
							<ControlTemplate
								TargetType="{x:Type Button}">
								<Border
									Name="border"
									Background="{TemplateBinding Background}"
									BorderBrush="{TemplateBinding BorderBrush}"
									BorderThickness="{TemplateBinding BorderThickness}"
									CornerRadius="12"
									Padding="{TemplateBinding Padding}">
									<ContentPresenter
										HorizontalAlignment="Center"
										VerticalAlignment="Center" />
								</Border>
								<ControlTemplate.Triggers>
									<Trigger
										Property="UIElement.IsMouseOver"
										Value="True">
										<Setter
											TargetName="border"
											Property="BorderBrush"
											Value="#2196F3" />
										<Setter
											TargetName="border"
											Property="Background"
											Value="#2D2D2D" />
									</Trigger>
								</ControlTemplate.Triggers>
							</ControlTemplate>
						</Control.Template>
						<StackPanel>
							<TextBlock
								Text="🛒"
								FontSize="32"
								HorizontalAlignment="Center"
								Margin="0,0,0,8" />
							<TextBlock
								Text="模组下载"
								FontSize="14"
								Foreground="#FFFFFF"
								FontFamily="Microsoft YaHei"
								HorizontalAlignment="Center" />
						</StackPanel>
					</Button>
				</Grid>
			</Grid>
		</Grid>
	</Grid>
</UserControl>

