<UserControl
	x:Class="MusicalNoteLauncher.Pages.DownloadTaskPage" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	Background="#1E1E1E" xmlns:pages="clr-namespace:MusicalNoteLauncher.Pages">
	<ScrollViewer
		VerticalScrollBarVisibility="Auto">
		<Grid
			Margin="20">
			<Grid.RowDefinitions>
				<RowDefinition
					Height="Auto" />
				<RowDefinition
					Height="*" />
			</Grid.RowDefinitions>
			<Grid
				Row="0"
				Margin="0,0,0,20">
				<TextBlock
					Text="下载任务"
					Foreground="#FFFFFF"
					FontSize="24"
					FontWeight="SemiBold"
					FontFamily="Microsoft YaHei"
					VerticalAlignment="Center" />
				<StackPanel
					Orientation="Horizontal"
					HorizontalAlignment="Right">
					<Button
						Content="全部暂停"
						Background="#E74C3C"
						Foreground="#FFFFFF"
						BorderThickness="0"
						Padding="12,6"
						FontSize="13"
						FontFamily="Microsoft YaHei"
						Cursor="Hand"
						Margin="0,0,8,0"
						Click="BtnPauseAll_Click">
						<Control.Template>
							<ControlTemplate
								TargetType="{x:Type Button}">
								<Border
									Name="border"
									Background="{TemplateBinding Background}"
									CornerRadius="4"
									Padding="{TemplateBinding Padding}">
									<ContentPresenter
										HorizontalAlignment="Center"
										VerticalAlignment="Center" />
								</Border>
								<ControlTemplate.Triggers>
									<Trigger
										Property="UIElement.IsMouseOver"
										Value="True">
										<Setter
											TargetName="border"
											Property="Background"
											Value="#C0392B" />
									</Trigger>
								</ControlTemplate.Triggers>
							</ControlTemplate>
						</Control.Template>
					</Button>
					<Button
						Content="清空已完成"
						Background="#383838"
						Foreground="#FFFFFF"
						BorderThickness="1"
						BorderBrush="#3A3A3A"
						Padding="12,6"
						FontSize="13"
						FontFamily="Microsoft YaHei"
						Cursor="Hand"
						Click="BtnClearCompleted_Click">
						<Control.Template>
							<ControlTemplate
								TargetType="{x:Type Button}">
								<Border
									Name="border"
									Background="{TemplateBinding Background}"
									BorderBrush="{TemplateBinding BorderBrush}"
									BorderThickness="{TemplateBinding BorderThickness}"
									CornerRadius="4"
									Padding="{TemplateBinding Padding}">
									<ContentPresenter
										HorizontalAlignment="Center"
										VerticalAlignment="Center" />
								</Border>
								<ControlTemplate.Triggers>
									<Trigger
										Property="UIElement.IsMouseOver"
										Value="True">
										<Setter
											TargetName="border"
											Property="Background"
											Value="#2D2D2D" />
									</Trigger>
								</ControlTemplate.Triggers>
							</ControlTemplate>
						</Control.Template>
					</Button>
				</StackPanel>
			</Grid>
			<Border
				Grid.Row="1"
				Background="#252525"
				CornerRadius="8"
				Padding="15">
				<Grid>
					<Grid.RowDefinitions>
						<RowDefinition
							Height="Auto" />
						<RowDefinition
							Height="*" />
					</Grid.RowDefinitions>
					<Grid
						Row="0"
						Margin="0,0,0,10">
						<Grid.ColumnDefinitions>
							<ColumnDefinition
								Width="*" />
							<ColumnDefinition
								Width="120" />
							<ColumnDefinition
								Width="100" />
							<ColumnDefinition
								Width="120" />
							<ColumnDefinition
								Width="100" />
							<ColumnDefinition
								Width="150" />
						</Grid.ColumnDefinitions>
						<TextBlock
							Grid.Column="0"
							Text="游戏版本"
							Foreground="#AAAAAA"
							FontSize="12"
							FontFamily="Microsoft YaHei" />
						<TextBlock
							Grid.Column="1"
							Text="大小"
							Foreground="#AAAAAA"
							FontSize="12"
							FontFamily="Microsoft YaHei"
							HorizontalAlignment="Center" />
						<TextBlock
							Grid.Column="2"
							Text="进度"
							Foreground="#AAAAAA"
							FontSize="12"
							FontFamily="Microsoft YaHei"
							HorizontalAlignment="Center" />
						<TextBlock
							Grid.Column="3"
							Text="速度"
							Foreground="#AAAAAA"
							FontSize="12"
							FontFamily="Microsoft YaHei"
							HorizontalAlignment="Center" />
						<TextBlock
							Grid.Column="4"
							Text="状态"
							Foreground="#AAAAAA"
							FontSize="12"
							FontFamily="Microsoft YaHei"
							HorizontalAlignment="Center" />
						<TextBlock
							Grid.Column="5"
							Text="操作"
							Foreground="#AAAAAA"
							FontSize="12"
							FontFamily="Microsoft YaHei"
							HorizontalAlignment="Center" />
					</Grid>
					<ListBox
						Name="lstDownloadTasks"
						Grid.Row="1"
						Background="#1E1E1E"
						BorderThickness="0"
						Foreground="#FFFFFF"
						FontFamily="Microsoft YaHei">
						<ItemsControl.ItemContainerStyle>
							<Style
								TargetType="{x:Type ListBoxItem}">
								<Setter
									Property="HorizontalContentAlignment"
									Value="Stretch" />
								<Setter
									Property="Padding"
									Value="0" />
								<Setter
									Property="Margin"
									Value="0" />
							</Style>
						</ItemsControl.ItemContainerStyle>
						<ItemsControl.ItemTemplate>
							<DataTemplate>
								<Border
									Background="#2D2D2D"
									CornerRadius="4"
									Padding="12,10"
									Margin="0,4">
									<Grid>
										<Grid.ColumnDefinitions>
											<ColumnDefinition
												Width="*" />
											<ColumnDefinition
												Width="120" />
											<ColumnDefinition
												Width="100" />
											<ColumnDefinition
												Width="120" />
											<ColumnDefinition
												Width="100" />
											<ColumnDefinition
												Width="150" />
										</Grid.ColumnDefinitions>
										<StackPanel
											Grid.Column="0"
											Orientation="Horizontal">
											<TextBlock
												Text="📥"
												FontSize="16"
												VerticalAlignment="Center"
												Margin="0,0,8,0" />
											<TextBlock
												Foreground="#FFFFFF"
												FontSize="13"
												VerticalAlignment="Center"
												Text="{Binding FileName}" />
										</StackPanel>
										<TextBlock
											Grid.Column="1"
											Foreground="#AAAAAA"
											FontSize="12"
											HorizontalAlignment="Center"
											VerticalAlignment="Center"
											Text="{Binding FileSize}" />
										<StackPanel
											Grid.Column="2"
											HorizontalAlignment="Center"
											VerticalAlignment="Center">
											<TextBlock
												Foreground="#FFFFFF"
												FontSize="12"
												HorizontalAlignment="Center"
												Text="{Binding ProgressText}" />
											<ProgressBar
												Minimum="0"
												Maximum="100"
												Width="60"
												Height="4"
												Margin="0,4,0,0"
												Foreground="#2196F3"
												Background="#383838"
												Value="{Binding Progress}" />
										</StackPanel>
										<TextBlock
											Grid.Column="3"
											Foreground="#2ECC71"
											FontSize="12"
											HorizontalAlignment="Center"
											VerticalAlignment="Center"
											Text="{Binding Speed}" />
										<StackPanel
											Grid.Column="4"
											Orientation="Horizontal"
											HorizontalAlignment="Center"
											VerticalAlignment="Center">
											<TextBlock
												FontSize="14"
												VerticalAlignment="Center"
												Text="{Binding StatusIcon}" />
											<TextBlock
												Foreground="#AAAAAA"
												FontSize="12"
												Margin="4,0,0,0"
												VerticalAlignment="Center"
												Text="{Binding Status}" />
										</StackPanel>
										<StackPanel
											Grid.Column="5"
											Orientation="Horizontal"
											HorizontalAlignment="Center"
											VerticalAlignment="Center">
											<!--未知连接 ID：4-->
											<Button
												Name="btnPause"
												Content="暂停"
												Width="50"
												Height="26"
												FontSize="11"
												Background="#4A4A4A"
												Foreground="#FFFFFF"
												BorderThickness="0"
												IsEnabled="{Binding IsDownloading}">
												<Button.Template>
													<ControlTemplate
														TargetType="{x:Type Button}">
														<Border
															Name="border"
															Background="{TemplateBinding Background}"
															CornerRadius="4"
															Padding="8,2">
															<ContentPresenter
																HorizontalAlignment="Center"
																VerticalAlignment="Center" />
														</Border>
														<ControlTemplate.Triggers>
															<Trigger
																Property="UIElement.IsMouseOver"
																Value="True">
																<Setter
																	TargetName="border"
																	Property="Background"
																	Value="#5A5A5A" />
															</Trigger>
															<Trigger
																Property="UIElement.IsEnabled"
																Value="False">
																<Setter
																	TargetName="border"
																	Property="Background"
																	Value="#2E2E2E" />
																<Setter
																	Property="TextElement.Foreground"
																	Value="#888888" />
															</Trigger>
														</ControlTemplate.Triggers>
													</ControlTemplate>
												</Button.Template>
											</Button>
											<!--未知连接 ID：5-->
											<Button
												Name="btnResume"
												Content="恢复"
												Width="50"
												Height="26"
												FontSize="11"
												Background="#23854E"
												Foreground="#FFFFFF"
												BorderThickness="0"
												Margin="4,0,0,0"
												IsEnabled="{Binding IsPaused}">
												<Button.Template>
													<ControlTemplate
														TargetType="{x:Type Button}">
														<Border
															Name="border"
															Background="{TemplateBinding Background}"
															CornerRadius="4"
															Padding="8,2">
															<ContentPresenter
																HorizontalAlignment="Center"
																VerticalAlignment="Center" />
														</Border>
														<ControlTemplate.Triggers>
															<Trigger
																Property="UIElement.IsMouseOver"
																Value="True">
																<Setter
																	TargetName="border"
																	Property="Background"
																	Value="#1E7042" />
															</Trigger>
															<Trigger
																Property="UIElement.IsEnabled"
																Value="False">
																<Setter
																	TargetName="border"
																	Property="Background"
																	Value="#2E2E2E" />
																<Setter
																	Property="TextElement.Foreground"
																	Value="#888888" />
															</Trigger>
														</ControlTemplate.Triggers>
													</ControlTemplate>
												</Button.Template>
											</Button>
											<!--未知连接 ID：6-->
											<Button
												Name="btnDelete"
												Content="删除"
												Width="50"
												Height="26"
												FontSize="11"
												Background="#C0392B"
												Foreground="#FFFFFF"
												BorderThickness="0"
												Margin="4,0,0,0">
												<Button.Template>
													<ControlTemplate
														TargetType="{x:Type Button}">
														<Border
															Name="border"
															Background="{TemplateBinding Background}"
															CornerRadius="4"
															Padding="8,2">
															<ContentPresenter
																HorizontalAlignment="Center"
																VerticalAlignment="Center" />
														</Border>
														<ControlTemplate.Triggers>
															<Trigger
																Property="UIElement.IsMouseOver"
																Value="True">
																<Setter
																	TargetName="border"
																	Property="Background"
																	Value="#A93226" />
															</Trigger>
														</ControlTemplate.Triggers>
													</ControlTemplate>
												</Button.Template>
											</Button>
										</StackPanel>
									</Grid>
								</Border>
							</DataTemplate>
						</ItemsControl.ItemTemplate>
					</ListBox>
					<StackPanel
						Name="pnlEmptyState"
						Grid.Row="1"
						Visibility="Visible"
						HorizontalAlignment="Center"
						VerticalAlignment="Center">
						<TextBlock
							Text="📥"
							FontSize="64"
							HorizontalAlignment="Center"
							Margin="0,0,0,15" />
						<TextBlock
							Text="暂无下载任务"
							Foreground="#888888"
							FontSize="16"
							FontFamily="Microsoft YaHei"
							HorizontalAlignment="Center" />
						<TextBlock
							Text="前往下载页面开始下载资源"
							Foreground="#666666"
							FontSize="13"
							FontFamily="Microsoft YaHei"
							HorizontalAlignment="Center"
							Margin="0,8,0,0" />
					</StackPanel>
				</Grid>
			</Border>
		</Grid>
	</ScrollViewer>
</UserControl>

