<UserControl
	x:Class="MusicalNoteLauncher.Pages.ShadersPage" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:local="clr-namespace:MusicalNoteLauncher.Pages"
	Background="#1E1E1E">
	<Grid
		Background="#1E1E1E">
		<Grid.RowDefinitions>
			<RowDefinition
				Height="60" />
			<RowDefinition
				Height="*" />
		</Grid.RowDefinitions>
		<Border
			Grid.Row="0"
			Background="#2D2D2D">
			<StackPanel
				Orientation="Horizontal"
				Margin="20,0"
				VerticalAlignment="Center">
				<Button
					Content="← 返回"
					Background="#00FFFFFF"
					Foreground="#2196F3"
					BorderThickness="0"
					FontSize="14"
					FontFamily="Microsoft YaHei"
					Cursor="Hand"
					Margin="0,0,20,0"
					Click="BtnBack_Click" />
				<TextBlock
					Text="光影/材质"
					FontSize="20"
					FontWeight="Bold"
					Foreground="#FFFFFF" />
			</StackPanel>
		</Border>
		<Grid
			Row="1"
			Margin="0,20,0,0">
			<Grid.RowDefinitions>
				<RowDefinition
					Height="Auto" />
				<RowDefinition
					Height="Auto" />
				<RowDefinition
					Height="*" />
			</Grid.RowDefinitions>
			<Border
				Grid.Row="0"
				Background="#383838"
				CornerRadius="8"
				Padding="16"
				Margin="0,0,0,16">
				<StackPanel>
					<TextBlock
						Text="✨ 光影/材质下载"
						FontSize="14"
						Foreground="#FFFFFF"
						FontFamily="Microsoft YaHei"
						Margin="0,0,0,8" />
					<TextBlock
						Text="光影着色器和材质包可以极大提升游戏画面质量，带来更逼真的视觉体验"
						FontSize="12"
						Foreground="#AAAAAA"
						FontFamily="Microsoft YaHei"
						TextWrapping="Wrap" />
				</StackPanel>
			</Border>
			<StackPanel
				Grid.Row="1"
				Orientation="Horizontal"
				Margin="0,16,0,16"
				HorizontalAlignment="Right">
				<StackPanel.Resources>
					<Style
						TargetType="{x:Type Button}">
						<Setter
							Property="Padding"
							Value="14,8" />
						<Setter
							Property="FontSize"
							Value="12" />
						<Setter
							Property="FontFamily"
							Value="Microsoft YaHei" />
						<Setter
							Property="Cursor"
							Value="Hand" />
						<Setter
							Property="Margin"
							Value="0,0,8,0" />
						<Setter
							Property="Background"
							Value="#2D2D2D" />
						<Setter
							Property="Foreground"
							Value="#AAAAAA" />
						<Setter
							Property="BorderBrush"
							Value="#3A3A3A" />
						<Setter
							Property="Template">
							<Setter.Value>
								<ControlTemplate
									TargetType="{x:Type Button}">
									<Border
										x:Name="border"
										Background="{TemplateBinding Background}"
										BorderBrush="{TemplateBinding BorderBrush}"
										BorderThickness="1"
										CornerRadius="6"
										Padding="{TemplateBinding Padding}">
										<ContentPresenter
											HorizontalAlignment="Center"
											VerticalAlignment="Center"
											TextElement.Foreground="{TemplateBinding Foreground}" />
									</Border>
									<ControlTemplate.Triggers>
										<Trigger
											Property="IsMouseOver"
											Value="True">
											<Setter
												TargetName="border"
												Property="Background"
												Value="#3A3A3A" />
											<Setter
												TargetName="border"
												Property="BorderBrush"
												Value="#2196F3" />
											<Setter
												Property="Foreground"
												Value="#FFFFFF" />
										</Trigger>
										<Trigger
											Property="IsPressed"
											Value="True">
											<Setter
												TargetName="border"
												Property="Background"
												Value="#1E88E5" />
											<Setter
												TargetName="border"
												Property="BorderBrush"
												Value="#2196F3" />
										</Trigger>
									</ControlTemplate.Triggers>
								</ControlTemplate>
							</Setter.Value>
						</Setter>
					</Style>
				</StackPanel.Resources>
				<Button
					Content="光影"
					Background="#2196F3"
					Foreground="#FFFFFF"
					BorderBrush="#1976D2"
					Click="BtnMode_Click" />
				<Button
					Content="材质"
					Click="BtnMode_Click" />
			</StackPanel>
			<Border
				Grid.Row="2"
				Background="#2D2D2D"
				CornerRadius="12"
				Padding="16">
				<ListBox
					Name="lbShaders"
					Background="#00FFFFFF"
					BorderThickness="0">
						<ItemsControl.ItemContainerStyle>
							<Style
								TargetType="{x:Type ListBoxItem}">
								<Setter
									Property="HorizontalAlignment"
									Value="Stretch" />
								<Setter
									Property="HorizontalContentAlignment"
									Value="Stretch" />
								<Setter
									Property="Height"
									Value="128" />
							</Style>
						</ItemsControl.ItemContainerStyle>
						<ItemsControl.ItemTemplate>
							<DataTemplate>
								<Border
									Background="#383838"
									CornerRadius="8"
									Padding="14"
									Margin="0,0,0,8"
									Height="120">
									<Grid>
										<Grid.ColumnDefinitions>
											<ColumnDefinition
												Width="80" />
											<ColumnDefinition
												Width="*" />
											<ColumnDefinition
												Width="80" />
										</Grid.ColumnDefinitions>
										<Border
											Grid.Column="0"
											Background="#444444"
											CornerRadius="10"
											Margin="0"
											Width="80"
											Height="80">
											<UIElement.OpacityMask>
												<VisualBrush>
													<VisualBrush.Visual>
														<Rectangle
															Width="80"
															Height="80"
															RadiusX="10"
															RadiusY="10"
															Fill="#FFFFFFFF" />
													</VisualBrush.Visual>
												</VisualBrush>
											</UIElement.OpacityMask>
											<Image
												Stretch="Uniform"
												HorizontalAlignment="Center"
												VerticalAlignment="Center"
												Source="{Binding Thumbnail}" />
										</Border>
										<StackPanel
											Grid.Column="1"
											Margin="12,0,0,0">
											<StackPanel
												Orientation="Horizontal">
												<TextBlock
													FontSize="14"
													FontWeight="SemiBold"
													Foreground="#FFFFFF"
													FontFamily="Microsoft YaHei"
													TextTrimming="CharacterEllipsis"
													MaxWidth="400"
													Text="{Binding Name, FallbackValue=未知名称}" />
												<TextBlock
													FontSize="11"
													Foreground="#888888"
													FontFamily="Microsoft YaHei"
													Margin="8,2,0,0"
													Text="{Binding Version, FallbackValue=未知版本}" />
											</StackPanel>
											<TextBlock
												FontSize="12"
												Foreground="#AAAAAA"
												FontFamily="Microsoft YaHei"
												Margin="0,4,0,4"
												TextTrimming="CharacterEllipsis"
												MaxWidth="500"
												Height="28"
												Text="{Binding Description, FallbackValue=暂无描述}" />
											<StackPanel
												Orientation="Horizontal">
												<TextBlock
													FontSize="11"
													Foreground="#888888"
													FontFamily="Microsoft YaHei"
													Margin="0,0,12,0"
													TextTrimming="CharacterEllipsis"
													MaxWidth="150"
													Text="{Binding Author, FallbackValue=未知作者}" />
												<TextBlock
													FontSize="11"
													Foreground="#888888"
													FontFamily="Microsoft YaHei"
													Text="{Binding Resolution, FallbackValue=未知分辨率}" />
											</StackPanel>
										</StackPanel>
										<!--未知连接 ID：5-->
										<Button
											Grid.Column="2"
											Content="下载"
											Background="#2196F3"
											Foreground="#FFFFFF"
											BorderThickness="0"
											Padding="14,6"
											FontSize="12"
											FontFamily="Microsoft YaHei"
											Cursor="Hand"
											HorizontalAlignment="Center"
											VerticalAlignment="Center"
											Width="70"
											Height="32"
											Click="BtnDownload_Click">
											<Control.Template>
												<ControlTemplate
													TargetType="{x:Type Button}">
													<Border
														Name="border"
														Background="{TemplateBinding Background}"
														CornerRadius="6"
														Padding="{TemplateBinding Padding}">
														<ContentPresenter
															HorizontalAlignment="Center"
															VerticalAlignment="Center" />
													</Border>
													<ControlTemplate.Triggers>
														<Trigger
															Property="UIElement.IsMouseOver"
															Value="True">
															<Setter
																TargetName="border"
																Property="Background"
																Value="#1976D2" />
														</Trigger>
													</ControlTemplate.Triggers>
												</ControlTemplate>
											</Control.Template>
										</Button>
									</Grid>
								</Border>
							</DataTemplate>
						</ItemsControl.ItemTemplate>
					</ListBox>
			</Border>
		</Grid>
	</Grid>
</UserControl>

