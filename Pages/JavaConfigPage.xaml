<UserControl
	x:Class="MusicalNoteLauncher.Pages.JavaConfigPage" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:d="http://schemas.microsoft.com/expression/blend/2008" xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" xmlns:pages="clr-namespace:MusicalNoteLauncher.Pages">
	<Grid
		Background="{StaticResource BackgroundBrush}">
		<Grid.RowDefinitions>
			<RowDefinition
				Height="60" />
			<RowDefinition
				Height="*" />
		</Grid.RowDefinitions>
		<Border
			Grid.Row="0"
			Background="{StaticResource CardBackgroundBrush}">
			<StackPanel
				Orientation="Horizontal"
				Margin="20,0"
				VerticalAlignment="Center">
				<TextBlock
					Text="Java 配置"
					FontSize="20"
					FontWeight="Bold"
					Foreground="{StaticResource TextPrimaryBrush}" />
			</StackPanel>
		</Border>
		<ScrollViewer
			Grid.Row="1"
			Margin="20"
			VerticalScrollBarVisibility="Auto">
			<StackPanel>
				<Border
					Background="{StaticResource SurfaceBrush}"
					CornerRadius="12"
					Padding="20"
					Margin="0,0,0,20">
					<StackPanel>
						<TextBlock
							Text="自动检测 Java 环境"
							FontSize="16"
							FontWeight="SemiBold"
							Foreground="{StaticResource TextPrimaryBrush}"
							Margin="0,0,0,16" />
						<Button
							Name="btnDetectJava"
							Content="🔍 检测系统 Java"
							Style="{StaticResource SecondaryButton}"
							Width="150"
							Margin="0,0,0,16"
							Click="btnDetectJava_Click" />
						<ItemsControl
							Name="javaList"
							Margin="0,0,0,16">
							<ItemsControl.ItemTemplate>
								<DataTemplate>
									<Border
										Background="{StaticResource CardBackgroundBrush}"
										CornerRadius="8"
										Padding="12"
										Margin="0,0,0,8">
										<Grid>
											<Grid.ColumnDefinitions>
												<ColumnDefinition
													Width="*" />
												<ColumnDefinition
													Width="Auto" />
												<ColumnDefinition
													Width="Auto" />
											</Grid.ColumnDefinitions>
											<StackPanel
												Grid.Column="0">
												<TextBlock
													FontSize="13"
													Foreground="{StaticResource TextPrimaryBrush}"
													Text="{Binding Path}" />
												<TextBlock
													FontSize="11"
													Foreground="{StaticResource TextSecondaryBrush}"
													Margin="0,4,0,0">
													<Run
														Text="版本: " />
													<Run
														Text="{Binding MajorVersion}" /> <Run
														Text=" | 完整版本: " /><Run
														Text="{Binding Version}" /></TextBlock>
											</StackPanel>
											<Border
												Grid.Column="1"
												Background="{StaticResource PrimaryBrush}"
												CornerRadius="4"
												Padding="8,4"
												Margin="8,0">
												<TextBlock
													FontSize="11"
													Foreground="#FFFFFFFF"
													Text="{Binding MajorVersion, StringFormat=Java {0}}" />
											</Border>
											<!--未知连接 ID：3-->
											<Button
												Grid.Column="2"
												Content="使用此版本"
												Style="{StaticResource GreenButton}"
												Tag="{Binding}" />
										</Grid>
									</Border>
								</DataTemplate>
							</ItemsControl.ItemTemplate>
						</ItemsControl>
						<Border
							Background="{StaticResource CardBackgroundBrush}"
							CornerRadius="8"
							Padding="12">
							<StackPanel>
								<TextBlock
									Text="版本匹配建议"
									FontSize="13"
									FontWeight="SemiBold"
									Foreground="{StaticResource TextPrimaryBrush}"
									Margin="0,0,0,8" />
								<TextBlock
									Name="txtVersionSuggestion"
									FontSize="12"
									Foreground="{StaticResource TextSecondaryBrush}"
									TextWrapping="Wrap" />
							</StackPanel>
						</Border>
					</StackPanel>
				</Border>
				<Border
					Background="{StaticResource SurfaceBrush}"
					CornerRadius="12"
					Padding="20"
					Margin="0,0,0,20">
					<StackPanel>
						<TextBlock
							Text="一键下载 Java 环境"
							FontSize="16"
							FontWeight="SemiBold"
							Foreground="{StaticResource TextPrimaryBrush}"
							Margin="0,0,0,16" />
						<Border
							Background="{StaticResource CardBackgroundBrush}"
							CornerRadius="8"
							Padding="12"
							Margin="0,0,0,16">
							<StackPanel>
								<TextBlock
									Text="推荐版本"
									FontSize="13"
									FontWeight="SemiBold"
									Foreground="{StaticResource TextPrimaryBrush}"
									Margin="0,0,0,8" />
								<StackPanel
									Orientation="Horizontal">
									<TextBlock
										Text="根据您选择的MC版本，推荐: "
										FontSize="12"
										Foreground="{StaticResource TextSecondaryBrush}" />
									<TextBlock
										Name="txtRecommendedJava"
										Text="Java 8"
										FontSize="12"
										FontWeight="SemiBold"
										Foreground="{StaticResource GreenButtonBrush}" />
								</StackPanel>
							</StackPanel>
						</Border>
						<TextBlock
							Text="选择要下载的Java版本:"
							FontSize="13"
							Foreground="{StaticResource TextSecondaryBrush}"
							Margin="0,0,0,8" />
						<StackPanel
							Orientation="Horizontal"
							Margin="0,0,0,16">
							<Button
								Name="btnDownloadJava8"
								Content="Java 8"
								Style="{StaticResource SecondaryButton}"
								Width="80"
								Margin="0,0,8,0"
								Tag="8"
								Click="btnDownloadJava_Click" />
							<Button
								Name="btnDownloadJava11"
								Content="Java 11"
								Style="{StaticResource SecondaryButton}"
								Width="80"
								Margin="0,0,8,0"
								Tag="11"
								Click="btnDownloadJava_Click" />
							<Button
								Name="btnDownloadJava17"
								Content="Java 17"
								Style="{StaticResource SecondaryButton}"
								Width="80"
								Margin="0,0,8,0"
								Tag="17"
								Click="btnDownloadJava_Click" />
							<Button
								Name="btnDownloadJava21"
								Content="Java 21"
								Style="{StaticResource SecondaryButton}"
								Width="80"
								Tag="21"
								Click="btnDownloadJava_Click" />
						</StackPanel>
						<Button
							Name="btnDownloadRecommended"
							Content="⬇️ 一键下载推荐版本"
							Style="{StaticResource GreenButton}"
							Width="180"
							HorizontalAlignment="Left"
							Click="btnDownloadRecommended_Click" />
						<Border
							Name="pnlDownloadProgress"
							Background="{StaticResource CardBackgroundBrush}"
							CornerRadius="8"
							Padding="12"
							Margin="0,16,0,0"
							Visibility="Collapsed">
							<StackPanel>
								<TextBlock
									Name="txtDownloadStatus"
									Text="正在下载..."
									FontSize="12"
									Foreground="{StaticResource TextPrimaryBrush}"
									Margin="0,0,0,8" />
								<ProgressBar
									Name="progressDownload"
									Height="8"
									Minimum="0"
									Maximum="100"
									Value="0"
									Background="{StaticResource BorderBrush}"
									Foreground="{StaticResource GreenButtonBrush}" />
								<TextBlock
									Name="txtDownloadProgress"
									Text="0%"
									FontSize="11"
									Foreground="{StaticResource TextSecondaryBrush}"
									Margin="0,4,0,0"
									HorizontalAlignment="Center" />
							</StackPanel>
						</Border>
					</StackPanel>
				</Border>
				<Border
					Background="{StaticResource SurfaceBrush}"
					CornerRadius="12"
					Padding="20"
					Margin="0,0,0,20">
					<StackPanel>
						<TextBlock
							Text="手动配置 Java 路径"
							FontSize="16"
							FontWeight="SemiBold"
							Foreground="{StaticResource TextPrimaryBrush}"
							Margin="0,0,0,16" />
						<Grid
							Margin="0,0,0,16">
							<Grid.ColumnDefinitions>
								<ColumnDefinition
									Width="*" />
								<ColumnDefinition
									Width="Auto" />
							</Grid.ColumnDefinitions>
							<TextBox
								Name="txtJavaPath"
								Style="{StaticResource ModernTextBox}"
								FontFamily="Microsoft YaHei"
								ToolTip="请输入Java.exe的完整路径，例如: C:\Program Files\Java\jdk-17\bin\java.exe" />
							<Button
								Grid.Column="1"
								Content="浏览..."
								Style="{StaticResource SecondaryButton}"
								Width="80"
								Margin="8,0,0,0"
								Click="btnBrowseJava_Click" />
						</Grid>
						<Button
							Name="btnSetJavaPath"
							Content="✅ 设为当前 Java"
							Style="{StaticResource GreenButton}"
							Width="150"
							HorizontalAlignment="Left"
							Click="btnSetJavaPath_Click" />
					</StackPanel>
				</Border>
				<Border
					Background="{StaticResource SurfaceBrush}"
					CornerRadius="12"
					Padding="20"
					Margin="0,0,0,20">
					<StackPanel>
						<TextBlock
							Text="当前 Java 配置"
							FontSize="16"
							FontWeight="SemiBold"
							Foreground="{StaticResource TextPrimaryBrush}"
							Margin="0,0,0,16" />
						<Grid>
							<Grid.ColumnDefinitions>
								<ColumnDefinition
									Width="120" />
								<ColumnDefinition
									Width="*" />
							</Grid.ColumnDefinitions>
							<Grid.RowDefinitions>
								<RowDefinition
									Height="Auto" />
								<RowDefinition
									Height="Auto" />
								<RowDefinition
									Height="Auto" />
								<RowDefinition
									Height="Auto" />
							</Grid.RowDefinitions>
							<TextBlock
								Grid.Row="0"
								Grid.Column="0"
								Text="Java 路径:"
								Foreground="{StaticResource TextSecondaryBrush}"
								Margin="0,0,0,8" />
							<TextBlock
								Name="txtCurrentJavaPath"
								Grid.Row="0"
								Grid.Column="1"
								Text="未设置"
								Foreground="{StaticResource TextPrimaryBrush}"
								Margin="0,0,0,8" />
							<TextBlock
								Grid.Row="1"
								Grid.Column="0"
								Text="Java 版本:"
								Foreground="{StaticResource TextSecondaryBrush}"
								Margin="0,0,0,8" />
							<TextBlock
								Name="txtCurrentJavaVersion"
								Grid.Row="1"
								Grid.Column="1"
								Text="-"
								Foreground="{StaticResource TextPrimaryBrush}"
								Margin="0,0,0,8" />
							<TextBlock
								Grid.Row="2"
								Grid.Column="0"
								Text="配置方式:"
								Foreground="{StaticResource TextSecondaryBrush}"
								Margin="0,0,0,8" />
							<TextBlock
								Name="txtConfigType"
								Grid.Row="2"
								Grid.Column="1"
								Text="-"
								Foreground="{StaticResource TextPrimaryBrush}"
								Margin="0,0,0,8" />
							<TextBlock
								Grid.Row="3"
								Grid.Column="0"
								Text="推荐最大内存:"
								Foreground="{StaticResource TextSecondaryBrush}"
								Margin="0,0,0,8" />
							<TextBlock
								Name="txtRecommendedMemory"
								Grid.Row="3"
								Grid.Column="1"
								Text="-"
								Foreground="{StaticResource TextPrimaryBrush}"
								Margin="0,0,0,8" />
						</Grid>
						<Button
							Name="btnValidateJava"
							Content="🔧 验证 Java 配置"
							Style="{StaticResource SecondaryButton}"
							Width="150"
							Margin="0,16,0,0"
							HorizontalAlignment="Left"
							Click="btnValidateJava_Click" />
					</StackPanel>
				</Border>
				<Border
					Background="{StaticResource SurfaceBrush}"
					CornerRadius="12"
					Padding="20">
					<StackPanel>
						<TextBlock
							Text="操作日志"
							FontSize="16"
							FontWeight="SemiBold"
							Foreground="{StaticResource TextPrimaryBrush}"
							Margin="0,0,0,16" />
						<TextBox
							Name="txtLog"
							IsReadOnly="True"
							Background="{StaticResource CardBackgroundBrush}"
							Foreground="{StaticResource TextPrimaryBrush}"
							FontFamily="Consolas"
							FontSize="11"
							Height="150"
							TextWrapping="Wrap"
							VerticalScrollBarVisibility="Auto" />
					</StackPanel>
				</Border>
			</StackPanel>
		</ScrollViewer>
	</Grid>
</UserControl>

