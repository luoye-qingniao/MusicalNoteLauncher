<UserControl x:Class="MusicalNoteLauncher.Pages.SettingsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#1E1E1E">
    <Grid>
        <ScrollViewer Padding="20" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!-- 游戏设置 -->
                <Border Background="#2D2D2D" Padding="20" Margin="0,0,0,20">
                    <StackPanel>
                        <TextBlock Text="游戏设置" FontSize="18" FontWeight="Bold" Foreground="White" Margin="0,0,0,15"/>
                        
                        <StackPanel Margin="0,0,0,15">
                            <TextBlock Text="游戏路径" FontSize="14" Foreground="#AAAAAA" Margin="0,0,0,5"/>
                            <Border Background="#383838" Padding="12">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="F:\Games\Minecraft" FontSize="14" Foreground="White" Width="400"/>
                                    <Button Background="#2196F3" Foreground="White" BorderThickness="0" Padding="10,5" FontSize="12">
                                        浏览
                                    </Button>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <StackPanel Margin="0,0,0,15">
                            <TextBlock Text="Java 路径" FontSize="14" Foreground="#AAAAAA" Margin="0,0,0,5"/>
                            <Border Background="#383838" Padding="12">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="C:\Program Files\Java\jdk-21\bin\java.exe" FontSize="14" Foreground="White" Width="400"/>
                                    <Button Background="#2196F3" Foreground="White" BorderThickness="0" Padding="10,5" FontSize="12">
                                        浏览
                                    </Button>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <StackPanel Margin="0,0,0,15">
                            <TextBlock Text="内存分配" FontSize="14" Foreground="#AAAAAA" Margin="0,0,0,5"/>
                            <StackPanel Orientation="Horizontal">
                                <Button Background="#383838" Foreground="#AAAAAA" BorderThickness="0" Padding="12,8" FontSize="12" Margin="0,0,5,0">2GB</Button>
                                <Button Background="#2196F3" Foreground="White" BorderThickness="0" Padding="12,8" FontSize="12" Margin="0,0,5,0">4GB</Button>
                                <Button Background="#383838" Foreground="#AAAAAA" BorderThickness="0" Padding="12,8" FontSize="12" Margin="0,0,5,0">8GB</Button>
                                <Button Background="#383838" Foreground="#AAAAAA" BorderThickness="0" Padding="12,8" FontSize="12">16GB</Button>
                            </StackPanel>
                        </StackPanel>

                        <StackPanel Margin="0,0,0,10">
                            <TextBlock Text="启动参数" FontSize="14" Foreground="#AAAAAA" Margin="0,0,0,5"/>
                            <TextBox Background="#383838" Foreground="White" BorderThickness="0" Padding="12" FontSize="12" Height="60" AcceptsReturn="True"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- 界面设置 -->
                <Border Background="#2D2D2D" Padding="20" Margin="0,0,0,20">
                    <StackPanel>
                        <TextBlock Text="界面设置" FontSize="18" FontWeight="Bold" Foreground="White" Margin="0,0,0,15"/>
                        
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <TextBlock Text="深色模式" FontSize="14" Foreground="#AAAAAA" Width="150" VerticalAlignment="Center"/>
                            <ToggleButton IsChecked="True" Width="60" Height="30">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border Background="{TemplateBinding IsChecked, Converter={StaticResource BoolToColorConverter}, ConverterParameter='#2196F3;#666666'}">
                                            <Ellipse Fill="White" Width="24" Height="24" Margin="3" HorizontalAlignment="{TemplateBinding IsChecked, Converter={StaticResource BoolToHorizontalAlignmentConverter}}"/>
                                        </Border>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <TextBlock Text="动画效果" FontSize="14" Foreground="#AAAAAA" Width="150" VerticalAlignment="Center"/>
                            <ToggleButton IsChecked="True" Width="60" Height="30">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border Background="{TemplateBinding IsChecked, Converter={StaticResource BoolToColorConverter}, ConverterParameter='#2196F3;#666666'}">
                                            <Ellipse Fill="White" Width="24" Height="24" Margin="3" HorizontalAlignment="{TemplateBinding IsChecked, Converter={StaticResource BoolToHorizontalAlignmentConverter}}"/>
                                        </Border>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="通知提醒" FontSize="14" Foreground="#AAAAAA" Width="150" VerticalAlignment="Center"/>
                            <ToggleButton IsChecked="True" Width="60" Height="30">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border Background="{TemplateBinding IsChecked, Converter={StaticResource BoolToColorConverter}, ConverterParameter='#2196F3;#666666'}">
                                            <Ellipse Fill="White" Width="24" Height="24" Margin="3" HorizontalAlignment="{TemplateBinding IsChecked, Converter={StaticResource BoolToHorizontalAlignmentConverter}}"/>
                                        </Border>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- 其他设置 -->
                <Border Background="#2D2D2D" Padding="20">
                    <StackPanel>
                        <TextBlock Text="其他设置" FontSize="18" FontWeight="Bold" Foreground="White" Margin="0,0,0,15"/>
                        
                        <StackPanel Margin="0,0,0,15">
                            <TextBlock Text="自动更新" FontSize="14" Foreground="#AAAAAA" Margin="0,0,0,5"/>
                            <ComboBox Background="#383838" Foreground="White" BorderThickness="0" Padding="10" FontSize="12">
                                <ComboBoxItem>有更新时通知</ComboBoxItem>
                                <ComboBoxItem IsSelected="True">自动下载并安装</ComboBoxItem>
                                <ComboBoxItem>不检查更新</ComboBoxItem>
                            </ComboBox>
                        </StackPanel>

                        <Button Background="#F44336" Foreground="White" BorderThickness="0" Padding="15,10" FontSize="14" Width="200">
                            重置所有设置
                        </Button>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>