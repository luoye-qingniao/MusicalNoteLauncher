<UserControl
	x:Class="MusicalNoteLauncher.Pages.MultiplayerSocialPage" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	Background="#1E1E1E" xmlns:pages="clr-namespace:MusicalNoteLauncher.Pages">
	<Grid
		Background="#1E1E1E">
		<Grid.RowDefinitions>
			<RowDefinition
				Height="70" />
			<RowDefinition
				Height="*" />
		</Grid.RowDefinitions>
		<Border
			Grid.Row="0"
			Background="{StaticResource HeaderGradientBrush}"
			CornerRadius="0,0,12,12">
			<StackPanel
				Margin="24,0"
				VerticalAlignment="Center">
				<TextBlock
					Text="🎮 联机社交"
					FontSize="22"
					FontWeight="Bold"
					Foreground="#FFFFFF"
					FontFamily="Segoe UI Emoji, Segoe UI Symbol, Microsoft YaHei" />
				<TextBlock
					Text="选择联机方式，开启多人游戏之旅"
					FontSize="12"
					Foreground="#AAAAAA"
					FontFamily="Microsoft YaHei" />
			</StackPanel>
		</Border>
		<ScrollViewer
			Grid.Row="1"
			Margin="20"
			VerticalScrollBarVisibility="Auto"
			HorizontalScrollBarVisibility="Disabled">
			<Grid>
				<Grid
					Name="MainPage"
					Visibility="Visible">
					<Grid.RowDefinitions>
						<RowDefinition
							Height="Auto" />
						<RowDefinition
							Height="Auto" />
						<RowDefinition
							Height="Auto" />
						<RowDefinition
							Height="Auto" />
					</Grid.RowDefinitions>
					<Border
						Grid.Row="0"
						Style="{StaticResource ModernCard}"
						Padding="20"
						Margin="0,0,0,20">
						<StackPanel>
							<StackPanel
								Orientation="Horizontal"
								Margin="0,0,0,10">
								<Ellipse
									Width="8"
									Height="8"
									Fill="{StaticResource GreenButtonBrush}"
									Margin="0,4,10,0" />
								<TextBlock
									Text="联机方式选择"
									FontSize="16"
									FontWeight="Bold"
									Foreground="#FFFFFF"
									FontFamily="Microsoft YaHei" />
							</StackPanel>
							<TextBlock
								Text="选择您想要使用的联机方式，支持多种离线联机方案"
								FontSize="13"
								Foreground="#AAAAAA"
								FontFamily="Microsoft YaHei"
								TextWrapping="Wrap" />
						</StackPanel>
					</Border>
					<Border
						Grid.Row="1"
						Background="{StaticResource CardGradientBrush}"
						CornerRadius="16"
						Padding="24"
						Margin="0,0,0,20"
						Effect="{StaticResource CardShadow}">
						<Grid>
							<Grid.RowDefinitions>
								<RowDefinition
									Height="160" />
								<RowDefinition
									Height="160" />
								<RowDefinition
									Height="160" />
							</Grid.RowDefinitions>
							<Grid.ColumnDefinitions>
								<ColumnDefinition
									Width="*" />
								<ColumnDefinition
									Width="*" />
							</Grid.ColumnDefinitions>
							<Border
								Grid.Row="0"
								Grid.Column="0"
								Style="{StaticResource FeatureCard}"
								Margin="0,0,15,15"
								MouseLeftButtonDown="Card_LAN_Click">
								<StackPanel
									VerticalAlignment="Center"
									HorizontalAlignment="Center"
									Margin="10">
									<TextBlock
										Text="🌐"
										FontSize="32"
										HorizontalAlignment="Center"
										Margin="0,0,0,10" />
									<TextBlock
										Text="局域网联机"
										FontSize="15"
										FontWeight="Bold"
										Foreground="#FFFFFF"
										FontFamily="Microsoft YaHei"
										TextAlignment="Center" />
									<TextBlock
										Text="同一网络下快速联机"
										FontSize="12"
										Foreground="#888888"
										FontFamily="Microsoft YaHei"
										Margin="0,3,0,0"
										TextAlignment="Center" />
								</StackPanel>
							</Border>
							<Border
								Grid.Row="0"
								Grid.Column="1"
								Style="{StaticResource FeatureCard}"
								Margin="15,0,0,15"
								MouseLeftButtonDown="Card_VirtualLAN_Click">
								<StackPanel
									VerticalAlignment="Center"
									HorizontalAlignment="Center"
									Margin="10">
									<TextBlock
										Text="🔗"
										FontSize="32"
										HorizontalAlignment="Center"
										Margin="0,0,0,10" />
									<TextBlock
										Text="虚拟局域网"
										FontSize="15"
										FontWeight="Bold"
										Foreground="#FFFFFF"
										FontFamily="Microsoft YaHei"
										TextAlignment="Center" />
									<TextBlock
										Text="跨网络虚拟联机"
										FontSize="12"
										Foreground="#888888"
										FontFamily="Microsoft YaHei"
										Margin="0,3,0,0"
										TextAlignment="Center" />
								</StackPanel>
							</Border>
							<Border
								Grid.Row="1"
								Grid.Column="0"
								Style="{StaticResource FeatureCard}"
								Margin="0,0,15,15"
								MouseLeftButtonDown="Card_NAT_Click">
								<StackPanel
									VerticalAlignment="Center"
									HorizontalAlignment="Center"
									Margin="10">
									<TextBlock
										Text="🔓"
										FontSize="32"
										HorizontalAlignment="Center"
										Margin="0,0,0,10" />
									<TextBlock
										Text="内网穿透"
										FontSize="15"
										FontWeight="Bold"
										Foreground="#FFFFFF"
										FontFamily="Microsoft YaHei"
										TextAlignment="Center" />
									<TextBlock
										Text="外网访问内网服务"
										FontSize="12"
										Foreground="#888888"
										FontFamily="Microsoft YaHei"
										Margin="0,3,0,0"
										TextAlignment="Center" />
								</StackPanel>
							</Border>
							<Border
								Grid.Row="1"
								Grid.Column="1"
								Style="{StaticResource FeatureCard}"
								Margin="15,0,0,15"
								MouseLeftButtonDown="Card_Server_Click">
								<StackPanel
									VerticalAlignment="Center"
									HorizontalAlignment="Center"
									Margin="10">
									<TextBlock
										Text="🖥️"
										FontSize="32"
										HorizontalAlignment="Center"
										Margin="0,0,0,10" />
									<TextBlock
										Text="自建服务器"
										FontSize="15"
										FontWeight="Bold"
										Foreground="#FFFFFF"
										FontFamily="Microsoft YaHei"
										TextAlignment="Center" />
									<TextBlock
										Text="完全自定义游戏环境"
										FontSize="12"
										Foreground="#888888"
										FontFamily="Microsoft YaHei"
										Margin="0,3,0,0"
										TextAlignment="Center" />
								</StackPanel>
							</Border>
							<Border
								Grid.Row="2"
								Grid.Column="0"
								Style="{StaticResource FeatureCard}"
								Margin="0,0,15,0"
								MouseLeftButtonDown="Card_TaoWa_Click">
								<StackPanel
									VerticalAlignment="Center"
									HorizontalAlignment="Center"
									Margin="10">
									<TextBlock
										Text="🏺"
										FontSize="32"
										HorizontalAlignment="Center"
										Margin="0,0,0,10" />
									<TextBlock
										Text="陶瓦联机"
										FontSize="15"
										FontWeight="Bold"
										Foreground="#FFFFFF"
										FontFamily="Microsoft YaHei"
										TextAlignment="Center" />
									<TextBlock
										Text="EasyTier 一键联机"
										FontSize="12"
										Foreground="#888888"
										FontFamily="Microsoft YaHei"
										Margin="0,3,0,0"
										TextAlignment="Center" />
								</StackPanel>
							</Border>
							<Border
								Grid.Row="2"
								Grid.Column="1"
								Style="{StaticResource FeatureCard}"
								Margin="15,0,0,0"
								MouseLeftButtonDown="Card_Mod_Click">
								<StackPanel
									VerticalAlignment="Center"
									HorizontalAlignment="Center"
									Margin="10">
									<TextBlock
										Text="📦"
										FontSize="32"
										HorizontalAlignment="Center"
										Margin="0,0,0,10" />
									<TextBlock
										Text="Mod管理"
										FontSize="15"
										FontWeight="Bold"
										Foreground="#FFFFFF"
										FontFamily="Microsoft YaHei"
										TextAlignment="Center" />
									<TextBlock
										Text="管理游戏模组插件"
										FontSize="12"
										Foreground="#888888"
										FontFamily="Microsoft YaHei"
										Margin="0,3,0,0"
										TextAlignment="Center" />
								</StackPanel>
							</Border>
						</Grid>
					</Border>
					<Border
						Grid.Row="3"
						Style="{StaticResource EntryCard}"
						Padding="24"
						Margin="0"
						MouseLeftButtonDown="Card_Settings_Click">
						<Grid
							Height="70">
							<Grid.ColumnDefinitions>
								<ColumnDefinition
									Width="Auto" />
								<ColumnDefinition
									Width="*" />
								<ColumnDefinition
									Width="Auto" />
							</Grid.ColumnDefinitions>
							<Border
								Grid.Column="0"
								Width="50"
								Height="50"
								CornerRadius="12"
								Background="{StaticResource SurfaceBrush}"
								Margin="0,0,20,0">
								<TextBlock
									Text="⚙️"
									FontSize="28"
									HorizontalAlignment="Center"
									VerticalAlignment="Center"
									FontFamily="Segoe UI Emoji, Segoe UI Symbol, Microsoft YaHei" />
							</Border>
							<StackPanel
								Grid.Column="1"
								VerticalAlignment="Center">
								<TextBlock
									Text="离线设置"
									FontSize="16"
									FontWeight="Bold"
									Foreground="#FFFFFF"
									FontFamily="Microsoft YaHei" />
								<TextBlock
									Text="正版验证、UUID修复、用户名规则"
									FontSize="13"
									Foreground="#888888"
									FontFamily="Microsoft YaHei" />
							</StackPanel>
							<Border
								Grid.Column="2"
								Width="36"
								Height="36"
								CornerRadius="9"
								Background="{StaticResource SurfaceBrush}"
								HorizontalAlignment="Center"
								VerticalAlignment="Center">
								<TextBlock
									Text="→"
									FontSize="18"
									Foreground="{StaticResource PrimaryBrush}"
									HorizontalAlignment="Center"
									VerticalAlignment="Center" />
							</Border>
						</Grid>
					</Border>
				</Grid>
				<Grid
					Name="LANPage"
					Visibility="Collapsed">
					<Grid.RowDefinitions>
						<RowDefinition
							Height="Auto" />
						<RowDefinition
							Height="Auto" />
					</Grid.RowDefinitions>
					<StackPanel
						Grid.Row="0"
						Orientation="Horizontal"
						Margin="0,0,0,20">
						<Button
							Name="btnBackFromLAN"
							Content="← 返回"
							Style="{StaticResource NavButton}"
							Foreground="{StaticResource PrimaryBrush}"
							FontSize="15"
							Click="BtnBack_Click" />
						<TextBlock
							Text="局域网联机"
							FontSize="22"
							FontWeight="Bold"
							Foreground="#FFFFFF"
							Margin="20,0,0,0" />
					</StackPanel>
					<StackPanel
						Grid.Row="1"
						Margin="0">
						<StackPanel
							Margin="0,0,0,30">
							<TextBlock
								Text="📡 局域网联机"
								FontSize="28"
								Foreground="#FFFFFF"
								FontWeight="Bold"
								Margin="0,0,0,12" />
							<TextBlock
								Text="同一WiFi/路由器下的设备联机，无需额外Mod"
								Foreground="#AAAAAA"
								FontSize="14"
								TextWrapping="Wrap" />
						</StackPanel>
						<Border
							Style="{StaticResource ModernCard}"
							Padding="24"
							Margin="0,0,0,20">
							<StackPanel>
								<StackPanel
									Orientation="Horizontal"
									Margin="0,0,0,18">
									<Border
										Width="4"
										Height="20"
										Background="{StaticResource GreenButtonBrush}"
										CornerRadius="2"
										Margin="0,0,12,0" />
									<TextBlock
										Text="房主操作步骤"
										FontSize="17"
										FontWeight="Bold"
										Foreground="#FFFFFF"
										FontFamily="Microsoft YaHei" />
								</StackPanel>
								<StackPanel
									Margin="0,0,0,20">
									<TextBlock
										Foreground="#CCCCCC"
										FontSize="14"
										Margin="0,0,0,10">
										<Run
											TextDecorations="Underline">1.</Run> 进入单人存档</TextBlock>
									<TextBlock
										Foreground="#CCCCCC"
										FontSize="14"
										Margin="0,0,0,10">
										<Run
											TextDecorations="Underline">2.</Run> 按 ESC 键 → 点击"对局域网开放"</TextBlock>
									<TextBlock
										Foreground="#CCCCCC"
										FontSize="14"
										Margin="0,0,0,10">
										<Run
											TextDecorations="Underline">3.</Run> 设置端口号（默认25565）和是否允许作弊</TextBlock>
									<TextBlock
										Foreground="#CCCCCC"
										FontSize="14">
										<Run
											TextDecorations="Underline">4.</Run> 点击"创建局域网世界"</TextBlock>
								</StackPanel>
								<Border
									Height="1"
									Background="{StaticResource BorderBrush}"
									Margin="0,0,0,18" />
								<StackPanel
									Orientation="Horizontal"
									Margin="0,0,0,18">
									<Border
										Width="4"
										Height="20"
										Background="{StaticResource PrimaryBrush}"
										CornerRadius="2"
										Margin="0,0,12,0" />
									<TextBlock
										Text="房客操作步骤"
										FontSize="17"
										FontWeight="Bold"
										Foreground="#FFFFFF"
										FontFamily="Microsoft YaHei" />
								</StackPanel>
								<StackPanel>
									<TextBlock
										Foreground="#CCCCCC"
										FontSize="14"
										Margin="0,0,0,10">
										<Run
											TextDecorations="Underline">1.</Run> 打开多人游戏 → 直接连接</TextBlock>
									<TextBlock
										Foreground="#CCCCCC"
										FontSize="14"
										Margin="0,0,0,10">
										<Run
											TextDecorations="Underline">2.</Run> 输入房主的局域网IP地址</TextBlock>
									<TextBlock
										Foreground="#CCCCCC"
										FontSize="14">
										<Run
											TextDecorations="Underline">3.</Run> 点击"加入服务器"</TextBlock>
								</StackPanel>
							</StackPanel>
						</Border>
						<Border
							Style="{StaticResource ModernCard}"
							Padding="24"
							Margin="0,0,0,20">
							<StackPanel>
								<StackPanel
									Orientation="Horizontal"
									Margin="0,0,0,18">
									<TextBlock
										Text="🚀"
										FontSize="20"
										Margin="0,0,10,0" />
									<TextBlock
										Text="快速获取IP"
										FontSize="17"
										FontWeight="Bold"
										Foreground="#FFFFFF"
										FontFamily="Microsoft YaHei" />
								</StackPanel>
								<StackPanel
									Orientation="Horizontal">
									<Button
										Name="btnGetLanIP"
										Content="获取本机IP"
										Style="{StaticResource GreenButton}"
										Padding="24,12"
										Click="BtnGetLanIP_Click" />
									<Border
										Width="24" />
									<TextBox
										Name="txtLanIP"
										Style="{StaticResource StandardTextBox}"
										Width="280"
										IsReadOnly="True" />
								</StackPanel>
							</StackPanel>
						</Border>
						<Border
							Style="{StaticResource ModernCard}"
							Padding="24">
							<StackPanel>
								<StackPanel
									Orientation="Horizontal"
									Margin="0,0,0,18">
									<TextBlock
										Text="🔍"
										FontSize="20"
										Margin="0,0,10,0" />
									<TextBlock
										Text="端口检测"
										FontSize="17"
										FontWeight="Bold"
										Foreground="#FFFFFF"
										FontFamily="Microsoft YaHei" />
								</StackPanel>
								<StackPanel
									Orientation="Horizontal">
									<Button
										Name="btnDetectPort"
										Content="检测端口"
										Background="#9C27B0"
										Foreground="#FFFFFF"
										Padding="24,12"
										Click="BtnDetectPort_Click">
										<Control.Template>
											<ControlTemplate
												TargetType="{x:Type Button}">
												<Border
													Name="border"
													Background="#9C27B0"
													CornerRadius="8"
													Padding="24,12">
													<ContentPresenter
														HorizontalAlignment="Center"
														VerticalAlignment="Center" />
												</Border>
												<ControlTemplate.Triggers>
													<Trigger
														Property="UIElement.IsMouseOver"
														Value="True">
														<Setter
															TargetName="border"
															Property="Background"
															Value="#7B1FA2" />
													</Trigger>
												</ControlTemplate.Triggers>
											</ControlTemplate>
										</Control.Template>
									</Button>
									<Border
										Width="24" />
									<TextBox
										Name="txtPortStatus"
										Style="{StaticResource StandardTextBox}"
										Width="280"
										IsReadOnly="True" />
								</StackPanel>
							</StackPanel>
						</Border>
					</StackPanel>
				</Grid>
				<Grid
					Name="VirtualLANPage"
					Visibility="Collapsed">
					<Grid.RowDefinitions>
						<RowDefinition
							Height="Auto" />
						<RowDefinition
							Height="Auto" />
					</Grid.RowDefinitions>
					<StackPanel
						Grid.Row="0"
						Orientation="Horizontal"
						Margin="0,0,0,20">
						<Button
							Name="btnBackFromVirtualLAN"
							Content="← 返回"
							Style="{StaticResource NavButton}"
							Foreground="{StaticResource PrimaryBrush}"
							FontSize="15"
							Click="BtnBack_Click" />
						<TextBlock
							Text="虚拟局域网"
							FontSize="22"
							FontWeight="Bold"
							Foreground="#FFFFFF"
							Margin="20,0,0,0" />
					</StackPanel>
					<StackPanel
						Grid.Row="1">
						<StackPanel
							Margin="0,0,0,30">
							<TextBlock
								Text="🌐 虚拟局域网"
								FontSize="28"
								Foreground="#FFFFFF"
								FontWeight="Bold"
								Margin="0,0,0,12" />
							<TextBlock
								Text="通过虚拟局域网软件，让不同网络的玩家实现联机"
								Foreground="#AAAAAA"
								FontSize="14"
								TextWrapping="Wrap" />
						</StackPanel>
						<Border
							Style="{StaticResource ModernCard}"
							Padding="24"
							Margin="0,0,0,20">
							<StackPanel>
								<StackPanel
									Orientation="Horizontal"
									Margin="0,0,0,15">
									<TextBlock
										Text="🎯"
										FontSize="22"
										Margin="0,0,12,0" />
									<StackPanel>
										<TextBlock
											Text="e4mc"
											FontSize="17"
											FontWeight="Bold"
											Foreground="{StaticResource GreenButtonBrush}"
											FontFamily="Microsoft YaHei" />
										<TextBlock
											Text="(推荐)"
											FontSize="14"
											Foreground="#888888"
											FontFamily="Microsoft YaHei" />
									</StackPanel>
								</StackPanel>
								<TextBlock
									Foreground="#CCCCCC"
									FontSize="14"
									Margin="0,0,0,18"
									TextWrapping="Wrap">e4mc是一款离线局域网联机Mod，无需服务器即可让玩家跨网络联机。所有玩家都需要安装此Mod。</TextBlock>
								<Button
									Name="btnDownloade4mc"
									Content="下载e4mc Mod"
									Style="{StaticResource GreenButton}"
									Padding="20,11"
									Click="BtnDownloade4mc_Click" />
							</StackPanel>
						</Border>
						<Border
							Style="{StaticResource ModernCard}"
							Padding="24"
							Margin="0,0,0,20">
							<StackPanel>
								<StackPanel
									Orientation="Horizontal"
									Margin="0,0,0,15">
									<TextBlock
										Text="🔗"
										FontSize="22"
										Margin="0,0,12,0" />
									<TextBlock
										Text="ZeroTier"
										FontSize="17"
										FontWeight="Bold"
										Foreground="{StaticResource PrimaryBrush}"
										FontFamily="Microsoft YaHei" />
								</StackPanel>
								<TextBlock
									Foreground="#CCCCCC"
									FontSize="14"
									Margin="0,0,0,18"
									TextWrapping="Wrap">ZeroTier是一款虚拟局域网软件，可以创建虚拟网络，让玩家处于同一局域网环境中。</TextBlock>
								<Button
									Name="btnOpenZeroTier"
									Content="打开ZeroTier官网"
									Style="{StaticResource PrimaryButton}"
									Padding="20,11"
									Click="BtnOpenZeroTier_Click" />
							</StackPanel>
						</Border>
						<Border
							Style="{StaticResource ModernCard}"
							Padding="24">
							<StackPanel>
								<StackPanel
									Orientation="Horizontal"
									Margin="0,0,0,15">
									<TextBlock
										Text="🔗"
										FontSize="22"
										Margin="0,0,12,0" />
									<TextBlock
										Text="Hamachi"
										FontSize="17"
										FontWeight="Bold"
										Foreground="#FF9800"
										FontFamily="Microsoft YaHei" />
								</StackPanel>
								<TextBlock
									Foreground="#CCCCCC"
									FontSize="14"
									Margin="0,0,0,18"
									TextWrapping="Wrap">Hamachi是老牌虚拟局域网软件，使用简单，但免费版有连接数量限制。</TextBlock>
								<Button
									Name="btnOpenHamachi"
									Content="打开Hamachi官网"
									Background="#FF9800"
									Foreground="#FFFFFF"
									Padding="20,11"
									Click="BtnOpenHamachi_Click">
									<Control.Template>
										<ControlTemplate
											TargetType="{x:Type Button}">
											<Border
												Name="border"
