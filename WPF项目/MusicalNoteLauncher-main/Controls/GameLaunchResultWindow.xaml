<Window x:Class="MusicalNoteLauncher.Controls.GameLaunchResultWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None" AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Width="520" Height="520"
        TextOptions.TextFormattingMode="Ideal"
        TextOptions.TextRenderingMode="ClearType"
        RenderOptions.ClearTypeHint="Enabled"
        Topmost="True" ShowInTaskbar="False"
        Loaded="Window_Loaded"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">

    <Border CornerRadius="16" ClipToBounds="True">
        <Border.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                <GradientStop Color="#1E1E2E" Offset="0"/>
                <GradientStop Color="#181825" Offset="1"/>
            </LinearGradientBrush>
        </Border.Background>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- ═══ Header ═══ -->
            <Border Grid.Row="0" Padding="28,24,28,16">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Border Name="borderIcon" Grid.Column="0" Width="48" Height="48"
                            CornerRadius="12" Margin="0,0,14,0">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="14" ShadowDepth="0" Opacity="0.3"/>
                        </Border.Effect>
                        <TextBlock Name="txtIcon" Text="✓" FontSize="24"
                                   Foreground="White"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>

                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Name="txtTitle" Text="游戏启动成功"
                                   FontSize="17" FontWeight="Bold"
                                   Foreground="#E0E0E0"
                                   FontFamily="Microsoft YaHei"/>
                        <TextBlock Name="txtSubtitle" Text="Minecraft 已成功运行"
                                   FontSize="12" Margin="0,4,0,0"
                                   Foreground="#888"
                                   FontFamily="Microsoft YaHei"/>
                    </StackPanel>

                    <Button Grid.Column="2" Content="✕"
                            Width="32" Height="32" FontSize="14"
                            Background="Transparent" Foreground="#888"
                            BorderThickness="0" Cursor="Hand"
                            Click="BtnClose_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="bd" CornerRadius="8"
                                        Background="Transparent">
                                    <ContentPresenter HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="bd" Property="Background" Value="#33FFFFFF"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>
            </Border>

            <Rectangle Grid.Row="0" VerticalAlignment="Bottom" Height="1"
                       Fill="#22FFFFFF" Margin="28,0,28,0"/>

            <!-- ═══ 详情区域 ═══ -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                          Padding="28,16,28,8">
                <StackPanel>

                    <TextBlock Text="📋 游戏详情" FontSize="13" FontWeight="SemiBold"
                               Foreground="#BBB" FontFamily="Microsoft YaHei"
                               Margin="0,0,0,12"/>

                    <Border CornerRadius="10" Padding="16,14"
                            Background="#0AFFFFFF" Margin="0,0,0,16">
                        <StackPanel Name="spGameDetails"/>
                    </Border>

                    <!-- 错误详情 -->
                    <Border Name="borderError" Visibility="Collapsed"
                            CornerRadius="10" Padding="16,14"
                            BorderBrush="#33E74C3C" BorderThickness="1"
                            Background="#0DE74C3C" Margin="0,0,0,16">
                        <StackPanel>
                            <TextBlock Text="❌ 错误详情" FontSize="13" FontWeight="SemiBold"
                                       Foreground="#E74C3C" FontFamily="Microsoft YaHei"
                                       Margin="0,0,0,10"/>
                            <StackPanel Name="spErrorRows"/>

                            <TextBlock Text="📄 错误日志预览" FontSize="12"
                                       Foreground="#999" FontFamily="Microsoft YaHei"
                                       Margin="0,14,0,6"/>
                            <Border CornerRadius="8" Padding="12"
                                    Background="#0A000000">
                                <TextBlock Name="txtErrorLog" Text=""
                                           FontSize="11" FontFamily="Consolas"
                                           Foreground="#CCC"
                                           TextWrapping="Wrap" MaxHeight="120"
                                           TextTrimming="CharacterEllipsis"/>
                            </Border>
                        </StackPanel>
                    </Border>

                </StackPanel>
            </ScrollViewer>

            <Rectangle Grid.Row="2" VerticalAlignment="Top" Height="1"
                       Fill="#22FFFFFF" Margin="28,0,28,0"/>

            <!-- ═══ 底部按钮 ═══ -->
            <Border Grid.Row="2" Padding="28,16,28,20">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Button Name="btnExport" Grid.Column="0"
                            Content="📤 导出报告"
                            Background="Transparent"
                            Foreground="#4A90D9"
                            BorderBrush="#334A90D9" BorderThickness="1"
                            Padding="0,11" FontSize="13"
                            FontFamily="Microsoft YaHei"
                            Cursor="Hand" Click="BtnExport_Click"
                            Visibility="Collapsed" Margin="0,0,8,0">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="bd" CornerRadius="10"
                                        Background="{TemplateBinding Background}"
                                        BorderBrush="{TemplateBinding BorderBrush}"
                                        BorderThickness="{TemplateBinding BorderThickness}"
                                        Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="bd" Property="Background" Value="#1A4A90D9"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <Button Name="btnAIAnalyze" Grid.Column="1"
                            Content="🤖 AI 分析错误"
                            Background="#2ECC71"
                            Foreground="White" BorderThickness="0"
                            Padding="0,11" FontSize="13"
                            FontFamily="Microsoft YaHei"
                            Cursor="Hand" Click="BtnAIAnalyze_Click"
                            Visibility="Collapsed" Margin="8,0,0,0">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="bd" CornerRadius="10"
                                        Padding="{TemplateBinding Padding}">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                            <GradientStop Color="#2ECC71" Offset="0"/>
                                            <GradientStop Color="#27AE60" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                    <ContentPresenter HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="bd" Property="Background">
                                            <Setter.Value>
                                                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                    <GradientStop Color="#27AE60" Offset="0"/>
                                                    <GradientStop Color="#1E8449" Offset="1"/>
                                                </LinearGradientBrush>
                                            </Setter.Value>
                                        </Setter>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <Button Name="btnClose" Grid.Column="2"
                            Content="关闭"
                            Background="#2A2A3C" Foreground="#BBB"
                            BorderThickness="0"
                            Padding="0,11" FontSize="13"
                            FontFamily="Microsoft YaHei"
                            Cursor="Hand" Click="BtnClose_Click"
                            Margin="8,0,0,0">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="bd" CornerRadius="10"
                                        Background="{TemplateBinding Background}"
                                        Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="bd" Property="Background" Value="#3A3A4E"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
