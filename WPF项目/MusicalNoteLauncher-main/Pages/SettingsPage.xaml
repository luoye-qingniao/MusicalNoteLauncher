													Background="{DynamicResource SurfaceBrush}"
													Foreground="{DynamicResource TextPrimaryBrush}"
													BorderBrush="{DynamicResource BorderBrush}"
													BorderThickness="1"
													Padding="10,6"
													FontSize="12"
													FontFamily="Microsoft YaHei"
													Cursor="Hand"
													Click="BtnDetectJava_Click">
													<Button.Template>
														<ControlTemplate TargetType="{x:Type Button}">
															<Border Name="border" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="4" Padding="{TemplateBinding Padding}">
																<ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
															</Border>
															<ControlTemplate.Triggers>
																<Trigger Property="IsMouseOver" Value="True">
																	<Setter TargetName="border" Property="Background" Value="{DynamicResource CardHoverBrush}" />
																</Trigger>
															</ControlTemplate.Triggers>
														</ControlTemplate>
													</Button.Template>
												</Button>
											</Grid>
											<TextBlock
												Name="txtNoJavaFound"
												Text="未检测到 Java，请点击 [重新检测] 或手动设置"
												Foreground="{DynamicResource TextSecondaryBrush}"
												FontSize="12"
												FontFamily="Microsoft YaHei"
												Margin="0,4,0,0"
												Visibility="Visible" />
											<ItemsControl
											Name="javaList"
											Margin="0,0,0,8">
											<ItemsControl.ItemTemplate>
												<DataTemplate>
													<Border
														Background="{DynamicResource SurfaceBrush}"
														BorderBrush="{DynamicResource BorderBrush}"
														BorderThickness="1"
														CornerRadius="6"
														Padding="12,10"
														Margin="0,0,0,6">
														<Grid>
															<Grid.ColumnDefinitions>
																<ColumnDefinition Width="*" />
																<ColumnDefinition Width="Auto" />
															</Grid.ColumnDefinitions>
