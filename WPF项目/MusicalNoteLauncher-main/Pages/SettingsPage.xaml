<UserControl
	x:Class="MusicalNoteLauncher.Pages.SettingsPage" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	Background="{DynamicResource BackgroundBrush}" xmlns:pages="clr-namespace:MusicalNoteLauncher.Pages">
	<ScrollViewer
		VerticalScrollBarVisibility="Auto">
		<Grid
			Margin="20">
			<Grid.RowDefinitions>
				<RowDefinition
					Height="Auto" />
				<RowDefinition
					Height="*" />
			</Grid.RowDefinitions>
			<TextBlock
				Grid.Row="0"
				Text="设置中心"
				Foreground="{DynamicResource TextPrimaryBrush}"
				FontSize="24"
				FontWeight="SemiBold"
				FontFamily="Microsoft YaHei"
				Margin="0,0,0,20" />
			<Grid
				Row="1">
				<Grid.ColumnDefinitions>
					<ColumnDefinition
						Width="200" />
					<ColumnDefinition
						Width="*" />
				</Grid.ColumnDefinitions>
				<Border
					Grid.Column="0"
					Background="{DynamicResource CardBackgroundBrush}"
					CornerRadius="8"
					Padding="10"
					Margin="0,0,16,0">
					<StackPanel>
						<Button
							Name="btnCategoryGeneral"
							Content="常规设置"
							Background="{DynamicResource PrimaryBrush}"
							Foreground="{DynamicResource TextPrimaryBrush}"
							BorderThickness="0"
							Padding="12,10"
							FontSize="13"
							FontFamily="Microsoft YaHei"
							Cursor="Hand"
							HorizontalContentAlignment="Left"
							Margin="0,4"
							Click="BtnCategory_Click">
							<Control.Template>
								<ControlTemplate
									TargetType="{x:Type Button}">
									<Border
										Name="border"
										Background="{TemplateBinding Background}"
										CornerRadius="4"
										Padding="{TemplateBinding Padding}">
										<ContentPresenter
											HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
											VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
									</Border>
									<ControlTemplate.Triggers>
										<Trigger
											Property="UIElement.IsMouseOver"
											Value="True">
											<Setter
												TargetName="border"
												Property="Background"
												Value="{DynamicResource PrimaryDarkBrush}" />
										</Trigger>
									</ControlTemplate.Triggers>
								</ControlTemplate>
							</Control.Template>
						</Button>
						<Button
							Name="btnCategoryGame"
							Content="游戏设置"
							Background="{DynamicResource SurfaceBrush}"
							Foreground="{DynamicResource TextPrimaryBrush}"
							BorderThickness="0"
							Padding="12,10"
							FontSize="13"
							FontFamily="Microsoft YaHei"
							Cursor="Hand"
							HorizontalContentAlignment="Left"
							Margin="0,4"
							Click="BtnCategory_Click">
							<Control.Template>
								<ControlTemplate
									TargetType="{x:Type Button}">
									<Border
										Name="border"
										Background="{TemplateBinding Background}"
										CornerRadius="4"
										Padding="{TemplateBinding Padding}">
										<ContentPresenter
											HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
											VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
									</Border>
									<ControlTemplate.Triggers>
										<Trigger
											Property="UIElement.IsMouseOver"
											Value="True">
											<Setter
												TargetName="border"
												Property="Background"
												Value="{DynamicResource CardHoverBrush}" />
										</Trigger>
									</ControlTemplate.Triggers>
								</ControlTemplate>
							</Control.Template>
						</Button>
						<Button
							Name="btnCategoryJava"
							Content="Java设置"
							Background="{DynamicResource SurfaceBrush}"
							Foreground="{DynamicResource TextPrimaryBrush}"
							BorderThickness="0"
							Padding="12,10"
							FontSize="13"
							FontFamily="Microsoft YaHei"
							Cursor="Hand"
							HorizontalContentAlignment="Left"
							Margin="0,4"
							Click="BtnCategory_Click">
							<Control.Template>
								<ControlTemplate
									TargetType="{x:Type Button}">
									<Border
										Name="border"
										Background="{TemplateBinding Background}"
										CornerRadius="4"
										Padding="{TemplateBinding Padding}">
										<ContentPresenter
											HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
											VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
									</Border>
									<ControlTemplate.Triggers>
										<Trigger
											Property="UIElement.IsMouseOver"
											Value="True">
											<Setter
												TargetName="border"
												Property="Background"
												Value="{DynamicResource CardHoverBrush}" />
										</Trigger>
									</ControlTemplate.Triggers>
								</ControlTemplate>
							</Control.Template>
						</Button>
						<Button
							Name="btnCategoryDownload"
							Content="下载设置"
							Background="{DynamicResource SurfaceBrush}"
							Foreground="{DynamicResource TextPrimaryBrush}"
							BorderThickness="0"
							Padding="12,10"
							FontSize="13"
							FontFamily="Microsoft YaHei"
							Cursor="Hand"
							HorizontalContentAlignment="Left"
							Margin="0,4"
							Click="BtnCategory_Click">
							<Control.Template>
								<ControlTemplate
									TargetType="{x:Type Button}">
									<Border
										Name="border"
										Background="{TemplateBinding Background}"
										CornerRadius="4"
										Padding="{TemplateBinding Padding}">
										<ContentPresenter
											HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
											VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
									</Border>
									<ControlTemplate.Triggers>
										<Trigger
											Property="UIElement.IsMouseOver"
											Value="True">
											<Setter
												TargetName="border"
												Property="Background"
												Value="{DynamicResource CardHoverBrush}" />
										</Trigger>
									</ControlTemplate.Triggers>
								</ControlTemplate>
							</Control.Template>
						</Button>
						<Button
							Name="btnCategoryAbout"
							Content="关于"
							Background="{DynamicResource SurfaceBrush}"
							Foreground="{DynamicResource TextPrimaryBrush}"
							BorderThickness="0"
							Padding="12,10"
							FontSize="13"
							FontFamily="Microsoft YaHei"
							Cursor="Hand"
							HorizontalContentAlignment="Left"
							Margin="0,4"
							Click="BtnCategory_Click">
							<Control.Template>
								<ControlTemplate
									TargetType="{x:Type Button}">
									<Border
										Name="border"
										Background="{TemplateBinding Background}"
										CornerRadius="4"
										Padding="{TemplateBinding Padding}">
										<ContentPresenter
											HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
											VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
									</Border>
									<ControlTemplate.Triggers>
										<Trigger
											Property="UIElement.IsMouseOver"
											Value="True">
											<Setter
												TargetName="border"
												Property="Background"
												Value="{DynamicResource CardHoverBrush}" />
										</Trigger>
									</ControlTemplate.Triggers>
								</ControlTemplate>
							</Control.Template>
						</Button>
						<Button
							Name="btnCategoryBackground"
							Content="背景设置"
							Background="{DynamicResource SurfaceBrush}"
							Foreground="{DynamicResource TextPrimaryBrush}"
							BorderThickness="0"
							Padding="12,10"
							FontSize="13"
							FontFamily="Microsoft YaHei"
							Cursor="Hand"
							HorizontalContentAlignment="Left"
							Margin="0,4"
							Click="BtnCategory_Click">
							<Control.Template>
								<ControlTemplate
									TargetType="{x:Type Button}">
									<Border
										Name="border"
										Background="{TemplateBinding Background}"
										CornerRadius="4"
										Padding="{TemplateBinding Padding}">
										<ContentPresenter
											HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
											VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
									</Border>
									<ControlTemplate.Triggers>
										<Trigger
											Property="UIElement.IsMouseOver"
											Value="True">
											<Setter
												TargetName="border"
												Property="Background"
												Value="{DynamicResource CardHoverBrush}" />
										</Trigger>
									</ControlTemplate.Triggers>
								</ControlTemplate>
							</Control.Template>
						</Button>
										<TextBlock
											Name="txtMemOptStatus"
											Visibility="Collapsed"
											Foreground="{DynamicResource TextSecondaryBrush}"
											FontSize="11"
											FontFamily="Microsoft YaHei"
											Margin="4,4,0,0"
											Text="准备中..." />
									</StackPanel>
				</Border>
				<Border
					Grid.Column="1"
					Background="{DynamicResource CardBackgroundBrush}"
					CornerRadius="8"
					Padding="20">
					<StackPanel>
						<TabControl
							Name="tabSettings"
							Background="#00FFFFFF"
							BorderThickness="0"
							SelectedIndex="0">
							<Control.Template>
								<ControlTemplate
									TargetType="{x:Type TabControl}">
									<Border
										Background="#00FFFFFF">
										<ContentPresenter
											ContentSource="SelectedContent" />
									</Border>
								</ControlTemplate>
							</Control.Template>
							<TabItem
								Header="常规设置"
								IsSelected="True">
								<StackPanel>
									<TextBlock
										Text="常规设置"
										Foreground="{DynamicResource TextPrimaryBrush}"
										FontSize="18"
										FontWeight="SemiBold"
										FontFamily="Microsoft YaHei"
										Margin="0,0,0,16" />
									<TextBlock
										Text="启动设置"
										Foreground="{DynamicResource TextSecondaryBrush}"
										FontSize="12"
										FontFamily="Microsoft YaHei"
										Margin="0,0,0,8" />
									<CheckBox
										Name="chkAutoLogin"
										Content="启动时自动登录上次账号"
										IsChecked="False"
										Foreground="{DynamicResource TextPrimaryBrush}"
										FontFamily="Microsoft YaHei"
										Margin="0,8,0,0" />
									<CheckBox
										Name="chkMinimizeToTray"
										Content="最小化到系统托盘"
										IsChecked="False"
										Foreground="{DynamicResource TextPrimaryBrush}"
										FontFamily="Microsoft YaHei"
										Margin="0,8,0,0" />
									<CheckBox
										Name="chkCheckUpdate"
										Content="自动检查更新"
										IsChecked="True"
										Foreground="{DynamicResource TextPrimaryBrush}"
										FontFamily="Microsoft YaHei"
										Margin="0,8,0,0" />
									<TextBlock
										Text="界面设置"
										Foreground="{DynamicResource TextSecondaryBrush}"
										FontSize="12"
										FontFamily="Microsoft YaHei"
										Margin="0,24,0,8" />
									<CheckBox
										Name="chkShowSplash"
										Content="显示启动画面"
										IsChecked="True"
										Foreground="{DynamicResource TextPrimaryBrush}"
										FontFamily="Microsoft YaHei"
										Margin="0,8,0,0" />
									<CheckBox
									Name="chkHardwareAcceleration"
									Content="启用硬件加速"
									IsChecked="True"
									Foreground="{DynamicResource TextPrimaryBrush}"
									FontFamily="Microsoft YaHei"
									Margin="0,8,0,0" />
								<TextBlock
									Text="配色主题"
									Foreground="{DynamicResource TextSecondaryBrush}"
									FontSize="12"
									FontFamily="Microsoft YaHei"
									Margin="0,24,0,8" />
								<Grid>
									<Grid.ColumnDefinitions>
										<ColumnDefinition Width="*" />
										<ColumnDefinition Width="Auto" />
									</Grid.ColumnDefinitions>
									<ComboBox
										Name="cbThemeColor"
										Grid.Column="0"
										Background="{DynamicResource SurfaceBrush}"
										Foreground="{DynamicResource TextPrimaryBrush}"
										BorderBrush="{DynamicResource BorderBrush}"
										BorderThickness="1"
										Padding="10,6"
										FontSize="13"
										FontFamily="Microsoft YaHei"
										Cursor="Hand"
										SelectionChanged="CbThemeColor_SelectionChanged">
										<ComboBox.ItemTemplate>
											<DataTemplate>
												<TextBlock Text="{Binding Name}"
													Foreground="{DynamicResource TextPrimaryBrush}"
													FontSize="13"
													FontFamily="Microsoft YaHei"
													VerticalAlignment="Center" />
											</DataTemplate>
										</ComboBox.ItemTemplate>
										<Control.Template>
											<ControlTemplate TargetType="{x:Type ComboBox}">
												<Grid>
													<Border Background="{TemplateBinding Background}"
															BorderBrush="{TemplateBinding BorderBrush}"
															BorderThickness="{TemplateBinding BorderThickness}"
															CornerRadius="4">
														<Grid>
															<Grid.ColumnDefinitions>
																<ColumnDefinition Width="*" />
																<ColumnDefinition Width="Auto" />
															</Grid.ColumnDefinitions>
															<ContentPresenter Grid.Column="0"
																Content="{TemplateBinding SelectionBoxItem}"
																ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
																Margin="{TemplateBinding Padding}"
																VerticalAlignment="Center" />
															<ToggleButton Grid.Column="1"
																Background="{DynamicResource SurfaceBrush}" BorderThickness="0" Padding="8"
																IsChecked="{Binding Path=IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}">
																<Path Data="M0,0 L8,0 L4,4"
																	Fill="{DynamicResource TextPrimaryBrush}"
																	Width="8" Height="8" Stretch="Fill" />
															</ToggleButton>
														</Grid>
													</Border>
													<Popup IsOpen="{TemplateBinding IsDropDownOpen}"
														Placement="Bottom" AllowsTransparency="True">
														<Border Background="{DynamicResource CardBackgroundBrush}"
															BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="4"
															MinWidth="{TemplateBinding ActualWidth}">
															<ScrollViewer MaxHeight="200">
																<ItemsPresenter />
															</ScrollViewer>
														</Border>
													</Popup>
												</Grid>
											</ControlTemplate>
										</Control.Template>
									</ComboBox>
									<StackPanel Grid.Column="1" Orientation="Horizontal" Margin="12,0,0,0" VerticalAlignment="Center">
										<Border Name="previewPrimaryColor"
											Width="28" Height="28" CornerRadius="4"
											Background="{DynamicResource PrimaryBrush}"
											Margin="0,0,8,0" />
										<Border Name="previewSecondaryColor"
											Width="28" Height="28" CornerRadius="4"
											Background="{DynamicResource PrimaryDarkBrush}" />
									</StackPanel>
								</Grid>
								<TextBlock
									Text="游戏目录"
									Foreground="{DynamicResource TextSecondaryBrush}"
									FontSize="12"
									FontFamily="Microsoft YaHei"
									Margin="0,24,0,8" />
								<Border
									Background="{DynamicResource SurfaceBrush}"
									CornerRadius="6"
									Padding="4"
									Margin="0,0,0,0">
									<StackPanel x:Name="panelGameFolders">
										<TextBlock
											Text="文件夹列表"
											Foreground="{DynamicResource TextSecondaryBrush}"
											FontSize="12"
											FontFamily="Microsoft YaHei"
											Margin="9,10,5,4"
											Opacity="0.7" />
										<ItemsControl x:Name="listGameFolders">
											<ItemsControl.ItemTemplate>
												<DataTemplate>
													<Border
														x:Name="itemBorder"
														Background="Transparent"
														CornerRadius="4"
														Padding="8,6"
														Margin="4,2"
														Cursor="Hand">
														<Grid>
															<Grid.ColumnDefinitions>
																<ColumnDefinition Width="Auto" />
																<ColumnDefinition Width="*" />
																<ColumnDefinition Width="Auto" />
															</Grid.ColumnDefinitions>
															<RadioButton
																Grid.Column="0"
																IsChecked="{Binding IsSelected}"
																GroupName="GameFolderGroup"
																VerticalAlignment="Center"
																Margin="0,0,8,0"
																Tag="{Binding}"
																Checked="FolderRadio_Checked">
																<RadioButton.Template>
																	<ControlTemplate TargetType="{x:Type RadioButton}">
																		<Border x:Name="radioBorder"
																			Width="16" Height="16"
																			CornerRadius="8"
																			BorderThickness="2"
																			BorderBrush="{DynamicResource TextSecondaryBrush}"
																			Background="Transparent"
																			VerticalAlignment="Center">
																			<Ellipse x:Name="checkDot"
																				Width="8" Height="8"
																				Fill="{DynamicResource PrimaryBrush}"
																				Visibility="Collapsed" />
																		</Border>
																		<ControlTemplate.Triggers>
																			<Trigger Property="IsChecked" Value="True">
																				<Setter TargetName="checkDot" Property="Visibility" Value="Visible" />
																				<Setter TargetName="radioBorder" Property="BorderBrush" Value="{DynamicResource PrimaryBrush}" />
																			</Trigger>
																		</ControlTemplate.Triggers>
																	</ControlTemplate>
																</RadioButton.Template>
															</RadioButton>
															<StackPanel Grid.Column="1" VerticalAlignment="Center">
																<TextBlock
																	Text="{Binding Name}"
																	Foreground="{DynamicResource PrimaryBrush}"
																	FontSize="15"
																	FontFamily="Microsoft YaHei"
																	FontWeight="SemiBold"
																	TextTrimming="CharacterEllipsis" />
																<TextBlock
																	Text="{Binding DisplayPath}"
																	Foreground="{DynamicResource TextSecondaryBrush}"
																	FontSize="11"
																	FontFamily="Microsoft YaHei"
																	Margin="0,2,0,0"
																	TextTrimming="CharacterEllipsis" />
															</StackPanel>
															<Button
																Grid.Column="2"
																Tag="{Binding}"
																Background="Transparent"
																BorderThickness="0"
																Padding="6"
																VerticalAlignment="Center"
																Cursor="Hand"
																Click="FolderSettings_Click">
																<Path
																	Width="16" Height="16"
																	Data="M12 15.5A1.5 1.5 0 1 1 12 18.5A1.5 1.5 0 0 1 12 15.5M12 10.5A1.5 1.5 0 1 1 12 13.5A1.5 1.5 0 0 1 12 10.5M12 5.5A1.5 1.5 0 1 1 12 8.5A1.5 1.5 0 0 1 12 5.5"
																	Fill="{DynamicResource TextSecondaryBrush}"
																	Stretch="Uniform" />
																<Button.Template>
																	<ControlTemplate TargetType="{x:Type Button}">
																		<Border x:Name="btnBorder"
																			Background="{TemplateBinding Background}"
																			CornerRadius="4"
																			Padding="{TemplateBinding Padding}">
																			<ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
																		</Border>
																		<ControlTemplate.Triggers>
																			<Trigger Property="IsMouseOver" Value="True">
																				<Setter TargetName="btnBorder" Property="Background" Value="{DynamicResource CardHoverBrush}" />
																			</Trigger>
																		</ControlTemplate.Triggers>
																	</ControlTemplate>
																</Button.Template>
															</Button>
														</Grid>
													</Border>
													<DataTemplate.Triggers>
														<DataTrigger Binding="{Binding IsSelected}" Value="True">
															<Setter TargetName="itemBorder" Property="Background" Value="{DynamicResource CardBackgroundBrush}" />
														</DataTrigger>
														<Trigger SourceName="itemBorder" Property="IsMouseOver" Value="True">
															<Setter TargetName="itemBorder" Property="Background" Value="{DynamicResource CardHoverBrush}" />
														</Trigger>
													</DataTemplate.Triggers>
												</DataTemplate>
											</ItemsControl.ItemTemplate>
										</ItemsControl>
										<TextBlock
											Text="添加或导入"
											Foreground="{DynamicResource TextSecondaryBrush}"
											FontSize="12"
											FontFamily="Microsoft YaHei"
											Margin="9,12,5,4"
											Opacity="0.7" />
										<Border
											x:Name="btnCreateFolder"
											Background="Transparent"
											CornerRadius="4"
											Padding="8,8"
											Margin="4,2"
											Cursor="Hand"
											MouseLeftButtonUp="BtnCreateFolder_Click">
											<Grid>
												<Grid.ColumnDefinitions>
													<ColumnDefinition Width="Auto" />
													<ColumnDefinition Width="*" />
												</Grid.ColumnDefinitions>
												<Path Grid.Column="0"
													Width="22" Height="22"
													Margin="0,0,10,0"
													Data="M10 4H4c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V8c0-1.1-.9-2-2-2h-8l-2-2z"
													Fill="{DynamicResource TextPrimaryBrush}"
													Stretch="Uniform"
													VerticalAlignment="Center" />
												<TextBlock Grid.Column="1"
													Text="新建 .minecraft 文件夹"
													Foreground="{DynamicResource TextPrimaryBrush}"
													FontSize="14"
													FontFamily="Microsoft YaHei"
													VerticalAlignment="Center" />
											</Grid>
											<Border.Style>
												<Style TargetType="{x:Type Border}">
													<Style.Triggers>
														<Trigger Property="IsMouseOver" Value="True">
															<Setter Property="Background" Value="{DynamicResource CardHoverBrush}" />
														</Trigger>
													</Style.Triggers>
												</Style>
											</Border.Style>
										</Border>
										<Border
											x:Name="btnAddFolder"
											Background="Transparent"
											CornerRadius="4"
											Padding="8,8"
											Margin="4,2"
											Cursor="Hand"
											MouseLeftButtonUp="BtnAddFolder_Click">
											<Grid>
												<Grid.ColumnDefinitions>
													<ColumnDefinition Width="Auto" />
													<ColumnDefinition Width="*" />
												</Grid.ColumnDefinitions>
												<Path Grid.Column="0"
													Width="22" Height="22"
													Margin="0,0,10,0"
													Data="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm5 11h-4v4h-2v-4H7v-2h4V7h2v4h4v2z"
													Fill="{DynamicResource TextPrimaryBrush}"
													Stretch="Uniform"
													VerticalAlignment="Center" />
												<TextBlock Grid.Column="1"
													Text="添加已有文件夹"
													Foreground="{DynamicResource TextPrimaryBrush}"
													FontSize="14"
													FontFamily="Microsoft YaHei"
													VerticalAlignment="Center" />
											</Grid>
											<Border.Style>
												<Style TargetType="{x:Type Border}">
													<Style.Triggers>
														<Trigger Property="IsMouseOver" Value="True">
															<Setter Property="Background" Value="{DynamicResource CardHoverBrush}" />
														</Trigger>
													</Style.Triggers>
												</Style>
											</Border.Style>
										</Border>
										<Border
											x:Name="btnImportModpack"
											Background="Transparent"
											CornerRadius="4"
											Padding="8,8"
											Margin="4,2,4,8"
											Cursor="Hand"
											MouseLeftButtonUp="BtnImportModpack_Click">
											<Grid>
												<Grid.ColumnDefinitions>
													<ColumnDefinition Width="Auto" />
													<ColumnDefinition Width="*" />
												</Grid.ColumnDefinitions>
												<Path Grid.Column="0"
													Width="22" Height="22"
													Margin="0,0,10,0"
													Data="M12 4V1L8 5l4 4V6c3.31 0 6 2.69 6 6 0 1.01-.25 1.97-.7 2.8l1.46 1.46C19.54 15.03 20 13.57 20 12c0-4.42-3.58-8-8-8zm0 14c-3.31 0-6-2.69-6-6 0-1.01.25-1.97.7-2.8L5.24 7.74C4.46 8.97 4 10.43 4 12c0 4.42 3.58 8 8 8v3l4-4-4-4v3z"
													Fill="{DynamicResource TextPrimaryBrush}"
													Stretch="Uniform"
													VerticalAlignment="Center" />
												<TextBlock Grid.Column="1"
													Text="导入整合包"
													Foreground="{DynamicResource TextPrimaryBrush}"
													FontSize="14"
													FontFamily="Microsoft YaHei"
													VerticalAlignment="Center" />
											</Grid>
											<Border.Style>
												<Style TargetType="{x:Type Border}">
													<Style.Triggers>
														<Trigger Property="IsMouseOver" Value="True">
															<Setter Property="Background" Value="{DynamicResource CardHoverBrush}" />
														</Trigger>
													</Style.Triggers>
												</Style>
											</Border.Style>
										</Border>
									</StackPanel>
