														FontSize="11"
														FontFamily="Microsoft YaHei"
														VerticalAlignment="Center" />
												</StackPanel>
											</Grid>
											<!-- 内存优化 -->
											<CheckBox
												Name="chkLaunchArgumentRam"
												Content="启动游戏前进行内存优化"
												IsChecked="False"
												Foreground="{DynamicResource TextPrimaryBrush}"
												FontFamily="Microsoft YaHei"
												FontSize="13"
												Margin="0,12,0,0"
												ToolTip="通过修剪进程工作集和 .NET GC 释放物理内存。&#xa;修剪全部进程需要管理员权限，否则仅优化启动器自身。&#xa;部分内存数据会被换出到页面文件，机械硬盘可能短暂卡顿。&#xa;若已安装 Mem Reduct，会自动调用其进行深度清理。" />
											<Button
												Name="btnMemoryOptimize"
												Content="立即优化内存"
												Background="{DynamicResource SurfaceBrush}"
												Foreground="{DynamicResource TextPrimaryBrush}"
												BorderBrush="{DynamicResource BorderBrush}"
												BorderThickness="1"
												Padding="12,6"
												FontSize="12"
												ToolTip="手动执行一次完整的内存清理（工作集修剪 + GC + Mem Reduct）"
												FontFamily="Microsoft YaHei"
												Cursor="Hand"
												HorizontalAlignment="Left"
												Margin="0,8,0,0"
