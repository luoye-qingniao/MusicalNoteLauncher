													<ControlTemplate TargetType="{x:Type Button}">
														<Border Name="border" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="4" Padding="{TemplateBinding Padding}">
															<ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
														</Border>
														<ControlTemplate.Triggers>
															<Trigger Property="IsMouseOver" Value="True">
																<Setter TargetName="border" Property="Background" Value="{DynamicResource CardHoverBrush}" />
															</Trigger>
														</ControlTemplate.Triggers>
													</ControlTemplate>
												</Button.Template>
											</Button>
										</StackPanel>
									</Border>
									<TextBlock
										Text="分辨率设置"
										Foreground="{DynamicResource TextSecondaryBrush}"
										FontSize="12"
										FontFamily="Microsoft YaHei"
										Margin="0,24,0,8" />
									<Grid>
										<Grid.ColumnDefinitions>
											<ColumnDefinition
												Width="*" />
											<ColumnDefinition
												Width="Auto" />
										</Grid.ColumnDefinitions>
										<ComboBox
											Name="cbResolution"
											Background="{DynamicResource SurfaceBrush}"
											Foreground="{DynamicResource TextPrimaryBrush}"
											BorderBrush="{DynamicResource BorderBrush}"
											BorderThickness="1"
											Padding="10,6"
											FontSize="13"
											FontFamily="Microsoft YaHei"
											Grid.Column="0">
											<Control.Template>
												<ControlTemplate
													TargetType="{x:Type ComboBox}">
													<Grid>
														<Border
															Background="{TemplateBinding Background}"
															BorderBrush="{TemplateBinding BorderBrush}"
															BorderThickness="{TemplateBinding BorderThickness}"
															CornerRadius="4">
															<Grid>
																<Grid.ColumnDefinitions>
																	<ColumnDefinition
																		Width="*" />
																	<ColumnDefinition
																		Width="Auto" />
																</Grid.ColumnDefinitions>
																<ContentPresenter
																	Grid.Column="0"
																	Content="{TemplateBinding SelectionBoxItem}"
													ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
													Margin="{TemplateBinding Padding}"
													VerticalAlignment="Center" />
													<ToggleButton
														Grid.Column="1"
														Background="{DynamicResource SurfaceBrush}"
														BorderThickness="0"
														Padding="8"
														IsChecked="{Binding Path=IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}">
														<Path
															Data="M0,0 L8,0 L4,4"
															Fill="{DynamicResource TextPrimaryBrush}"
															Width="8"
															Height="8"
															Stretch="Fill" />
																</ToggleButton>
															</Grid>
														</Border>
														<Popup
															IsOpen="{TemplateBinding IsDropDownOpen}"
															Placement="Bottom"
															AllowsTransparency="True">
															<Border
																Background="{DynamicResource CardBackgroundBrush}"
																BorderBrush="{DynamicResource BorderBrush}"
																BorderThickness="1"
																CornerRadius="4"
																MinWidth="{TemplateBinding ActualWidth}">
																<ScrollViewer
																	MaxHeight="200">
																	<ItemsPresenter />
																</ScrollViewer>
															</Border>
														</Popup>
													</Grid>
												</ControlTemplate>
											</Control.Template>
											<ComboBoxItem
												Content="800×600"
												Foreground="{DynamicResource TextPrimaryBrush}"
												Background="{DynamicResource CardBackgroundBrush}" />
											<ComboBoxItem
												Content="1024×768"
												Foreground="{DynamicResource TextPrimaryBrush}"
												Background="{DynamicResource CardBackgroundBrush}" />
											<ComboBoxItem
												Content="1280×720"
												Foreground="{DynamicResource TextPrimaryBrush}"
												Background="{DynamicResource CardBackgroundBrush}" />
											<ComboBoxItem
												Content="1280×1024"
												IsSelected="True"
												Foreground="{DynamicResource TextPrimaryBrush}"
												Background="{DynamicResource CardBackgroundBrush}" />
											<ComboBoxItem
												Content="1920×1080"
												Foreground="{DynamicResource TextPrimaryBrush}"
												Background="{DynamicResource CardBackgroundBrush}" />
										</ComboBox>
										<CheckBox
										Name="chkFullscreen"
										Content="全屏模式"
										IsChecked="False"
										Foreground="{DynamicResource TextPrimaryBrush}"
										FontFamily="Microsoft YaHei"
										Grid.Column="1"
										Margin="16,0,0,0"
										VerticalAlignment="Center" />
								</Grid>
									<!-- 皮肤资源包设置 -->
									<TextBlock
										Text="皮肤资源包"
										Foreground="{DynamicResource TextSecondaryBrush}"
										FontSize="12"
										FontFamily="Microsoft YaHei"
										Margin="0,24,0,8" />
									<CheckBox
										Name="chkEnableSkinResourcePack"
										Content="启用离线皮肤资源包（将自定义皮肤注入游戏，无需安装 Mod）"
										IsChecked="True"
										Foreground="{DynamicResource TextPrimaryBrush}"
										FontFamily="Microsoft YaHei"
										FontSize="13"
										Margin="0,0,0,4"
										ToolTip="启动游戏前，自动将您的自定义皮肤打包为 Minecraft 资源包并注入 options.txt。&#xa;关闭后游戏将使用默认的 Steve/Alex 皮肤。" />
									<TextBlock
										Text="由于技术问题，此功能只保证对 1.19.2 以前的版本有效！"
