										Name="btnResetGameConfig"
										Content="重置游戏配置"
										Background="{DynamicResource SurfaceBrush}"
										Foreground="{DynamicResource TextPrimaryBrush}"
										BorderBrush="{DynamicResource BorderBrush}"
										BorderThickness="1"
										Padding="14,8"
										FontSize="13"
										FontFamily="Microsoft YaHei"
										Cursor="Hand"
										HorizontalAlignment="Left"
										Margin="0,24,0,0"
										Click="BtnResetGameConfig_Click"
										ToolTip="备份当前 options.txt 并生成全新默认配置文件，一键消除 Skipping bad option 警告">
										<Button.Template>
											<ControlTemplate TargetType="{x:Type Button}">
												<Border Name="border" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="4" Padding="{TemplateBinding Padding}">
													<ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
												</Border>
												<ControlTemplate.Triggers>
													<Trigger Property="IsMouseOver" Value="True">
														<Setter TargetName="border" Property="Background" Value="{DynamicResource CardHoverBrush}" />
													</Trigger>
												</ControlTemplate.Triggers>
											</ControlTemplate>
										</Button.Template>
									</Button>
								</StackPanel>
							</TabItem>
							<TabItem
								Header="Java设置">
								<StackPanel>
									<TextBlock
										Text="Java设置"
										Foreground="{DynamicResource TextPrimaryBrush}"
										FontSize="18"
										FontWeight="SemiBold"
										FontFamily="Microsoft YaHei"
										Margin="0,0,0,16" />
									<!-- 当前 Java 状态 -->
									<Border
										Background="{DynamicResource CardBackgroundBrush}"
										BorderBrush="{DynamicResource BorderBrush}"
										BorderThickness="1"
										CornerRadius="8"
										Padding="20,16"
										Margin="0,0,0,16">
										<StackPanel>
											<TextBlock
												Text="当前 Java"
												Foreground="{DynamicResource TextPrimaryBrush}"
												FontSize="14"
												FontWeight="SemiBold"
												FontFamily="Microsoft YaHei"
												Margin="0,0,0,10" />
											<Grid>
												<Grid.ColumnDefinitions>
													<ColumnDefinition Width="Auto" />
													<ColumnDefinition Width="*" />
												</Grid.ColumnDefinitions>
												<Border
													Name="bdrJavaStatus"
													Grid.Column="0"
													Width="8"
													Height="8"
													CornerRadius="4"
													Background="#FF9800"
													Margin="0,0,12,0"
													VerticalAlignment="Center" />
												<StackPanel Grid.Column="1">
													<TextBlock
														Name="txtCurrentJavaVersionBold"
														Text="未配置"
														Foreground="{DynamicResource TextPrimaryBrush}"
														FontSize="15"
														FontWeight="SemiBold"
														FontFamily="Microsoft YaHei" />
													<TextBlock
														Name="txtCurrentJavaPathSmall"
														Text="请在下方检测或设置 Java 路径"
														Foreground="{DynamicResource TextSecondaryBrush}"
														FontSize="11"
														FontFamily="Microsoft YaHei"
														Margin="0,2,0,0"
														TextTrimming="CharacterEllipsis" />
													<TextBlock
														Name="txtCurrentJavaMem"
														Text=""
														Foreground="{DynamicResource TextSecondaryBrush}"
														FontSize="11"
														FontFamily="Microsoft YaHei"
														Margin="0,1,0,0" />
												</StackPanel>
											</Grid>
										</StackPanel>
									</Border>
