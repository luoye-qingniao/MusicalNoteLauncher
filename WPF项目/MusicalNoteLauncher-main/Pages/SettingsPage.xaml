														Margin="0,0,4,0"
														VerticalAlignment="Center" />
													<TextBlock
														Name="txtRamUsedLabel"
														Text="已使用 0 GB / 0 GB"
														Foreground="{DynamicResource TextSecondaryBrush}"
														FontSize="11"
														FontFamily="Microsoft YaHei"
														VerticalAlignment="Center" />
												</StackPanel>
												<StackPanel
													Grid.Column="1"
													Orientation="Horizontal"
													HorizontalAlignment="Center">
													<Border
														Width="10"
														Height="10"
														CornerRadius="2"
														Background="#9B59B6"
														Opacity="0.7"
														Margin="0,0,4,0"
