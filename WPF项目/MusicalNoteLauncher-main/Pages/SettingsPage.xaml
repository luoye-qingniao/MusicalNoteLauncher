															FontFamily="Microsoft YaHei"
															Margin="0,2,0,0" />
													</StackPanel>
												</Grid>
											</Grid>
										</StackPanel>
									</Border>
									<!-- 特别鸣谢 -->
									<Border
										Background="{DynamicResource SurfaceBrush}"
										CornerRadius="8"
										Padding="25,30,25,20">
										<StackPanel>
											<TextBlock
												Text="特别鸣谢"
												Foreground="{DynamicResource TextPrimaryBrush}"
												FontSize="15"
												FontWeight="Bold"
												FontFamily="Microsoft YaHei"
												Margin="0,0,0,16" />
											<StackPanel>
												<Grid Margin="0,0,0,10">
													<Grid.ColumnDefinitions>
														<ColumnDefinition Width="Auto" />
														<ColumnDefinition />
													</Grid.ColumnDefinitions>
													<Image Source="/Assets/Heads/PCL2.png" Width="34" Height="34" Margin="0,0,12,0" VerticalAlignment="Top">
														<Image.Clip>
															<EllipseGeometry Center="17,17" RadiusX="17" RadiusY="17" />
														</Image.Clip>
													</Image>
													<StackPanel Grid.Column="1">
														<TextBlock
															Text="PCL (Plain Craft Launcher)"
															Foreground="{DynamicResource TextPrimaryBrush}"
															FontSize="13"
															FontWeight="SemiBold"
															FontFamily="Microsoft YaHei" />
														<TextBlock
															Text="设计灵感与架构参考"
															Foreground="{DynamicResource TextSecondaryBrush}"
															FontSize="12"
															FontFamily="Microsoft YaHei"
															Margin="0,2,0,0" />
													</StackPanel>
												</Grid>
												<StackPanel Margin="0,0,0,10">
													<TextBlock
														Text="HMCL (Hello Minecraft! Launcher)"
														Foreground="{DynamicResource TextPrimaryBrush}"
														FontSize="13"
														FontWeight="SemiBold"
														FontFamily="Microsoft YaHei" />
													<TextBlock
														Text="项目参考与技术方案"
														Foreground="{DynamicResource TextSecondaryBrush}"
														FontSize="12"
														FontFamily="Microsoft YaHei"
														Margin="0,2,0,0" />
												</StackPanel>
												<Grid Margin="0,0,0,10">
													<Grid.ColumnDefinitions>
														<ColumnDefinition Width="Auto" />
														<ColumnDefinition />
													</Grid.ColumnDefinitions>
													<Image Source="/Assets/Heads/bangbang93.png" Width="34" Height="34" Margin="0,0,12,0" VerticalAlignment="Top">
														<Image.Clip>
															<EllipseGeometry Center="17,17" RadiusX="17" RadiusY="17" />
														</Image.Clip>
													</Image>
													<StackPanel Grid.Column="1">
														<TextBlock
															Text="BMCLAPI (bangbang93)"
															Foreground="{DynamicResource TextPrimaryBrush}"
															FontSize="13"
															FontWeight="SemiBold"
															FontFamily="Microsoft YaHei" />
														<TextBlock
															Text="Minecraft 下载镜像加速"
															Foreground="{DynamicResource TextSecondaryBrush}"
															FontSize="12"
															FontFamily="Microsoft YaHei"
															Margin="0,2,0,0" />
													</StackPanel>
												</Grid>
												<StackPanel Margin="0,0,0,10">
													<TextBlock
														Text="CurseForge"
														Foreground="{DynamicResource TextPrimaryBrush}"
														FontSize="13"
														FontWeight="SemiBold"
														FontFamily="Microsoft YaHei" />
													<TextBlock
														Text="Mod 与整合包资源平台"
														Foreground="{DynamicResource TextSecondaryBrush}"
														FontSize="12"
														FontFamily="Microsoft YaHei"
														Margin="0,2,0,0" />
												</StackPanel>
												<StackPanel Margin="0,0,0,10">
													<TextBlock
														Text="Modrinth"
														Foreground="{DynamicResource TextPrimaryBrush}"
														FontSize="13"
														FontWeight="SemiBold"
														FontFamily="Microsoft YaHei" />
													<TextBlock
														Text="Mod 与整合包资源平台"
														Foreground="{DynamicResource TextSecondaryBrush}"
														FontSize="12"
														FontFamily="Microsoft YaHei"
														Margin="0,2,0,0" />
												</StackPanel>
												<Grid>
													<Grid.ColumnDefinitions>
														<ColumnDefinition Width="Auto" />
														<ColumnDefinition />
													</Grid.ColumnDefinitions>
													<Image Source="/Assets/Heads/EasyTier.png" Width="34" Height="34" Margin="0,0,12,0" VerticalAlignment="Top">
														<Image.Clip>
															<EllipseGeometry Center="17,17" RadiusX="17" RadiusY="17" />
														</Image.Clip>
													</Image>
													<StackPanel Grid.Column="1">
														<TextBlock
															Text="EasyTier"
															Foreground="{DynamicResource TextPrimaryBrush}"
															FontSize="13"
															FontWeight="SemiBold"
															FontFamily="Microsoft YaHei" />
														<TextBlock
															Text="P2P 虚拟组网联机"
															Foreground="{DynamicResource TextSecondaryBrush}"
															FontSize="12"
															FontFamily="Microsoft YaHei"
															Margin="0,2,0,0" />
													</StackPanel>
												</Grid>
											</StackPanel>
										</StackPanel>
									</Border>
								</StackPanel>
							</TabItem>
							<!-- ═══════════════════════════════════════════════ -->
							<!-- 背景设置 TabItem -->
							<!-- ═══════════════════════════════════════════════ -->
							<TabItem
								Header="背景设置">
								<StackPanel>
									<TextBlock
										Text="背景设置"
										Foreground="{DynamicResource TextPrimaryBrush}"
										FontSize="18"
										FontWeight="SemiBold"
										FontFamily="Microsoft YaHei"
										Margin="0,0,0,16" />

									<!-- 背景模式选择 -->
									<TextBlock
										Text="背景模式"
										Foreground="{DynamicResource TextSecondaryBrush}"
										FontSize="12"
										FontFamily="Microsoft YaHei"
										Margin="0,0,0,8" />
									<Border
										Background="{DynamicResource SurfaceBrush}"
										CornerRadius="8"
										Padding="16">
										<StackPanel>
											<RadioButton
												Name="radioBgMica"
												Content="默认 Mica 云母背景"
												GroupName="BackgroundMode"
												IsChecked="True"
												Foreground="{DynamicResource TextPrimaryBrush}"
												FontSize="13"
												FontFamily="Microsoft YaHei"
												Margin="0,4"
												Checked="RadioBgMode_Checked" />
											<RadioButton
												Name="radioBgImage"
												Content="本地图片背景"
												GroupName="BackgroundMode"
												Foreground="{DynamicResource TextPrimaryBrush}"
												FontSize="13"
												FontFamily="Microsoft YaHei"
												Margin="0,4"
												Checked="RadioBgMode_Checked" />
											<RadioButton
												Name="radioBgVideo"
												Content="本地视频背景（MP4）"
												GroupName="BackgroundMode"
												Foreground="{DynamicResource TextPrimaryBrush}"
												FontSize="13"
												FontFamily="Microsoft YaHei"
												Margin="0,4"
												Checked="RadioBgMode_Checked" />
										</StackPanel>
									</Border>

									<!-- 图片文件选择 -->
									<StackPanel
										Name="panBgImagePath"
										Visibility="Collapsed"
										Margin="0,16,0,0">
										<TextBlock
											Text="图片文件"
											Foreground="{DynamicResource TextSecondaryBrush}"
											FontSize="12"
											FontFamily="Microsoft YaHei"
											Margin="0,0,0,8" />
										<Grid>
											<Grid.ColumnDefinitions>
												<ColumnDefinition Width="*" />
												<ColumnDefinition Width="Auto" />
											</Grid.ColumnDefinitions>
											<TextBox
												Name="txtBgImagePath"
												Grid.Column="0"
												Text=""
												Background="{DynamicResource SurfaceBrush}"
												Foreground="{DynamicResource TextPrimaryBrush}"
												BorderBrush="{DynamicResource BorderBrush}"
												BorderThickness="1"
												Padding="10,8"
												FontSize="13"
												FontFamily="Microsoft YaHei"
												IsReadOnly="True" />
											<Button
												Grid.Column="1"
												Content="浏览..."
												Background="{DynamicResource SurfaceBrush}"
												Foreground="{DynamicResource TextPrimaryBrush}"
												BorderBrush="{DynamicResource BorderBrush}"
												BorderThickness="1"
												Padding="12,8"
												FontSize="12"
												FontFamily="Microsoft YaHei"
												Cursor="Hand"
												Margin="8,0,0,0"
												Click="BtnBrowseBgImage_Click">
												<Button.Template>
													<ControlTemplate TargetType="{x:Type Button}">
														<Border Name="border" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="4" Padding="{TemplateBinding Padding}">
															<ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
														</Border>
														<ControlTemplate.Triggers>
															<Trigger Property="IsMouseOver" Value="True">
																<Setter TargetName="border" Property="Background" Value="{DynamicResource CardHoverBrush}" />
															</Trigger>
														</ControlTemplate.Triggers>
													</ControlTemplate>
												</Button.Template>
											</Button>
										</Grid>
									</StackPanel>

									<!-- 视频文件选择 -->
									<StackPanel
										Name="panBgVideoPath"
										Visibility="Collapsed"
										Margin="0,16,0,0">
										<TextBlock
											Text="视频文件"
											Foreground="{DynamicResource TextSecondaryBrush}"
											FontSize="12"
											FontFamily="Microsoft YaHei"
											Margin="0,0,0,8" />
										<Grid>
											<Grid.ColumnDefinitions>
												<ColumnDefinition Width="*" />
												<ColumnDefinition Width="Auto" />
											</Grid.ColumnDefinitions>
											<TextBox
												Name="txtBgVideoPath"
												Grid.Column="0"
												Text=""
												Background="{DynamicResource SurfaceBrush}"
												Foreground="{DynamicResource TextPrimaryBrush}"
												BorderBrush="{DynamicResource BorderBrush}"
												BorderThickness="1"
												Padding="10,8"
												FontSize="13"
												FontFamily="Microsoft YaHei"
												IsReadOnly="True" />
											<Button
												Grid.Column="1"
												Content="浏览..."
												Background="{DynamicResource SurfaceBrush}"
												Foreground="{DynamicResource TextPrimaryBrush}"
												BorderBrush="{DynamicResource BorderBrush}"
												BorderThickness="1"
												Padding="12,8"
												FontSize="12"
												FontFamily="Microsoft YaHei"
												Cursor="Hand"
												Margin="8,0,0,0"
												Click="BtnBrowseBgVideo_Click">
												<Button.Template>
													<ControlTemplate TargetType="{x:Type Button}">
														<Border Name="border" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="4" Padding="{TemplateBinding Padding}">
															<ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
														</Border>
														<ControlTemplate.Triggers>
															<Trigger Property="IsMouseOver" Value="True">
																<Setter TargetName="border" Property="Background" Value="{DynamicResource CardHoverBrush}" />
															</Trigger>
														</ControlTemplate.Triggers>
													</ControlTemplate>
												</Button.Template>
											</Button>
										</Grid>
									</StackPanel>

									<!-- 透明度调节 -->
									<TextBlock
										Text="背景透明度"
										Foreground="{DynamicResource TextSecondaryBrush}"
										FontSize="12"
										FontFamily="Microsoft YaHei"
										Margin="0,24,0,8" />
									<Grid>
										<Grid.ColumnDefinitions>
											<ColumnDefinition Width="*" />
											<ColumnDefinition Width="Auto" />
										</Grid.ColumnDefinitions>
										<Slider
											Name="sliderBgOpacity"
											Grid.Column="0"
											Minimum="0"
											Maximum="1"
											Value="0.6"
											TickFrequency="0.05"
											IsSnapToTickEnabled="True"
											ValueChanged="SliderBgOpacity_ValueChanged"
											VerticalAlignment="Center"
											Margin="0,0,12,0" />
										<TextBlock
											Name="txtBgOpacityValue"
											Grid.Column="1"
											Text="60%"
											Foreground="{DynamicResource TextPrimaryBrush}"
											FontSize="14"
											FontFamily="Microsoft YaHei"
											MinWidth="40"
											TextAlignment="Right"
											VerticalAlignment="Center" />
									</Grid>

									<!-- 高斯模糊强度调节 -->
									<TextBlock
										Text="高斯模糊强度"
										Foreground="{DynamicResource TextSecondaryBrush}"
										FontSize="12"
										FontFamily="Microsoft YaHei"
										Margin="0,24,0,8" />
									<Grid>
										<Grid.ColumnDefinitions>
											<ColumnDefinition Width="*" />
											<ColumnDefinition Width="Auto" />
										</Grid.ColumnDefinitions>
										<Slider
											Name="sliderBgBlur"
											Grid.Column="0"
											Minimum="0"
											Maximum="20"
											Value="0"
											TickFrequency="1"
											IsSnapToTickEnabled="True"
											ValueChanged="SliderBgBlur_ValueChanged"
											VerticalAlignment="Center"
											Margin="0,0,12,0" />
										<TextBlock
											Name="txtBgBlurValue"
											Grid.Column="1"
											Text="0"
											Foreground="{DynamicResource TextPrimaryBrush}"
											FontSize="14"
											FontFamily="Microsoft YaHei"
											MinWidth="30"
											TextAlignment="Right"
											VerticalAlignment="Center" />
									</Grid>

									<!-- 重置按钮 -->
									<Button
										Name="btnResetBackground"
										Content="重置默认背景"
										Background="{DynamicResource SurfaceBrush}"
										Foreground="{DynamicResource TextPrimaryBrush}"
										BorderBrush="{DynamicResource BorderBrush}"
										BorderThickness="1"
										Padding="14,8"
										FontSize="13"
										FontFamily="Microsoft YaHei"
										Cursor="Hand"
										HorizontalAlignment="Left"
										Margin="0,24,0,0"
										Click="BtnResetBackground_Click">
										<Button.Template>
											<ControlTemplate TargetType="{x:Type Button}">
												<Border Name="border" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="4" Padding="{TemplateBinding Padding}">
													<ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
												</Border>
												<ControlTemplate.Triggers>
													<Trigger Property="IsMouseOver" Value="True">
														<Setter TargetName="border" Property="Background" Value="{DynamicResource CardHoverBrush}" />
													</Trigger>
												</ControlTemplate.Triggers>
											</ControlTemplate>
										</Button.Template>
									</Button>
								</StackPanel>
							</TabItem>
						</TabControl>
						<Button
							Content="保存设置"
							Background="{DynamicResource PrimaryBrush}"
							Foreground="{DynamicResource TextPrimaryBrush}"
							BorderThickness="0"
							Padding="16,10"
							FontSize="14"
							FontFamily="Microsoft YaHei"
							Cursor="Hand"
							Margin="0,30,0,0"
							HorizontalAlignment="Left"
							Click="BtnSaveSettings_Click">
							<Button.Template>
								<ControlTemplate
									TargetType="{x:Type Button}">
									<Border
										Name="border"
										Background="{TemplateBinding Background}"
										CornerRadius="4"
										Padding="{TemplateBinding Padding}">
										<ContentPresenter
											HorizontalAlignment="Center"
											VerticalAlignment="Center" />
									</Border>
									<ControlTemplate.Triggers>
										<Trigger
											Property="UIElement.IsMouseOver"
											Value="True">
											<Setter
												TargetName="border"
												Property="Background"
												Value="{DynamicResource PrimaryDarkBrush}" />
										</Trigger>
									</ControlTemplate.Triggers>
								</ControlTemplate>
							</Button.Template>
						</Button>
					</StackPanel>
				</Border>
			</Grid>
		</Grid>
	</ScrollViewer>
</UserControl>
