																			FontSize="10"
																			Foreground="White"
																			FontWeight="SemiBold">
																			<Run Text="Java " />
																			<Run Text="{Binding MajorVersion}" />
																		</TextBlock>
																	</Border>
																	<TextBlock
																		FontSize="11"
																		Foreground="{DynamicResource TextSecondaryBrush}"
																		VerticalAlignment="Center">
																		<Run Text="{Binding MaxMemoryMb}" />
																		<Run Text=" MB 可用" />
																	</TextBlock>
																</StackPanel>
															</StackPanel>
															<Button
																Grid.Column="1"
																Content="使用"
																Background="#4CAF50"
																Foreground="White"
																BorderThickness="0"
																Padding="12,6"
																FontSize="12"
																FontWeight="SemiBold"
																FontFamily="Microsoft YaHei"
																Cursor="Hand"
																Tag="{Binding}"
																Click="BtnUseDetectedJava_Click">
																<Button.Template>
																	<ControlTemplate TargetType="{x:Type Button}">
																		<Border Name="border" Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
																			<ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
																		</Border>
