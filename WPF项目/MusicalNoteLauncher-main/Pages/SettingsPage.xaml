										FontSize="11"
										FontFamily="Microsoft YaHei"
										Margin="20,2,0,4"
										Opacity="0.9" />
									<TextBlock
										Text="提示：皮肤可在个人资料页面设置，此选项控制启动时是否自动加载。"
										Foreground="{DynamicResource TextSecondaryBrush}"
										FontSize="11"
										FontFamily="Microsoft YaHei"
										Margin="20,0,0,0"
										Opacity="0.7" />
									<!-- ★ 重置游戏配置 -->
