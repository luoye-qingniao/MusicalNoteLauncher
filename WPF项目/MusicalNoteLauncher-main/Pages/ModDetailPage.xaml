<UserControl x:Class="MusicalNoteLauncher.Pages.ModDetailPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="700" d:DesignWidth="900"
             Background="{DynamicResource BackgroundBrush}">

    <Grid Background="{DynamicResource BackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="60" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- 头部 -->
        <Border Grid.Row="0" Background="{DynamicResource CardHoverBrush}">
            <StackPanel Orientation="Horizontal" Margin="20,0" VerticalAlignment="Center">
                <Button x:Name="BtnBack" Content="&#x2190; 返回"
                        Background="#00FFFFFF" Foreground="#2196F3" BorderThickness="0"
                        FontSize="14" FontFamily="Microsoft YaHei" Cursor="Hand"
                        Margin="0,0,20,0" Click="BtnBack_Click" />
                <Border Background="#FF9800" CornerRadius="8" Width="32" Height="32" Margin="0,0,10,0">
                    <TextBlock Text="&#x1F9E9;" FontSize="16" HorizontalAlignment="Center"
                               VerticalAlignment="Center" />
                </Border>
                <TextBlock x:Name="TxtPageTitle" Text="模组详情" FontSize="20" FontWeight="Bold"
                           Foreground="{DynamicResource TextPrimaryBrush}" FontFamily="Microsoft YaHei" />
            </StackPanel>
        </Border>

        <!-- 加载遮罩 -->
        <Grid x:Name="LoadingOverlay" Grid.Row="1" Visibility="Collapsed"
              Background="{DynamicResource SurfaceBrush}" Opacity="0.85" Panel.ZIndex="100">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Text="&#x2B6F;" FontSize="36" Foreground="#1EBB8E"
                           HorizontalAlignment="Center" RenderTransformOrigin="0.5,0.5">
                    <TextBlock.RenderTransform>
                        <RotateTransform x:Name="SpinnerRotate" />
                    </TextBlock.RenderTransform>
                </TextBlock>
                <TextBlock x:Name="LoadingText" Text="正在加载模组详情..." FontSize="14"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           HorizontalAlignment="Center" Margin="0,8,0,0"
                           FontFamily="Microsoft YaHei" />
            </StackPanel>
        </Grid>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <StackPanel x:Name="RootPanel" Margin="24,20,24,40">
                <!-- 模组介绍区域 -->
                <Border Background="{DynamicResource CardHoverBrush}"
                        CornerRadius="12" Padding="24" Margin="0,0,0,16">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="72" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <!-- 图标 -->
                        <Border x:Name="IconBorder" Width="64" Height="64"
                                CornerRadius="10" ClipToBounds="True"
                                Background="{DynamicResource SurfaceBrush}"
                                VerticalAlignment="Top">
                            <Image x:Name="ImgIcon" Stretch="UniformToFill"
                                   Width="64" Height="64" />
                        </Border>
                        <Border x:Name="IconPlaceholder" Width="64" Height="64"
                                CornerRadius="10"
                                Background="{DynamicResource SurfaceBrush}"
                                VerticalAlignment="Top" Visibility="Collapsed">
                            <TextBlock Text="&#x1F4E6;" FontSize="28"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center" />
                        </Border>

                        <StackPanel Grid.Column="1" Margin="14,0,0,0">
                            <TextBlock x:Name="TxtName" FontSize="20" FontWeight="Bold"
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       TextWrapping="Wrap"
                                       FontFamily="Microsoft YaHei" Margin="0,0,0,4" />
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <TextBlock x:Name="TxtAuthor" FontSize="13"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           FontFamily="Microsoft YaHei" />
                                <TextBlock Text=" &#xB7; " FontSize="13"
                                           Foreground="{DynamicResource TextSecondaryBrush}" />
                                <TextBlock x:Name="TxtSource" FontSize="13"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           FontFamily="Microsoft YaHei" />
                                <TextBlock Text=" &#xB7; " FontSize="13"
                                           Foreground="{DynamicResource TextSecondaryBrush}" />
                                <TextBlock x:Name="TxtDownloads" FontSize="13"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           FontFamily="Microsoft YaHei" />
                            </StackPanel>
                            <Border Background="{DynamicResource SurfaceBrush}"
                                    CornerRadius="8" Padding="14">
                                <TextBlock x:Name="TxtDescription" FontSize="13"
                                           Foreground="{DynamicResource TextPrimaryBrush}"
                                           TextWrapping="Wrap" MaxHeight="120"
                                           TextTrimming="CharacterEllipsis"
                                           FontFamily="Microsoft YaHei" />
                            </Border>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- 前置模组区域 -->
                <Border x:Name="SectionDeps" Background="{DynamicResource CardHoverBrush}"
                        CornerRadius="12" Padding="24" Margin="0,0,0,16"
                        Visibility="Collapsed">
                    <StackPanel>
                        <TextBlock Text="&#x1F517; 前置模组" FontSize="15" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   FontFamily="Microsoft YaHei" Margin="0,0,0,12" />
                        <TextBlock x:Name="DepsLoadingHint" Text="正在分析依赖..."
                                   FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"
                                   FontFamily="Microsoft YaHei" Visibility="Collapsed" />
                        <StackPanel x:Name="PanelDeps" />
                    </StackPanel>
                </Border>

                <!-- 版本列表区域 -->
                <Border Background="{DynamicResource CardHoverBrush}"
                        CornerRadius="12" Padding="24">
                    <StackPanel>
                        <TextBlock Text="&#x1F4E6; 版本列表" FontSize="15" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   FontFamily="Microsoft YaHei" Margin="0,0,0,12" />
                        <StackPanel x:Name="PanelVersions" />
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
