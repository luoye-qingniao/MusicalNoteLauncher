<UserControl
	x:Class="MusicalNoteLauncher.Pages.VersionSelectPage" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:core="clr-namespace:MusicalNoteLauncher.Core"
	Background="{DynamicResource BackgroundBrush}">
	<Grid Background="{DynamicResource BackgroundBrush}">
		<Grid.RowDefinitions>
			<RowDefinition Height="60" />
			<RowDefinition Height="*" />
		</Grid.RowDefinitions>

		<!-- 头部 -->
		<Border Grid.Row="0" Background="{DynamicResource CardHoverBrush}">
			<StackPanel Orientation="Horizontal" Margin="20,0" VerticalAlignment="Center">
				<Button Content="← 返回" Background="#00FFFFFF" Foreground="#2196F3" BorderThickness="0"
				        FontSize="14" FontFamily="Microsoft YaHei" Cursor="Hand" Margin="0,0,20,0" Click="BtnBack_Click"/>
				<Border Background="#FF9800" CornerRadius="8" Width="32" Height="32" Margin="0,0,10,0">
					<TextBlock Text="📋" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center"/>
				</Border>
				<TextBlock x:Name="PageTitle" Text="选择下载版本" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}" FontFamily="Microsoft YaHei"/>
			</StackPanel>
		</Border>

		<!-- 版本选择内容 -->
		<Grid Grid.Row="1" Margin="24,20,24,24">
			<Grid.RowDefinitions>
				<RowDefinition Height="Auto"/>
				<RowDefinition Height="Auto"/>
				<RowDefinition Height="*"/>
				<RowDefinition Height="Auto"/>
			</Grid.RowDefinitions>

			<!-- 标题栏 -->
			<Border Grid.Row="0" Background="{DynamicResource CardBackgroundBrush}" CornerRadius="12,12,0,0" Padding="20,18"
			        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
				<StackPanel Orientation="Horizontal">
					<TextBlock Text="📋" FontSize="18" VerticalAlignment="Center" Margin="0,0,10,0"/>
					<TextBlock x:Name="VersionTitle" Text="正在加载版本列表..."
					           FontSize="17" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}"
					           FontFamily="Microsoft YaHei" VerticalAlignment="Center"/>
				</StackPanel>
			</Border>

			<!-- 版本筛选栏 -->
			<Border Grid.Row="1" Background="{DynamicResource CardBackgroundBrush}" Padding="10,8"
			        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
				<StackPanel x:Name="VersionFilterPanel" Orientation="Horizontal"/>
			</Border>

			<!-- 版本列表 -->
			<Border Grid.Row="2" Background="{DynamicResource CardBackgroundBrush}">
				<Grid>
					<!-- 加载中遮罩 -->
					<Border x:Name="LoadingOverlay" Background="{DynamicResource CardBackgroundBrush}" Visibility="Visible">
						<StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
							<TextBlock Text="⏳" FontSize="32" HorizontalAlignment="Center" Margin="0,0,0,12"/>
							<TextBlock x:Name="LoadingText" Text="正在获取版本列表..." FontSize="14"
							           Foreground="{DynamicResource TextSecondaryBrush}" FontFamily="Microsoft YaHei"
							           HorizontalAlignment="Center"/>
						</StackPanel>
					</Border>
					<!-- 空列表提示 -->
					<TextBlock x:Name="EmptyHint" Text="没有找到可用的版本" FontSize="14"
					           Foreground="{DynamicResource TextSecondaryBrush}" FontFamily="Microsoft YaHei"
					           HorizontalAlignment="Center" VerticalAlignment="Center" Visibility="Collapsed"/>
					<!-- 版本列表 -->
					<ListView x:Name="VersionListView" Background="Transparent"
					          Foreground="{DynamicResource TextPrimaryBrush}"
					          BorderThickness="0" ScrollViewer.HorizontalScrollBarVisibility="Disabled"
					          Margin="4,0" MouseDoubleClick="VersionListView_MouseDoubleClick" Visibility="Collapsed">
						<ListView.ItemContainerStyle>
							<Style TargetType="ListViewItem">
								<Setter Property="Background" Value="Transparent"/>
								<Setter Property="Padding" Value="14,12"/>
								<Setter Property="Margin" Value="0,2"/>
								<Setter Property="Template">
									<Setter.Value>
										<ControlTemplate TargetType="ListViewItem">
											<Border x:Name="Bd" Background="{TemplateBinding Background}"
											        CornerRadius="8" Padding="{TemplateBinding Padding}" Margin="8,2">
												<ContentPresenter/>
											</Border>
											<ControlTemplate.Triggers>
												<Trigger Property="IsMouseOver" Value="True">
													<Setter TargetName="Bd" Property="Background" Value="{DynamicResource CardHoverBrush}"/>
												</Trigger>
												<Trigger Property="IsSelected" Value="True">
													<Setter TargetName="Bd" Property="Background" Value="{DynamicResource SurfaceBrush}"/>
												</Trigger>
											</ControlTemplate.Triggers>
										</ControlTemplate>
									</Setter.Value>
								</Setter>
							</Style>
						</ListView.ItemContainerStyle>
						<ListView.ItemTemplate>
							<DataTemplate>
								<Grid>
									<Grid.ColumnDefinitions>
										<ColumnDefinition Width="*"/>
										<ColumnDefinition Width="Auto"/>
									</Grid.ColumnDefinitions>
									<StackPanel Grid.Column="0" VerticalAlignment="Center">
										<StackPanel Orientation="Horizontal">
											<TextBlock Text="{Binding VersionName}" FontSize="14" FontWeight="Bold"
											           Foreground="{DynamicResource TextPrimaryBrush}" FontFamily="Microsoft YaHei"/>
											<Border CornerRadius="4" Margin="10,0,0,0" VerticalAlignment="Center"
											        Padding="7,3" Background="{Binding VersionType, Converter={StaticResource VersionTypeColorConverter}}">
												<Border.Effect>
													<DropShadowEffect BlurRadius="3" ShadowDepth="0" Opacity="0.4" Color="Black"/>
												</Border.Effect>
												<TextBlock Text="{Binding VersionType}" FontSize="10" FontWeight="SemiBold" Foreground="White"/>
											</Border>
											<Border CornerRadius="4" Margin="6,0,0,0" VerticalAlignment="Center"
											        Padding="7,3" Visibility="{Binding IsRecommended, Converter={StaticResource BoolToVisibilityConverter}}"
											        Background="#FF1EBB8E">
												<Border.Effect>
													<DropShadowEffect BlurRadius="4" ShadowDepth="0" Opacity="0.4" Color="#1EBB8E"/>
												</Border.Effect>
												<StackPanel Orientation="Horizontal">
													<TextBlock Text="★" FontSize="10" Foreground="#FFD700" VerticalAlignment="Center" Margin="0,0,3,0"/>
													<TextBlock Text="推荐" FontSize="10" FontWeight="Bold" Foreground="White"/>
												</StackPanel>
											</Border>
										</StackPanel>
										<TextBlock Text="{Binding DisplayInfo}" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"
										           FontFamily="Microsoft YaHei" Margin="0,6,0,0"/>
									</StackPanel>
									<StackPanel Grid.Column="1" VerticalAlignment="Center" Orientation="Horizontal">
										<TextBlock Text="{Binding FileSize, Converter={StaticResource FileSizeConverter}}"
										           FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center" Margin="0,0,16,0"/>
										<Button Content="下载" Width="88" Height="32" FontSize="12" FontWeight="SemiBold"
										        FontFamily="Microsoft YaHei" Foreground="White" Cursor="Hand"
										        Click="VersionItemDownload_Click" Tag="{Binding}">
											<Button.Template>
												<ControlTemplate TargetType="Button">
													<Border x:Name="btnBorder" CornerRadius="8" Padding="16,6">
														<Border.Background>
															<LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
																<GradientStop Color="#1EBB8E" Offset="0"/>
																<GradientStop Color="#168A6E" Offset="1"/>
															</LinearGradientBrush>
														</Border.Background>
														<Border.Effect>
															<DropShadowEffect BlurRadius="6" ShadowDepth="2" Opacity="0.3" Color="#1EBB8E"/>
														</Border.Effect>
														<ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
													</Border>
													<ControlTemplate.Triggers>
														<Trigger Property="IsMouseOver" Value="True">
															<Setter TargetName="btnBorder" Property="Background">
																<Setter.Value>
																	<LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
																		<GradientStop Color="#20D49E" Offset="0"/>
																		<GradientStop Color="#1EBB8E" Offset="1"/>
																	</LinearGradientBrush>
																</Setter.Value>
															</Setter>
														</Trigger>
														<Trigger Property="IsPressed" Value="True">
															<Setter TargetName="btnBorder" Property="Background" Value="#147A5E"/>
														</Trigger>
													</ControlTemplate.Triggers>
												</ControlTemplate>
											</Button.Template>
										</Button>
									</StackPanel>
								</Grid>
							</DataTemplate>
						</ListView.ItemTemplate>
					</ListView>
				</Grid>
			</Border>

			<!-- 底部操作栏 -->
			<Border Grid.Row="3" Background="{DynamicResource CardBackgroundBrush}" CornerRadius="0,0,12,12"
			        Padding="14,12" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0">
				<Grid>
					<TextBlock x:Name="VersionCountText" Text="" FontSize="13"
					           Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center" HorizontalAlignment="Left"
					           FontFamily="Microsoft YaHei"/>
					<Button x:Name="VersionCancelBtn" Content="取消" Width="110" Height="34"
					        FontSize="13" FontWeight="SemiBold" FontFamily="Microsoft YaHei"
					        Foreground="{DynamicResource TextPrimaryBrush}" Cursor="Hand" HorizontalAlignment="Right"
					        Click="BtnBack_Click">
						<Button.Template>
							<ControlTemplate TargetType="Button">
								<Border x:Name="cancelBorder" Background="{DynamicResource SurfaceBrush}" CornerRadius="8"
								        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
									<ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
								</Border>
								<ControlTemplate.Triggers>
									<Trigger Property="IsMouseOver" Value="True">
										<Setter TargetName="cancelBorder" Property="Background" Value="{DynamicResource CardHoverBrush}"/>
									</Trigger>
								</ControlTemplate.Triggers>
							</ControlTemplate>
						</Button.Template>
					</Button>
				</Grid>
			</Border>
		</Grid>
	</Grid>
</UserControl>
