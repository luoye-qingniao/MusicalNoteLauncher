<UserControl
	x:Class="MusicalNoteLauncher.Pages.MailPage" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	Background="{DynamicResource BackgroundBrush}" xmlns:pages="clr-namespace:MusicalNoteLauncher.Pages">
	<ScrollViewer
		VerticalScrollBarVisibility="Auto">
		<Grid
			Margin="20">
			<Grid.RowDefinitions>
				<RowDefinition
					Height="Auto" />
				<RowDefinition
					Height="*" />
			</Grid.RowDefinitions>
			<TextBlock
				Grid.Row="0"
				Text="邮件查看"
				Foreground="{DynamicResource TextPrimaryBrush}"
				FontSize="24"
				FontWeight="SemiBold"
				FontFamily="Microsoft YaHei"
				Margin="0,0,0,20" />
			<Grid
				Row="1">
				<Grid.ColumnDefinitions>
					<ColumnDefinition
						Width="300" />
					<ColumnDefinition
						Width="*" />
				</Grid.ColumnDefinitions>
				<Border
					Grid.Column="0"
					Background="{DynamicResource CardBackgroundBrush}"
					CornerRadius="8"
					Padding="15"
					Margin="0,0,16,0">
					<Grid>
						<Grid.RowDefinitions>
							<RowDefinition
								Height="Auto" />
							<RowDefinition
								Height="*" />
						</Grid.RowDefinitions>
						<TextBlock
							Grid.Row="0"
							Text="邮件列表"
							Foreground="{DynamicResource TextPrimaryBrush}"
							FontSize="16"
							FontWeight="SemiBold"
							FontFamily="Microsoft YaHei"
							Margin="0,0,0,15" />
						<ListBox
							Name="lstMails"
							Grid.Row="1"
							Background="{DynamicResource BackgroundBrush}"
							BorderThickness="0"
							Foreground="{DynamicResource TextPrimaryBrush}"
							FontFamily="Microsoft YaHei">
							<ItemsControl.ItemTemplate>
								<DataTemplate>
									<Border
										Background="{DynamicResource CardHoverBrush}"
										CornerRadius="4"
										Padding="12,10"
										Margin="0,4">
										<StackPanel>
											<Grid
												Margin="0,0,0,6">
												<Grid.ColumnDefinitions>
													<ColumnDefinition
														Width="Auto" />
													<ColumnDefinition
														Width="*" />
													<ColumnDefinition
														Width="Auto" />
												</Grid.ColumnDefinitions>
												<TextBlock
													Grid.Column="0"
													Text="✉️"
													FontSize="16"
													VerticalAlignment="Center"
													Margin="0,0,8,0" />
												<TextBlock
													Grid.Column="1"
													Foreground="{DynamicResource TextPrimaryBrush}"
													FontSize="14"
													FontWeight="SemiBold"
													Text="{Binding Sender}" />
												<TextBlock
													Grid.Column="2"
													Foreground="{DynamicResource TextSecondaryBrush}"
													FontSize="11"
													Text="{Binding Time}" />
											</Grid>
											<TextBlock
												Foreground="{DynamicResource TextPrimaryBrush}"
												FontSize="13"
												TextTrimming="CharacterEllipsis"
												Margin="24,0,0,4"
												Text="{Binding Subject}" />
											<TextBlock
												Foreground="#888888"
												FontSize="12"
												TextTrimming="CharacterEllipsis"
												Margin="24,0,0,0"
												Text="{Binding Preview}" />
										</StackPanel>
									</Border>
								</DataTemplate>
							</ItemsControl.ItemTemplate>
						</ListBox>
					</Grid>
				</Border>
				<Border
					Grid.Column="1"
					Background="{DynamicResource CardBackgroundBrush}"
					CornerRadius="8"
					Padding="20">
					<Grid>
						<Grid.RowDefinitions>
							<RowDefinition
								Height="Auto" />
							<RowDefinition
								Height="*" />
							<RowDefinition
								Height="Auto" />
						</Grid.RowDefinitions>
						<StackPanel
							Grid.Row="0"
							Margin="0,0,0,20">
							<TextBlock
								Text="选择一封邮件查看内容"
								Foreground="#888888"
								FontSize="16"
								FontFamily="Microsoft YaHei"
								HorizontalAlignment="Center"
								Margin="0,40,0,0" />
						</StackPanel>
						<Border
							Grid.Row="1"
							Background="{DynamicResource BackgroundBrush}"
							CornerRadius="4"
							Padding="15">
							<TextBlock
								Text="暂无邮件内容"
								Foreground="#666666"
								FontSize="13"
								FontFamily="Microsoft YaHei"
								HorizontalAlignment="Center"
								VerticalAlignment="Center" />
						</Border>
						<StackPanel
							Grid.Row="2"
							Orientation="Horizontal"
							HorizontalAlignment="Right"
							Margin="0,15,0,0">
							<Button
								Content="回复"
								Background="#2196F3"
								Foreground="{DynamicResource TextPrimaryBrush}"
								BorderThickness="0"
								Padding="16,8"
								FontSize="13"
								FontFamily="Microsoft YaHei"
								Cursor="Hand"
								Margin="0,0,8,0"
								Click="BtnReply_Click">
								<Control.Template>
									<ControlTemplate
										TargetType="{x:Type Button}">
										<Border
											Name="border"
											Background="{TemplateBinding Background}"
											CornerRadius="4"
											Padding="{TemplateBinding Padding}">
											<ContentPresenter
												HorizontalAlignment="Center"
												VerticalAlignment="Center" />
										</Border>
										<ControlTemplate.Triggers>
											<Trigger
												Property="UIElement.IsMouseOver"
												Value="True">
												<Setter
													TargetName="border"
													Property="Background"
													Value="#1976D2" />
											</Trigger>
										</ControlTemplate.Triggers>
									</ControlTemplate>
								</Control.Template>
							</Button>
							<Button
								Content="删除"
								Background="{DynamicResource SurfaceBrush}"
								Foreground="#E74C3C"
								BorderThickness="1"
								BorderBrush="#E74C3C"
								Padding="16,8"
								FontSize="13"
								FontFamily="Microsoft YaHei"
								Cursor="Hand"
								Click="BtnDelete_Click">
								<Control.Template>
									<ControlTemplate
										TargetType="{x:Type Button}">
										<Border
											Name="border"
											Background="{TemplateBinding Background}"
											BorderBrush="{TemplateBinding BorderBrush}"
											BorderThickness="{TemplateBinding BorderThickness}"
											CornerRadius="4"
											Padding="{TemplateBinding Padding}">
											<ContentPresenter
												HorizontalAlignment="Center"
												VerticalAlignment="Center" />
										</Border>
										<ControlTemplate.Triggers>
											<Trigger
												Property="UIElement.IsMouseOver"
												Value="True">
												<Setter
													TargetName="border"
													Property="Background"
													Value="{DynamicResource CardHoverBrush}" />
											</Trigger>
										</ControlTemplate.Triggers>
									</ControlTemplate>
								</Control.Template>
							</Button>
						</StackPanel>
					</Grid>
				</Border>
			</Grid>
		</Grid>
	</ScrollViewer>
</UserControl>

