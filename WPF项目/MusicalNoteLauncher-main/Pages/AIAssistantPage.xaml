<UserControl
	x:Class="MusicalNoteLauncher.Pages.AIAssistantPage"
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	TextOptions.TextFormattingMode="Ideal"
	TextOptions.TextRenderingMode="ClearType"
	RenderOptions.ClearTypeHint="Enabled"
	RenderOptions.BitmapScalingMode="HighQuality"
	Background="Transparent">

	<Grid>
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="*"/>
			<RowDefinition Height="Auto"/>
		</Grid.RowDefinitions>

		<!-- ── Header ── -->
		<Border Grid.Row="0" Margin="24,20,24,0" CornerRadius="16,16,0,0"
				Background="{DynamicResource CardBackgroundBrush}">
			<Border Padding="24,20">
				<Grid>
					<Grid.ColumnDefinitions>
						<ColumnDefinition Width="Auto"/>
						<ColumnDefinition Width="*"/>
						<ColumnDefinition Width="Auto"/>
					</Grid.ColumnDefinitions>

					<!-- AI 头像 -->
					<Border Grid.Column="0" Width="48" Height="48" CornerRadius="14"
							Margin="0,0,16,0">
						<Border.Background>
							<LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
								<GradientStop Color="#2ECC71" Offset="0"/>
								<GradientStop Color="#27AE60" Offset="1"/>
							</LinearGradientBrush>
						</Border.Background>
						<Border.Effect>
							<DropShadowEffect Color="#2ECC71" BlurRadius="12" ShadowDepth="0" Opacity="0.35"/>
						</Border.Effect>
						<TextBlock Text="🤖" FontSize="24" HorizontalAlignment="Center" VerticalAlignment="Center"/>
					</Border>

					<!-- 标题 -->
					<StackPanel Grid.Column="1" VerticalAlignment="Center">
						<StackPanel Orientation="Horizontal">
							<TextBlock Text="AI 游戏助手" FontSize="18" FontWeight="Bold"
									   Foreground="{DynamicResource TextPrimaryBrush}"
									   FontFamily="Microsoft YaHei"/>
							<!-- 状态指示灯 -->
							<Border Name="statusDot" Width="8" Height="8" CornerRadius="4"
									Background="#FF9800" Margin="10,0,0,0" VerticalAlignment="Center"
									ToolTip="API 未配置"/>
							<TextBlock Name="txtStatusLabel" Text="未配置"
									   FontSize="11" Foreground="#FF9800"
									   FontFamily="Microsoft YaHei" VerticalAlignment="Center"
									   Margin="6,0,0,0"/>
						</StackPanel>
						<TextBlock Text="小音符 · 你的 Minecraft 专属智能伙伴"
								   FontSize="12" Margin="0,4,0,0"
								   Foreground="{DynamicResource TextSecondaryBrush}"
								   FontFamily="Microsoft YaHei"/>
					</StackPanel>

					<!-- 设置按钮 -->
					<Button Grid.Column="2" Name="btnSettings"
							Background="Transparent" BorderThickness="0"
							Width="40" Height="40" Padding="8"
							Cursor="Hand" Click="BtnSettings_Click"
							VerticalAlignment="Center">
						<Button.Template>
							<ControlTemplate TargetType="Button">
								<Border x:Name="bd" CornerRadius="10"
										Background="{TemplateBinding Background}"
										Padding="{TemplateBinding Padding}">
									<TextBlock Text="⚙" FontSize="18"
											   HorizontalAlignment="Center"
											   VerticalAlignment="Center"
											   Foreground="{DynamicResource TextSecondaryBrush}"/>
								</Border>
								<ControlTemplate.Triggers>
									<Trigger Property="IsMouseOver" Value="True">
										<Setter TargetName="bd" Property="Background"
												Value="{DynamicResource CardHoverBrush}"/>
										<Setter TargetName="bd" Property="TextElement.Foreground"
												Value="{DynamicResource TextPrimaryBrush}"/>
									</Trigger>
								</ControlTemplate.Triggers>
							</ControlTemplate>
						</Button.Template>
					</Button>
				</Grid>
			</Border>
		</Border>

		<!-- ── 消息区域 ── -->
		<Border Grid.Row="1" Margin="24,0,24,0"
				Background="{DynamicResource CardBackgroundBrush}">
			<ScrollViewer x:Name="scrollMessages"
						  VerticalScrollBarVisibility="Auto"
						  HorizontalScrollBarVisibility="Disabled"
						  Padding="24,8,24,12">
				<StackPanel Name="spMessages" VerticalAlignment="Top">

					<!-- 欢迎卡片 -->
					<Border CornerRadius="14" Padding="24,20"
							Margin="0,10,0,14" MaxWidth="680">
						<Border.Background>
							<LinearGradientBrush StartPoint="0,0" EndPoint="1,0.5">
								<GradientStop Color="#1A2ECC71" Offset="0"/>
								<GradientStop Color="#0D2ECC71" Offset="1"/>
							</LinearGradientBrush>
						</Border.Background>
						<StackPanel>
							<!-- AI 标签 -->
							<StackPanel Orientation="Horizontal" Margin="0,0,0,12">
								<Border Width="36" Height="36" CornerRadius="10"
										Background="#2ECC71" Margin="0,0,10,0">
									<Border.Effect>
										<DropShadowEffect Color="#2ECC71" BlurRadius="8" ShadowDepth="0" Opacity="0.3"/>
									</Border.Effect>
									<TextBlock Text="🤖" FontSize="16"
											   HorizontalAlignment="Center" VerticalAlignment="Center"/>
								</Border>
								<StackPanel VerticalAlignment="Center">
									<TextBlock Text="小音符" FontSize="14" FontWeight="Bold"
											   Foreground="#2ECC71" FontFamily="Microsoft YaHei"/>
									<TextBlock Text="MNL 智能助手" FontSize="11"
											   Foreground="#882ECC71" FontFamily="Microsoft YaHei"/>
								</StackPanel>
							</StackPanel>

							<!-- 欢迎文字 -->
							<TextBlock Text="你好！我是你的 Minecraft 游戏助手小音符 🎵"
									   FontSize="15" FontWeight="SemiBold"
									   Foreground="{DynamicResource TextPrimaryBrush}"
									   FontFamily="Microsoft YaHei" TextWrapping="Wrap"/>
							<TextBlock Text="我可以帮你解答关于游戏玩法、红石电路、建筑技巧、模组安装、光影配置等各种问题。"
									   FontSize="13" Margin="0,8,0,0"
									   Foreground="{DynamicResource TextSecondaryBrush}"
									   FontFamily="Microsoft YaHei" TextWrapping="Wrap"
									   LineHeight="20"/>
						<!-- 未配置 API 提示卡片 -->
						<Border Name="cardConfigPrompt" CornerRadius="14" Padding="20,16"
								Margin="0,14,0,0" MaxWidth="680" Cursor="Hand"
								MouseLeftButtonDown="CardConfigPrompt_Click">
							<Border.Background>
								<LinearGradientBrush StartPoint="0,0" EndPoint="1,0.5">
									<GradientStop Color="#1AFF9800" Offset="0"/>
									<GradientStop Color="#0DFF9800" Offset="1"/>
								</LinearGradientBrush>
							</Border.Background>
							<StackPanel>
								<StackPanel Orientation="Horizontal" Margin="0,0,0,10">
									<Border Width="32" Height="32" CornerRadius="8"
											Background="#FF9800">
										<TextBlock Text="🔑" FontSize="14"
												   HorizontalAlignment="Center" VerticalAlignment="Center"/>
									</Border>
									<StackPanel VerticalAlignment="Center" Margin="10,0,0,0">
										<TextBlock Text="API 尚未配置" FontSize="13" FontWeight="Bold"
												   Foreground="#FF9800" FontFamily="Microsoft YaHei"/>
										<TextBlock Text="点击此处或右上角 ⚙ 进行配置"
												   FontSize="11" Foreground="#CCFF9800"
												   FontFamily="Microsoft YaHei"/>
									</StackPanel>
								</StackPanel>
								<TextBlock Text="配置 OpenAI 兼容 API 后，小音符将为你提供智能问答服务。支持 OpenAI / DeepSeek / 硅基流动 等平台。"
										   FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"
										   FontFamily="Microsoft YaHei" TextWrapping="Wrap" LineHeight="18"/>
							</StackPanel>
						</Border>
						</StackPanel>
					</Border>

					<!-- 快速提问 -->
					<Border Background="{DynamicResource CardHoverBrush}"
							CornerRadius="14" Padding="20,16" Margin="0,0,0,6" MaxWidth="680">
						<StackPanel>
							<StackPanel Orientation="Horizontal" Margin="0,0,0,12">
								<TextBlock Text="⚡" FontSize="14" VerticalAlignment="Center"/>
								<TextBlock Text="快速提问" FontSize="13" FontWeight="SemiBold"
										   Foreground="{DynamicResource TextPrimaryBrush}"
										   FontFamily="Microsoft YaHei" VerticalAlignment="Center"
										   Margin="6,0,0,0"/>
							</StackPanel>
							<WrapPanel Orientation="Horizontal" HorizontalAlignment="Left">
								<Button Name="btnQ1"
										Content="怎么搭建下界传送门？"
										Background="{DynamicResource SurfaceBrush}"
										Foreground="{DynamicResource TextPrimaryBrush}"
										BorderBrush="{DynamicResource BorderBrush}"
										BorderThickness="1"
										Padding="14,8" FontSize="12"
										FontFamily="Microsoft YaHei"
										Cursor="Hand" Margin="0,0,8,8"
										Click="BtnQuickQuestion_Click">
									<Button.Template>
										<ControlTemplate TargetType="Button">
											<Border x:Name="bd" CornerRadius="20"
													Background="{TemplateBinding Background}"
													BorderBrush="{TemplateBinding BorderBrush}"
													BorderThickness="{TemplateBinding BorderThickness}"
													Padding="{TemplateBinding Padding}">
												<ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
											</Border>
											<ControlTemplate.Triggers>
												<Trigger Property="IsMouseOver" Value="True">
													<Setter TargetName="bd" Property="Background" Value="#2196F3"/>
													<Setter TargetName="bd" Property="BorderBrush" Value="#2196F3"/>
													<Setter TargetName="bd" Property="TextElement.Foreground" Value="White"/>
												</Trigger>
											</ControlTemplate.Triggers>
										</ControlTemplate>
									</Button.Template>
								</Button>
								<Button Name="btnQ2"
										Content="推荐几个好用的光影包"
										Background="{DynamicResource SurfaceBrush}"
										Foreground="{DynamicResource TextPrimaryBrush}"
										BorderBrush="{DynamicResource BorderBrush}"
										BorderThickness="1"
										Padding="14,8" FontSize="12"
										FontFamily="Microsoft YaHei"
										Cursor="Hand" Margin="0,0,8,8"
										Click="BtnQuickQuestion_Click">
									<Button.Template>
										<ControlTemplate TargetType="Button">
											<Border x:Name="bd" CornerRadius="20"
													Background="{TemplateBinding Background}"
													BorderBrush="{TemplateBinding BorderBrush}"
													BorderThickness="{TemplateBinding BorderThickness}"
													Padding="{TemplateBinding Padding}">
												<ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
											</Border>
											<ControlTemplate.Triggers>
												<Trigger Property="IsMouseOver" Value="True">
													<Setter TargetName="bd" Property="Background" Value="#2196F3"/>
													<Setter TargetName="bd" Property="BorderBrush" Value="#2196F3"/>
													<Setter TargetName="bd" Property="TextElement.Foreground" Value="White"/>
												</Trigger>
											</ControlTemplate.Triggers>
										</ControlTemplate>
									</Button.Template>
								</Button>
								<Button Name="btnQ3"
										Content="如何安装 Forge 和 Mod？"
										Background="{DynamicResource SurfaceBrush}"
										Foreground="{DynamicResource TextPrimaryBrush}"
										BorderBrush="{DynamicResource BorderBrush}"
										BorderThickness="1"
										Padding="14,8" FontSize="12"
										FontFamily="Microsoft YaHei"
										Cursor="Hand" Margin="0,0,0,8"
										Click="BtnQuickQuestion_Click">
									<Button.Template>
										<ControlTemplate TargetType="Button">
											<Border x:Name="bd" CornerRadius="20"
													Background="{TemplateBinding Background}"
													BorderBrush="{TemplateBinding BorderBrush}"
													BorderThickness="{TemplateBinding BorderThickness}"
													Padding="{TemplateBinding Padding}">
												<ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
											</Border>
											<ControlTemplate.Triggers>
												<Trigger Property="IsMouseOver" Value="True">
													<Setter TargetName="bd" Property="Background" Value="#2196F3"/>
													<Setter TargetName="bd" Property="BorderBrush" Value="#2196F3"/>
													<Setter TargetName="bd" Property="TextElement.Foreground" Value="White"/>
												</Trigger>
											</ControlTemplate.Triggers>
										</ControlTemplate>
									</Button.Template>
								</Button>
							</WrapPanel>
						</StackPanel>
					</Border>

				</StackPanel>
			</ScrollViewer>
		</Border>

		<!-- ── 输入区域 ── -->
		<Border Grid.Row="2" Margin="24,0,24,20" CornerRadius="0,0,16,16"
				Background="{DynamicResource CardBackgroundBrush}" Padding="20,14,20,18">
			<StackPanel>
				<Grid>
					<Grid.ColumnDefinitions>
						<ColumnDefinition Width="*"/>
						<ColumnDefinition Width="Auto"/>
					</Grid.ColumnDefinitions>

					<TextBox Name="txtInput"
							 Background="{DynamicResource SurfaceBrush}"
							 Foreground="{DynamicResource TextPrimaryBrush}"
							 BorderBrush="{DynamicResource BorderBrush}"
							 BorderThickness="1"
							 Padding="18,12" FontSize="14"
							 FontFamily="Microsoft YaHei"
							 Cursor="IBeam"
							 VerticalAlignment="Center"
							 Margin="0,0,12,0"
							 KeyDown="TxtInput_KeyDown"
							 TextWrapping="Wrap"
							 AcceptsReturn="True"
							 MaxHeight="120">
						<TextBox.Template>
							<ControlTemplate TargetType="TextBox">
								<Border x:Name="bd"
										Background="{TemplateBinding Background}"
										BorderBrush="{TemplateBinding BorderBrush}"
										BorderThickness="{TemplateBinding BorderThickness}"
										CornerRadius="12" Padding="{TemplateBinding Padding}">
									<ScrollViewer x:Name="PART_ContentHost" VerticalAlignment="Center"/>
								</Border>
								<ControlTemplate.Triggers>
									<Trigger Property="IsFocused" Value="True">
										<Setter TargetName="bd" Property="BorderBrush" Value="#2ECC71"/>
									</Trigger>
									<Trigger Property="IsMouseOver" Value="True">
										<Setter TargetName="bd" Property="BorderBrush" Value="#4A90D9"/>
									</Trigger>
								</ControlTemplate.Triggers>
							</ControlTemplate>
						</TextBox.Template>
					</TextBox>

					<Button Name="btnSend" Grid.Column="1"
							Background="#2ECC71" Foreground="White"
							BorderThickness="0"
							Padding="28,12" FontSize="14" FontWeight="SemiBold"
							FontFamily="Microsoft YaHei"
							Cursor="Hand" Click="BtnSend_Click"
							VerticalAlignment="Center">
						<Button.Template>
							<ControlTemplate TargetType="Button">
								<Border x:Name="bd"
										CornerRadius="12"
										Padding="{TemplateBinding Padding}">
									<Border.Background>
										<LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
											<GradientStop Color="#2ECC71" Offset="0"/>
											<GradientStop Color="#27AE60" Offset="1"/>
										</LinearGradientBrush>
									</Border.Background>
									<StackPanel Orientation="Horizontal">
										<TextBlock Text="发送" FontSize="14" FontWeight="SemiBold"
												   Foreground="White" FontFamily="Microsoft YaHei"
												   VerticalAlignment="Center"/>
									</StackPanel>
								</Border>
								<ControlTemplate.Triggers>
									<Trigger Property="IsMouseOver" Value="True">
										<Setter TargetName="bd" Property="Background">
											<Setter.Value>
												<LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
													<GradientStop Color="#27AE60" Offset="0"/>
													<GradientStop Color="#1E8449" Offset="1"/>
												</LinearGradientBrush>
											</Setter.Value>
										</Setter>
									</Trigger>
									<Trigger Property="IsEnabled" Value="False">
										<Setter TargetName="bd" Property="Opacity" Value="0.45"/>
									</Trigger>
								</ControlTemplate.Triggers>
							</ControlTemplate>
						</Button.Template>
					</Button>
				</Grid>

				<!-- 状态提示 -->
				<TextBlock Name="txtStatus" Text=""
						   FontSize="11" Foreground="#FF9800"
						   FontFamily="Microsoft YaHei"
						   HorizontalAlignment="Left"
						   Margin="4,10,0,0" Visibility="Collapsed"/>
			</StackPanel>
		</Border>

		<!-- ── 设置弹窗 ── -->
		<Popup Name="popupSettings" Placement="Top" StaysOpen="False"
			   AllowsTransparency="True"
			   PopupAnimation="Fade">
			<Border Background="{DynamicResource CardBackgroundBrush}"
					BorderBrush="{DynamicResource BorderBrush}"
					BorderThickness="1" CornerRadius="16" Padding="24"
					Width="420">
				<Border.Effect>
					<DropShadowEffect Color="#000000" BlurRadius="24"
									  ShadowDepth="4" Opacity="0.25"/>
				</Border.Effect>
				<StackPanel>
					<!-- 弹窗标题栏 -->
					<Grid Margin="0,0,0,20">
						<Grid.ColumnDefinitions>
							<ColumnDefinition Width="*"/>
							<ColumnDefinition Width="Auto"/>
						</Grid.ColumnDefinitions>
						<StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
							<TextBlock Text="⚙" FontSize="16" VerticalAlignment="Center"/>
							<TextBlock Text="API 配置" FontSize="15" FontWeight="Bold"
									   Foreground="{DynamicResource TextPrimaryBrush}"
									   FontFamily="Microsoft YaHei" Margin="8,0,0,0"
									   VerticalAlignment="Center"/>
						</StackPanel>
						<Button Grid.Column="1" Name="btnCloseSettings"
								Content="✕"
								Background="Transparent"
								Foreground="{DynamicResource TextSecondaryBrush}"
								BorderThickness="0"
								Width="32" Height="32" FontSize="14"
								FontFamily="Microsoft YaHei"
								Cursor="Hand" Click="BtnCloseSettings_Click">
							<Button.Template>
								<ControlTemplate TargetType="Button">
									<Border x:Name="bd" CornerRadius="8"
											Background="Transparent">
										<ContentPresenter HorizontalAlignment="Center"
														  VerticalAlignment="Center"/>
									</Border>
									<ControlTemplate.Triggers>
										<Trigger Property="IsMouseOver" Value="True">
											<Setter TargetName="bd" Property="Background"
													Value="{DynamicResource CardHoverBrush}"/>
										</Trigger>
									</ControlTemplate.Triggers>
								</ControlTemplate>
							</Button.Template>
						</Button>
					</Grid>

					<!-- 提供商预设选择 -->
					<TextBlock Text="大模型提供商" FontSize="12"
							   Foreground="{DynamicResource TextSecondaryBrush}"
							   FontFamily="Microsoft YaHei" Margin="0,0,0,6"/>
					<ComboBox Name="cmbProvider"
							  Background="{DynamicResource SurfaceBrush}"
							  Foreground="{DynamicResource TextPrimaryBrush}"
							  BorderBrush="{DynamicResource BorderBrush}"
							  BorderThickness="1"
							  Padding="12,10" FontSize="13"
							  FontFamily="Microsoft YaHei"
							  Margin="0,0,0,16"
							  SelectionChanged="CmbProvider_SelectionChanged">
						<ComboBox.Template>
							<ControlTemplate TargetType="ComboBox">
								<Border x:Name="bd"
										Background="{TemplateBinding Background}"
										BorderBrush="{TemplateBinding BorderBrush}"
										BorderThickness="{TemplateBinding BorderThickness}"
										CornerRadius="8">
									<Grid>
										<ToggleButton x:Name="ToggleButton" Focusable="False"
													  IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
													  ClickMode="Press" Margin="0">
											<ToggleButton.Template>
												<ControlTemplate TargetType="ToggleButton">
													<Border Background="Transparent" Padding="14,12">
														<Grid>
															<Grid.ColumnDefinitions>
																<ColumnDefinition Width="*"/>
																<ColumnDefinition Width="Auto"/>
															</Grid.ColumnDefinitions>
															<ContentPresenter Grid.Column="0"
																Content="{TemplateBinding Content}"
																HorizontalAlignment="Left"
																VerticalAlignment="Center"/>
															<TextBlock Grid.Column="1" Text="▼" FontSize="10"
																	   Foreground="{DynamicResource TextSecondaryBrush}"
																	   VerticalAlignment="Center"/>
														</Grid>
													</Border>
												</ControlTemplate>
											</ToggleButton.Template>
										</ToggleButton>
										<ContentPresenter Name="ContentSite"
											IsHitTestVisible="False"
											Content="{TemplateBinding SelectionBoxItem}"
											ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
											ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"
											Margin="14,12,30,12"
											VerticalAlignment="Center"
											HorizontalAlignment="Left"/>
										<Popup Name="Popup" Placement="Bottom"
											   IsOpen="{TemplateBinding IsDropDownOpen}"
											   AllowsTransparency="True" Focusable="False"
											   PopupAnimation="Slide">
											<Border x:Name="DropDownBorder"
													Background="{DynamicResource CardBackgroundBrush}"
													BorderBrush="{DynamicResource BorderBrush}"
													BorderThickness="1" CornerRadius="8"
													MinWidth="{TemplateBinding ActualWidth}"
													MaxHeight="300">
												<ScrollViewer>
													<ItemsPresenter/>
												</ScrollViewer>
											</Border>
										</Popup>
									</Grid>
								</Border>
								<ControlTemplate.Triggers>
									<Trigger Property="IsMouseOver" Value="True">
										<Setter TargetName="bd" Property="BorderBrush" Value="#4A90D9"/>
									</Trigger>
									<Trigger Property="IsDropDownOpen" Value="True">
										<Setter TargetName="bd" Property="BorderBrush" Value="#2ECC71"/>
									</Trigger>
								</ControlTemplate.Triggers>
							</ControlTemplate>
						</ComboBox.Template>
						<ComboBoxItem Content="🔵 OpenAI（GPT-4o / GPT-3.5）" Tag="openai"/>
						<ComboBoxItem Content="🟢 DeepSeek（DeepSeek-V3 / R1）" Tag="deepseek"/>
						<ComboBoxItem Content="🟠 硅基流动（SiliconFlow）" Tag="siliconflow"/>
						<ComboBoxItem Content="🟣 阿里百炼（通义千问）" Tag="aliyun"/>
						<ComboBoxItem Content="🟡 智谱 AI（GLM-4）" Tag="zhipu"/>
						<ComboBoxItem Content="⚪ 自定义接口" Tag="custom"/>
						<ComboBox.Resources>
							<Style TargetType="ComboBoxItem">
								<Setter Property="Padding" Value="16,10"/>
								<Setter Property="FontSize" Value="13"/>
								<Setter Property="FontFamily" Value="Microsoft YaHei"/>
								<Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
								<Setter Property="Background" Value="Transparent"/>
								<Setter Property="BorderThickness" Value="0"/>
								<Setter Property="Template">
									<Setter.Value>
										<ControlTemplate TargetType="ComboBoxItem">
											<Border x:Name="bd"
													Background="{TemplateBinding Background}"
													Padding="{TemplateBinding Padding}">
												<ContentPresenter/>
											</Border>
											<ControlTemplate.Triggers>
												<Trigger Property="IsMouseOver" Value="True">
													<Setter TargetName="bd" Property="Background"
															Value="{DynamicResource CardHoverBrush}"/>
												</Trigger>
												<Trigger Property="IsSelected" Value="True">
													<Setter TargetName="bd" Property="Background" Value="#1A2ECC71"/>
												</Trigger>
											</ControlTemplate.Triggers>
										</ControlTemplate>
									</Setter.Value>
								</Setter>
							</Style>
						</ComboBox.Resources>
					</ComboBox>

					<!-- API 接口地址 -->
					<TextBlock Text="API 接口地址" FontSize="12"
							   Foreground="{DynamicResource TextSecondaryBrush}"
							   FontFamily="Microsoft YaHei" Margin="0,0,0,6"/>
					<TextBox Name="txtApiEndpoint"
							 Background="{DynamicResource SurfaceBrush}"
							 Foreground="{DynamicResource TextPrimaryBrush}"
							 BorderBrush="{DynamicResource BorderBrush}"
							 BorderThickness="1"
							 Padding="14,10" FontSize="12"
							 FontFamily="Microsoft YaHei"
							 Margin="0,0,0,14">
						<TextBox.Template>
							<ControlTemplate TargetType="TextBox">
								<Border x:Name="bd"
										Background="{TemplateBinding Background}"
										BorderBrush="{TemplateBinding BorderBrush}"
										BorderThickness="{TemplateBinding BorderThickness}"
										CornerRadius="8"
										Padding="{TemplateBinding Padding}">
									<ScrollViewer x:Name="PART_ContentHost" VerticalAlignment="Center"/>
								</Border>
								<ControlTemplate.Triggers>
									<Trigger Property="IsFocused" Value="True">
										<Setter TargetName="bd" Property="BorderBrush" Value="#2ECC71"/>
									</Trigger>
								</ControlTemplate.Triggers>
							</ControlTemplate>
						</TextBox.Template>
					</TextBox>

					<TextBlock Text="API Key" FontSize="12"
							   Foreground="{DynamicResource TextSecondaryBrush}"
							   FontFamily="Microsoft YaHei" Margin="0,0,0,6"/>
					<TextBox Name="txtApiKey"
							 Background="{DynamicResource SurfaceBrush}"
							 Foreground="{DynamicResource TextPrimaryBrush}"
							 BorderBrush="{DynamicResource BorderBrush}"
							 BorderThickness="1"
							 Padding="14,10" FontSize="12"
							 FontFamily="Microsoft YaHei"
							 Margin="0,0,0,16">
						<TextBox.Template>
							<ControlTemplate TargetType="TextBox">
								<Border x:Name="bd"
										Background="{TemplateBinding Background}"
										BorderBrush="{TemplateBinding BorderBrush}"
										BorderThickness="{TemplateBinding BorderThickness}"
										CornerRadius="8"
										Padding="{TemplateBinding Padding}">
									<ScrollViewer x:Name="PART_ContentHost" VerticalAlignment="Center"/>
								</Border>
								<ControlTemplate.Triggers>
									<Trigger Property="IsFocused" Value="True">
										<Setter TargetName="bd" Property="BorderBrush" Value="#2ECC71"/>
									</Trigger>
								</ControlTemplate.Triggers>
							</ControlTemplate>
						</TextBox.Template>
					</TextBox>

					<TextBlock Text="模型名称" FontSize="12"
							   Foreground="{DynamicResource TextSecondaryBrush}"
							   FontFamily="Microsoft YaHei" Margin="0,0,0,6"/>
					<TextBox Name="txtModelName"
							 Background="{DynamicResource SurfaceBrush}"
							 Foreground="{DynamicResource TextPrimaryBrush}"
							 BorderBrush="{DynamicResource BorderBrush}"
							 BorderThickness="1"
							 Padding="14,10" FontSize="12"
							 FontFamily="Microsoft YaHei"
							 Margin="0,0,0,20">
						<TextBox.Template>
							<ControlTemplate TargetType="TextBox">
								<Border x:Name="bd"
										Background="{TemplateBinding Background}"
										BorderBrush="{TemplateBinding BorderBrush}"
										BorderThickness="{TemplateBinding BorderThickness}"
										CornerRadius="8"
										Padding="{TemplateBinding Padding}">
									<ScrollViewer x:Name="PART_ContentHost" VerticalAlignment="Center"/>
								</Border>
								<ControlTemplate.Triggers>
									<Trigger Property="IsFocused" Value="True">
										<Setter TargetName="bd" Property="BorderBrush" Value="#2ECC71"/>
									</Trigger>
								</ControlTemplate.Triggers>
							</ControlTemplate>
						</TextBox.Template>
					</TextBox>

					<Button Name="btnSaveSettings"
							Content="💾  保存配置"
							Background="#2ECC71" Foreground="White"
							BorderThickness="0"
							Padding="0,12" FontSize="13" FontWeight="SemiBold"
							FontFamily="Microsoft YaHei"
							Cursor="Hand" Click="BtnSaveSettings_Click">
						<Button.Template>
							<ControlTemplate TargetType="Button">
								<Border x:Name="bd" CornerRadius="10"
										Padding="{TemplateBinding Padding}">
									<Border.Background>
										<LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
											<GradientStop Color="#2ECC71" Offset="0"/>
											<GradientStop Color="#27AE60" Offset="1"/>
										</LinearGradientBrush>
									</Border.Background>
									<ContentPresenter HorizontalAlignment="Center"
													  VerticalAlignment="Center"/>
								</Border>
								<ControlTemplate.Triggers>
									<Trigger Property="IsMouseOver" Value="True">
										<Setter TargetName="bd" Property="Background">
											<Setter.Value>
												<LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
													<GradientStop Color="#27AE60" Offset="0"/>
													<GradientStop Color="#1E8449" Offset="1"/>
												</LinearGradientBrush>
											</Setter.Value>
										</Setter>
									</Trigger>
								</ControlTemplate.Triggers>
							</ControlTemplate>
						</Button.Template>
					</Button>
				</StackPanel>
			</Border>
		</Popup>
	</Grid>
</UserControl>
