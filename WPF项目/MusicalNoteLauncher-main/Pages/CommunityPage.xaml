<UserControl
    x:Class="MusicalNoteLauncher.Pages.CommunityPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:pages="clr-namespace:MusicalNoteLauncher.Pages"
    Background="{DynamicResource BackgroundBrush}">

    <UserControl.Resources>
        <Storyboard x:Key="FadeIn">
            <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.25"/>
        </Storyboard>

        <!-- 频道卡片样式 -->
        <Style x:Key="ChannelCardStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource CardBackgroundBrush}"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="14,12"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource CardHoverBrush}"/>
                    <Setter Property="Effect">
                        <Setter.Value>
                            <DropShadowEffect BlurRadius="8" Opacity="0.15" ShadowDepth="2"/>
                        </Setter.Value>
                    </Setter>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- 帖子卡片样式 -->
        <Style x:Key="PostCardStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource CardBackgroundBrush}"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="18,14"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource CardHoverBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- 主按钮 -->
        <Style x:Key="PrimaryBtn" TargetType="Button">
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="18,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontFamily" Value="Microsoft YaHei"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Name="bd" Background="#6C5CE7" CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#5B4CDB"/>
                                <Setter TargetName="bd" Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect Color="#6C5CE7" Opacity="0.4" BlurRadius="8"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 次要按钮 -->
        <Style x:Key="SecondaryBtn" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontFamily" Value="Microsoft YaHei"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Name="bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{DynamicResource SurfaceBrush}"/>
                                <Setter TargetName="bd" Property="BorderBrush" Value="{DynamicResource PrimaryBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 图标按钮 -->
        <Style x:Key="IconBtn" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Name="bd" Background="{TemplateBinding Background}" CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{DynamicResource CardHoverBrush}"/>
                                <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 输入框 -->
        <Style x:Key="InputBox" TargetType="TextBox">
            <Setter Property="Background" Value="{DynamicResource SurfaceBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
            <Setter Property="CaretBrush" Value="{DynamicResource TextPrimaryBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="14,10"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontFamily" Value="Microsoft YaHei"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Name="bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="8">
                            <ScrollViewer Name="PART_ContentHost" Margin="2"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="bd" Property="BorderBrush" Value="#6C5CE7"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <!-- ========== 频道列表 ========== -->
        <Grid x:Name="panelChannelList" Visibility="Visible">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- 标题行 -->
            <Grid Grid.Row="0" Margin="24,20,24,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="🎮 交流社区" FontSize="24" FontWeight="Bold"
                               Foreground="{DynamicResource TextPrimaryBrush}" FontFamily="Microsoft YaHei"/>
                    <TextBlock Text="选择一个频道，开始交流" FontSize="13"
                               Foreground="{DynamicResource TextSecondaryBrush}" FontFamily="Microsoft YaHei"
                               Margin="0,4,0,0"/>
                </StackPanel>
                <Button Grid.Column="1" Content="＋ 创建频道" Style="{StaticResource PrimaryBtn}"
                        Click="BtnCreateChannel_Click" VerticalAlignment="Center"/>
            </Grid>

            <!-- 频道列表 -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="24,0,24,20"
                         PreviewMouseWheel="ScrollViewer_PreviewMouseWheel">
                <ListBox x:Name="lstChannels" Background="Transparent" BorderThickness="0"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         ScrollViewer.VerticalScrollBarVisibility="Disabled">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Style="{StaticResource ChannelCardStyle}"
                                    MouseLeftButtonDown="Channel_Click" Tag="{Binding}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- 频道图标 -->
                                    <Border Grid.Column="0" Width="44" Height="44"
                                            Background="{Binding ChannelColor}" CornerRadius="12"
                                            Margin="0,0,14,0">
                                        <TextBlock Text="{Binding Icon}" FontSize="20"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>

                                    <!-- 频道信息 -->
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding Name}" FontSize="15" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                                       FontFamily="Microsoft YaHei"/>
                                        </StackPanel>
                                        <TextBlock Text="{Binding Description}" FontSize="12"
                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                   FontFamily="Microsoft YaHei" Margin="0,3,0,0"
                                                   TextWrapping="Wrap" MaxHeight="32"
                                                   TextTrimming="CharacterEllipsis"/>
                                    </StackPanel>

                                    <!-- 帖子数 + 箭头 -->
                                    <StackPanel Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Right">
                                        <TextBlock FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"
                                                   FontFamily="Microsoft YaHei" HorizontalAlignment="Right">
                                            <Run Text="{Binding PostCount}"/><Run Text=" 帖"/>
                                        </TextBlock>
                                        <TextBlock Text="→" FontSize="14" Foreground="{DynamicResource TextSecondaryBrush}"
                                                   HorizontalAlignment="Right" Margin="0,2,0,0"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </ScrollViewer>
        </Grid>

        <!-- ========== 帖子列表 ========== -->
        <Grid x:Name="panelPostList" Visibility="Collapsed">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- 头部 -->
            <Border Grid.Row="0" Background="{DynamicResource CardBackgroundBrush}" Padding="24,16">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0" Content="← 返回" Style="{StaticResource SecondaryBtn}"
                            Click="BtnBackToChannels_Click" VerticalAlignment="Center"/>
                    <StackPanel Grid.Column="1" Margin="14,0">
                        <TextBlock x:Name="txtChannelTitle" Text="💬 综合讨论"
                                   FontSize="18" FontWeight="Bold"
                                   Foreground="{DynamicResource TextPrimaryBrush}" FontFamily="Microsoft YaHei"/>
                        <TextBlock x:Name="txtChannelDesc" Text="频道描述"
                                   FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"
                                   FontFamily="Microsoft YaHei" Margin="0,2,0,0"/>
                    </StackPanel>
                    <Button Grid.Column="2" Content="✏️ 发帖" Style="{StaticResource PrimaryBtn}"
                            Click="BtnCreatePost_Click" VerticalAlignment="Center"/>
                </Grid>
            </Border>

            <!-- 发帖表单 (默认隐藏) -->
            <Border x:Name="panelCreatePost" Grid.Row="1" Visibility="Collapsed"
                    Background="{DynamicResource CardBackgroundBrush}" Padding="24,16"
                    Margin="24,12,24,0" CornerRadius="12">
                <StackPanel>
                    <TextBlock Text="发布新帖子" FontSize="16" FontWeight="Bold"
                               Foreground="{DynamicResource TextPrimaryBrush}" FontFamily="Microsoft YaHei"
                               Margin="0,0,0,12"/>
                    <TextBox x:Name="txtPostTitle" Style="{StaticResource InputBox}"
                             Margin="0,0,0,10">
                        <TextBox.Tag>帖子标题...</TextBox.Tag>
                    </TextBox>
                    <TextBox x:Name="txtPostContent" Style="{StaticResource InputBox}"
                             Height="100" TextWrapping="Wrap" AcceptsReturn="True">
                        <TextBox.Tag>帖子内容...</TextBox.Tag>
                    </TextBox>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
                        <Button Content="取消" Style="{StaticResource SecondaryBtn}"
                                Click="BtnCreatePost_Click" Margin="0,0,10,0"/>
                        <Button Content="发布" Style="{StaticResource PrimaryBtn}"
                                Click="BtnSubmitPost_Click"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- 帖子列表 -->
            <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" Margin="24,12,24,20"
                         PreviewMouseWheel="ScrollViewer_PreviewMouseWheel">
                <ListBox x:Name="lstPosts" Background="Transparent" BorderThickness="0"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         ScrollViewer.VerticalScrollBarVisibility="Disabled">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Style="{StaticResource PostCardStyle}"
                                    MouseLeftButtonDown="PostItem_Click" Tag="{Binding}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- 头像 -->
                                    <Border Grid.Column="0" Width="40" Height="40"
                                            Background="{Binding AvatarColor}" CornerRadius="20"
                                            Margin="0,0,12,0">
                                        <TextBlock Text="{Binding AvatarEmoji}" FontSize="18"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>

                                    <!-- 内容 -->
                                    <StackPanel Grid.Column="1">
                                        <!-- 标题 -->
                                        <TextBlock Text="{Binding Title}" FontSize="15" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                                   FontFamily="Microsoft YaHei"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <!-- 预览 -->
                                        <TextBlock Text="{Binding Content}" FontSize="13"
                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                   FontFamily="Microsoft YaHei" Margin="0,4,0,0"
                                                   TextWrapping="Wrap" MaxHeight="40"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <!-- 元信息行 -->
                                        <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                            <TextBlock Text="{Binding Author}" FontSize="11"
                                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                                       FontFamily="Microsoft YaHei"/>
                                            <TextBlock Text=" · " FontSize="11"
                                                       Foreground="{DynamicResource TextSecondaryBrush}"/>
                                            <TextBlock Text="{Binding Time}" FontSize="11"
                                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                                       FontFamily="Microsoft YaHei"/>
                                        </StackPanel>
                                        <!-- 操作行 -->
                                        <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                            <Button Content="{Binding LikeCountDisplay}" Tag="{Binding}"
                                                    Style="{StaticResource IconBtn}" Click="BtnLikePost_Click"
                                                    Foreground="{DynamicResource TextSecondaryBrush}"/>
                                            <TextBlock Text="💬" FontSize="12" Margin="8,0,4,0"
                                                       VerticalAlignment="Center"/>
                                            <TextBlock Text="{Binding CommentCount}" FontSize="11"
                                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                                       FontFamily="Microsoft YaHei" VerticalAlignment="Center"/>
                                            <TextBlock Text="👁" FontSize="12" Margin="12,0,4,0"
                                                       VerticalAlignment="Center"/>
                                            <TextBlock Text="{Binding ViewCount}" FontSize="11"
                                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                                       FontFamily="Microsoft YaHei" VerticalAlignment="Center"/>
                                            <Button Content="📋 分享" Tag="{Binding}" Style="{StaticResource IconBtn}"
                                                    Click="BtnShare_Click" Margin="12,0,0,0"
                                                    Foreground="{DynamicResource TextSecondaryBrush}"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </ScrollViewer>
        </Grid>

        <!-- ========== 帖子详情 ========== -->
        <Grid x:Name="panelPostDetail" Visibility="Collapsed">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- 头部 -->
            <Border Grid.Row="0" Background="{DynamicResource CardBackgroundBrush}" Padding="24,14">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0" Content="← 返回" Style="{StaticResource SecondaryBtn}"
                            Click="BtnBackToPosts_Click" VerticalAlignment="Center"/>

                    <!-- 作者信息 -->
                    <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="14,0" VerticalAlignment="Center">
                        <Border x:Name="detailAvatar" Width="36" Height="36"
                                Background="#6C5CE7" CornerRadius="18" Margin="0,0,10,0">
                            <TextBlock Text="👤" FontSize="16"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel>
                            <TextBlock x:Name="txtDetailAuthor" Text="作者" FontSize="14" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimaryBrush}" FontFamily="Microsoft YaHei"/>
                            <TextBlock x:Name="txtDetailTime" Text="刚刚" FontSize="11"
                                       Foreground="{DynamicResource TextSecondaryBrush}" FontFamily="Microsoft YaHei"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- 分享按钮 -->
                    <Button Grid.Column="2" Content="📋 分享" Style="{StaticResource IconBtn}"
                            Click="BtnShare_Click" Padding="8,4"/>
                </Grid>
            </Border>

            <!-- 帖子内容 + 评论 -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="24,16,24,0"
                         PreviewMouseWheel="ScrollViewer_PreviewMouseWheel">
                <StackPanel>
                    <!-- 帖子标题 -->
                    <TextBlock x:Name="txtDetailTitle" Text="帖子标题" FontSize="20" FontWeight="Bold"
                               Foreground="{DynamicResource TextPrimaryBrush}" FontFamily="Microsoft YaHei"
                               TextWrapping="Wrap" Margin="0,0,0,12"/>

                    <!-- 帖子内容 -->
                    <TextBlock x:Name="txtDetailContent" Text="帖子内容" FontSize="14"
                               Foreground="{DynamicResource TextPrimaryBrush}" FontFamily="Microsoft YaHei"
                               TextWrapping="Wrap" LineHeight="24" Margin="0,0,0,16"/>

                    <!-- 操作栏 -->
                    <Border Background="{DynamicResource SurfaceBrush}" CornerRadius="10" Padding="12,8"
                            Margin="0,0,0,20">
                        <StackPanel Orientation="Horizontal">
                            <Button x:Name="btnDetailLike" Content="👍 点赞" Style="{StaticResource IconBtn}"
                                    Click="BtnLikePost_Click" Foreground="{DynamicResource TextSecondaryBrush}"/>
                            <TextBlock x:Name="txtDetailStats" Text="👍 0  ·  💬 0  ·  👁 0" FontSize="12"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       FontFamily="Microsoft YaHei" VerticalAlignment="Center" Margin="12,0,0,0"/>
                        </StackPanel>
                    </Border>

                    <!-- 评论标题 -->
                    <TextBlock FontSize="16" FontWeight="Bold" Margin="0,0,0,12"
                               Foreground="{DynamicResource TextPrimaryBrush}" FontFamily="Microsoft YaHei">
                        <Run Text="💬 评论 ("/>
                        <Run Text="{Binding CommentCount, ElementName=lstComments}"/><Run Text=")"/>
                    </TextBlock>

                    <!-- 评论列表 -->
                    <ListBox x:Name="lstComments" Background="Transparent" BorderThickness="0"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             ScrollViewer.VerticalScrollBarVisibility="Disabled" Margin="0,0,0,80">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{DynamicResource CardBackgroundBrush}"
                                        CornerRadius="10" Padding="14,12" Margin="0,0,0,8">
                                    <StackPanel>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Border Grid.Column="0" Width="30" Height="30"
                                                    Background="{Binding AvatarColor}" CornerRadius="15"
                                                    Margin="0,0,10,0">
                                                <TextBlock Text="{Binding AvatarEmoji}" FontSize="14"
                                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <StackPanel Grid.Column="1">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="{Binding Author}" FontSize="13"
                                                               FontWeight="SemiBold"
                                                               Foreground="{DynamicResource TextPrimaryBrush}"
                                                               FontFamily="Microsoft YaHei"/>
                                                    <TextBlock Text="{Binding Time}" FontSize="11"
                                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                                               FontFamily="Microsoft YaHei" Margin="8,0,0,0"
                                                               VerticalAlignment="Center"/>
                                                </StackPanel>
                                                <TextBlock Text="{Binding Content}" FontSize="13"
                                                           Foreground="{DynamicResource TextPrimaryBrush}"
                                                           FontFamily="Microsoft YaHei" Margin="0,4,0,0"
                                                           TextWrapping="Wrap"/>
                                                <Button Content="👍" Tag="{Binding}"
                                                        Style="{StaticResource IconBtn}" Margin="-6,4,0,0"
                                                        Click="BtnLikeComment_Click"
                                                        Foreground="{DynamicResource TextSecondaryBrush}"/>
                                            </StackPanel>
                                        </Grid>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </StackPanel>
            </ScrollViewer>

            <!-- 评论输入框 -->
            <Border Grid.Row="2" Background="{DynamicResource CardBackgroundBrush}"
                    Padding="16,12" Margin="0,0,0,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="txtCommentInput" Style="{StaticResource InputBox}"
                             KeyDown="TxtCommentInput_KeyDown">
                        <TextBox.Tag>输入评论... (Enter 发送)</TextBox.Tag>
                    </TextBox>
                    <Button Grid.Column="1" Content="发送" Style="{StaticResource PrimaryBtn}"
                            Click="BtnSubmitComment_Click" Margin="10,0,0,0" Padding="16,8"/>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
