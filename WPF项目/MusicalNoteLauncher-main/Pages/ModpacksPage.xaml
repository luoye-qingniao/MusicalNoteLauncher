<UserControl
	x:Class="MusicalNoteLauncher.Pages.ModpacksPage" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:local="clr-namespace:MusicalNoteLauncher.Pages" xmlns:core="clr-namespace:MusicalNoteLauncher.Core"
	Background="{DynamicResource BackgroundBrush}">
	<Grid Background="{DynamicResource BackgroundBrush}">
		<Grid.RowDefinitions>
			<RowDefinition Height="60" />
			<RowDefinition Height="*" />
		</Grid.RowDefinitions>

		<!-- 头部 -->
		<Border Grid.Row="0" Background="{DynamicResource CardHoverBrush}">
			<StackPanel Orientation="Horizontal" Margin="20,0" VerticalAlignment="Center">
				<Button Content="← 返回" Background="#00FFFFFF" Foreground="#2196F3" BorderThickness="0"
				        FontSize="14" FontFamily="Microsoft YaHei" Cursor="Hand" Margin="0,0,20,0" Click="BtnBack_Click"/>
				<Border Background="#9C27B0" CornerRadius="8" Width="32" Height="32" Margin="0,0,10,0">
					<TextBlock Text="📁" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center"/>
				</Border>
				<TextBlock Text="整合包" FontSize="20" FontWeight="Bold" Foreground="White" FontFamily="Microsoft YaHei"/>
			</StackPanel>
		</Border>

		<Grid Grid.Row="1" Margin="24,20,24,24">
			<Grid.RowDefinitions>
				<RowDefinition Height="Auto" />
				<RowDefinition Height="Auto" />
				<RowDefinition Height="*" />
			</Grid.RowDefinitions>

			<!-- 信息横幅 -->
			<Border Grid.Row="0" Background="{DynamicResource SurfaceBrush}" CornerRadius="12" Padding="0" Margin="0,0,0,16"
			        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
				<Grid>
					<Grid.ColumnDefinitions>
						<ColumnDefinition Width="4"/>
						<ColumnDefinition Width="*"/>
					</Grid.ColumnDefinitions>
					<Border Grid.Column="0" Background="#9C27B0" CornerRadius="12,0,0,12"/>
					<StackPanel Grid.Column="1" Margin="16,14,16,14">
						<TextBlock Text="📁 整合包下载" FontSize="15" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}"
						           FontFamily="Microsoft YaHei" Margin="0,0,0,6"/>
						<TextBlock Text="整合包包含了Mod、材质包和配置文件，可以一键安装并体验完整的游戏玩法"
						           FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" FontFamily="Microsoft YaHei" TextWrapping="Wrap"/>
					</StackPanel>
				</Grid>
			</Border>

			<!-- 筛选面板 —— PCL 风格 -->
			<Border Grid.Row="1" Background="{DynamicResource CardHoverBrush}" CornerRadius="12" Padding="25,20,25,15" Margin="0,0,0,14">
				<StackPanel>
					<Grid Margin="0,0,0,10" HorizontalAlignment="Stretch">
						<Grid.ColumnDefinitions>
							<ColumnDefinition Width="Auto"/>
							<ColumnDefinition Width="1.3*"/>
							<ColumnDefinition Width="1.2*"/>
							<ColumnDefinition Width="50"/>
							<ColumnDefinition Width="Auto"/>
							<ColumnDefinition Width="1*"/>
						</Grid.ColumnDefinitions>
						<Grid.RowDefinitions>
							<RowDefinition Height="30"/>
							<RowDefinition Height="10"/>
							<RowDefinition Height="30"/>
						</Grid.RowDefinitions>

						<!-- 名称 -->
						<TextBlock VerticalAlignment="Center" Text="名称" Margin="0,0,16,0"
						           Foreground="{DynamicResource TextPrimaryBrush}" FontSize="13" FontFamily="Microsoft YaHei"/>
						<Border Grid.Column="1" Grid.ColumnSpan="2" Height="30" Background="Transparent"
						        BorderBrush="#444" BorderThickness="1" CornerRadius="6">
							<Grid>
								<Path Width="12" Margin="10,0,0,0" IsHitTestVisible="False" Height="12"
								      Fill="{DynamicResource TextSecondaryBrush}" Stretch="Uniform" HorizontalAlignment="Left"
								      Data="M675.9168 242.816C556.3008 123.2 362.4448 123.2 242.8288 242.816 123.2128 362.432 123.2128 556.288 242.8288 675.904 362.4448 795.52 556.3008 795.52 675.9168 675.904 795.5328 556.288 795.5328 362.432 675.9168 242.816L675.9168 242.816ZM1000.7168 892.48C1030.6048 922.368 1030.6048 970.816 1000.7168 1000.704 970.8288 1030.656 922.3808 1030.656 892.4288 1000.704L730.0608 838.336C728.1408 836.416 727.4368 833.92 725.7728 831.872 546.3168 960.448 295.7568 945.408 134.5408 784.192-44.8512 604.8-44.8512 313.92 134.5408 134.528 313.9328-44.864 604.8128-44.864 784.2048 134.528 945.4208 295.744 960.4608 546.304 831.8848 725.76 833.9328 727.424 836.4288 728.128 838.3488 730.048L1000.7168 892.48Z"/>
								<TextBox x:Name="txtSearch" Padding="28,0,28,0" BorderThickness="0"
								         Background="Transparent" Foreground="{DynamicResource TextPrimaryBrush}"
								         FontSize="13" FontFamily="Microsoft YaHei" CaretBrush="{DynamicResource TextPrimaryBrush}"
								         VerticalContentAlignment="Center" TextChanged="TxtSearch_TextChanged"
								         KeyDown="TxtSearch_KeyDown" MaxLength="50"/>
								<TextBlock Text="搜索整合包名称..." Padding="28,0,0,0"
								           Foreground="{DynamicResource TextSecondaryBrush}" FontSize="13"
								           FontFamily="Microsoft YaHei" VerticalAlignment="Center"
								           IsHitTestVisible="False" x:Name="txtSearchHint"/>
								<Button x:Name="btnSearchClear" Width="20" Height="20" Cursor="Hand"
								        HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,6,0"
								        Opacity="0" IsHitTestVisible="False" Click="BtnSearchClear_Click"
								        Background="Transparent" BorderThickness="0">
									<Path Width="10" Height="10" Stretch="Uniform" Fill="{DynamicResource TextSecondaryBrush}"
									      Data="F1 M2,0 L0,2 8,10 0,18 2,20 10,12 18,20 20,18 12,10 20,2 18,0 10,8 2,0Z"/>
								</Button>
							</Grid>
						</Border>

						<!-- 来源 -->
						<TextBlock VerticalAlignment="Center" Grid.Column="4" Text="来源" Margin="0,0,16,0"
						           Foreground="{DynamicResource TextPrimaryBrush}" FontSize="13" FontFamily="Microsoft YaHei"/>
						<ComboBox x:Name="cmbSource" Grid.Column="5" Height="30" FontSize="13" FontFamily="Microsoft YaHei"
						          Background="{DynamicResource SurfaceBrush}" Foreground="{DynamicResource TextPrimaryBrush}"
						          BorderBrush="#444" BorderThickness="1" SelectionChanged="Filter_SelectionChanged">
							<ComboBoxItem Content="全部" Tag="All" IsSelected="True"/>
							<ComboBoxItem Content="CurseForge" Tag="CurseForge"/>
							<ComboBoxItem Content="Modrinth" Tag="Modrinth"/>
						</ComboBox>

						<!-- 版本 -->
					<TextBlock VerticalAlignment="Center" Grid.Row="2" Text="版本" Margin="0,0,16,0"
					           Foreground="{DynamicResource TextPrimaryBrush}" FontSize="13" FontFamily="Microsoft YaHei"/>
					<ComboBox x:Name="cmbVersion" Grid.Row="2" Grid.Column="1"
					          Height="30" FontSize="13" FontFamily="Microsoft YaHei" IsEditable="True"
					          Background="{DynamicResource SurfaceBrush}" Foreground="{DynamicResource TextPrimaryBrush}"
					          BorderBrush="#444" BorderThickness="1" SelectionChanged="Filter_SelectionChanged"
					          Text="全部 (也可自行输入)">
						<ComboBoxItem Content="全部 (也可自行输入)" Tag=""/>
					</ComboBox>

					<!-- 类型 -->
					<TextBlock VerticalAlignment="Center" Grid.Column="4" Grid.Row="2" Text="类型" Margin="0,0,16,0"
					           Foreground="{DynamicResource TextPrimaryBrush}" FontSize="13" FontFamily="Microsoft YaHei"/>
					<ComboBox x:Name="cmbType" Grid.Column="5" Grid.Row="2" Height="30" FontSize="13" FontFamily="Microsoft YaHei"
					          Background="{DynamicResource SurfaceBrush}" Foreground="{DynamicResource TextPrimaryBrush}"
					          BorderBrush="#444" BorderThickness="1" SelectionChanged="Filter_SelectionChanged">
						<ComboBoxItem Content="全部" Tag="" IsSelected="True"/>
						<ComboBoxItem Content="多人" Tag="multiplayer"/>
						<ComboBoxItem Content="性能优化" Tag="optimization"/>
						<ComboBoxItem Content="硬核" Tag="challenging"/>
						<ComboBoxItem Content="战斗" Tag="combat"/>
						<ComboBoxItem Content="任务" Tag="quests"/>
						<ComboBoxItem Content="科技" Tag="technology"/>
						<ComboBoxItem Content="魔法" Tag="magic"/>
						<ComboBoxItem Content="冒险" Tag="adventure"/>
						<ComboBoxItem Content="水槽包" Tag="kitchen-sink"/>
						<ComboBoxItem Content="探索" Tag="exploration"/>
						<ComboBoxItem Content="小游戏" Tag="mini-game"/>
						<ComboBoxItem Content="科幻" Tag="sci-fi"/>
						<ComboBoxItem Content="空岛" Tag="skyblock"/>
						<ComboBoxItem Content="原版改良" Tag="vanilla-plus"/>
						<ComboBoxItem Content="FTB" Tag="ftb"/>
						<ComboBoxItem Content="基于地图" Tag="map-based"/>
						<ComboBoxItem Content="轻量整合" Tag="lightweight"/>
						<ComboBoxItem Content="大型整合" Tag="large-pack"/>
					</ComboBox>
				</Grid>

					<!-- 按钮行 -->
					<Grid Height="35">
						<Grid.ColumnDefinitions>
							<ColumnDefinition Width="Auto"/>
							<ColumnDefinition Width="Auto"/>
						</Grid.ColumnDefinitions>
						<Button x:Name="BtnSearchRun" Content="搜索" MinWidth="120" Padding="13,0" Margin="0,0,16,0"
						        FontSize="13" FontWeight="SemiBold" FontFamily="Microsoft YaHei"
						        Foreground="White" Cursor="Hand" Click="BtnSearchRun_Click">
							<Button.Template>
								<ControlTemplate TargetType="Button">
									<Border x:Name="bd" CornerRadius="6" Padding="{TemplateBinding Padding}"
									        Background="#9C27B0" BorderThickness="0">
										<Border.Effect>
											<DropShadowEffect BlurRadius="6" ShadowDepth="2" Opacity="0.3" Color="#9C27B0"/>
										</Border.Effect>
										<ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
										                  TextElement.Foreground="White" TextElement.FontWeight="SemiBold"/>
									</Border>
									<ControlTemplate.Triggers>
										<Trigger Property="IsMouseOver" Value="True">
											<Setter TargetName="bd" Property="Background" Value="#BA68C8"/>
										</Trigger>
										<Trigger Property="IsPressed" Value="True">
											<Setter TargetName="bd" Property="Background" Value="#7B1FA2"/>
										</Trigger>
									</ControlTemplate.Triggers>
								</ControlTemplate>
							</Button.Template>
						</Button>
						<Button x:Name="BtnSearchReset" Content="重置条件" Grid.Column="1" MinWidth="120" Padding="13,0"
						        FontSize="13" FontFamily="Microsoft YaHei" Cursor="Hand" Click="BtnSearchReset_Click"
						        Background="{DynamicResource SurfaceBrush}" Foreground="{DynamicResource TextPrimaryBrush}"
						        BorderBrush="#555" BorderThickness="1"/>
					</Grid>
				</StackPanel>
			</Border>

			<!-- 列表区域 -->
			<Grid Grid.Row="2">
				<Grid.RowDefinitions>
					<RowDefinition Height="*"/>
					<RowDefinition Height="Auto"/>
				</Grid.RowDefinitions>
				<Border Grid.Row="0" Background="{DynamicResource CardHoverBrush}" CornerRadius="12,12,0,0" Padding="4">
				<ListBox Name="lbModpacks" Background="#00FFFFFF" BorderThickness="0"
				         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
					<ItemsControl.ItemContainerStyle>
						<Style TargetType="{x:Type ListBoxItem}">
							<Setter Property="HorizontalAlignment" Value="Stretch"/>
							<Setter Property="HorizontalContentAlignment" Value="Stretch"/>
							<Setter Property="Height" Value="128"/>
							<Setter Property="Template">
								<Setter.Value>
									<ControlTemplate TargetType="ListBoxItem">
										<Border x:Name="itemBorder" Background="#00FFFFFF"
										        CornerRadius="10" Padding="2" Margin="6,3">
											<ContentPresenter/>
										</Border>
										<ControlTemplate.Triggers>
											<Trigger Property="IsMouseOver" Value="True">
												<Setter TargetName="itemBorder" Property="Background" Value="#FFFFFF08"/>
											</Trigger>
										</ControlTemplate.Triggers>
									</ControlTemplate>
								</Setter.Value>
							</Setter>
						</Style>
					</ItemsControl.ItemContainerStyle>
					<ItemsControl.ItemTemplate>
						<DataTemplate>
							<Border Background="{DynamicResource SurfaceBrush}" CornerRadius="10" Padding="16" Height="120">
								<Border.Effect>
									<DropShadowEffect BlurRadius="6" ShadowDepth="1" Opacity="0.12" Color="Black"/>
								</Border.Effect>
								<Grid>
									<Grid.ColumnDefinitions>
										<ColumnDefinition Width="80"/>
										<ColumnDefinition Width="*"/>
										<ColumnDefinition Width="120"/>
									</Grid.ColumnDefinitions>

									<!-- 图标 -->
									<Border Grid.Column="0" Background="{DynamicResource SurfaceBrush}" CornerRadius="12"
									        Width="80" Height="80" VerticalAlignment="Center">
										<Border.Effect>
											<DropShadowEffect BlurRadius="8" ShadowDepth="2" Opacity="0.2" Color="Black"/>
										</Border.Effect>
										<UIElement.OpacityMask>
											<VisualBrush>
												<VisualBrush.Visual>
													<Rectangle Width="80" Height="80" RadiusX="12" RadiusY="12" Fill="#FFFFFFFF"/>
												</VisualBrush.Visual>
											</VisualBrush>
										</UIElement.OpacityMask>
										<Image Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"
										       Source="{Binding IconUrl}"/>
									</Border>

									<!-- 信息 -->
									<StackPanel Grid.Column="1" Margin="14,0,0,0" VerticalAlignment="Center">
										<StackPanel Orientation="Horizontal">
											<TextBlock FontSize="15" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}"
											           FontFamily="Microsoft YaHei" TextTrimming="CharacterEllipsis"
											           MaxWidth="400" Text="{Binding Name, FallbackValue=未知名称}"/>
											<Border CornerRadius="4" Margin="8,0,0,0" VerticalAlignment="Center"
											        Padding="6,2" Background="#9C27B0">
												<TextBlock FontSize="10" FontWeight="SemiBold" Foreground="White"
												           Text="{Binding Version, FallbackValue=未知版本}"/>
											</Border>
										</StackPanel>
										<TextBlock FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" FontFamily="Microsoft YaHei"
										           Margin="0,5,0,5" TextTrimming="CharacterEllipsis" MaxWidth="500"
										           Height="24" Text="{Binding Description, FallbackValue=暂无描述}"/>
										<StackPanel Orientation="Horizontal">
											<TextBlock FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"
											           FontFamily="Microsoft YaHei" Margin="0,0,14,0"
											           TextTrimming="CharacterEllipsis" MaxWidth="150"
											           Text="{Binding Author, FallbackValue=未知作者}"/>
											<TextBlock FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"
											           FontFamily="Microsoft YaHei"
											           Text="{Binding Downloads, FallbackValue=0}"/>
										</StackPanel>
									</StackPanel>

									<!-- 下载安装按钮 -->
									<Button Grid.Column="2" Content="下载安装" Width="100" Height="42"
									        FontSize="13" FontWeight="SemiBold" FontFamily="Microsoft YaHei"
									        Foreground="White" Cursor="Hand" VerticalAlignment="Center" Click="BtnDownload_Click">
										<Button.Template>
											<ControlTemplate TargetType="Button">
												<Border x:Name="btnBorder" CornerRadius="10" Padding="18,8">
													<Border.Background>
														<LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
															<GradientStop Color="#1EBB8E" Offset="0"/>
															<GradientStop Color="#168A6E" Offset="1"/>
														</LinearGradientBrush>
													</Border.Background>
													<Border.Effect>
														<DropShadowEffect BlurRadius="8" ShadowDepth="2" Opacity="0.3" Color="#1EBB8E"/>
													</Border.Effect>
													<ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
												</Border>
												<ControlTemplate.Triggers>
													<Trigger Property="IsMouseOver" Value="True">
														<Setter TargetName="btnBorder" Property="Background">
															<Setter.Value>
																<LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
																	<GradientStop Color="#20D49E" Offset="0"/>
																	<GradientStop Color="#1EBB8E" Offset="1"/>
																</LinearGradientBrush>
															</Setter.Value>
														</Setter>
													</Trigger>
													<Trigger Property="IsPressed" Value="True">
														<Setter TargetName="btnBorder" Property="Background" Value="#147A5E"/>
													</Trigger>
												</ControlTemplate.Triggers>
											</ControlTemplate>
										</Button.Template>
									</Button>
								</Grid>
							</Border>
						</DataTemplate>
					</ItemsControl.ItemTemplate>
				</ListBox>
			</Border>
			<!-- 分页条 -->
			<Border Grid.Row="1" Background="{DynamicResource CardHoverBrush}" CornerRadius="0,0,12,12" Padding="10,8"
			        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0">
				<StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
					<Button x:Name="BtnPageFirst" Content="首页"
					        FontSize="12" FontFamily="Microsoft YaHei" Cursor="Hand"
					        Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,4,0" Click="BtnPageFirst_Click">
						<Button.Template>
							<ControlTemplate TargetType="Button">
								<Border x:Name="bd" Background="{DynamicResource SurfaceBrush}" CornerRadius="6" Padding="12,6"
								        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
									<Border.Effect>
										<DropShadowEffect BlurRadius="4" ShadowDepth="1" Opacity="0.08" Color="Black"/>
									</Border.Effect>
									<ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
									                  TextElement.Foreground="{TemplateBinding Foreground}" TextElement.FontSize="12"/>
								</Border>
								<ControlTemplate.Triggers>
									<Trigger Property="IsMouseOver" Value="True">
										<Setter TargetName="bd" Property="Background" Value="{DynamicResource CardHoverBrush}"/>
										<Setter TargetName="bd" Property="BorderBrush" Value="#FF9800"/>
									</Trigger>
									<Trigger Property="IsEnabled" Value="False">
										<Setter TargetName="bd" Property="Opacity" Value="0.4"/>
									</Trigger>
								</ControlTemplate.Triggers>
							</ControlTemplate>
						</Button.Template>
					</Button>
					<Button x:Name="BtnPagePrev" Content="←"
					        FontSize="14" FontFamily="Microsoft YaHei" Cursor="Hand"
					        Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,4,0" Click="BtnPagePrev_Click">
						<Button.Template>
							<ControlTemplate TargetType="Button">
								<Border x:Name="bd" Background="{DynamicResource SurfaceBrush}" CornerRadius="6" Padding="10,6"
								        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
									<Border.Effect>
										<DropShadowEffect BlurRadius="4" ShadowDepth="1" Opacity="0.08" Color="Black"/>
									</Border.Effect>
									<ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
									                  TextElement.Foreground="{TemplateBinding Foreground}" TextElement.FontSize="14"/>
								</Border>
								<ControlTemplate.Triggers>
									<Trigger Property="IsMouseOver" Value="True">
										<Setter TargetName="bd" Property="Background" Value="{DynamicResource CardHoverBrush}"/>
										<Setter TargetName="bd" Property="BorderBrush" Value="#FF9800"/>
									</Trigger>
									<Trigger Property="IsEnabled" Value="False">
										<Setter TargetName="bd" Property="Opacity" Value="0.4"/>
									</Trigger>
								</ControlTemplate.Triggers>
							</ControlTemplate>
						</Button.Template>
					</Button>
					<TextBlock x:Name="LabPage" Text="1 / 1" FontSize="13"
					           Foreground="{DynamicResource TextSecondaryBrush}"
					           FontFamily="Microsoft YaHei" VerticalAlignment="Center" Margin="10,0,10,0"/>
					<Button x:Name="BtnPageNext" Content="→"
					        FontSize="14" FontFamily="Microsoft YaHei" Cursor="Hand"
					        Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,4,0" Click="BtnPageNext_Click">
						<Button.Template>
							<ControlTemplate TargetType="Button">
								<Border x:Name="bd" Background="{DynamicResource SurfaceBrush}" CornerRadius="6" Padding="10,6"
								        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
									<Border.Effect>
										<DropShadowEffect BlurRadius="4" ShadowDepth="1" Opacity="0.08" Color="Black"/>
									</Border.Effect>
									<ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
									                  TextElement.Foreground="{TemplateBinding Foreground}" TextElement.FontSize="14"/>
								</Border>
								<ControlTemplate.Triggers>
									<Trigger Property="IsMouseOver" Value="True">
										<Setter TargetName="bd" Property="Background" Value="{DynamicResource CardHoverBrush}"/>
										<Setter TargetName="bd" Property="BorderBrush" Value="#FF9800"/>
									</Trigger>
									<Trigger Property="IsEnabled" Value="False">
										<Setter TargetName="bd" Property="Opacity" Value="0.4"/>
									</Trigger>
								</ControlTemplate.Triggers>
							</ControlTemplate>
						</Button.Template>
					</Button>
				</StackPanel>
			</Border>
			</Grid>
		</Grid>

		<!-- 安装进度覆盖层 -->
		<Border x:Name="InstallProgressOverlay" Grid.Row="1" Visibility="Collapsed" Panel.ZIndex="200">
			<Border.Background>
				<LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
					<GradientStop Color="#E6101010" Offset="0"/>
					<GradientStop Color="#F01E1E1E" Offset="1"/>
				</LinearGradientBrush>
			</Border.Background>
			<Grid HorizontalAlignment="Center" VerticalAlignment="Center" Width="420">
				<Border Background="{DynamicResource CardBackgroundBrush}" CornerRadius="16" Padding="30,28"
				        BorderBrush="#444444" BorderThickness="1">
					<Border.Effect>
						<DropShadowEffect BlurRadius="24" ShadowDepth="4" Opacity="0.5" Color="Black"/>
					</Border.Effect>
					<StackPanel>
						<StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,16">
							<TextBlock Text="📦" FontSize="24" VerticalAlignment="Center" Margin="0,0,10,0"/>
							<TextBlock x:Name="InstallTitleText" Text="正在安装整合包..."
							           FontSize="18" FontWeight="Bold" Foreground="White"
							           FontFamily="Microsoft YaHei" VerticalAlignment="Center"/>
						</StackPanel>
						<TextBlock x:Name="InstallStatusText" Text="准备中..."
						           FontSize="14" Foreground="{DynamicResource TextPrimaryBrush}" FontFamily="Microsoft YaHei"
						           HorizontalAlignment="Center" Margin="0,0,0,18" TextWrapping="Wrap" TextAlignment="Center"/>
						<ProgressBar x:Name="InstallProgressBar" Height="8" Minimum="0" Maximum="100" Value="0"
						             BorderThickness="0" Margin="0,0,0,16">
							<ProgressBar.Foreground>
								<LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
									<GradientStop Color="#1EBB8E" Offset="0"/>
									<GradientStop Color="#20D49E" Offset="1"/>
								</LinearGradientBrush>
							</ProgressBar.Foreground>
							<ProgressBar.Background>
								<SolidColorBrush Color="#333333"/>
							</ProgressBar.Background>
						</ProgressBar>
						<TextBlock x:Name="InstallPercentText" Text="0%"
						           FontSize="28" FontWeight="Bold" Foreground="#1EBB8E"
						           FontFamily="Microsoft YaHei" HorizontalAlignment="Center"/>
						<Button x:Name="InstallCancelBtn" Content="取消" Width="100" Height="34"
						        FontSize="13" FontWeight="SemiBold" FontFamily="Microsoft YaHei"
						        Foreground="{DynamicResource TextPrimaryBrush}" Cursor="Hand" HorizontalAlignment="Center"
						        Margin="0,16,0,0" Click="InstallCancelBtn_Click">
							<Button.Template>
								<ControlTemplate TargetType="Button">
									<Border x:Name="cancelBorder" Background="{DynamicResource SurfaceBrush}" CornerRadius="8"
									        BorderBrush="#555555" BorderThickness="1">
										<ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
									</Border>
									<ControlTemplate.Triggers>
										<Trigger Property="IsMouseOver" Value="True">
											<Setter TargetName="cancelBorder" Property="Background" Value="#4A4A4A"/>
										</Trigger>
									</ControlTemplate.Triggers>
								</ControlTemplate>
							</Button.Template>
						</Button>
					</StackPanel>
				</Border>
			</Grid>
		</Border>
	</Grid>
</UserControl>