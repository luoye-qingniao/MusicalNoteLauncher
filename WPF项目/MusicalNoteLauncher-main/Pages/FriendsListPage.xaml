<UserControl
	x:Class="MusicalNoteLauncher.Pages.FriendsListPage" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	Background="{DynamicResource BackgroundBrush}" xmlns:pages="clr-namespace:MusicalNoteLauncher.Pages">
	<UserControl.Resources>
		<Style x:Key="RoundedFilterBtn" TargetType="{x:Type Button}">
			<Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
			<Setter Property="BorderThickness" Value="0" />
			<Setter Property="Padding" Value="14,7" />
			<Setter Property="FontSize" Value="12" />
			<Setter Property="FontFamily" Value="Microsoft YaHei" />
			<Setter Property="Cursor" Value="Hand" />
			<Setter Property="Margin" Value="0,0,8,0" />
			<Setter Property="Template">
				<Setter.Value>
					<ControlTemplate TargetType="{x:Type Button}">
						<Border Name="bd" Background="{DynamicResource SurfaceBrush}" CornerRadius="16" Padding="{TemplateBinding Padding}">
							<ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
						</Border>
						<ControlTemplate.Triggers>
							<Trigger Property="IsMouseOver" Value="True">
								<Setter TargetName="bd" Property="Background" Value="{DynamicResource CardHoverBrush}" />
							</Trigger>
						</ControlTemplate.Triggers>
					</ControlTemplate>
				</Setter.Value>
			</Setter>
		</Style>

		<Style x:Key="RoundedPrimaryBtn" TargetType="{x:Type Button}">
			<Setter Property="Foreground" Value="White" />
			<Setter Property="BorderThickness" Value="0" />
			<Setter Property="Padding" Value="18,8" />
			<Setter Property="FontSize" Value="13" />
			<Setter Property="FontFamily" Value="Microsoft YaHei" />
			<Setter Property="Cursor" Value="Hand" />
			<Setter Property="Template">
				<Setter.Value>
					<ControlTemplate TargetType="{x:Type Button}">
						<Border Name="bd" Background="#2196F3" CornerRadius="6" Padding="{TemplateBinding Padding}">
							<ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
						</Border>
						<ControlTemplate.Triggers>
							<Trigger Property="IsMouseOver" Value="True">
								<Setter TargetName="bd" Property="Background" Value="#1976D2" />
							</Trigger>
						</ControlTemplate.Triggers>
					</ControlTemplate>
				</Setter.Value>
			</Setter>
		</Style>
	</UserControl.Resources>

	<ScrollViewer VerticalScrollBarVisibility="Auto">
		<Grid Margin="20">
			<Grid.RowDefinitions>
				<RowDefinition Height="Auto" />
				<RowDefinition Height="*" />
			</Grid.RowDefinitions>

			<!-- ========== 顶部标题栏 ========== -->
			<Border Grid.Row="0" Margin="0,0,0,16" Padding="0">
				<Grid>
					<Grid.ColumnDefinitions>
						<ColumnDefinition Width="Auto" />
						<ColumnDefinition Width="*" />
						<ColumnDefinition Width="Auto" />
					</Grid.ColumnDefinitions>
					<StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
						<TextBlock Text="好友列表" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="22" FontWeight="SemiBold" FontFamily="Microsoft YaHei" VerticalAlignment="Center" Margin="0,0,12,0" />
						<Border Name="bdCount" Background="{DynamicResource SurfaceBrush}" CornerRadius="10" Padding="10,3" VerticalAlignment="Center">
							<TextBlock Name="txtFriendCount" Text="0 位好友" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11" FontFamily="Microsoft YaHei" />
						</Border>
					</StackPanel>
					<Button Grid.Column="2" Content="＋ 添加好友" Style="{StaticResource RoundedPrimaryBtn}" Click="BtnAddFriend_Click" />
				</Grid>
			</Border>

			<!-- ========== 主体：好友列表 + 聊天面板 ========== -->
			<Grid Grid.Row="1">
				<Grid.ColumnDefinitions>
					<ColumnDefinition Width="*" />
					<ColumnDefinition Width="360" />
				</Grid.ColumnDefinitions>

				<!-- ===== 左侧：好友列表 ===== -->
				<Border Grid.Column="0" Background="{DynamicResource CardBackgroundBrush}" CornerRadius="10" Padding="16" Margin="0,0,12,0">
					<Grid>
						<Grid.RowDefinitions>
							<RowDefinition Height="Auto" />
							<RowDefinition Height="Auto" />
							<RowDefinition Height="*" />
						</Grid.RowDefinitions>

						<!-- 搜索框 -->
						<Border Grid.Row="0" Background="{DynamicResource SurfaceBrush}" CornerRadius="8" Padding="10,6" Margin="0,0,0,12">
							<Grid>
								<Grid.ColumnDefinitions>
									<ColumnDefinition Width="Auto" />
									<ColumnDefinition Width="*" />
									<ColumnDefinition Width="Auto" />
								</Grid.ColumnDefinitions>
								<TextBlock Grid.Column="0" Text="🔍" FontSize="14" VerticalAlignment="Center" Margin="0,0,8,0" />
								<TextBox Name="txtSearch" Grid.Column="1" Background="Transparent" Foreground="{DynamicResource TextPrimaryBrush}" BorderThickness="0" FontSize="13" FontFamily="Microsoft YaHei" VerticalAlignment="Center" TextChanged="TxtSearch_TextChanged" />
								<Button Name="btnClearSearch" Grid.Column="2" Content="✕" FontSize="12" Cursor="Hand" Foreground="{DynamicResource TextSecondaryBrush}" Background="Transparent" BorderThickness="0" Padding="6,2" Visibility="Collapsed" Click="BtnClearSearch_Click" />
							</Grid>
						</Border>

						<!-- 筛选按钮 + 在线统计 -->
						<Grid Grid.Row="1" Margin="0,0,0,12">
							<StackPanel Grid.Column="0" Orientation="Horizontal">
								<Button x:Name="btnFilterAll" Content="全部" Style="{StaticResource RoundedFilterBtn}" Click="BtnFilter_Click">
									<Button.Resources>
										<SolidColorBrush x:Key="SurfaceBrush" Color="#2196F3" />
									</Button.Resources>
								</Button>
								<Button x:Name="btnFilterOnline" Content="在线" Style="{StaticResource RoundedFilterBtn}" Click="BtnFilter_Click" />
								<Button x:Name="btnFilterOffline" Content="离线" Style="{StaticResource RoundedFilterBtn}" Click="BtnFilter_Click" />
							</StackPanel>
						</Grid>

						<!-- 好友列表 -->
						<ListBox Name="lstFriends" Grid.Row="2" Background="Transparent" BorderThickness="0" Foreground="{DynamicResource TextPrimaryBrush}" FontFamily="Microsoft YaHei" SelectionChanged="LstFriends_SelectionChanged">
							<ItemsControl.ItemTemplate>
								<DataTemplate>
									<Border Name="itemBorder" Background="Transparent" CornerRadius="8" Padding="12,10" Margin="0,2">
										<Grid>
											<Grid.ColumnDefinitions>
												<ColumnDefinition Width="Auto" />
												<ColumnDefinition Width="*" />
												<ColumnDefinition Width="Auto" />
											</Grid.ColumnDefinitions>

											<!-- 头像：圆形 + 在线状态点 -->
											<Grid Grid.Column="0" Margin="0,0,12,0">
												<Border Width="44" Height="44" CornerRadius="22" Background="{Binding AvatarColor}">
													<TextBlock FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center" Text="{Binding AvatarEmoji}" />
												</Border>
												<!-- 在线状态指示点 -->
												<Border Width="12" Height="12" CornerRadius="6" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,-2,-2">
													<Border.Style>
														<Style TargetType="{x:Type Border}">
															<Setter Property="Background" Value="#4CAF50" />
															<Setter Property="BorderBrush" Value="{DynamicResource CardBackgroundBrush}" />
															<Setter Property="BorderThickness" Value="2" />
															<Style.Triggers>
																<DataTrigger Binding="{Binding IsOnline}" Value="False">
																	<Setter Property="Background" Value="#9E9E9E" />
																</DataTrigger>
															</Style.Triggers>
														</Style>
													</Border.Style>
												</Border>
											</Grid>

											<!-- 名字 + 状态文字 -->
											<StackPanel Grid.Column="1" VerticalAlignment="Center">
												<TextBlock Foreground="{DynamicResource TextPrimaryBrush}" FontSize="14" FontWeight="SemiBold" Text="{Binding FriendName}" />
												<TextBlock FontSize="11" Text="{Binding StatusText}" Foreground="{Binding StatusColor}" Margin="0,2,0,0" />
											</StackPanel>

											<!-- 操作按钮 -->
											<StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
												<Button Content="邀请" Style="{StaticResource RoundedPrimaryBtn}" FontSize="11" Padding="12,5" Margin="0,0,6,0" Click="BtnInvite_Click" />
												<Button Content="聊天" FontSize="11" Padding="12,5" FontFamily="Microsoft YaHei" Cursor="Hand" Click="BtnChat_Click">
													<Button.Style>
														<Style TargetType="{x:Type Button}">
															<Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
															<Setter Property="Background" Value="Transparent" />
															<Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
															<Setter Property="BorderThickness" Value="1" />
															<Setter Property="Template">
																<Setter.Value>
																	<ControlTemplate TargetType="{x:Type Button}">
																		<Border Name="bd" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="6" Padding="{TemplateBinding Padding}">
																			<ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
																		</Border>
																		<ControlTemplate.Triggers>
																			<Trigger Property="IsMouseOver" Value="True">
																				<Setter TargetName="bd" Property="Background" Value="{DynamicResource CardHoverBrush}" />
																			</Trigger>
																		</ControlTemplate.Triggers>
																	</ControlTemplate>
																</Setter.Value>
															</Setter>
														</Style>
													</Button.Style>
												</Button>
											</StackPanel>
										</Grid>
									</Border>
									<DataTemplate.Triggers>
										<DataTrigger Binding="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=ListBoxItem}, Path=IsSelected}" Value="True">
											<Setter TargetName="itemBorder" Property="Background" Value="{DynamicResource CardHoverBrush}" />
										</DataTrigger>
									</DataTemplate.Triggers>
								</DataTemplate>
							</ItemsControl.ItemTemplate>
						</ListBox>
					</Grid>
				</Border>

				<!-- ===== 右侧：聊天面板 ===== -->
				<Border Grid.Column="1" Background="{DynamicResource CardBackgroundBrush}" CornerRadius="10" Padding="16">
					<Grid>
						<Grid.RowDefinitions>
							<RowDefinition Height="Auto" />
							<RowDefinition Height="Auto" />
							<RowDefinition Height="*" />
							<RowDefinition Height="Auto" />
						</Grid.RowDefinitions>

						<!-- 聊天头部 -->
						<Grid Grid.Row="0" Margin="0,0,0,12">
							<Grid.ColumnDefinitions>
								<ColumnDefinition Width="*" />
								<ColumnDefinition Width="Auto" />
							</Grid.ColumnDefinitions>
							<TextBlock Name="txtChatTitle" Text="聊天" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="15" FontWeight="SemiBold" FontFamily="Microsoft YaHei" VerticalAlignment="Center" />
							<Button Name="btnCloseChat" Content="✕" FontSize="14" Cursor="Hand" Foreground="{DynamicResource TextSecondaryBrush}" Background="Transparent" BorderThickness="0" Padding="8,4" Grid.Column="1" Visibility="Collapsed" Click="BtnCloseChat_Click" />
						</Grid>

						<!-- 聊天副标题 / 空状态提示 -->
						<Border Name="bdChatPlaceholder" Grid.Row="1" Grid.RowSpan="2" Visibility="Visible">
							<StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0,40,0,0">
								<TextBlock Text="💬" FontSize="40" HorizontalAlignment="Center" Margin="0,0,0,12" />
								<TextBlock Name="txtChatSubtitle" Text="选择一位好友开始聊天" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="13" FontFamily="Microsoft YaHei" HorizontalAlignment="Center" />
							</StackPanel>
						</Border>

						<!-- 消息区域 -->
						<ScrollViewer Name="svChatMessages" Grid.Row="2" VerticalScrollBarVisibility="Auto" Margin="0,0,0,12" Visibility="Collapsed">
							<StackPanel Name="pnlChatMessages" />
						</ScrollViewer>

						<!-- 输入区域 -->
						<Border Grid.Row="3" Visibility="Collapsed" Name="bdChatInput">
							<Grid>
								<Grid.ColumnDefinitions>
									<ColumnDefinition Width="*" />
									<ColumnDefinition Width="Auto" />
								</Grid.ColumnDefinitions>
								<Border Grid.Column="0" Background="{DynamicResource SurfaceBrush}" CornerRadius="8" Padding="10,6" Margin="0,0,8,0">
									<TextBox Name="txtMessage" Background="Transparent" Foreground="{DynamicResource TextPrimaryBrush}" BorderThickness="0" FontSize="13" FontFamily="Microsoft YaHei" VerticalAlignment="Center" KeyDown="TxtMessage_KeyDown" />
								</Border>
								<Button Grid.Column="1" Content="发送" Style="{StaticResource RoundedPrimaryBtn}" Padding="16,8" Click="BtnSend_Click" />
							</Grid>
						</Border>
					</Grid>
				</Border>
			</Grid>
		</Grid>
	</ScrollViewer>
</UserControl>
