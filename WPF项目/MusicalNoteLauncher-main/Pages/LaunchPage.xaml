<Page x:Class="MusicalNoteLauncher.Pages.LaunchPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      mc:Ignorable="d"
      Title="游戏启动">

    <Grid Background="{StaticResource BackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="80"/>
        </Grid.RowDefinitions>

        <!-- 顶部标题栏 -->
        <Border Grid.Row="0" Background="{StaticResource CardBackgroundBrush}">
            <StackPanel Orientation="Horizontal" Margin="20,0" VerticalAlignment="Center">
                <TextBlock Text="游戏启动" FontSize="20" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}"/>
            </StackPanel>
        </Border>

        <!-- 主内容区 -->
        <Grid Grid.Row="1" Margin="20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="350"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- 左侧配置面板 -->
            <Border Background="{StaticResource SurfaceBrush}" CornerRadius="12" Padding="20">
                <StackPanel>
                    <!-- 版本类型切换 -->
                    <TextBlock Text="版本类型" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,12"/>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                        <Button x:Name="btnJavaVersion" 
                                Content="Java版" 
                                Style="{StaticResource ModernToggleButton}"
                                Width="80"
                                Click="BtnVersionType_Click"
                                Tag="Java"/>
                        <Button x:Name="btnBedrockVersion" 
                                Content="基岩版" 
                                Style="{StaticResource ModernToggleButton}"
                                Width="80"
                                Margin="8,0,0,0"
                                Click="BtnVersionType_Click"
                                Tag="Bedrock"/>
                    </StackPanel>

                    <!-- 版本选择 -->
                    <TextBlock Text="选择版本" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,12"/>
                    <ComboBox x:Name="cboVersions" 
                              Style="{StaticResource ModernComboBox}"
                              ItemContainerStyle="{StaticResource ModernComboBoxItem}"
                              Margin="0,0,0,16"
                              FontFamily="Microsoft YaHei"
                              SelectedIndex="0"
                              PreviewMouseLeftButtonDown="CboVersions_PreviewMouseLeftButtonDown"/>
                    <TextBlock Text="点击下拉框可刷新版本列表" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,8"/>

                    <!-- 用户名 -->
                    <TextBlock Text="用户名" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,12"/>
                    <TextBox x:Name="txtUsername" 
                             Style="{StaticResource ModernTextBox}"
                             Margin="0,0,0,16"
                             FontFamily="Microsoft YaHei"
                             Text="Player"/>

                    <!-- 内存设置 -->
                    <TextBlock Text="内存设置" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,12"/>
                    
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        
                        <TextBox x:Name="txtMinMemory" 
                                 Style="{StaticResource ModernTextBox}"
                                 FontFamily="Microsoft YaHei"
                                 Text="2048"
                                 Grid.Column="0"/>
                        <TextBlock Text="~" Foreground="{StaticResource TextSecondaryBrush}" Margin="8,0" Grid.Column="1"/>
                        <TextBox x:Name="txtMaxMemory" 
                                 Style="{StaticResource ModernTextBox}"
                                 FontFamily="Microsoft YaHei"
                                 Text="4096"
                                 Grid.Column="2"/>
                    </Grid>
                    <TextBlock Text="MB" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,16"/>

                    <!-- 额外参数 -->
                    <TextBlock Text="额外参数" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,12"/>
                    <TextBox x:Name="txtArgs" 
                             Style="{StaticResource ModernTextBox}"
                             Margin="0,0,0,16"
                             FontFamily="Microsoft YaHei"
                             ToolTip="例如: -Dfml.ignoreInvalidMinecraftCertificates=true"/>

                    <!-- 离线模式 -->
                    <CheckBox x:Name="chkOfflineMode" 
                              Content="离线模式"
                              Style="{StaticResource ModernCheckBox}"
                              IsChecked="True"
                              Margin="0,0,0,16"/>
                </StackPanel>
            </Border>

            <!-- 右侧日志面板 -->
            <Border Grid.Column="1" Background="{StaticResource SurfaceBrush}" CornerRadius="12" Margin="16,0,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="40"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="{StaticResource CardBackgroundBrush}" CornerRadius="12,12,0,0">
                        <StackPanel Orientation="Horizontal" Margin="16,0" VerticalAlignment="Center">
                            <TextBlock Text="启动日志" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}"/>
                            <TextBlock x:Name="txtStatus" Margin="16,0,0,0" FontSize="13" Foreground="{StaticResource GreenButtonBrush}"/>
                        </StackPanel>
                    </Border>

                    <ScrollViewer Grid.Row="1" Margin="16" 
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Auto"
                              CanContentScroll="True"
                              Background="#1a1a1a"
                              Padding="8">
                        <TextBox x:Name="txtLog" 
                                 IsReadOnly="True"
                                 Background="Transparent"
                                 Foreground="#e0e0e0"
                                 FontFamily="Consolas"
                                 FontSize="12"
                                 TextWrapping="Wrap"
                                 AcceptsReturn="True"
                                 VerticalAlignment="Stretch"
                                 HorizontalAlignment="Stretch"
                                 Padding="4"/>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>

        <!-- 底部按钮栏 -->
        <Border Grid.Row="2" Background="{StaticResource CardBackgroundBrush}" Margin="20,0">
            <StackPanel Orientation="Horizontal" Margin="20,0" VerticalAlignment="Center" HorizontalAlignment="Right">
                <Button x:Name="btnRefreshVersions" 
                        Content="🔄 刷新版本"
                        Style="{StaticResource SecondaryButton}"
                        Width="100"
                        Margin="0,0,12,0"
                        Click="btnRefreshVersions_Click"/>
                <Button x:Name="btnLaunch" 
                        Content="🎮 启动游戏"
                        Style="{StaticResource GreenButton}"
                        Width="150"
                        Height="45"
                        FontSize="16"
                        Click="btnLaunch_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</Page>
