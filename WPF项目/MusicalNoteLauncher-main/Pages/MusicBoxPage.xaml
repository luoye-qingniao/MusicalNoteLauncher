<UserControl
    x:Class="MusicalNoteLauncher.Pages.MusicBoxPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:pages="clr-namespace:MusicalNoteLauncher.Pages"
    Background="{DynamicResource BackgroundBrush}">

    <UserControl.Resources>
        <!-- 缓存状态转换器 -->
        <core:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" xmlns:core="clr-namespace:MusicalNoteLauncher.Core"/>

        <!-- ⚡ Styles 必须在 DataTemplate 之前定义（StaticResource 需要前向声明） -->

        <Style x:Key="TrackCardStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource CardBackgroundBrush}"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource CardHoverBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- 小按钮 -->
        <Style x:Key="IconBtn" TargetType="Button">
            <Setter Property="Width" Value="32"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6"
                                Padding="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{DynamicResource SurfaceBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 歌曲卡片 DataTemplate -->
        <DataTemplate DataType="{x:Type models:MusicTrack}" xmlns:models="clr-namespace:MusicalNoteLauncher.Models">
            <Border Style="{StaticResource TrackCardStyle}" MouseLeftButtonDown="TrackCard_Click" Tag="{Binding}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Width="44" Height="44" CornerRadius="8"
                            Background="{DynamicResource SurfaceBrush}" ClipToBounds="True">
                        <Image Source="{Binding AlbumCoverUrl}" Stretch="UniformToFill"
                               Width="44" Height="44"
                               RenderOptions.BitmapScalingMode="HighQuality"/>
                    </Border>
                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="12,0,8,0">
                        <TextBlock Text="{Binding Name}" FontSize="14" FontFamily="Microsoft YaHei"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   TextTrimming="CharacterEllipsis"/>
                        <TextBlock Text="{Binding Subtitle}" FontSize="12" FontFamily="Microsoft YaHei"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   TextTrimming="CharacterEllipsis" Margin="0,2,0,0"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Right">
                        <TextBlock Text="{Binding DurationText}" FontSize="12"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   HorizontalAlignment="Right"/>
                        <TextBlock Text="📥" FontSize="11"
                                   Visibility="{Binding IsCached, Converter={StaticResource BoolToVisibilityConverter}}"
                                   HorizontalAlignment="Right" Margin="0,2,0,0"/>
                    </StackPanel>
                </Grid>
            </Border>
        </DataTemplate>

        <!-- 歌单卡片 DataTemplate -->
        <DataTemplate DataType="{x:Type models:PlaylistInfo}" xmlns:models="clr-namespace:MusicalNoteLauncher.Models">
            <Border Style="{StaticResource TrackCardStyle}" MouseLeftButtonDown="TrackCard_Click" Tag="{Binding}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Width="44" Height="44" CornerRadius="8"
                            Background="{DynamicResource SurfaceBrush}" ClipToBounds="True">
                        <Image Source="{Binding CoverUrl}" Stretch="UniformToFill"
                               Width="44" Height="44"
                               RenderOptions.BitmapScalingMode="HighQuality"/>
                    </Border>
                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="12,0,8,0">
                        <TextBlock Text="{Binding Name}" FontSize="14" FontFamily="Microsoft YaHei"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   TextTrimming="CharacterEllipsis"/>
                        <TextBlock Text="{Binding Description}" FontSize="12" FontFamily="Microsoft YaHei"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   TextTrimming="CharacterEllipsis" Margin="0,2,0,0"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Right">
                        <TextBlock Text="📋" FontSize="16" HorizontalAlignment="Right"/>
                        <TextBlock FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"
                                   HorizontalAlignment="Right" Margin="0,2,0,0">
                            <TextBlock.Text>
                                <MultiBinding StringFormat="{}{0}首">
                                    <Binding Path="TrackCount"/>
                                </MultiBinding>
                            </TextBlock.Text>
                        </TextBlock>
                    </StackPanel>
                </Grid>
            </Border>
        </DataTemplate>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ── 顶部搜索栏 + 登录状态 ── -->
        <Border Grid.Row="0" Background="{DynamicResource CardHoverBrush}" Padding="16,12" Margin="0,0,0,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- 搜索框 -->
                <Border Grid.Column="0" Background="{DynamicResource SurfaceBrush}" CornerRadius="20" Padding="4">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="🔍" FontSize="14" VerticalAlignment="Center" Margin="12,0,4,0"/>
                        <TextBox x:Name="txtSearch" Grid.Column="1" 
                                 Background="Transparent" Foreground="{DynamicResource TextPrimaryBrush}"
                                 BorderThickness="0" FontSize="14" FontFamily="Microsoft YaHei"
                                 VerticalAlignment="Center" Padding="4,6"
                                 KeyDown="TxtSearch_KeyDown"
                                 Tag="搜索歌曲、歌手...">
                            <TextBox.Style>
                                <Style TargetType="TextBox">
                                    <Style.Triggers>
                                        <Trigger Property="Text" Value="">
                                            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBox.Style>
                        </TextBox>
                        <TextBlock Grid.Column="1" Text="  搜索歌曲、歌手..." FontSize="14" 
                                   Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"
                                   IsHitTestVisible="False" Margin="4,0,0,0"
                                   Visibility="Collapsed"
                                   x:Name="lblPlaceholder"/>
                        <Button Grid.Column="2" Content="搜索" Click="BtnSearch_Click"
                                Background="{DynamicResource PrimaryBrush}" Foreground="White"
                                BorderThickness="0" Padding="16,6" FontSize="13" Cursor="Hand"
                                Margin="4,0,0,0" FontFamily="Microsoft YaHei">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Name="bd" Background="{TemplateBinding Background}" CornerRadius="16"
                                            Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="bd" Property="Background" Value="{DynamicResource PrimaryDarkBrush}"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </Grid>
                </Border>

                <!-- 登录状态 -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="12,0,0,0" VerticalAlignment="Center">
                    <!-- 未登录 -->
                    <Button x:Name="btnLogin" Click="BtnLogin_Click"
                            Background="Transparent" Foreground="{DynamicResource TextSecondaryBrush}"
                            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                            Padding="14,8" FontSize="13" Cursor="Hand" FontFamily="Microsoft YaHei"
                            Visibility="Visible">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Name="bd" Background="{TemplateBinding Background}"
                                        BorderBrush="{TemplateBinding BorderBrush}"
                                        BorderThickness="{TemplateBinding BorderThickness}"
                                        CornerRadius="16" Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="bd" Property="Background" Value="{DynamicResource CardHoverBrush}"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                        <Button.Content>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="🎵" FontSize="14" VerticalAlignment="Center"/>
                                <TextBlock Text=" 登录网易云" FontSize="13" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button.Content>
                    </Button>

                    <!-- 已登录 -->
                    <Border x:Name="panelLoggedIn" Background="{DynamicResource SurfaceBrush}" CornerRadius="16" 
                            Padding="10,6" Visibility="Collapsed" Cursor="Hand" MouseLeftButtonDown="PanelLoggedIn_MouseLeftButtonDown">
                        <StackPanel Orientation="Horizontal">
                            <Border Width="28" Height="28" CornerRadius="14" ClipToBounds="True" Margin="0,0,8,0">
                                <Image x:Name="imgAvatar" Stretch="UniformToFill" Width="28" Height="28"/>
                            </Border>
                            <TextBlock x:Name="txtNickname" Text="" FontSize="13" Foreground="{DynamicResource TextPrimaryBrush}"
                                       FontFamily="Microsoft YaHei" VerticalAlignment="Center"/>
                            <TextBlock Text=" ▼" FontSize="10" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center" Margin="4,0,0,0"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ── 主内容区 ── -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="3*"/>
                <ColumnDefinition Width="2*"/>
            </Grid.ColumnDefinitions>

            <!-- 左侧: 搜索结果 -->
            <Border Grid.Column="0" Background="{DynamicResource CardHoverBrush}" CornerRadius="12" 
                    Padding="16" Margin="0,0,8,0">
                <Grid>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12">
                            <TextBlock x:Name="lblSearchResultTitle" Text="💿 推荐歌单" FontSize="15" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimaryBrush}" FontFamily="Microsoft YaHei"/>
                            <TextBlock x:Name="lblResultCount" Text="" FontSize="12" 
                                       Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center" Margin="8,0,0,0"/>
                        </StackPanel>

                        <!-- 搜索结果列表 / 推荐歌单列表 -->
                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                            <ItemsControl x:Name="listMain"/>
                        </ScrollViewer>
                    </Grid>

                    <!-- 浮动提示弹窗（覆盖在列表之上） -->
                    <Border x:Name="popupHint" Visibility="Collapsed"
                            HorizontalAlignment="Center" VerticalAlignment="Center"
                            Background="{DynamicResource CardHoverBrush}"
                            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                            CornerRadius="16" Padding="40,32" MaxWidth="340"
                            Panel.ZIndex="10">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="24" ShadowDepth="4" Opacity="0.25"/>
                        </Border.Effect>
                        <StackPanel>
                            <TextBlock x:Name="popupIcon" Text="🎵" FontSize="40"
                                       HorizontalAlignment="Center" Margin="0,0,0,12"/>
                            <TextBlock x:Name="popupText" Text="" FontSize="15" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimaryBrush}" HorizontalAlignment="Center"
                                       FontFamily="Microsoft YaHei" TextWrapping="Wrap" TextAlignment="Center"/>
                            <TextBlock x:Name="popupSub" Text="" FontSize="12"
                                       Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Center"
                                       FontFamily="Microsoft YaHei" TextWrapping="Wrap" TextAlignment="Center"
                                       Margin="0,8,0,0"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <!-- 右侧: 当前播放列表 + 推荐 -->
            <Border Grid.Column="1" Background="{DynamicResource CardHoverBrush}" CornerRadius="12"
                    Padding="16" Margin="8,0,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12">
                        <TextBlock Text="📋 播放队列" FontSize="15" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimaryBrush}" FontFamily="Microsoft YaHei"/>
                        <TextBlock x:Name="lblPlaylistCount" Text="" FontSize="12" 
                                   Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center" Margin="8,0,0,0"/>
                        <Button x:Name="btnClearPlaylist" Content="清空" Click="BtnClearPlaylist_Click"
                                Background="Transparent" Foreground="{DynamicResource TextSecondaryBrush}"
                                BorderThickness="0" Padding="8,4" FontSize="12" Cursor="Hand"
                                HorizontalAlignment="Right" Margin="8,0,0,0">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Foreground" Value="#E74C3C"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </StackPanel>

                    <!-- 播放列表 -->
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                        <ItemsControl x:Name="listPlaylist">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="{DynamicResource SurfaceBrush}" CornerRadius="6"
                                            Padding="10,7" Margin="0,0,0,3" Cursor="Hand"
                                            MouseLeftButtonDown="PlaylistTrack_Click" Tag="{Binding}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="🎵" FontSize="12" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Name}" FontSize="12" FontFamily="Microsoft YaHei"
                                                           Foreground="{DynamicResource TextPrimaryBrush}"
                                                           TextTrimming="CharacterEllipsis"/>
                                                <TextBlock Text="{Binding Artist}" FontSize="11" FontFamily="Microsoft YaHei"
                                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                                           TextTrimming="CharacterEllipsis"/>
                                            </StackPanel>
                                            <TextBlock Grid.Column="2" Text="{Binding DurationText}" FontSize="11"
                                                       Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"
                                                       Margin="8,0,0,0"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>

        <!-- ── 底部迷你播放器 ── -->
        <Border Grid.Row="2" Background="{DynamicResource CardHoverBrush}" CornerRadius="12"
                Padding="16,10" Margin="0,10,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- 左侧: 当前播放信息 -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" MinWidth="200">
                    <Border Width="48" Height="48" CornerRadius="6" Background="{DynamicResource SurfaceBrush}" ClipToBounds="True">
                        <Image x:Name="imgCurrentCover" Stretch="UniformToFill" Width="48" Height="48"
                               RenderOptions.BitmapScalingMode="LowQuality"/>
                    </Border>
                    <StackPanel VerticalAlignment="Center" Margin="12,0,0,0">
                        <TextBlock x:Name="txtCurrentTrack" Text="未在播放" FontSize="14" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimaryBrush}" FontFamily="Microsoft YaHei"
                                   TextTrimming="CharacterEllipsis" MaxWidth="160"/>
                        <TextBlock x:Name="txtCurrentArtist" Text="" FontSize="12"
                                   Foreground="{DynamicResource TextSecondaryBrush}" FontFamily="Microsoft YaHei"
                                   TextTrimming="CharacterEllipsis" MaxWidth="160"/>
                    </StackPanel>
                </StackPanel>

                <!-- 中间: 播放控制 -->
                <StackPanel Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <!-- 控制按钮行 -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <Button Content="&#9198;" Click="BtnPrev_Click" Style="{StaticResource IconBtn}" FontSize="14" ToolTip="上一首"/>
                        <Button x:Name="btnPlayPause" Content="▶" Click="BtnPlayPause_Click" 
                                FontSize="18" Style="{StaticResource IconBtn}" ToolTip="播放/暂停"
                                Foreground="{DynamicResource TextPrimaryBrush}" Margin="8,0"/>
                        <Button Content="&#9197;" Click="BtnNext_Click" Style="{StaticResource IconBtn}" FontSize="14" ToolTip="下一首"/>
                        <Button x:Name="btnPlayMode" Content="➡" Click="BtnPlayMode_Click"
                                Style="{StaticResource IconBtn}" FontSize="12" ToolTip="播放模式" Margin="4,0,0,0"/>
                    </StackPanel>

                    <!-- 进度条 -->
                    <Grid Margin="0,4,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="36"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="36"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="txtPosition" Grid.Column="0" Text="0:00" FontSize="11"
                                   Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Right"
                                   VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <Slider x:Name="sliderProgress" Grid.Column="1" Minimum="0" Maximum="100" Value="0"
                                IsMoveToPointEnabled="True" Cursor="Hand" VerticalAlignment="Center"
                                ValueChanged="SliderProgress_ValueChanged"
                                PreviewMouseLeftButtonDown="SliderProgress_MouseLeftButtonDown"
                                PreviewMouseLeftButtonUp="SliderProgress_MouseLeftButtonUp">
                            <Slider.Style>
                                <Style TargetType="Slider">
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Slider">
                                                <Grid Height="18">
                                                    <Track Name="PART_Track">
                                                        <Track.DecreaseRepeatButton>
                                                            <RepeatButton>
                                                                <RepeatButton.Template>
                                                                    <ControlTemplate>
                                                                        <Rectangle Fill="{DynamicResource PrimaryBrush}" Height="4" RadiusX="2" RadiusY="2"/>
                                                                    </ControlTemplate>
                                                                </RepeatButton.Template>
                                                            </RepeatButton>
                                                        </Track.DecreaseRepeatButton>
                                                        <Track.IncreaseRepeatButton>
                                                            <RepeatButton>
                                                                <RepeatButton.Template>
                                                                    <ControlTemplate>
                                                                        <Rectangle Fill="{DynamicResource SurfaceBrush}" Height="4" RadiusX="2" RadiusY="2"/>
                                                                    </ControlTemplate>
                                                                </RepeatButton.Template>
                                                            </RepeatButton>
                                                        </Track.IncreaseRepeatButton>
                                                        <Track.Thumb>
                                                            <Thumb Width="12" Height="12" Cursor="Hand">
                                                                <Thumb.Template>
                                                                    <ControlTemplate>
                                                                        <Ellipse Fill="{DynamicResource PrimaryBrush}" Width="12" Height="12"/>
                                                                    </ControlTemplate>
                                                                </Thumb.Template>
                                                            </Thumb>
                                                        </Track.Thumb>
                                                    </Track>
                                                </Grid>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Slider.Style>
                        </Slider>
                        <TextBlock x:Name="txtDuration" Grid.Column="2" Text="0:00" FontSize="11"
                                   Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Left"
                                   VerticalAlignment="Center" Margin="6,0,0,0"/>
                    </Grid>
                </StackPanel>

                <!-- 右侧: 音量控制 + 缓存操作 -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <!-- 缓存按钮 -->
                    <Button x:Name="btnCacheCurrent" Content="📥" Click="BtnCacheCurrent_Click"
                            Style="{StaticResource IconBtn}" FontSize="14" ToolTip="缓存当前歌曲"/>
                    <!-- 音量 -->
                    <TextBlock Text="🔊" FontSize="12" VerticalAlignment="Center" Margin="8,0,4,0"
                               Foreground="{DynamicResource TextSecondaryBrush}"/>
                    <Slider x:Name="sliderVolume" Minimum="0" Maximum="100" Value="70" Width="80"
                            Cursor="Hand" VerticalAlignment="Center" ValueChanged="SliderVolume_ValueChanged">
                        <Slider.Style>
                            <Style TargetType="Slider">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Slider">
                                            <Grid Height="18">
                                                <Track Name="PART_Track">
                                                    <Track.DecreaseRepeatButton>
                                                        <RepeatButton>
                                                            <RepeatButton.Template>
                                                                <ControlTemplate>
                                                                    <Rectangle Fill="{DynamicResource TextSecondaryBrush}" Height="3" RadiusX="1.5" RadiusY="1.5"/>
                                                                </ControlTemplate>
                                                            </RepeatButton.Template>
                                                        </RepeatButton>
                                                    </Track.DecreaseRepeatButton>
                                                    <Track.IncreaseRepeatButton>
                                                        <RepeatButton>
                                                            <RepeatButton.Template>
                                                                <ControlTemplate>
                                                                    <Rectangle Fill="{DynamicResource SurfaceBrush}" Height="3" RadiusX="1.5" RadiusY="1.5"/>
                                                                </ControlTemplate>
                                                            </RepeatButton.Template>
                                                        </RepeatButton>
                                                    </Track.IncreaseRepeatButton>
                                                    <Track.Thumb>
                                                        <Thumb Width="10" Height="10" Cursor="Hand">
                                                            <Thumb.Template>
                                                                <ControlTemplate>
                                                                    <Ellipse Fill="{DynamicResource TextSecondaryBrush}" Width="10" Height="10"/>
                                                                </ControlTemplate>
                                                            </Thumb.Template>
                                                        </Thumb>
                                                    </Track.Thumb>
                                                </Track>
                                            </Grid>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Slider.Style>
                    </Slider>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ── 隐藏的 MediaElement 用于音频播放 ── -->
        <MediaElement x:Name="mediaPlayer" Visibility="Collapsed"
                      LoadedBehavior="Manual" UnloadedBehavior="Stop"
                      MediaOpened="MediaPlayer_MediaOpened"
                      MediaEnded="MediaPlayer_MediaEnded"
                      MediaFailed="MediaPlayer_MediaFailed"/>
    </Grid>
</UserControl>
