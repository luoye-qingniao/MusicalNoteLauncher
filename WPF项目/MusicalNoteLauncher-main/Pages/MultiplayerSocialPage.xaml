										Margin="0,0,12,0" />
									<TextBlock
										Text="UUID设置"
										FontSize="17"
										FontWeight="Bold"
										Foreground="{DynamicResource TextPrimaryBrush}"
										FontFamily="Microsoft YaHei" />
								</StackPanel>
								<StackPanel
									Orientation="Horizontal">
									<CheckBox
										Name="cbFixUUID"
										Content="启用UUID修复"
										Foreground="{DynamicResource TextPrimaryBrush}"
										FontSize="14"
										Margin="0,0,24,0" />
									<TextBlock
										Text="为离线玩家生成固定UUID"
										Foreground="{DynamicResource TextSecondaryBrush}"
										FontSize="14" />
								</StackPanel>
							</StackPanel>
						</Border>
						<Border
							Style="{StaticResource ModernCard}"
							Padding="24"
							Margin="0,0,0,20">
							<StackPanel>
								<StackPanel
									Orientation="Horizontal"
									Margin="0,0,0,18">
									<TextBlock
										Text="👤"
										FontSize="22"
										Margin="0,0,12,0" />
									<TextBlock
										Text="用户名设置"
										FontSize="17"
										FontWeight="Bold"
										Foreground="{DynamicResource TextPrimaryBrush}"
										FontFamily="Microsoft YaHei" />
								</StackPanel>
								<StackPanel
									Orientation="Horizontal">
									<TextBox
										Name="txtUsername"
										Style="{StaticResource StandardTextBox}"
										Width="220" />
									<Border
										Width="24" />
									<Button
										Name="btnValidateUsername"
										Content="验证用户名"
										Background="#FF9800"
										Foreground="{DynamicResource TextPrimaryBrush}"
										Padding="18,11"
										Click="BtnValidateUsername_Click">
										<Control.Template>
											<ControlTemplate
												TargetType="{x:Type Button}">
												<Border
													Name="border"
													Background="#FF9800"
													CornerRadius="8"
													Padding="18,11">
													<ContentPresenter
														HorizontalAlignment="Center"
														VerticalAlignment="Center" />
												</Border>
												<ControlTemplate.Triggers>
													<Trigger
														Property="UIElement.IsMouseOver"
														Value="True">
														<Setter
															TargetName="border"
															Property="Background"
															Value="#F57C00" />
													</Trigger>
												</ControlTemplate.Triggers>
											</ControlTemplate>
										</Control.Template>
									</Button>
								</StackPanel>
								<TextBlock
									Foreground="{DynamicResource TextSecondaryBrush}"
									FontSize="13"
									Margin="0,12,0,0"
									TextWrapping="Wrap">💡 用户名规则：3-16个字符，只能包含字母、数字和下划线</TextBlock>
							</StackPanel>
						</Border>
						<Border
							Style="{StaticResource ModernCard}"
							Padding="24">
							<StackPanel>
								<StackPanel
									Orientation="Horizontal"
									Margin="0,0,0,18">
									<TextBlock
										Text="📋"
										FontSize="22"
										Margin="0,0,12,0" />
									<TextBlock
										Text="版本统一检查"
										FontSize="17"
										FontWeight="Bold"
										Foreground="{DynamicResource TextPrimaryBrush}"
										FontFamily="Microsoft YaHei" />
								</StackPanel>
								<Button
									Name="btnCheckVersion"
									Content="检查版本一致性"
									Background="#9C27B0"
									Foreground="{DynamicResource TextPrimaryBrush}"
									Padding="20,11"
									Click="BtnCheckVersion_Click">
									<Control.Template>
										<ControlTemplate
											TargetType="{x:Type Button}">
											<Border
												Name="border"
												Background="#9C27B0"
												CornerRadius="8"
												Padding="20,11">
												<ContentPresenter
													HorizontalAlignment="Center"
													VerticalAlignment="Center" />
											</Border>
											<ControlTemplate.Triggers>
												<Trigger
													Property="UIElement.IsMouseOver"
													Value="True">
													<Setter
														TargetName="border"
														Property="Background"
														Value="#7B1FA2" />
												</Trigger>
											</ControlTemplate.Triggers>
										</ControlTemplate>
									</Control.Template>
								</Button>
								<TextBlock
									Foreground="{DynamicResource TextSecondaryBrush}"
									FontSize="13"
									Margin="0,12,0,0"
									TextWrapping="Wrap">确保所有玩家使用相同版本的游戏和Mod</TextBlock>
							</StackPanel>
						</Border>
					</StackPanel>
				</Grid>
			</Grid>
		</ScrollViewer>
	</Grid>
</UserControl>


