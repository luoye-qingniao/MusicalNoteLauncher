<UserControl
	x:Class="MusicalNoteLauncher.Pages.MultiplayerSocialPage" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	Background="{DynamicResource BackgroundBrush}" xmlns:pages="clr-namespace:MusicalNoteLauncher.Pages">
	<Grid
		Background="{DynamicResource BackgroundBrush}">
		<Grid.RowDefinitions>
			<RowDefinition
				Height="70" />
			<RowDefinition
				Height="*" />
		</Grid.RowDefinitions>
		<Border
			Grid.Row="0"
			Background="{StaticResource HeaderGradientBrush}"
			CornerRadius="0,0,12,12">
			<StackPanel
				Margin="24,0"
				VerticalAlignment="Center">
				<TextBlock
					Text="🎮 联机社交"
					FontSize="22"
					FontWeight="Bold"
					Foreground="{DynamicResource TextPrimaryBrush}"
					FontFamily="Segoe UI Emoji, Segoe UI Symbol, Microsoft YaHei" />
				<TextBlock
					Text="选择联机方式，开启多人游戏之旅"
					FontSize="12"
					Foreground="{DynamicResource TextSecondaryBrush}"
					FontFamily="Microsoft YaHei" />
			</StackPanel>
		</Border>
		<ScrollViewer
			Grid.Row="1"
			Margin="20"
			VerticalScrollBarVisibility="Auto"
			HorizontalScrollBarVisibility="Disabled">
			<Grid>
				<Grid
					Name="MainPage"
					Visibility="Visible">
					<Grid.RowDefinitions>
						<RowDefinition
							Height="Auto" />
						<RowDefinition
							Height="Auto" />
						<RowDefinition
							Height="Auto" />
						<RowDefinition
							Height="Auto" />
					</Grid.RowDefinitions>
					<Border
						Grid.Row="0"
						Style="{StaticResource ModernCard}"
						Padding="20"
						Margin="0,0,0,20">
						<StackPanel>
							<StackPanel
								Orientation="Horizontal"
								Margin="0,0,0,10">
								<Ellipse
									Width="8"
									Height="8"
									Fill="{StaticResource GreenButtonBrush}"
									Margin="0,4,10,0" />
								<TextBlock
									Text="联机方式选择"
									FontSize="16"
									FontWeight="Bold"
									Foreground="{DynamicResource TextPrimaryBrush}"
									FontFamily="Microsoft YaHei" />
							</StackPanel>
							<TextBlock
								Text="选择您想要使用的联机方式，支持多种离线联机方案"
								FontSize="13"
								Foreground="{DynamicResource TextSecondaryBrush}"
								FontFamily="Microsoft YaHei"
								TextWrapping="Wrap" />
						</StackPanel>
					</Border>
					<Border
						Grid.Row="1"
						Background="{StaticResource CardGradientBrush}"
						CornerRadius="16"
						Padding="24"
						Margin="0,0,0,20"
						Effect="{StaticResource CardShadow}">
						<Grid>
							<Grid.RowDefinitions>
								<RowDefinition
									Height="160" />
								<RowDefinition
									Height="160" />
								<RowDefinition
									Height="160" />
								<RowDefinition
									Height="160" />
							</Grid.RowDefinitions>
							<Grid.ColumnDefinitions>
								<ColumnDefinition
									Width="*" />
								<ColumnDefinition
									Width="*" />
							</Grid.ColumnDefinitions>
							<Border
								Grid.Row="0"
								Grid.Column="0"
								Style="{StaticResource FeatureCard}"
								Margin="0,0,15,15"
								MouseLeftButtonDown="Card_LAN_Click">
								<StackPanel
									VerticalAlignment="Center"
									HorizontalAlignment="Center"
									Margin="10">
									<TextBlock
										Text="🌐"
										FontSize="32"
										HorizontalAlignment="Center"
										Margin="0,0,0,10" />
									<TextBlock
										Text="局域网联机"
										FontSize="15"
										FontWeight="Bold"
										Foreground="{DynamicResource TextPrimaryBrush}"
										FontFamily="Microsoft YaHei"
										TextAlignment="Center" />
									<TextBlock
										Text="同一网络下快速联机"
										FontSize="12"
										Foreground="{DynamicResource TextSecondaryBrush}"
										FontFamily="Microsoft YaHei"
										Margin="0,3,0,0"
										TextAlignment="Center" />
								</StackPanel>
							</Border>
							<Border
								Grid.Row="0"
								Grid.Column="1"
								Style="{StaticResource FeatureCard}"
								Margin="15,0,0,15"
								MouseLeftButtonDown="Card_VirtualLAN_Click">
								<StackPanel
									VerticalAlignment="Center"
									HorizontalAlignment="Center"
									Margin="10">
									<TextBlock
										Text="🔗"
										FontSize="32"
										HorizontalAlignment="Center"
										Margin="0,0,0,10" />
									<TextBlock
										Text="虚拟局域网"
										FontSize="15"
										FontWeight="Bold"
										Foreground="{DynamicResource TextPrimaryBrush}"
										FontFamily="Microsoft YaHei"
										TextAlignment="Center" />
									<TextBlock
										Text="跨网络虚拟联机"
										FontSize="12"
										Foreground="{DynamicResource TextSecondaryBrush}"
										FontFamily="Microsoft YaHei"
										Margin="0,3,0,0"
										TextAlignment="Center" />
								</StackPanel>
							</Border>
							<Border
								Grid.Row="1"
								Grid.Column="0"
								Style="{StaticResource FeatureCard}"
								Margin="0,0,15,15"
								MouseLeftButtonDown="Card_NAT_Click">
								<StackPanel
									VerticalAlignment="Center"
									HorizontalAlignment="Center"
									Margin="10">
									<TextBlock
										Text="🔓"
										FontSize="32"
										HorizontalAlignment="Center"
										Margin="0,0,0,10" />
									<TextBlock
										Text="内网穿透"
										FontSize="15"
										FontWeight="Bold"
										Foreground="{DynamicResource TextPrimaryBrush}"
										FontFamily="Microsoft YaHei"
										TextAlignment="Center" />
									<TextBlock
										Text="外网访问内网服务"
										FontSize="12"
										Foreground="{DynamicResource TextSecondaryBrush}"
										FontFamily="Microsoft YaHei"
										Margin="0,3,0,0"
										TextAlignment="Center" />
								</StackPanel>
							</Border>
							<Border
								Grid.Row="1"
								Grid.Column="1"
								Style="{StaticResource FeatureCard}"
								Margin="15,0,0,15"
								MouseLeftButtonDown="Card_Server_Click">
								<StackPanel
									VerticalAlignment="Center"
									HorizontalAlignment="Center"
									Margin="10">
									<TextBlock
										Text="🖥️"
										FontSize="32"
										HorizontalAlignment="Center"
										Margin="0,0,0,10" />
									<TextBlock
										Text="自建服务器"
										FontSize="15"
										FontWeight="Bold"
										Foreground="{DynamicResource TextPrimaryBrush}"
										FontFamily="Microsoft YaHei"
										TextAlignment="Center" />
									<TextBlock
										Text="完全自定义游戏环境"
										FontSize="12"
										Foreground="{DynamicResource TextSecondaryBrush}"
										FontFamily="Microsoft YaHei"
										Margin="0,3,0,0"
										TextAlignment="Center" />
								</StackPanel>
							</Border>
							<Border
								Grid.Row="2"
								Grid.Column="0"
								Style="{StaticResource FeatureCard}"
								Margin="0,0,15,15"
								MouseLeftButtonDown="Card_TaoWa_Click">
								<StackPanel
									VerticalAlignment="Center"
									HorizontalAlignment="Center"
									Margin="10">
									<TextBlock
										Text="🏺"
										FontSize="32"
										HorizontalAlignment="Center"
										Margin="0,0,0,10" />
									<TextBlock
										Text="陶瓦联机"
										FontSize="15"
										FontWeight="Bold"
										Foreground="{DynamicResource TextPrimaryBrush}"
										FontFamily="Microsoft YaHei"
										TextAlignment="Center" />
									<TextBlock
										Text="EasyTier 一键联机"
										FontSize="12"
										Foreground="{DynamicResource TextSecondaryBrush}"
										FontFamily="Microsoft YaHei"
										Margin="0,3,0,0"
										TextAlignment="Center" />
								</StackPanel>
							</Border>
							<Border
								Grid.Row="2"
								Grid.Column="1"
								Style="{StaticResource FeatureCard}"
								Margin="15,0,0,15"
								MouseLeftButtonDown="Card_Mod_Click">
								<StackPanel
									VerticalAlignment="Center"
									HorizontalAlignment="Center"
									Margin="10">
									<TextBlock
										Text="📦"
										FontSize="32"
										HorizontalAlignment="Center"
										Margin="0,0,0,10" />
									<TextBlock
										Text="Mod管理"
										FontSize="15"
										FontWeight="Bold"
										Foreground="{DynamicResource TextPrimaryBrush}"
										FontFamily="Microsoft YaHei"
										TextAlignment="Center" />
									<TextBlock
										Text="管理游戏模组插件"
										FontSize="12"
										Foreground="{DynamicResource TextSecondaryBrush}"
										FontFamily="Microsoft YaHei"
										Margin="0,3,0,0"
										TextAlignment="Center" />
								</StackPanel>
							</Border>
							<Border
								Grid.Row="3"
								Grid.Column="0"
								Style="{StaticResource FeatureCard}"
								Margin="0,0,15,0"
								MouseLeftButtonDown="Card_MCTier_Click">
								<StackPanel
									VerticalAlignment="Center"
									HorizontalAlignment="Center"
									Margin="10">
									<TextBlock
										Text="🌍"
										FontSize="32"
										HorizontalAlignment="Center"
										Margin="0,0,0,10" />
									<TextBlock
										Text="MCTier 联机"
										FontSize="15"
										FontWeight="Bold"
										Foreground="{DynamicResource TextPrimaryBrush}"
										FontFamily="Microsoft YaHei"
										TextAlignment="Center" />
									<TextBlock
										Text="点对点虚拟组网 · 全端口开放"
										FontSize="12"
										Foreground="{DynamicResource TextSecondaryBrush}"
										FontFamily="Microsoft YaHei"
										Margin="0,3,0,0"
										TextAlignment="Center" />
								</StackPanel>
							</Border>
							<Border
								Grid.Row="3"
								Grid.Column="1"
								Style="{StaticResource FeatureCard}"
								Margin="15,0,0,0"
								MouseLeftButtonDown="Card_Settings_Click">
								<StackPanel
									VerticalAlignment="Center"
									HorizontalAlignment="Center"
									Margin="10">
									<TextBlock
										Text="⚙️"
										FontSize="32"
										HorizontalAlignment="Center"
										Margin="0,0,0,10" />
									<TextBlock
										Text="离线设置"
										FontSize="15"
										FontWeight="Bold"
										Foreground="{DynamicResource TextPrimaryBrush}"
										FontFamily="Microsoft YaHei"
										TextAlignment="Center" />
									<TextBlock
										Text="配置离线账号"
										FontSize="12"
										Foreground="{DynamicResource TextSecondaryBrush}"
										FontFamily="Microsoft YaHei"
										Margin="0,3,0,0"
										TextAlignment="Center" />
								</StackPanel>
							</Border>
						</Grid>
					</Border>
				</Grid>
				<Grid
					Name="MCTierPage"
					Visibility="Collapsed">
					<Grid.RowDefinitions>
						<RowDefinition
							Height="Auto" />
						<RowDefinition
							Height="Auto" />
					</Grid.RowDefinitions>
					<StackPanel
						Grid.Row="0"
						Orientation="Horizontal"
						Margin="0,0,0,20">
						<Button
							Content="← 返回"
							Style="{StaticResource NavButton}"
							Foreground="{StaticResource PrimaryBrush}"
							FontSize="15"
							Click="BtnBack_Click" />
						<TextBlock
							Text="🌍 MCTier 联机"
							FontSize="22"
							FontWeight="Bold"
							Foreground="{DynamicResource TextPrimaryBrush}"
							Margin="20,0,0,0" />
					</StackPanel>
					<StackPanel
						Grid.Row="1">
						<Border
							Style="{StaticResource ModernCard}"
							Padding="24"
							Margin="0,0,0,20">
							<StackPanel>
								<TextBlock
									Foreground="{DynamicResource TextPrimaryBrush}"
									FontSize="14"
									Margin="0,0,0,18"
									TextWrapping="Wrap">MCTier 是一款专为 Minecraft 联机设计的点对点虚拟组网工具。它使用 TAP 虚拟网卡技术，自动完成 NAT 穿透，无需公网 IP 即可实现全端口开放、低延迟的联机体验。</TextBlock>
								<StackPanel
									Orientation="Horizontal">
									<Button
										Name="btnDownloadMCTier"
										Content="📥 一键下载并安装"
										Background="#00BCD4"
										Foreground="{DynamicResource TextPrimaryBrush}"
										Padding="20,11"
										FontSize="14"
										FontFamily="Microsoft YaHei"
										Cursor="Hand"
										Click="BtnDownloadMCTier_Click">
										<Control.Template>
											<ControlTemplate
												TargetType="{x:Type Button}">
												<Border
													Name="border"
													Background="{TemplateBinding Background}"
													CornerRadius="8"
													Padding="{TemplateBinding Padding}">
													<ContentPresenter
														HorizontalAlignment="Center"
														VerticalAlignment="Center" />
												</Border>
												<ControlTemplate.Triggers>
													<Trigger
														Property="UIElement.IsMouseOver"
														Value="True">
														<Setter
															TargetName="border"
															Property="Background"
															Value="#0097A7" />
													</Trigger>
												</ControlTemplate.Triggers>
											</ControlTemplate>
										</Control.Template>
									</Button>
									<Border
										Width="16" />
									<Button
										Name="btnOpenMCTierFolder"
										Content="打开安装目录"
										Style="{StaticResource SecondaryButton}"
										Padding="20,11"
										FontSize="14"
										FontFamily="Microsoft YaHei"
										Cursor="Hand"
										Click="BtnOpenMCTierFolder_Click" />
									<Border
										Width="12" />
									<Button
										Name="btnLaunchMCTier"
										Content="▶ 启动程序"
										Background="#4CAF50"
										Foreground="{DynamicResource TextPrimaryBrush}"
										Padding="20,11"
										FontSize="14"
										FontFamily="Microsoft YaHei"
										Cursor="Hand"
										Click="BtnLaunchMCTier_Click">
										<Control.Template>
											<ControlTemplate
												TargetType="{x:Type Button}">
												<Border
													Name="border"
													Background="{TemplateBinding Background}"
													CornerRadius="8"
													Padding="{TemplateBinding Padding}">
													<ContentPresenter
														HorizontalAlignment="Center"
														VerticalAlignment="Center" />
												</Border>
												<ControlTemplate.Triggers>
													<Trigger
														Property="UIElement.IsMouseOver"
														Value="True">
														<Setter
															TargetName="border"
															Property="Background"
															Value="#388E3C" />
													</Trigger>
												</ControlTemplate.Triggers>
											</ControlTemplate>
										</Control.Template>
									</Button>
								</StackPanel>
								<ProgressBar
									Name="pbMCTierDownload"
									Height="8"
									Margin="0,14,0,0"
									Visibility="Collapsed"
									Foreground="#00BCD4"
									Minimum="0"
									Maximum="100" />
								<TextBlock
									Name="txtMCTierDownloadStatus"
									FontSize="12"
									Foreground="{DynamicResource TextSecondaryBrush}"
									Margin="0,6,0,0"
									Visibility="Collapsed"
									TextWrapping="Wrap"
									FontFamily="Microsoft YaHei" />
							</StackPanel>
						</Border>
						<Border
							Style="{StaticResource ModernCard}"
							Padding="24"
							Margin="0,0,0,20"
							Name="MCTierNetworkPanel"
							Visibility="Collapsed">
							<StackPanel>
								<StackPanel
									Orientation="Horizontal"
									Margin="0,0,0,18">
									<TextBlock
										Text="🎮"
										FontSize="22"
										Margin="0,0,12,0" />
									<TextBlock
										Text="开始联机"
										FontSize="17"
										FontWeight="Bold"
										Foreground="{DynamicResource TextPrimaryBrush}"
										FontFamily="Microsoft YaHei" />
								</StackPanel>
								<Grid
									Name="MCTierMainPage">
									<Grid.ColumnDefinitions>
										<ColumnDefinition
											Width="*" />
										<ColumnDefinition
											Width="16" />
										<ColumnDefinition
											Width="*" />
									</Grid.ColumnDefinitions>
									<Border
										Grid.Column="0"
										Name="MCTierHostCard"
										Background="{DynamicResource SurfaceBrush}"
										CornerRadius="12"
										Padding="24"
										Cursor="Hand"
										MouseLeftButtonDown="MCTierHostCard_Click">
										<StackPanel>
											<TextBlock
												Text="🏠"
												FontSize="32"
												Margin="0,0,0,12" />
											<TextBlock
												Text="我想当房主"
												FontSize="16"
												FontWeight="Bold"
												Foreground="{DynamicResource TextPrimaryBrush}"
												FontFamily="Microsoft YaHei"
												Margin="0,0,0,6" />
											<TextBlock
												Text="创建联机房间，生成邀请码"
												FontSize="12"
												Foreground="{DynamicResource TextSecondaryBrush}"
												FontFamily="Microsoft YaHei"
												TextWrapping="Wrap" />
										</StackPanel>
									</Border>
									<Border
										Grid.Column="2"
										Name="MCTierClientCard"
										Background="{DynamicResource SurfaceBrush}"
										CornerRadius="12"
										Padding="24"
										Cursor="Hand"
										MouseLeftButtonDown="MCTierClientCard_Click">
										<StackPanel>
											<TextBlock
												Text="👥"
												FontSize="32"
												Margin="0,0,0,12" />
											<TextBlock
												Text="我想当房客"
												FontSize="16"
												FontWeight="Bold"
												Foreground="{DynamicResource TextPrimaryBrush}"
												FontFamily="Microsoft YaHei"
												Margin="0,0,0,6" />
											<TextBlock
												Text="输入邀请码，加入房间"
												FontSize="12"
												Foreground="{DynamicResource TextSecondaryBrush}"
												FontFamily="Microsoft YaHei"
												TextWrapping="Wrap" />
										</StackPanel>
									</Border>
								</Grid>
								<Grid
									Name="MCTierHostPage"
									Visibility="Collapsed">
									<Grid.RowDefinitions>
										<RowDefinition
											Height="Auto" />
										<RowDefinition
											Height="Auto" />
										<RowDefinition
											Height="Auto" />
										<RowDefinition
											Height="Auto" />
									</Grid.RowDefinitions>
									<StackPanel
										Grid.Row="0"
										Orientation="Horizontal"
										Margin="0,0,0,15">
										<Button
											Content="← 返回"
											Style="{StaticResource NavButton}"
											Foreground="{StaticResource PrimaryBrush}"
											FontSize="14"
											Click="MCTierBack_Click" />
									</StackPanel>
									<Border
										Grid.Row="1"
										Background="{DynamicResource SurfaceBrush}"
										CornerRadius="10"
										Padding="20"
										Margin="0,0,0,15">
										<StackPanel>
											<TextBlock
												Text="房间信息"
												FontSize="14"
												FontWeight="Bold"
												Foreground="#00BCD4"
												FontFamily="Microsoft YaHei"
												Margin="0,0,0,12" />
											<StackPanel
												Orientation="Horizontal"
												Margin="0,0,0,8">
												<TextBlock
													Text="网络名："
													FontSize="13"
													Foreground="{DynamicResource TextSecondaryBrush}"
													FontFamily="Microsoft YaHei" />
												<TextBlock
													Name="txtMCTierHostName"
													FontSize="14"
													FontWeight="Bold"
													Foreground="{DynamicResource TextPrimaryBrush}"
													FontFamily="Consolas" />
											</StackPanel>
											<StackPanel
												Orientation="Horizontal">
												<TextBlock
													Text="邀请码："
													FontSize="13"
													Foreground="{DynamicResource TextSecondaryBrush}"
													FontFamily="Microsoft YaHei" />
												<TextBlock
													Name="txtMCTierHostCode"
													FontSize="20"
													FontWeight="Bold"
													Foreground="#00BCD4"
													FontFamily="Consolas" />
											</StackPanel>
										</StackPanel>
									</Border>
									<Border
										Grid.Row="2"
										Background="{DynamicResource SurfaceBrush}"
										CornerRadius="10"
										Padding="20"
										Margin="0,0,0,15">
										<StackPanel>
											<TextBlock
												Text="房间状态"
												FontSize="14"
												FontWeight="Bold"
												Foreground="#00BCD4"
												FontFamily="Microsoft YaHei"
												Margin="0,0,0,12" />
											<StackPanel
												Orientation="Horizontal">
												<Border
													Name="MCTierHostStatusDot"
													Width="10"
													Height="10"
													CornerRadius="5"
													Background="#4CAF50"
													Margin="0,5,8,0" />
												<TextBlock
													Name="txtMCTierHostStatus"
													Text="已启动"
													FontSize="13"
													Foreground="{DynamicResource TextPrimaryBrush}"
													FontFamily="Microsoft YaHei" />
											</StackPanel>
										</StackPanel>
									</Border>
									<Button
										Grid.Row="3"
										Name="btnMCTierHostStop"
										Background="#F44336"
										Foreground="#FFFFFF"
										Content="停止联机"
										Padding="20,11"
										FontSize="14"
										FontFamily="Microsoft YaHei"
										Cursor="Hand"
										HorizontalAlignment="Left"
										Click="MCTierHostStop_Click">
										<Control.Template>
											<ControlTemplate
												TargetType="{x:Type Button}">
												<Border
													Name="border"
													Background="{TemplateBinding Background}"
													CornerRadius="8"
													Padding="{TemplateBinding Padding}">
													<ContentPresenter
														HorizontalAlignment="Center"
														VerticalAlignment="Center" />
												</Border>
												<ControlTemplate.Triggers>
													<Trigger
														Property="UIElement.IsMouseOver"
														Value="True">
														<Setter
															TargetName="border"
															Property="Background"
															Value="#D32F2F" />
													</Trigger>
												</ControlTemplate.Triggers>
											</ControlTemplate>
										</Control.Template>
									</Button>
								</Grid>
								<Grid
									Name="MCTierClientPage"
									Visibility="Collapsed">
									<Grid.RowDefinitions>
										<RowDefinition
											Height="Auto" />
										<RowDefinition
											Height="Auto" />
										<RowDefinition
											Height="Auto" />
										<RowDefinition
											Height="Auto" />
									</Grid.RowDefinitions>
									<StackPanel
										Grid.Row="0"
										Orientation="Horizontal"
										Margin="0,0,0,15">
										<Button
