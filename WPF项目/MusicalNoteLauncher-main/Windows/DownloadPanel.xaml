<Window x:Class="MusicalNoteLauncher.Windows.DownloadPanel"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:viewModels="clr-namespace:MusicalNoteLauncher.ViewModels"
        Title="下载任务" Height="400" Width="500"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        SnapsToDevicePixels="True" UseLayoutRounding="True">
    <Border Background="{StaticResource BackgroundBrush}" 
            CornerRadius="12" 
            Effect="{StaticResource CardShadow}"
            SnapsToDevicePixels="True"
            UseLayoutRounding="True">
        <Grid>
            <!-- 标题栏 -->
            <Grid Height="48" Background="{StaticResource CardBackgroundBrush}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="48"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="下载任务" 
                           FontSize="16" 
                           FontWeight="SemiBold" 
                           Foreground="{StaticResource TextPrimaryBrush}"
                           VerticalAlignment="Center" 
                           Margin="20,0,0,0"
                           SnapsToDevicePixels="True"
                           UseLayoutRounding="True"/>
                <Button Grid.Column="1" 
                        Style="{StaticResource NavButton}" 
                        Click="btnClose_Click"
                        SnapsToDevicePixels="True"
                        UseLayoutRounding="True">
                    <TextBlock Text="×" FontSize="24" Margin="-4,0,0,0"/>
                </Button>
            </Grid>

            <!-- 任务列表区域 -->
            <Grid Margin="0,48,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="60"/>
                </Grid.RowDefinitions>

                <!-- 任务列表 -->
                <ScrollViewer Grid.Row="0" Margin="16"
                              ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                              ScrollViewer.VerticalScrollBarVisibility="Auto">
                    <StackPanel x:Name="taskPanel" Orientation="Vertical">
                        <!-- 空状态 -->
                        <Border x:Name="emptyPanel"
                                Background="{StaticResource SurfaceBrush}"
                                CornerRadius="8"
                                Padding="24"
                                Visibility="Visible">
                            <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                                <TextBlock Text="暂无下载任务"
                                           FontSize="14"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           HorizontalAlignment="Center"/>
                                <TextBlock Text="点击版本列表中的下载按钮开始下载"
                                           FontSize="12"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           Margin="0,8,0,0"
                                           HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>

                <!-- 底部状态栏 -->
                <Border Grid.Row="1" 
                        Background="{StaticResource CardBackgroundBrush}"
                        Margin="16,8,16,16"
                        CornerRadius="8"
                        Padding="16">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="80"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="txtTaskCount" 
                                   Text="0 个任务"
                                   FontSize="12"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   VerticalAlignment="Center"/>
                        <Button Grid.Column="1"
                                Content="清空完成"
                                Style="{StaticResource SecondaryButton}"
                                Click="btnClearCompleted_Click"
                                HorizontalAlignment="Right"/>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Border>
</Window>
