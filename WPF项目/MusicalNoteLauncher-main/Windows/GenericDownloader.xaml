<Window x:Class="MusicalNoteLauncher.Windows.GenericDownloader"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="下载" Height="300" Width="500"
        WindowStyle="None"
        ResizeMode="NoResize"
        Background="{DynamicResource BackgroundBrush}">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 标题栏 -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Name="btnClose" Content="×" Width="30" Height="30" 
                    Background="Transparent" Foreground="{DynamicResource TextPrimaryBrush}"
                    FontSize="20" Click="btnClose_Click"
                    BorderThickness="0" Cursor="Hand"
                    HorizontalAlignment="Right">
                <Button.Style>
                    <Style TargetType="Button">
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#FF4444"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
        </StackPanel>

        <!-- 图标 -->
        <Image Grid.Row="1" Source="pack://application:,,,/Resources/Download.png" 
               Width="64" Height="64" 
               HorizontalAlignment="Center" 
               Margin="0,20,0,10"/>

        <!-- 文件名 -->
        <TextBlock Grid.Row="2" Name="txtFileName" Text="正在下载..." 
                   FontSize="16" Foreground="{DynamicResource TextPrimaryBrush}"
                   HorizontalAlignment="Center"
                   FontFamily="Microsoft YaHei"/>

        <!-- 进度条 -->
        <ProgressBar Grid.Row="3" Name="progressBar" 
                     Height="20" Margin="0,10,0,10"
                     Background="#333333"
                     Foreground="#2196F3"/>

        <!-- 进度文字 -->
        <StackPanel Grid.Row="4" Orientation="Vertical" Margin="0,10,0,0">
            <TextBlock Name="txtProgress" Text="0% (0 MB / 0 MB)" 
                       FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"
                       HorizontalAlignment="Center"
                       FontFamily="Microsoft YaHei"/>
            <TextBlock Name="txtSpeed" Text="速度: --" 
                       FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"
                       HorizontalAlignment="Center"
                       FontFamily="Microsoft YaHei"
                       Margin="0,5,0,0"/>
        </StackPanel>

        <!-- 按钮 -->
        <StackPanel Grid.Row="5" Orientation="Horizontal" 
                    HorizontalAlignment="Center"
                    Margin="0,20,0,0">
            <Button Name="btnPause" Content="暂停" 
                    Background="#FF9800" Foreground="{DynamicResource TextPrimaryBrush}"
                    BorderThickness="0" Padding="15,8"
                    FontSize="14" FontFamily="Microsoft YaHei"
                    Cursor="Hand" Width="80"
                    Click="btnPause_Click"
                    Margin="0,0,10,0">
                <Control.Template>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border Name="border" Background="{TemplateBinding Background}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#F57C00"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Control.Template>
            </Button>
            <Button Name="btnCancel" Content="取消" 
                    Background="#F44336" Foreground="{DynamicResource TextPrimaryBrush}"
                    BorderThickness="0" Padding="15,8"
                    FontSize="14" FontFamily="Microsoft YaHei"
                    Cursor="Hand" Width="80"
                    Click="btnCancel_Click">
                <Control.Template>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border Name="border" Background="{TemplateBinding Background}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#E53935"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Control.Template>
            </Button>
        </StackPanel>
    </Grid>
</Window>